---
// Marias flytt-kalkyl — PRIVAT familjesida. Medvetet UTAN Layout.astro → ingen PostHog/session-recording
// på mammas ekonomi. All känslig data hämtas lösenordsgatat från KV (/api/maria) — inget i denna källa.
// Lokal sandlåda: var och en skruvar sin egen kopia (localStorage), original ligger kvar i KV.
// Ljust tema, härlett ur sajtens egen light-palett (Forge .cf-light: emerald #0a8f54 på svalvit) + Inter.
---
<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Marias flytt</title>
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  <style is:global>
    :root{
      --bg:#f2f4f7;--card:#ffffff;--soft:#eef1f5;--field:#f4f6f9;
      --line:#e4e7ee;--line2:#d8dce4;
      --ink:#15171d;--ink2:#31343c;--dim:#5d6370;--faint:#8a8f9c;
      --accent:#0a8f54;--accent-h:#0c9d5d;--accent-tint:rgba(10,143,84,.09);
      --ok:#0a8f54;--ok-tint:rgba(10,143,84,.11);
      --warn:#a76a12;--warn-tint:rgba(167,106,18,.12);
      --bad:#c23b30;--bad-tint:rgba(194,59,48,.09);
      --shadow-sm:0 1px 2px rgba(20,30,55,.05);
      --shadow:0 1px 2px rgba(20,30,55,.04),0 8px 28px rgba(20,30,55,.06);
      --radius:16px;
    }
    *{box-sizing:border-box}
    html{font-feature-settings:"ss01","cv11";-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
    body{margin:0;background:var(--bg);color:var(--ink);font:15px/1.55 "Inter",ui-sans-serif,system-ui,-apple-system,sans-serif}
    a{color:var(--accent)}
    .wrap{max-width:1120px;margin:0 auto;padding:32px 20px 96px}
    /* Gate */
    #gate{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
    #gate[hidden]{display:none}
    .gate-card{width:100%;max-width:380px;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:34px 30px;text-align:center}
    .gate-lock{width:52px;height:52px;margin:0 auto 14px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;background:var(--accent-tint)}
    .gate-card h1{font-size:21px;font-weight:700;letter-spacing:-.01em;margin:0 0 6px}
    .gate-card p{color:var(--dim);font-size:14px;margin:0 0 18px}
    .gate-card input{width:100%;background:var(--field);border:1px solid var(--line2);border-radius:10px;color:var(--ink);font:inherit;font-size:22px;letter-spacing:8px;text-align:center;padding:12px}
    .gate-card input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-tint)}
    .gate-card button{margin-top:14px;width:100%;background:var(--accent);color:#fff;border:0;border-radius:10px;padding:12px;font-size:15px;font-weight:600;cursor:pointer;transition:background .12s}
    .gate-card button:hover{background:var(--accent-h)}
    .gate-card .err{color:var(--bad);font-size:13px;min-height:18px;margin-top:10px}
    /* Header */
    .mf-head{margin-bottom:4px}
    .mf-eyebrow{display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:600;letter-spacing:.3px;color:var(--accent);background:var(--accent-tint);border-radius:999px;padding:4px 12px;margin-bottom:14px}
    .mf-head h2{margin:0 0 8px;font-size:27px;font-weight:750;letter-spacing:-.02em;color:var(--ink)}
    .mf-sub{color:var(--dim);font-size:14.5px;max-width:760px;line-height:1.55}
    /* Verdict-banner */
    .mf-verdict{display:grid;grid-template-columns:auto 1px auto 1fr;gap:22px;align-items:center;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px 24px;margin:20px 0 24px}
    .v-label{font-size:11.5px;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);font-weight:600;margin-bottom:5px}
    .v-num{font-size:27px;font-weight:750;font-variant-numeric:tabular-nums;letter-spacing:-.01em;line-height:1}
    .v-num.pos{color:var(--ok)}.v-num.neg{color:var(--bad)}.v-num.warnv{color:var(--warn)}
    .v-sep{width:1px;align-self:stretch;background:var(--line);margin:2px 0}
    .v-take{font-size:13.5px;color:var(--dim);line-height:1.5;border-left:1px solid var(--line);padding-left:22px}
    @media(max-width:760px){.mf-verdict{grid-template-columns:1fr 1fr}.v-sep{display:none}.v-take{grid-column:1/-1;border-left:0;border-top:1px solid var(--line);padding:12px 0 0}}
    /* Toolbar */
    .mf-toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin:0 0 14px}
    .mf-btn{background:var(--card);border:1px solid var(--line2);color:var(--ink2);font-size:13.5px;font-weight:600;border-radius:10px;padding:9px 15px;cursor:pointer;box-shadow:var(--shadow-sm);transition:border-color .12s,color .12s}
    .mf-btn:hover{border-color:var(--accent);color:var(--accent)}
    .mf-btn.primary{background:var(--accent);color:#fff;border-color:var(--accent)}
    .mf-btn.primary:hover{background:var(--accent-h);color:#fff}
    .mf-legend{display:flex;flex-wrap:wrap;gap:16px;align-items:center;font-size:12.5px;color:var(--dim);margin-bottom:18px}
    .mf-flag{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3px;border-radius:6px;padding:2px 7px;margin-left:6px;vertical-align:middle}
    .mf-schablon{background:var(--warn-tint);color:var(--warn)}
    .mf-komplettera{background:var(--bad-tint);color:var(--bad)}
    .mf-justerad{background:var(--accent-tint);color:var(--accent);cursor:help}
    .mf-revert{margin-left:5px;font-size:10px;font-weight:700;color:var(--accent);cursor:pointer;border-bottom:1px dashed var(--accent);vertical-align:middle}
    .mf-revert:hover{color:var(--accent-h)}
    /* Cards + tabell */
    .mf-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
    .mf-card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:20px 22px}
    .mf-card-wide,.mf-card-sum{grid-column:1/-1}
    .mf-card h3{margin:0 0 14px;font-size:16.5px;font-weight:700;color:var(--ink);display:flex;align-items:center;gap:9px;flex-wrap:wrap}
    .mf-subh{margin:18px 0 8px;font-size:11.5px;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);font-weight:600}
    .mf-tag{font-size:11px;font-weight:600;color:var(--dim);background:var(--soft);border:1px solid var(--line);border-radius:999px;padding:3px 10px}
    .mf-table{width:100%;border-collapse:collapse}
    .mf-table td{padding:6px 0;font-size:14px;vertical-align:top;color:var(--ink2)}
    .mf-lbl{color:var(--dim);padding-right:14px}
    .mf-val{text-align:right;white-space:nowrap;font-variant-numeric:tabular-nums;color:var(--ink2)}
    .mf-note{display:block;font-size:11.5px;color:var(--faint);margin-top:2px;font-style:italic;white-space:normal}
    .mf-calc .mf-lbl,.mf-calc .mf-val,.mf-strong .mf-lbl{color:var(--ink)}
    .mf-strong td{font-weight:700}
    .mf-hi-ok .mf-val{color:var(--ok)}.mf-hi-warn .mf-val{color:var(--warn)}.mf-hi-hi .mf-val{color:var(--bad)}
    .mf-divider td{border-top:1px solid var(--line);padding:0;height:7px}
    .mf-inline-res{color:var(--faint);font-size:12.5px;margin-left:4px}
    .mf-edit{cursor:text;border-bottom:1px dashed rgba(10,143,84,.5);padding:0 1px;border-radius:3px;transition:background .12s}
    .mf-edit:hover{background:var(--accent-tint)}
    .mf-edit:focus{outline:none;background:var(--accent-tint)}
    .mf-input{width:120px;background:#fff;border:1px solid var(--accent);border-radius:7px;color:var(--ink);font:inherit;font-size:14px;padding:3px 7px;text-align:right;font-variant-numeric:tabular-nums;box-shadow:0 0 0 3px var(--accent-tint)}
    .mf-input:focus{outline:none}
    /* Callouts + pills */
    .mf-callout{margin-top:14px;font-size:13px;line-height:1.55;border-radius:12px;padding:11px 14px;border:1px solid var(--line);background:var(--soft);color:var(--ink2)}
    .mf-callout b{color:var(--ink)}
    .mf-callout-warn{background:var(--warn-tint);border-color:color-mix(in srgb,var(--warn) 30%,var(--line));color:#5c400f}
    .mf-callout-warn b{color:#4a3309}
    .mf-callout-hi{background:var(--bad-tint);border-color:color-mix(in srgb,var(--bad) 28%,var(--line));color:#7a2118}
    .mf-callout-hi b{color:#5e180f}
    .mf-callout-ok{background:var(--ok-tint);border-color:color-mix(in srgb,var(--ok) 30%,var(--line));color:#0a5c39}
    .mf-callout-ok b{color:#074a2d}
    .mf-pill{display:inline-block;font-weight:700;font-size:13.5px;border-radius:999px;padding:3px 13px}
    .mf-ok{background:var(--ok-tint);color:var(--ok)}.mf-warn{background:var(--warn-tint);color:var(--warn)}.mf-bad{background:var(--bad-tint);color:var(--bad)}
    /* Toggle (segmentkontroll) */
    .mf-toggle{display:inline-flex;gap:4px;background:var(--soft);border:1px solid var(--line);border-radius:12px;padding:4px;margin-bottom:12px}
    .mf-tg{border:0;background:none;color:var(--dim);font-size:13.5px;font-weight:600;padding:8px 16px;border-radius:9px;cursor:pointer;transition:color .12s}
    .mf-tg.on{background:var(--card);color:var(--accent);box-shadow:var(--shadow-sm)}
    /* Resonemang + chatt */
    .mf-sec{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:20px 22px;margin-top:18px}
    .mf-sec h3{margin:0 0 12px;font-size:16.5px;font-weight:700}
    .mf-sec h4{margin:16px 0 7px;font-size:11.5px;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);font-weight:600}
    .mf-sec ul{margin:0;padding-left:20px;line-height:1.7;font-size:14px;color:var(--ink2)}
    .mf-sec li{margin-bottom:6px}
    .mf-sec li b{color:var(--ink)}
    .chat-feed{display:flex;flex-direction:column;gap:10px;margin:14px 0}
    .chat-msg{background:var(--soft);border:1px solid var(--line);border-radius:12px;padding:10px 14px}
    .chat-msg.sugg{border-color:color-mix(in srgb,var(--accent) 35%,var(--line));background:var(--accent-tint)}
    .chat-meta{font-size:12px;color:var(--faint);margin-bottom:3px}
    .chat-meta b{color:var(--ink)}
    .chat-body{font-size:14px;white-space:pre-wrap;color:var(--ink2)}
    .chat-form{display:flex;flex-direction:column;gap:9px;margin-top:12px}
    .chat-form input,.chat-form textarea{background:var(--field);border:1px solid var(--line2);border-radius:10px;color:var(--ink);font:inherit;font-size:14px;padding:10px 12px}
    .chat-form input:focus,.chat-form textarea:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-tint)}
    .chat-form input.name{max-width:220px}
    .muted{color:var(--dim)}
    @media(max-width:820px){.mf-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div id="gate">
    <div class="gate-card">
      <div class="gate-lock">🔒</div>
      <h1>Marias flytt</h1>
      <p>Privat familjesida. Skriv koden.</p>
      <input id="gate-pw" inputmode="numeric" autocomplete="off" placeholder="••••" />
      <button id="gate-go">Öppna</button>
      <div class="err" id="gate-err"></div>
    </div>
  </div>
  <div class="wrap" id="app" hidden></div>

  <script is:inline>
  (function () {
    var API = "/api/maria";
    var pw = sessionStorage.getItem("maria_pw") || "";
    var baseline = null, reasoning = null, chat = [];
    var overrides = {};   // delat spara-lager (path -> {v, by, ts, note}); baslinjen rörs ALDRIG
    var shared = null;    // baslinje + overrides = den delade sanningen alla ser
    var work = null;      // lokal sandlåda (dina osparade ändringar ovanpå shared)

    // ---- format ----
    function kr(n){ return (Math.round(n)||0).toLocaleString("sv-SE") + " kr"; }
    function pct(n){ return (Math.round((n||0)*100)/100).toLocaleString("sv-SE") + " %"; }
    function parseKr(s){ var n=parseFloat(String(s).replace(/\s/g,"").replace(/[^\d.-]/g,"")); return isNaN(n)?0:Math.round(n); }
    function parsePct(s){ var n=parseFloat(String(s).replace(/\s/g,"").replace(",",".").replace(/[^\d.-]/g,"")); return isNaN(n)?0:n; }
    function clone(o){ return JSON.parse(JSON.stringify(o)); }
    function get(o,p){ return p.split(".").reduce(function(a,k){return a==null?a:a[k];},o); }
    function set(o,p,v){ var ks=p.split("."),last=ks.pop(),c=o; ks.forEach(function(k){c=c[k]=c[k]||{};}); c[last]=v; }
    function applyOverrides(base,ov){ var o=clone(base); Object.keys(ov||{}).forEach(function(p){ if(ov[p]&&typeof ov[p].v!=="undefined") set(o,p,ov[p].v); }); return o; }
    function provDay(ts){ try{ return new Date(ts).toLocaleDateString("sv-SE",{day:"numeric",month:"short",year:"numeric"}); }catch(e){ return ""; } }

    var FLAGS={
      "karlpers.anskaffning1975":"schablon","karlpers.forbattringar":"komplettera",
      "grimvagen.varde":"schablon","grimvagen.anskaffning":"komplettera","grimvagen.forbattringar":"komplettera","grimvagen.maklararvodePct":"schablon",
      "vettershaga.brunn":"schablon","vettershaga.el":"schablon","vettershaga.grund":"schablon","vettershaga.montage":"komplettera",
      "vettershaga.installation":"schablon","vettershaga.malning":"schablon","vettershaga.kringkostnad":"schablon","vettershaga.buffertPct":"schablon",
      "privatekonomi.driftVettershagaMan":"schablon","nyahuset.lan":"komplettera","nyahuset.rantaPct":"schablon","nyahuset.amorteringPct":"schablon"
    };
    var FIELDS=[
      ["karlpers.totalpris","Karlpers totalpris","kr"],["karlpers.agarandelPct","Ägarandel","pct"],["karlpers.maklararvode","Karlpers mäklararvode","kr"],
      ["karlpers.anskaffning1975","Karlpers anskaffning 1975","kr"],["karlpers.forbattringar","Karlpers förbättringar","kr"],
      ["grimvagen.varde","Grimvägen värde","kr"],["grimvagen.lan","Grimvägen lån","kr"],["grimvagen.anskaffning","Grimvägen inköpspris","kr"],
      ["grimvagen.forbattringar","Grimvägen förbättringar","kr"],["grimvagen.maklararvodePct","Grimvägen mäklararvode","pct"],
      ["vettershaga.tomt","Tomt","kr"],["vettershaga.lagfartPct","Lagfart","pct"],["vettershaga.avlopp","Avlopp","kr"],["vettershaga.brunn","Brunn","kr"],
      ["vettershaga.el","El","kr"],["vettershaga.byggsats","Byggsats","kr"],["vettershaga.grund","Grund","kr"],["vettershaga.montage","Montage","kr"],
      ["vettershaga.installation","Installation","kr"],["vettershaga.malning","Målning","kr"],["vettershaga.kringkostnad","Kringkostnad","kr"],["vettershaga.buffertPct","Buffert","pct"],
      ["privatekonomi.fondsparande","Fondsparande","kr"],["privatekonomi.pensionNetto","Pension/mån","kr"],["privatekonomi.lonNetto","Lön/mån","kr"],
      ["privatekonomi.frejgatanHyra","Hyra Frejgatan","kr"],["privatekonomi.driftVettershagaMan","Drift Vettershaga","kr"],
      ["nyahuset.lan","Lån på nya huset","kr"],["nyahuset.rantaPct","Ränta","pct"],["nyahuset.amorteringPct","Amortering","pct"]
    ];

    // ---- compute (samma motor som pappen) ----
    function compute(S){
      var K=S.karlpers,G=S.grimvagen,V=S.vettershaga,P=S.privatekonomi,N=S.nyahuset||{};
      var andel=(K.agarandelPct||0)/100;
      var kSalj=K.totalpris*andel,kMaklare=K.maklararvode*andel,kAnskaff=K.anskaffning1975*andel,kForb=K.forbattringar*andel;
      var kVinst=Math.max(0,kSalj-kMaklare-kAnskaff-kForb),kSkatt=kVinst*0.22,kNetto=kSalj-kMaklare-kSkatt;
      var gMaklare=G.varde*(G.maklararvodePct||0)/100;
      var gVinst=Math.max(0,G.varde-G.anskaffning-G.forbattringar-gMaklare),gSkatt=gVinst*0.22,gNetto=G.varde-G.lan-gMaklare-gSkatt;
      var vLagfart=V.tomt*(V.lagfartPct||0)/100;
      var vDelsum=V.tomt+vLagfart+V.avlopp+V.brunn+V.el+V.byggsats+V.grund+V.montage+V.installation+V.malning+V.kringkostnad;
      var vBuffert=vDelsum*(V.buffertPct||0)/100,vTotal=vDelsum+vBuffert;
      var uppskov=N.permanent?gSkatt:0,gNettoEff=gNetto+uppskov;
      var kapital=kNetto+gNettoEff+P.fondsparande;
      var L=N.lan||0,ranteMan=L*(N.rantaPct||0)/100/12,ranteEfterAvdrag=ranteMan*0.7,amortMan=L*(N.amorteringPct||0)/100/12,lanKostnadMan=ranteEfterAvdrag+amortMan;
      var tillgangligt=kapital+L,buffert=tillgangligt-vTotal;
      var utgifterMan=P.frejgatanHyra+P.driftVettershagaMan+lanKostnadMan;
      var kvarJobbar=(P.pensionNetto+P.lonNetto)-utgifterMan,kvarPension=P.pensionNetto-utgifterMan;
      return {andel:andel,kSalj:kSalj,kMaklare:kMaklare,kAnskaff:kAnskaff,kForb:kForb,kVinst:kVinst,kSkatt:kSkatt,kNetto:kNetto,gMaklare:gMaklare,gVinst:gVinst,gSkatt:gSkatt,gNetto:gNetto,uppskov:uppskov,gNettoEff:gNettoEff,vLagfart:vLagfart,vDelsum:vDelsum,vBuffert:vBuffert,vTotal:vTotal,permanent:!!N.permanent,L:L,ranteEfterAvdrag:ranteEfterAvdrag,amortMan:amortMan,lanKostnadMan:lanKostnadMan,kapital:kapital,buffert:buffert,kvarJobbar:kvarJobbar,kvarPension:kvarPension};
    }
    function takeaway(c){
      var a=c.buffert>=0?("Kapitalet räcker, med "+kr(c.buffert)+" kvar som buffert."):("Med dagens antaganden fattas "+kr(-c.buffert)+" för att nå ända fram.");
      var b=c.kvarPension<5000?(" Efter pension blir marginalen tight — "+kr(c.kvarPension)+"/mån kvar till mat och liv."):(" Efter pension: "+kr(c.kvarPension)+"/mån kvar till mat och liv.");
      return a+b;
    }

    // ---- render helpers ----
    function ed(path,type){
      type=type||"kr"; var v=get(work,path); if(v==null)v=0;
      var fmt=type==="pct"?pct:kr;
      var f=FLAGS[path];
      var badge=f==="komplettera"?'<span class="mf-flag mf-komplettera">kompletteras</span>':(f==="schablon"?'<span class="mf-flag mf-schablon">schablon</span>':"");
      var ovBadge="";
      var ov=overrides[path];
      if(ov&&typeof ov.v!=="undefined"){
        var orig=get(baseline,path); if(orig==null)orig=0;
        var title="Original: "+fmt(orig)+" · ändrat av "+(ov.by||"någon")+(ov.ts?(" · "+provDay(ov.ts)):"")+(ov.note?("\n"+ov.note):"");
        ovBadge='<span class="mf-flag mf-justerad" title="'+esc(title)+'">justerad</span>'
          +'<span class="mf-revert" data-revert="'+esc(path)+'" title="Återställ till original för alla">↺</span>';
      }
      return '<span class="mf-edit" data-path="'+path+'" data-type="'+type+'" tabindex="0" title="Dubbelklicka för att ändra">'+fmt(v)+'</span>'+badge+ovBadge;
    }
    function row(label,val,o){ o=o||{};
      return '<tr class="'+(o.calc?"mf-calc":"")+(o.strong?" mf-strong":"")+(o.hi?" mf-hi-"+o.hi:"")+'"><td class="mf-lbl">'+label+(o.note?'<span class="mf-note">'+o.note+'</span>':"")+'</td><td class="mf-val">'+val+'</td></tr>'; }
    function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c];}); }
    function fmtDate(ts){ var d=new Date(ts); return d.toLocaleDateString("sv-SE")+" "+d.toLocaleTimeString("sv-SE",{hour:"2-digit",minute:"2-digit"}); }

    function draw(){
      var S=work, c=compute(S);
      var unsaved=diffList().length;
      var goBadge=c.buffert>=0?'<span class="mf-pill mf-ok">Buffert '+kr(c.buffert)+'</span>':'<span class="mf-pill mf-bad">Underskott '+kr(-c.buffert)+'</span>';
      var kvarBadge=c.kvarPension<5000?'<span class="mf-pill mf-warn">Tight — '+kr(c.kvarPension)+'/mån kvar</span>':'<span class="mf-pill mf-ok">'+kr(c.kvarPension)+'/mån kvar</span>';
      var reasonHtml="";
      if(reasoning){
        reasonHtml='<div class="mf-sec"><h3>🧭 Resonemang &amp; öppna frågor</h3>';
        if(reasoning.insikter&&reasoning.insikter.length){ reasonHtml+='<h4>Insikter</h4><ul>'+reasoning.insikter.map(function(x){return "<li>"+x+"</li>";}).join("")+'</ul>'; }
        if(reasoning.oppnaFragor&&reasoning.oppnaFragor.length){ reasonHtml+='<h4>Öppna frågor att komplettera</h4><ul>'+reasoning.oppnaFragor.map(function(x){return "<li>"+x+"</li>";}).join("")+'</ul>'; }
        if(reasoning.uppdaterad){ reasonHtml+='<p class="muted" style="font-size:11.5px;margin-top:12px">Senast uppdaterad: '+esc(reasoning.uppdaterad)+'</p>'; }
        reasonHtml+='</div>';
      }
      var chatHtml='<div class="mf-sec"><h3>💬 Familjechatt</h3><div class="muted" style="font-size:13px;margin-bottom:6px">💾 <b>Spara till alla</b> gör dina ändringar delade direkt (märks “justerad”). 📤 <b>Föreslå i chatten</b> om du hellre vill bolla först.</div><div class="chat-feed" id="chat-feed"></div>'
        +'<div class="chat-form"><input class="name" id="chat-name" placeholder="Ditt namn" maxlength="40" />'
        +'<textarea id="chat-msg" rows="2" placeholder="Skriv ett meddelande…" maxlength="1500"></textarea>'
        +'<div><button class="mf-btn primary" id="chat-send">Skicka</button></div></div></div>';

      document.getElementById("app").innerHTML =
      '<div class="mf-head"><span class="mf-eyebrow">🏡 Familjekalkyl</span><h2>Marias flytt</h2>'
      +'<div class="mf-sub">Karlpers säljs → nytt sommarhus i Vettershaga, Grimvägen säljs, vinterboende hyrs (Frejgatan). Dubbelklicka ett belopp för att räkna om. Ändringar är dina egna tills du <b>💾 Sparar till alla</b> — då blir de delade och märks <span class="mf-flag mf-justerad">justerad</span> (originalet spåras alltid — hovra flaggan).</div></div>'
      // Verdict-banner (viktigaste siffran först)
      +'<div class="mf-verdict">'
      +'<div class="v-item"><div class="v-label">Buffert efter bygge</div><div class="v-num '+(c.buffert>=0?"pos":"neg")+'">'+(c.buffert>=0?kr(c.buffert):"−"+kr(-c.buffert))+'</div></div>'
      +'<div class="v-sep"></div>'
      +'<div class="v-item"><div class="v-label">Kvar/mån efter pension</div><div class="v-num '+(c.kvarPension<5000?"warnv":"pos")+'">'+kr(c.kvarPension)+'</div></div>'
      +'<div class="v-take">'+takeaway(c)+'</div>'
      +'</div>'
      +'<div class="mf-toolbar">'
      +'<button class="mf-btn primary" id="btn-save"'+(unsaved?'':' disabled style="opacity:.5;cursor:default"')+'>💾 Spara till alla'+(unsaved?(' ('+unsaved+')'):'')+'</button>'
      +'<button class="mf-btn" id="btn-suggest">📤 Föreslå i chatten</button>'
      +'<button class="mf-btn" id="btn-reset">↺ Ångra mina osparade</button>'
      +'</div>'
      +'<div class="mf-legend"><span><span class="mf-flag mf-schablon">schablon</span> gissning</span><span><span class="mf-flag mf-komplettera">kompletteras</span> behöver riktig uppgift</span><span>✎ dubbelklicka ett belopp</span></div>'
      +'<div class="mf-grid">'
      +'<section class="mf-card"><h3>🏡 Karlpers <span class="mf-tag">fritidshus · inget uppskov</span></h3><table class="mf-table">'
      +row("Totalpris (båda systrarna)",ed("karlpers.totalpris"))
      +row("Marias ägarandel",ed("karlpers.agarandelPct","pct"))
      +row("Mäklararvode (totalt)",ed("karlpers.maklararvode"))
      +row("Anskaffning 1975 (totalt)",ed("karlpers.anskaffning1975"))
      +row("Förbättringsutgifter (totalt)",ed("karlpers.forbattringar"))
      +'<tr class="mf-divider"><td colspan="2"></td></tr>'
      +row("= Kapitalvinst (Marias andel)",kr(c.kVinst),{calc:true,strong:true})
      +row("Vinstskatt (22 %)",kr(c.kSkatt),{calc:true,hi:"warn",strong:true})
      +row("Netto kontant till Maria",kr(c.kNetto),{calc:true,hi:"ok",strong:true})
      +'</table><div class="mf-callout mf-callout-warn">⏰ Skatten ('+kr(c.kSkatt)+') betalas i slutskatten <b>våren 2027</b> — reservera den.</div></section>'
      +'<section class="mf-card"><h3>🏢 Grimvägen <span class="mf-tag">bostadsrätt</span></h3><table class="mf-table">'
      +row("Marknadsvärde",ed("grimvagen.varde"))
      +row("Kvarvarande lån",ed("grimvagen.lan"))
      +row("Inköpspris (när Maria köpte)",ed("grimvagen.anskaffning"))
      +row("Förbättringar / kapitaltillskott",ed("grimvagen.forbattringar"))
      +row("Mäklararvode",ed("grimvagen.maklararvodePct","pct"))
      +'<tr class="mf-divider"><td colspan="2"></td></tr>'
      +row("Kapitalvinst",kr(c.gVinst),{calc:true,strong:true})
      +row("Vinstskatt (22 %)",kr(c.gSkatt),{calc:true,hi:"warn",strong:true})
      +row("Netto (efter lån + skatt)",kr(c.gNetto),{calc:true,hi:"ok",strong:true})
      +'</table><div class="mf-callout mf-callout-hi">📌 Störst osäkerhet: <b>inköpspriset</b>. Står det 0 är skatten maximal — fyll i verkliga priset.</div></section>'
      +'<section class="mf-card mf-card-wide"><h3>🔨 Vettershaga — byggbudget <span class="mf-tag">villabyggsats ≠ färdigt hus</span></h3><table class="mf-table">'
      +row("Tomt",ed("vettershaga.tomt"))
      +row("Lagfart (stämpelskatt)",ed("vettershaga.lagfartPct","pct")+' <span class="mf-inline-res">= '+kr(c.vLagfart)+'</span>')
      +row("Enskilt avlopp (WC/spolvatten)",ed("vettershaga.avlopp"))
      +row("Borrad brunn",ed("vettershaga.brunn"))
      +row("El-framdragning (~50 m)",ed("vettershaga.el"))
      +row("Villabyggsats Ametisten",ed("vettershaga.byggsats"),{note:"material inkl. vitvaror/värme/kök/bad — ej grund, montage, målning"})
      +row("Grund / platta på mark",ed("vettershaga.grund"))
      +row("Montage/resning",ed("vettershaga.montage"),{note:"största osäkerheten — begär offert"})
      +row("VVS/el-installation (arbete)",ed("vettershaga.installation"))
      +row("Slutmålning/finish",ed("vettershaga.malning"))
      +row("Bygglov, karta, KA, besiktning",ed("vettershaga.kringkostnad"))
      +'<tr class="mf-divider"><td colspan="2"></td></tr>'
      +row("Delsumma",kr(c.vDelsum),{calc:true})
      +row("Buffert",ed("vettershaga.buffertPct","pct")+' <span class="mf-inline-res">= '+kr(c.vBuffert)+'</span>')
      +row("= TOTALT inflyttningsklart",kr(c.vTotal),{calc:true,hi:"hi",strong:true})
      +'</table></section>'
      +'<section class="mf-card mf-card-wide"><h3>🏦 Lån &amp; scenario <span class="mf-tag">permanentbostad vs fritidshus</span></h3>'
      +'<div class="mf-toggle"><button class="mf-tg'+(!c.permanent?" on":"")+'" data-perm="0">🏖 Fritidshus</button><button class="mf-tg'+(c.permanent?" on":"")+'" data-perm="1">🏠 Permanentbostad</button></div>'
      +'<div class="mf-callout '+(c.permanent?"mf-callout-ok":"mf-callout-warn")+'">'
      +(c.permanent?('🏠 Som permanentbostad kan Grimvägens vinstskatt <b>skjutas upp (uppskov, räntefritt)</b> → '+kr(c.uppskov)+' stannar i kassan nu. <b>Kräver att hon faktiskt bor mest i Vettershaga (folkbokförd där)</b> — annars skatterisk, inte genväg.')
        :('🏖 Som fritidshus betalas Grimvägens vinstskatt ('+kr(c.gSkatt)+') direkt, och banken lånar snålare (~75 % mot 85 %).'))
      +'</div><table class="mf-table">'
      +row("Lån på nya huset",ed("nyahuset.lan"))
      +row("Ränta",ed("nyahuset.rantaPct","pct"))
      +row("Amortering",ed("nyahuset.amorteringPct","pct"))
      +'<tr class="mf-divider"><td colspan="2"></td></tr>'
      +row("Ränta/mån (efter 30 % avdrag)",kr(c.ranteEfterAvdrag),{calc:true})
      +row("Amortering/mån",kr(c.amortMan),{calc:true})
      +row("= Lånekostnad/mån",kr(c.lanKostnadMan),{calc:true,strong:true})
      +'</table><div class="mf-callout mf-callout-hi">💡 Att låna istället för kontant höjer bufferten med lånebeloppet men kostar '+kr(c.lanKostnadMan)+'/mån. Vid 74 år + '+kr(S.privatekonomi.pensionNetto)+'/mån avgör bankens lånelöfte hur stort lån som går.</div></section>'
      +'<section class="mf-card mf-card-sum"><h3>💰 Summering — går det ihop?</h3><table class="mf-table">'
      +row("Karlpers, netto",kr(c.kNetto),{calc:true})
      +row("Grimvägen, netto"+(c.permanent?" (m. uppskov)":""),kr(c.gNettoEff),{calc:true})
      +row("Fondsparande",ed("privatekonomi.fondsparande"))
      +row("= Tillgängligt kapital",kr(c.kapital),{calc:true,strong:true})
      +row("+ Lån på nya huset","+"+kr(c.L),{calc:true})
      +row("− Nytt hus i Vettershaga","−"+kr(c.vTotal),{calc:true})
      +row("= Buffert kvar efter bygge",goBadge,{calc:true,strong:true,hi:c.buffert>=0?"ok":"hi"})
      +'</table><h4 class="mf-subh">Månadskassaflöde</h4><table class="mf-table">'
      +row("Pension (netto/mån)",ed("privatekonomi.pensionNetto"))
      +row("Lön medan hon jobbar 50 %",ed("privatekonomi.lonNetto"))
      +row("− Hyra Frejgatan","−"+ed("privatekonomi.frejgatanHyra"))
      +row("− Drift Vettershaga","−"+ed("privatekonomi.driftVettershagaMan"))
      +row("− Lånekostnad","−"+kr(c.lanKostnadMan),{calc:true})
      +'<tr class="mf-divider"><td colspan="2"></td></tr>'
      +row("Kvar/mån medan hon jobbar",kr(c.kvarJobbar),{calc:true})
      +row("Kvar/mån efter pension",kvarBadge,{calc:true,strong:true,hi:c.kvarPension<5000?"warn":"ok"})
      +'</table><div class="mf-callout mf-callout-warn">⚠️ Efter pension lämnar '+kr(S.privatekonomi.pensionNetto)+'/mån minus boende + lån <b>'+kr(c.kvarPension)+'/mån</b> till mat och liv.</div></section>'
      +'</div>'
      +reasonHtml+chatHtml;

      wire();
      renderChat();
    }

    function wire(){
      Array.prototype.forEach.call(document.querySelectorAll(".mf-tg"),function(b){ b.onclick=function(){ set(work,"nyahuset.permanent",b.getAttribute("data-perm")==="1"); save(); draw(); }; });
      Array.prototype.forEach.call(document.querySelectorAll(".mf-edit"),function(el){
        function start(){
          if(el.querySelector("input"))return;
          var path=el.getAttribute("data-path"),type=el.getAttribute("data-type"),raw=get(work,path); if(raw==null)raw=0;
          el.innerHTML='<input class="mf-input" value="'+raw+'" inputmode="decimal">';
          var inp=el.querySelector("input"); inp.focus(); inp.select(); var done=false;
          function commit(){ if(done)return; done=true; var val=type==="pct"?parsePct(inp.value):parseKr(inp.value); set(work,path,val); save(); draw(); }
          inp.addEventListener("blur",commit);
          inp.addEventListener("keydown",function(e){ if(e.key==="Enter"){e.preventDefault();inp.blur();} else if(e.key==="Escape"){done=true;draw();} });
        }
        el.addEventListener("dblclick",start);
        el.addEventListener("keydown",function(e){ if(e.key==="Enter"){e.preventDefault();start();} });
      });
      document.getElementById("btn-reset").onclick=function(){ work=clone(shared); localStorage.removeItem("maria_work"); draw(); };
      document.getElementById("btn-suggest").onclick=suggest;
      var bs=document.getElementById("btn-save"); if(bs) bs.onclick=saveToAll;
      Array.prototype.forEach.call(document.querySelectorAll(".mf-revert"),function(el){ el.onclick=function(){ revertOverride(el.getAttribute("data-revert")); }; });
      document.getElementById("chat-send").onclick=sendChat;
      var nm=document.getElementById("chat-name"); if(nm) nm.value=localStorage.getItem("maria_name")||"";
    }

    function save(){ try{ localStorage.setItem("maria_work",JSON.stringify(work)); }catch(e){} }

    // Osparade lokala ändringar (work vs den delade sanningen) över de sparbara fälten.
    function diffList(){
      var d=[];
      FIELDS.forEach(function(f){ var a=get(shared,f[0])||0,b=get(work,f[0])||0; if(a!==b) d.push({path:f[0],label:f[1],type:f[2],from:a,to:b}); });
      return d;
    }
    // Spara dina ändringar för ALLA (delat override-lager, attribuerat). Baslinjen rörs aldrig.
    function saveToAll(){
      var d=diffList();
      if(!d.length){ alert("Du har inga osparade ändringar att spara."); return; }
      var nameEl=document.getElementById("chat-name");
      var name=((nameEl&&nameEl.value)||localStorage.getItem("maria_name")||"").trim();
      if(!name){ name=(prompt("Ditt namn (visas som den som ändrade):")||"").trim(); if(!name)return; if(nameEl)nameEl.value=name; }
      localStorage.setItem("maria_name",name);
      var summary=d.map(function(x){ var fmt=x.type==="pct"?pct:kr; return "• "+x.label+": "+fmt(x.from)+" → "+fmt(x.to); }).join("\n");
      if(!confirm("Spara dessa ändringar för ALLA i familjen?\n\n"+summary+"\n\nOriginalet sparas kvar och kan alltid återställas.")) return;
      var note=(prompt("Valfri notering (varför? t.ex. \"offert från byggaren\"):")||"").trim();
      api("POST","&kind=override",{pw:pw,name:name,note:note,changes:d.map(function(x){return {path:x.path,value:x.to};})}).then(function(r){
        if(r.ok&&r.j.overrides){ overrides=r.j.overrides; shared=applyOverrides(baseline,overrides); work=clone(shared); save(); draw(); }
        else alert("Kunde inte spara: "+((r.j&&r.j.error)||r.status));
      });
    }
    // Återställ ETT fält till originalet för alla (tar bort dess override).
    function revertOverride(path){
      var ov=overrides[path]; if(!ov)return;
      if(!confirm("Återställ detta fält till originalet för alla?"+(ov.by?("\n\n(Tar bort ändringen av "+ov.by+".)"):""))) return;
      api("POST","&kind=override",{pw:pw,clearPath:path}).then(function(r){
        if(r.ok&&r.j.overrides){ overrides=r.j.overrides; shared=applyOverrides(baseline,overrides); set(work,path,get(baseline,path)); save(); draw(); }
        else alert("Kunde inte återställa: "+((r.j&&r.j.error)||r.status));
      });
    }

    function suggest(){
      var diffs=[];
      FIELDS.forEach(function(f){ var a=get(shared,f[0]),b=get(work,f[0]); if((a||0)!==(b||0)){ var fmt=f[2]==="pct"?pct:kr; diffs.push(f[1]+": "+fmt(a)+" → "+fmt(b)); } });
      var bp=get(shared,"nyahuset.permanent"),wp=get(work,"nyahuset.permanent");
      if(!!bp!==!!wp) diffs.push("Bostadstyp: "+(bp?"Permanent":"Fritidshus")+" → "+(wp?"Permanent":"Fritidshus"));
      var note=prompt(diffs.length?("Föreslå dessa ändringar i chatten?\n\n"+diffs.join("\n")+"\n\nLägg ev. till en motivering (valfritt):"):"Du har inte ändrat något ännu. Skriv ett fritt förslag istället:");
      if(note===null)return;
      var msg="💡 Förslag:"+(diffs.length?("\n"+diffs.join("\n")):"")+(note?("\n\n"+note):"");
      postChat(msg,true);
    }

    function api(method,qs,body){
      return fetch(API+"?pw="+encodeURIComponent(pw)+(qs||""),{method:method,headers:body?{"Content-Type":"application/json"}:undefined,body:body?JSON.stringify(body):undefined}).then(function(r){return r.json().then(function(j){return {ok:r.ok,status:r.status,j:j};});});
    }
    function postChat(message,isSuggestion){
      var name=(document.getElementById("chat-name")||{}).value||localStorage.getItem("maria_name")||"Anonym";
      localStorage.setItem("maria_name",name);
      api("POST","&kind=chat",{pw:pw,name:name,message:message,suggestion:!!isSuggestion}).then(function(r){ if(r.ok&&r.j.chat){chat=r.j.chat;renderChat();} else alert("Kunde inte skicka: "+(r.j.error||r.status)); });
    }
    function sendChat(){
      var ta=document.getElementById("chat-msg"); var m=(ta.value||"").trim(); if(!m)return; ta.value=""; postChat(m,false);
    }
    function renderChat(){
      var feed=document.getElementById("chat-feed"); if(!feed)return;
      if(!chat.length){ feed.innerHTML='<div class="muted" style="font-size:14px">Inga meddelanden än. Skriv det första!</div>'; return; }
      feed.innerHTML=chat.slice().reverse().map(function(m){
        return '<div class="chat-msg'+(m.suggestion?" sugg":"")+'"><div class="chat-meta"><b>'+esc(m.name)+'</b> · '+fmtDate(m.ts)+'</div><div class="chat-body">'+esc(m.message)+'</div></div>';
      }).join("");
    }

    // ---- gate + hydrate ----
    function hydrate(){
      return api("GET","&kind=state").then(function(r){
        if(r.status===401){ throw new Error("pw"); }
        if(!r.ok){ throw new Error(r.j.error||("HTTP "+r.status)); }
        baseline=r.j.baseline; reasoning=r.j.reasoning; chat=r.j.chat||[]; overrides=r.j.overrides||{};
        if(!baseline){ document.getElementById("app").innerHTML='<p class="muted">Baslinjen är inte inlagd än.</p>'; document.getElementById("app").hidden=false; document.getElementById("gate").hidden=true; return; }
        shared=applyOverrides(baseline,overrides);
        var savedWork=null; try{ savedWork=JSON.parse(localStorage.getItem("maria_work")||"null"); }catch(e){}
        work=savedWork||clone(shared);
        document.getElementById("gate").hidden=true; document.getElementById("app").hidden=false;
        draw();
      });
    }
    function tryOpen(code){
      pw=code; sessionStorage.setItem("maria_pw",pw);
      hydrate().catch(function(e){
        sessionStorage.removeItem("maria_pw"); pw="";
        document.getElementById("gate-err").textContent=(e.message==="pw")?"Fel kod.":("Fel: "+e.message);
      });
    }
    document.getElementById("gate-go").onclick=function(){ tryOpen(document.getElementById("gate-pw").value.trim()); };
    document.getElementById("gate-pw").addEventListener("keydown",function(e){ if(e.key==="Enter") document.getElementById("gate-go").click(); });
    if(pw){ hydrate().catch(function(){ sessionStorage.removeItem("maria_pw"); pw=""; document.getElementById("gate-pw").focus(); }); }
    else { document.getElementById("gate-pw").focus(); }
  })();
  </script>
</body>
</html>
