      // ≈-läget: schablonkostnader på/av (knapp i toolbaren + i jämför-tabellen)
      Array.prototype.forEach.call(document.querySelectorAll(".btn-sch"),function(b){
        b.onclick=function(e){ e.stopPropagation(); schOn=!schOn; try{localStorage.setItem("maria_sch",schOn?"1":"0");}catch(_){} draw(); };
      });
      // Sortera jämför-tabellen: 1:a klicket sorterar (Buffert: bäst först), 2:a vänder, 3:e återgår till katalogordning
      Array.prototype.forEach.call(document.querySelectorAll("#cmp-main th[data-sort]"),function(th){
        th.onclick=function(){
          var col=th.getAttribute("data-sort"),defDir=(col==="buf"||col==="plan")?-1:1; // bäst först
          if(cmpSort&&cmpSort.col===col&&cmpSort.dir===defDir) cmpSort={col:col,dir:-defDir};
          else if(cmpSort&&cmpSort.col===col) cmpSort=null;
          else cmpSort={col:col,dir:defDir};
          try{localStorage.setItem("maria_cmp_sort",JSON.stringify(cmpSort));}catch(_){}
          draw();
        };
      });
      var bc=document.getElementById("btn-collapse");
      if(bc) bc.onclick=function(){
        var secs=document.querySelectorAll("[data-collapse]");
        var anyOpen=Array.prototype.some.call(secs,function(s){return !s.classList.contains("collapsed");});
        Array.prototype.forEach.call(secs,function(s){ try{localStorage.setItem("maria_col_"+s.getAttribute("data-collapse"),anyOpen?"1":"0");}catch(_){} });
        draw();
      };
      document.getElementById("btn-reset").onclick=function(){ work=clone(shared); localStorage.removeItem("maria_work"); draw(); };
      var bs=document.getElementById("btn-save"); if(bs) bs.onclick=saveToAll;
      Array.prototype.forEach.call(document.querySelectorAll(".mf-revert[data-revert]"),function(el){ el.onclick=function(){ revertOverride(el.getAttribute("data-revert")); }; });
      // ↺ schablon: släng lokal offert-siffra på en alt-post → tillbaka till ?/schablon (jämförbarhet)
      Array.prototype.forEach.call(document.querySelectorAll("[data-altrevert]"),function(el){
        el.onclick=function(e){ e.stopPropagation();
          var ref=el.getAttribute("data-altrevert").split(":"),aid=ref[0],idx=+ref[1];
          if(altEdits[aid]){ delete altEdits[aid][idx]; if(!Object.keys(altEdits[aid]).length)delete altEdits[aid]; }
          try{localStorage.setItem("maria_alt_edits",JSON.stringify(altEdits));}catch(_){}
          draw(); };
      });
      document.getElementById("chat-send").onclick=sendChat;
      var nm=document.getElementById("chat-name"); if(nm) nm.value=localStorage.getItem("maria_name")||"";
    }

    function save(){ try{ localStorage.setItem("maria_work",JSON.stringify(work)); }catch(e){} }

    // Osparade lokala ändringar (work vs den delade sanningen) över de sparbara fälten.
    function diffList(){
      var d=[];
      FIELDS.forEach(function(f){ var a=get(shared,f[0])||0,b=get(work,f[0])||0; if(a!==b) d.push({path:f[0],label:f[1],type:f[2],from:a,to:b}); });
      return d;
    }
    // Spara dina ändringar för ALLA (delat override-lager, attribuerat). Baslinjen rörs aldrig.
    function saveToAll(){
      var d=diffList();
      if(!d.length){ alert("Du har inga osparade ändringar att spara."); return; }
      var nameEl=document.getElementById("chat-name");
      var name=((nameEl&&nameEl.value)||localStorage.getItem("maria_name")||"").trim();
      if(!name){ name=(prompt("Ditt namn (visas som den som ändrade):")||"").trim(); if(!name)return; if(nameEl)nameEl.value=name; }
      localStorage.setItem("maria_name",name);
      var summary=d.map(function(x){ var fmt=x.type==="pct"?pct:kr; return "• "+x.label+": "+fmt(x.from)+" → "+fmt(x.to); }).join("\n");
      if(!confirm("Spara dessa ändringar för ALLA i familjen?\n\n"+summary+"\n\nOriginalet sparas kvar och kan alltid återställas.")) return;
      var note=(prompt("Valfri notering (varför? t.ex. \"offert från byggaren\"):")||"").trim();
      api("POST","&kind=override",{pw:pw,name:name,note:note,changes:d.map(function(x){return {path:x.path,value:x.to};})}).then(function(r){
        if(r.ok&&r.j.overrides){ overrides=r.j.overrides; if(r.j.changelog)changelog=r.j.changelog; shared=applyOverrides(baseline,overrides); work=clone(shared); save(); draw(); }
        else alert("Kunde inte spara: "+((r.j&&r.j.error)||r.status));
      });
    }
    // Återställ ETT fält till originalet för alla (tar bort dess override).
    function revertOverride(path){
      var ov=overrides[path]; if(!ov)return;
      if(!confirm("Återställ detta fält till originalet för alla?"+(ov.by?("\n\n(Tar bort ändringen av "+ov.by+".)"):""))) return;
      var nameEl=document.getElementById("chat-name");
      var name=((nameEl&&nameEl.value)||localStorage.getItem("maria_name")||"").trim();
      api("POST","&kind=override",{pw:pw,name:name,clearPath:path}).then(function(r){
        if(r.ok&&r.j.overrides){ overrides=r.j.overrides; if(r.j.changelog)changelog=r.j.changelog; shared=applyOverrides(baseline,overrides); set(work,path,get(baseline,path)); save(); draw(); }
        else alert("Kunde inte återställa: "+((r.j&&r.j.error)||r.status));
      });
    }

    function api(method,qs,body){
      return fetch(API+"?pw="+encodeURIComponent(pw)+(qs||""),{method:method,headers:body?{"Content-Type":"application/json"}:undefined,body:body?JSON.stringify(body):undefined}).then(function(r){return r.json().then(function(j){return {ok:r.ok,status:r.status,j:j};});});
    }
    function postChat(message){
      var name=(document.getElementById("chat-name")||{}).value||localStorage.getItem("maria_name")||"Anonym";
      localStorage.setItem("maria_name",name);
      api("POST","&kind=chat",{pw:pw,name:name,message:message}).then(function(r){ if(r.ok&&r.j.chat){chat=r.j.chat;renderChat();} else alert("Kunde inte skicka: "+(r.j.error||r.status)); });
    }
    function sendChat(){
      var ta=document.getElementById("chat-msg"); var m=(ta.value||"").trim(); if(!m)return; ta.value=""; postChat(m);
    }
    function renderChat(){
      var feed=document.getElementById("chat-feed"); if(!feed)return;
      if(!chat.length){ feed.innerHTML='<div class="muted" style="font-size:14px">Inga meddelanden än. Skriv det första!</div>'; return; }
      feed.innerHTML=chat.slice().reverse().map(function(m){
        return '<div class="chat-msg'+(m.suggestion?" sugg":"")+'"><div class="chat-meta"><b>'+esc(m.name)+'</b> · '+fmtDate(m.ts)+'</div><div class="chat-body">'+esc(m.message)+'</div></div>';
      }).join("");
    }

    // ---- gate + hydrate ----
    function hydrate(){
      return api("GET","&kind=state").then(function(r){
        if(r.status===401){ throw new Error("pw"); }
        if(!r.ok){ throw new Error(r.j.error||("HTTP "+r.status)); }
        baseline=r.j.baseline; reasoning=r.j.reasoning; chat=r.j.chat||[]; overrides=r.j.overrides||{}; changelog=r.j.changelog||[];
        if(!baseline){ document.getElementById("app").innerHTML='<p class="muted">Baslinjen är inte inlagd än.</p>'; document.getElementById("app").hidden=false; document.getElementById("gate").hidden=true; return; }
        shared=applyOverrides(baseline,overrides);
        var savedWork=null; try{ savedWork=JSON.parse(localStorage.getItem("maria_work")||"null"); }catch(e){}
        work=savedWork||clone(shared);
        document.getElementById("gate").hidden=true; document.getElementById("app").hidden=false;
        draw();
      });
    }
    function tryOpen(code){
      pw=code; sessionStorage.setItem("maria_pw",pw);
      hydrate().catch(function(e){
        sessionStorage.removeItem("maria_pw"); pw="";
        document.getElementById("gate-err").textContent=(e.message==="pw")?"Fel kod.":("Fel: "+e.message);
      });
    }
    document.getElementById("gate-go").onclick=function(){ tryOpen(document.getElementById("gate-pw").value.trim()); };
    document.getElementById("gate-pw").addEventListener("keydown",function(e){ if(e.key==="Enter") document.getElementById("gate-go").click(); });
    if(pw){ hydrate().catch(function(){ sessionStorage.removeItem("maria_pw"); pw=""; document.getElementById("gate-pw").focus(); }); }
    else { document.getElementById("gate-pw").focus(); }
  })();
  </script>
</body>
</html>
