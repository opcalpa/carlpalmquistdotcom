      // "📐 Se planlösning" → öppna lightbox på plan-bilden (sista i galleriet)
      Array.prototype.forEach.call(document.querySelectorAll("[data-planopen]"),function(el){ el.onclick=function(){ var a=altById(el.getAttribute("data-planopen")); openLightbox(altGallery(a),(a.imgs||[]).length); }; });
      // Cover-art-karusell i Vettershaga: tryck på en bild → öppna i lightbox på rätt index
