       imgs:["/maria-hus/ametisten.jpg","/maria-hus/ametisten-2.jpg","/maria-hus/ametisten-3.jpg"],
       note:"Nuvarande plan. Byggsats = material; grund, montage och finish är egna poster. Redigerbar & delad (spara till alla).",
       incl:["Materialsats: stomme, fasad, yttertak, fönster","Kök, badrum, vitvaror, värmesystem"],
       excl:["Grund/platta","Montage & resning","VVS/el-installation (arbete)","Målning & finish","Bygglov, KA, besiktning","Tomt + anslutningar"],lines:null},
      {id:"sommar80",name:"Tidlös Sommar 80",sup:"Sommarnöjen",kvm:80,plan:"1-plan + loft",lev:"Nyckelfärdigt + Fast pris",
       url:"https://sommarnojen.se/hus/tidlos-sommar-70/",img:"/maria-hus/sommarnojen.jpg",
       imgs:["/maria-hus/sommarnojen.jpg","/maria-hus/sommarnojen-2.jpg","/maria-hus/sommarnojen-3.jpg"],
       note:"Arkitektritad volymmodul på plintar, skjutbara treglas. Fast pris bundlar grund→myndighet, 10 år ABS 18 + färdigställandeskydd.",
       incl:["Hus nyckelfärdigt monterat (kök, bad, golv, målning, invändig el+VVS)","Fast pris: grund (plintar), montage, el/VA-inkoppling","Bygglov, KA, besiktning, färdigställandeskydd","Permanentklassning (tillgänglighet, värmepump, energiberäkning)","10 års ansvar (ABS 18)"],
       excl:["Tomt","Anslutningsavgifter el/vatten/avlopp","Ev. enskilt avlopp + borrad brunn","Bergsprängning/pålning vid svår mark"],
       lines:[{l:"Hus nyckelfärdigt (Tidlös 80)",v:2610000},{l:"Permanentklassning",v:150000},
              {l:"Fast pris: grund, montage, el/VA-inkoppling, KA, besiktning, färdigställandeskydd",v:640000}]},
      {id:"sommar100",name:"Tidlös Sommar 100",sup:"Sommarnöjen",kvm:100,plan:"1-plan + loft",lev:"Nyckelfärdigt + Fast pris",
       url:"https://sommarnojen.se/hus/tidlos-sommar-100/",img:"/maria-hus/sommarnojen.jpg",
       imgs:["/maria-hus/sommarnojen.jpg","/maria-hus/sommarnojen-2.jpg","/maria-hus/sommarnojen-3.jpg"],
       note:"Som Sommar 80 men 100 kvm. Fler kvm, samma trygghet (fast pris + 10 år ABS 18).",
       incl:["Hus nyckelfärdigt monterat (kök, bad, golv, målning, invändig el+VVS)","Fast pris: grund (plintar), montage, el/VA-inkoppling","Bygglov, KA, besiktning, färdigställandeskydd","Permanentklassning (tillgänglighet, värmepump, energiberäkning)","10 års ansvar (ABS 18)"],
       excl:["Tomt","Anslutningsavgifter el/vatten/avlopp","Ev. enskilt avlopp + borrad brunn","Bergsprängning/pålning vid svår mark"],
       lines:[{l:"Hus nyckelfärdigt (Tidlös 100)",v:3330000},{l:"Permanentklassning",v:150000},
              {l:"Fast pris: grund, montage, el/VA-inkoppling, KA, besiktning, färdigställandeskydd",v:700000}]},
      {id:"husverket80",name:"Klassisk K3.80",sup:"Husverket",kvm:80,plan:"1-plan",lev:"Modul + entreprenadpaket",
       url:"https://husverket.se/fritidshus-80kvm/",img:"/maria-hus/husverket.jpg",
       imgs:["/maria-hus/husverket.jpg","/maria-hus/husverket-2.jpg","/maria-hus/husverket-3.jpg"],
       note:"Billig modul i permanentstandard. 'Stora entreprenadpaketet – Fast pris' (grund, VA/el, inkoppling, slutbesiktning, försäkring) sätts efter platsbesök.",
       incl:["Hus modul i permanentstandard (åretrunt)","'Stora entreprenadpaketet' (fast pris): grund, VA/el-infra, inkoppling","Slutbesiktning + färdigställande-/nybyggnadsförsäkring"],
       excl:["Tomt","Anslutningsavgifter","Fast pris-siffran sätts efter platsbesök"],
       lines:[{l:"Hus modul (Klassisk K3.80)",v:822900},{l:"Stora entreprenadpaketet – Fast pris",v:null,note:"grund, VA/el, inkoppling, besiktning, försäkring — offereras efter platsbesök"}]},
      {id:"gimmeshelter",name:"H80",sup:"Gimme Shelter",kvm:80,plan:"1-plan",lev:"Nyckelfärdigt (plintar)",
       url:"https://gimme-shelter.se/",img:"/maria-hus/gimmeshelter.jpg",
       imgs:["/maria-hus/gimmeshelter.jpg","/maria-hus/gimmeshelter-2.jpg","/maria-hus/gimmeshelter-3.jpg"],
       note:"Arkitektritad volymmodul, skjutbara treglas ner till golv. Smak-tvilling till Sommarnöjen. Pris vid förfrågan.",
       incl:["Hus nyckelfärdigt monterat på plintar","Vinterisolerat för åretruntboende"],
       excl:["Mark/grund-omfattning oklar — begär offert","Tomt + anslutningar","Pris vid förfrågan (inga öppna priser)"],
       lines:[{l:"Hus nyckelfärdigt (H80, plintar)",v:null,note:"pris vid förfrågan"}]},
      {id:"brutnatur",name:"Brut Natur",sup:"Brut Natur",kvm:80,plan:"1-plan",lev:"Nyckelfärdigt (KL-trä)",
       url:"https://brutnatur.se/fritidshus-norrtalje/",img:"/maria-hus/brutnatur.jpg",
       imgs:["/maria-hus/brutnatur.jpg","/maria-hus/brutnatur-2.jpg","/maria-hus/brutnatur-3.jpg"],
       note:"Arkitektritat i KL-trä + natursten + bränd panel (Shou Sugi Ban). Marknadsför Norrtälje. Pris vid förfrågan.",
       incl:["Hus nyckelfärdigt i KL-trä (natursten, bränd panel)","Marknadsför Norrtälje/Roslagen"],
       excl:["Mark/grund-omfattning oklar — begär offert","Tomt + anslutningar","Pris vid förfrågan (inga öppna priser)"],
       lines:[{l:"Hus nyckelfärdigt (CLT)",v:null,note:"pris vid förfrågan"}]}
    ];
    var selectedAlt=localStorage.getItem("maria_alt")||"ametisten";
    var altEdits={}; try{ altEdits=JSON.parse(localStorage.getItem("maria_alt_edits")||"{}"); }catch(e){}
    function altById(id){ for(var i=0;i<ALTERNATIVES.length;i++){ if(ALTERNATIVES[i].id===id) return ALTERNATIVES[i]; } return ALTERNATIVES[0]; }
    function altLines(alt){ if(!alt.lines)return null; var e=altEdits[alt.id]||{}; return alt.lines.map(function(ln,i){ return {l:ln.l,v:(e[i]!=null?e[i]:ln.v),note:ln.note}; }); }
    function houseSum(alt){
      if(!alt.lines){ var V=work.vettershaga; return {sum:(V.byggsats||0)+(V.grund||0)+(V.montage||0)+(V.installation||0)+(V.malning||0)+(V.kringkostnad||0),unknown:0}; }
      var sum=0,unknown=0; altLines(alt).forEach(function(ln){ if(ln.v==null||ln.v==="?")unknown++; else if(ln.v!=="ingår")sum+=(parseKr(ln.v)||0); });
      return {sum:sum,unknown:unknown};
    }
    function effV(alt){ var V=work.vettershaga; if(!alt.lines)return V;
      return {tomt:V.tomt,lagfartPct:V.lagfartPct,avlopp:V.avlopp,brunn:V.brunn,el:V.el,buffertPct:V.buffertPct,
              byggsats:houseSum(alt).sum,grund:0,montage:0,installation:0,malning:0,kringkostnad:0}; }
    function computeAlt(alt){ var S=clone(work); S.vettershaga=effV(alt); return compute(S); }

    // ---- Bildgalleri / lightbox (swipa + zooma) ----
    var _lbImgs=[],_lbI=0,_lbScale=1,_lbX=0,_lbY=0;
    function lbApplyT(){ var im=document.getElementById("mf-lb-img"); if(im) im.style.transform="translate("+_lbX+"px,"+_lbY+"px) scale("+_lbScale+")"; }
    function lbClampPan(){ var st=document.getElementById("mf-lb-stage"); if(!st)return; var mx=st.clientWidth*(_lbScale-1)/2, my=st.clientHeight*(_lbScale-1)/2; _lbX=Math.max(-mx,Math.min(mx,_lbX)); _lbY=Math.max(-my,Math.min(my,_lbY)); }
    function lbZoom(on){ _lbScale=on?2.4:1; _lbX=0; _lbY=0; var im=document.getElementById("mf-lb-img"); if(im)im.classList.toggle("zoom",on); lbApplyT(); }
    function lbRender(){ var im=document.getElementById("mf-lb-img"),c=document.getElementById("mf-lb-count"); if(!im)return; _lbScale=1;_lbX=0;_lbY=0; im.classList.remove("zoom"); im.src=_lbImgs[_lbI]||""; lbApplyT(); if(c)c.textContent=(_lbI+1)+" / "+_lbImgs.length; }
    function lbNav(d){ if(!_lbImgs.length)return; _lbI=(_lbI+d+_lbImgs.length)%_lbImgs.length; lbRender(); }
    function lbClose(){ var lb=document.getElementById("mf-lb"); if(lb)lb.classList.remove("open"); document.body.style.overflow=""; }
    function openLightbox(imgs,i){ imgs=(imgs&&imgs.length)?imgs:[]; if(!imgs.length)return; _lbImgs=imgs; _lbI=i||0; ensureLightbox(); document.getElementById("mf-lb").classList.add("open"); document.body.style.overflow="hidden"; lbRender(); }
    function ensureLightbox(){
      if(document.getElementById("mf-lb"))return;
      var lb=document.createElement("div"); lb.className="mf-lb"; lb.id="mf-lb";
      lb.innerHTML='<div class="mf-lb-top"><span class="mf-lb-count" id="mf-lb-count"></span><button class="mf-lb-close" id="mf-lb-close" aria-label="Stäng">×</button></div>'
        +'<div class="mf-lb-stage" id="mf-lb-stage"><button class="mf-lb-nav mf-lb-prev" id="mf-lb-prev" aria-label="Föregående">‹</button>'
        +'<img class="mf-lb-img" id="mf-lb-img" alt="Husbild">'
        +'<button class="mf-lb-nav mf-lb-next" id="mf-lb-next" aria-label="Nästa">›</button></div>'
        +'<div class="mf-lb-cap">Tryck på bilden för att zooma · svep för att bläddra</div>';
      document.body.appendChild(lb);
      lb.querySelector("#mf-lb-close").onclick=lbClose;
      lb.querySelector("#mf-lb-prev").onclick=function(e){ e.stopPropagation(); lbNav(-1); };
      lb.querySelector("#mf-lb-next").onclick=function(e){ e.stopPropagation(); lbNav(1); };
      lb.addEventListener("click",function(e){ if(e.target===lb) lbClose(); });
      var st=lb.querySelector("#mf-lb-stage"), sx=0,sy=0,px=0,py=0,moved=0,lastdx=0;
      st.addEventListener("touchstart",function(e){ var t=e.touches[0]; sx=t.clientX; sy=t.clientY; px=_lbX; py=_lbY; moved=0; lastdx=0; },{passive:true});
      st.addEventListener("touchmove",function(e){ var t=e.touches[0]; var dx=t.clientX-sx, dy=t.clientY-sy; lastdx=dx; moved=Math.max(moved,Math.abs(dx)+Math.abs(dy)); if(_lbScale>1){ _lbX=px+dx; _lbY=py+dy; lbClampPan(); lbApplyT(); e.preventDefault(); } },{passive:false});
      st.addEventListener("touchend",function(){ if(moved<10){ lbZoom(_lbScale===1); } else if(_lbScale===1 && Math.abs(lastdx)>45){ lbNav(lastdx<0?1:-1); } });
      st.addEventListener("click",function(e){ if(e.target.id==="mf-lb-img" && !("ontouchstart" in window)) lbZoom(_lbScale===1); });
      document.addEventListener("keydown",function(e){ var o=document.getElementById("mf-lb"); if(!o||!o.classList.contains("open"))return; if(e.key==="Escape")lbClose(); else if(e.key==="ArrowLeft")lbNav(-1); else if(e.key==="ArrowRight")lbNav(1); });
    }

    // ---- compute (samma motor som pappen) ----
    function compute(S){
      var K=S.karlpers,G=S.grimvagen,V=S.vettershaga,P=S.privatekonomi,N=S.nyahuset||{};
      var andel=(K.agarandelPct||0)/100;
      var kSalj=K.totalpris*andel,kMaklare=K.maklararvode*andel,kAnskaff=K.anskaffning1975*andel,kForb=K.forbattringar*andel;
      var kVinst=Math.max(0,kSalj-kMaklare-kAnskaff-kForb),kSkatt=kVinst*0.22,kNetto=kSalj-kMaklare-kSkatt;
      var gMaklare=G.varde*(G.maklararvodePct||0)/100;
      var gVinst=Math.max(0,G.varde-G.anskaffning-G.forbattringar-gMaklare),gSkatt=gVinst*0.22,gNetto=G.varde-G.lan-gMaklare-gSkatt;
      var vLagfart=V.tomt*(V.lagfartPct||0)/100;
      var vDelsum=V.tomt+vLagfart+V.avlopp+V.brunn+V.el+V.byggsats+V.grund+V.montage+V.installation+V.malning+V.kringkostnad;
      var vBuffert=vDelsum*(V.buffertPct||0)/100,vTotal=vDelsum+vBuffert;
      var uppskov=N.permanent?gSkatt:0,gNettoEff=gNetto+uppskov;
      var kapital=kNetto+gNettoEff+P.fondsparande;
      var L=N.lan||0,ranteMan=L*(N.rantaPct||0)/100/12,ranteEfterAvdrag=ranteMan*0.7,amortMan=L*(N.amorteringPct||0)/100/12,lanKostnadMan=ranteEfterAvdrag+amortMan;
      var tillgangligt=kapital+L,buffert=tillgangligt-vTotal;
      var utgifterMan=P.frejgatanHyra+P.driftVettershagaMan+lanKostnadMan;
      var kvarJobbar=(P.pensionNetto+P.lonNetto)-utgifterMan,kvarPension=P.pensionNetto-utgifterMan;
      return {andel:andel,kSalj:kSalj,kMaklare:kMaklare,kAnskaff:kAnskaff,kForb:kForb,kVinst:kVinst,kSkatt:kSkatt,kNetto:kNetto,gMaklare:gMaklare,gVinst:gVinst,gSkatt:gSkatt,gNetto:gNetto,uppskov:uppskov,gNettoEff:gNettoEff,vLagfart:vLagfart,vDelsum:vDelsum,vBuffert:vBuffert,vTotal:vTotal,permanent:!!N.permanent,L:L,ranteEfterAvdrag:ranteEfterAvdrag,amortMan:amortMan,lanKostnadMan:lanKostnadMan,kapital:kapital,buffert:buffert,kvarJobbar:kvarJobbar,kvarPension:kvarPension};
    }
    function takeaway(c){
      var a=c.buffert>=0?("Kapitalet räcker, med "+kr(c.buffert)+" kvar som buffert."):("Med dagens antaganden fattas "+kr(-c.buffert)+" för att nå ända fram.");
      var b=c.kvarPension<5000?(" Efter pension blir marginalen tight — "+kr(c.kvarPension)+"/mån kvar till mat och liv."):(" Efter pension: "+kr(c.kvarPension)+"/mån kvar till mat och liv.");
      return a+b;
    }

    // ---- render helpers ----
    function ed(path,type){
      type=type||"kr"; var v=get(work,path); if(v==null)v=0;
      var fmt=type==="pct"?pct:kr;
      var f=FLAGS[path];
      var badge=f==="komplettera"?'<span class="mf-flag mf-komplettera">kompletteras</span>':(f==="schablon"?'<span class="mf-flag mf-schablon">schablon</span>':"");
      var ovBadge="";
      var ov=overrides[path];
      if(ov&&typeof ov.v!=="undefined"){
        var orig=get(baseline,path); if(orig==null)orig=0;
        var title="Original: "+fmt(orig)+" · ändrat av "+(ov.by||"någon")+(ov.ts?(" · "+provDay(ov.ts)):"")+(ov.note?("\n"+ov.note):"");
        ovBadge='<span class="mf-flag mf-justerad" title="'+esc(title)+'">justerad</span>'
          +'<span class="mf-revert" data-revert="'+esc(path)+'" title="Återställ till original för alla">↺</span>';
      }
      return '<span class="mf-edit" data-path="'+path+'" data-type="'+type+'" tabindex="0" title="Dubbelklicka för att ändra">'+fmt(v)+'</span>'+badge+ovBadge;
    }
    function row(label,val,o){ o=o||{};
      return '<tr class="'+(o.calc?"mf-calc":"")+(o.strong?" mf-strong":"")+(o.hi?" mf-hi-"+o.hi:"")+'"><td class="mf-lbl">'+label+(o.note?'<span class="mf-note">'+o.note+'</span>':"")+'</td><td class="mf-val">'+val+'</td></tr>'; }
    function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c];}); }
    function fmtDate(ts){ var d=new Date(ts); return d.toLocaleDateString("sv-SE")+" "+d.toLocaleTimeString("sv-SE",{hour:"2-digit",minute:"2-digit"}); }

    function draw(){
      var alt=altById(selectedAlt);
      var S=clone(work); S.vettershaga=effV(alt);
      var c=compute(S);
      var hs=houseSum(alt);
      var unsaved=diffList().length;
      var goBadge=c.buffert>=0?'<span class="mf-pill mf-ok">Buffert '+kr(c.buffert)+'</span>':'<span class="mf-pill mf-bad">Underskott '+kr(-c.buffert)+'</span>';
      var kvarBadge=c.kvarPension<5000?'<span class="mf-pill mf-warn">Tight — '+kr(c.kvarPension)+'/mån kvar</span>':'<span class="mf-pill mf-ok">'+kr(c.kvarPension)+'/mån kvar</span>';
      var reasonHtml="";
      if(reasoning){
