      var kVinst=Math.max(0,kSalj-kMaklare-kAnskaff-kForb),kSkatt=kVinst*0.22,kNetto=kSalj-kMaklare-kSkatt;
      var gMaklare=G.varde*(G.maklararvodePct||0)/100;
      var gVinst=Math.max(0,G.varde-G.anskaffning-G.forbattringar-gMaklare),gSkatt=gVinst*0.22,gNetto=G.varde-G.lan-gMaklare-gSkatt;
