      // Lokal komplettering av alternativens hus-poster (offert fylls i)
      Array.prototype.forEach.call(document.querySelectorAll("[data-altedit]"),function(el){
        function start(){
          if(el.querySelector("input"))return;
          var ref=el.getAttribute("data-altedit").split(":"),aid=ref[0],idx=+ref[1];
          var cur=(altEdits[aid]&&altEdits[aid][idx]!=null)?altEdits[aid][idx]:"";
          el.innerHTML='<input class="mf-input" value="'+cur+'" inputmode="decimal">';
          var inp=el.querySelector("input"); inp.focus(); inp.select(); var done=false;
          function commit(){ if(done)return; done=true; altEdits[aid]=altEdits[aid]||{}; if(String(inp.value).trim()===""){ delete altEdits[aid][idx]; } else { altEdits[aid][idx]=parseKr(inp.value); } try{localStorage.setItem("maria_alt_edits",JSON.stringify(altEdits));}catch(e){} draw(); }
          inp.addEventListener("blur",commit);
          inp.addEventListener("keydown",function(e){ if(e.key==="Enter"){e.preventDefault();inp.blur();} else if(e.key==="Escape"){done=true;draw();} });
        }
        el.addEventListener(COARSE?"click":"dblclick",start);
        el.addEventListener("keydown",function(e){ if(e.key==="Enter"){e.preventDefault();start();} });
      });
      Array.prototype.forEach.call(document.querySelectorAll(".mf-edit"),function(el){
        function start(){
          if(el.querySelector("input"))return;
          var path=el.getAttribute("data-path"),type=el.getAttribute("data-type"),raw=get(work,path); if(raw==null)raw=0;
          el.innerHTML='<input class="mf-input" value="'+raw+'" inputmode="decimal">';
          var inp=el.querySelector("input"); inp.focus(); inp.select(); var done=false;
          function commit(){ if(done)return; done=true; var val=type==="pct"?parsePct(inp.value):parseKr(inp.value); set(work,path,val); save(); draw(); }
          inp.addEventListener("blur",commit);
          inp.addEventListener("keydown",function(e){ if(e.key==="Enter"){e.preventDefault();inp.blur();} else if(e.key==="Escape"){done=true;draw();} });
        }
        el.addEventListener(COARSE?"click":"dblclick",start);
        el.addEventListener("keydown",function(e){ if(e.key==="Enter"){e.preventDefault();start();} });
      });
      // Fällbara sektioner (klick på rubriken; läge sparas per sektion)
      Array.prototype.forEach.call(document.querySelectorAll("[data-collapse]"),function(sec){
        var key="maria_col_"+sec.getAttribute("data-collapse");
        var saved=localStorage.getItem(key);
        var collapsed = saved===null ? (sec.getAttribute("data-collapse-default")==="closed") : saved==="1";
        var h=sec.querySelector("h3"); if(!h)return;
        h.classList.add("mf-collhead");
        if(!h.querySelector(".mf-collchev")){ var cv=document.createElement("span"); cv.className="mf-collchev"; h.insertBefore(cv,h.firstChild); }
        function apply(){ sec.classList.toggle("collapsed",collapsed); var c=h.querySelector(".mf-collchev"); if(c)c.textContent=collapsed?"▸":"▾"; }
        apply();
        h.addEventListener("click",function(e){ if(e.target.closest("a,button,input,.mf-edit,.alt-fill,.alt-q,.mf-revert"))return; collapsed=!collapsed; try{localStorage.setItem(key,collapsed?"1":"0");}catch(_){} apply(); });
