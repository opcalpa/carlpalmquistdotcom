    // ---- format ----
    function kr(n){ return (Math.round(n)||0).toLocaleString("sv-SE") + " kr"; }
    function pct(n){ return (Math.round((n||0)*100)/100).toLocaleString("sv-SE") + " %"; }
    function parseKr(s){ var n=parseFloat(String(s).replace(/\s/g,"").replace(/[^\d.-]/g,"")); return isNaN(n)?0:Math.round(n); }
    function parsePct(s){ var n=parseFloat(String(s).replace(/\s/g,"").replace(",",".").replace(/[^\d.-]/g,"")); return isNaN(n)?0:n; }
    function clone(o){ return JSON.parse(JSON.stringify(o)); }
    function get(o,p){ return p.split(".").reduce(function(a,k){return a==null?a:a[k];},o); }
    function set(o,p,v){ var ks=p.split("."),last=ks.pop(),c=o; ks.forEach(function(k){c=c[k]=c[k]||{};}); c[last]=v; }
    function applyOverrides(base,ov){ var o=clone(base); Object.keys(ov||{}).forEach(function(p){ if(ov[p]&&typeof ov[p].v!=="undefined") set(o,p,ov[p].v); }); return o; }
    function provDay(ts){ try{ return new Date(ts).toLocaleDateString("sv-SE",{day:"numeric",month:"short",year:"numeric"}); }catch(e){ return ""; } }

