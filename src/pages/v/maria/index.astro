    ];
    var FIELD_LABEL={}, FIELD_TYPE={};
    FIELDS.forEach(function(f){ FIELD_LABEL[f[0]]=f[1]; FIELD_TYPE[f[0]]=f[2]; });
    function fmtVal(path,n){ return (FIELD_TYPE[path]==="pct"?pct:kr)(n); }

    // ---- Husalternativ (publika katalogpriser; Ametisten = live-baslinjen från KV) ----
    // lines[].v: tal (kr) | "ingår" (bundlat → 0) | null (? ej offererat → räknas ej, flaggar total).
