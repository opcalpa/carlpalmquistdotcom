      ["vettershaga.el","El","kr"],["vettershaga.byggsats","Byggsats","kr"],["vettershaga.grund","Grund","kr"],["vettershaga.montage","Montage","kr"],
      ["vettershaga.installation","Installation","kr"],["vettershaga.malning","Målning","kr"],["vettershaga.kringkostnad","Kringkostnad","kr"],["vettershaga.buffertPct","Buffert","pct"],
      ["privatekonomi.fondsparande","Fondsparande","kr"],["privatekonomi.pensionNetto","Pension/mån","kr"],["privatekonomi.lonNetto","Lön/mån","kr"],
