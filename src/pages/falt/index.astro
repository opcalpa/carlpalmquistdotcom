---
// Fält-pappen — mobil inkorg/utkorg + läs-spegel mot Calles lokala PA-app. Medvetet UTAN
// Layout.astro (ingen PostHog/session-recording på personliga anteckningar). Gate: pw →
// localStorage, valideras av servern (/api/falt). Design: pappens mörka identitet.
// Spegel-flikarna (To Do/Listor/Agera) är LÄSVYER av senaste snapshot pappen pushade —
// alltid "senaste gången Macen var vaken", aldrig redigerbara härifrån.
---

<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Fält-pappen</title>
  <link rel="manifest" href="/falt.webmanifest" />
  <meta name="theme-color" content="#0f1115" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Fält-pappen" />
  <link rel="apple-touch-icon" href="/images/Favikon/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/Favikon/favicon-32x32.png" />
  <style is:global>
    :root{
      --bg:#0f1115; --panel:#161922; --panel2:#1d212c; --line:#272c38;
      --txt:#e6e8ee; --dim:#9aa3b2; --accent:#6c8cff; --ok:#37c184; --warn:#e6b450; --hi:#e0607a;
      --radius:12px;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:var(--bg);color:var(--txt);font:16px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Inter,sans-serif;min-height:100vh;padding-bottom:env(safe-area-inset-bottom)}
    .wrap{max-width:640px;margin:0 auto;padding:14px 14px 40px}
    header{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 2px 12px}
    header h1{font-size:17px;font-weight:700;letter-spacing:.3px;cursor:pointer;min-width:0}
    header h1:active{color:var(--accent)}
    .hdr-r{display:flex;align-items:center;gap:8px;flex-shrink:0}
    .navsel{background:var(--panel2);border:1px solid var(--line);color:var(--txt);border-radius:10px;padding:8px 10px;font-size:14px;font-weight:600;max-width:160px}
    .refresh{background:transparent;border:1px solid var(--line);color:var(--dim);border-radius:999px;padding:8px 11px;font-size:15px;line-height:1}
    .refresh:active{color:var(--accent);border-color:var(--accent)}
    /* Läs-moduler pushade från pappen (recept/träning/aktiviteter) */
    .fcard{background:var(--panel);border:1px solid var(--line);border-radius:12px;margin-bottom:8px;overflow:hidden}
    .fcard>summary{list-style:none;cursor:pointer;padding:12px 14px;font-weight:600;font-size:15px}
    .fcard>summary::-webkit-details-marker{display:none}
    .fcard[open]>summary{border-bottom:1px solid var(--line)}
    .fbody{padding:12px 14px;font-size:14px;line-height:1.5}
    .fmeta{color:var(--dim);font-size:12.5px;margin-bottom:6px}
    .ftag{display:inline-block;font-size:11px;color:var(--dim);border:1px solid var(--line);border-radius:6px;padding:0 6px;margin-left:4px;font-weight:400}
    .fshelf{font-size:13px;color:var(--dim);margin:16px 0 6px;font-weight:700}
    .fshelf .fcount{background:var(--panel2);border-radius:6px;padding:0 6px;font-size:11px}
    .fvibe{font-style:italic;color:var(--dim);margin:0 0 8px}
    .fsteps{margin:0;padding-left:18px}
    .fsteps li{margin-bottom:6px}
    .fcue{display:block;color:var(--dim);font-size:12px}
    /* Träning: bild-thumbs + kör-knapp + mobil pass-player */
    .fthumb{width:34px;height:34px;border-radius:6px;object-fit:cover;vertical-align:middle;margin-right:7px;background:var(--panel2);flex:0 0 auto}
    .ftsteps li{list-style:none;margin-left:-18px;display:flex;align-items:flex-start}
    .fstep-t{flex:1;min-width:0}
    .fkor{width:100%;background:var(--accent);color:#fff;border:none;border-radius:10px;padding:11px;font-size:15px;font-weight:600;margin-bottom:10px;cursor:pointer}
    .fwp{position:fixed;inset:0;z-index:80;background:var(--bg);display:flex;flex-direction:column;padding:14px;box-sizing:border-box}
    .fwp-top{display:flex;align-items:center;gap:8px;position:relative;padding-bottom:8px}
    .fwp-x{background:transparent;border:1px solid var(--line);color:var(--txt);border-radius:50%;width:34px;height:34px;font-size:15px;cursor:pointer;flex:0 0 auto}
    .fwp-ti{font-size:13px;color:var(--dim);flex:1;text-align:center}
    .fwp-prog{position:absolute;left:0;right:0;bottom:0;height:3px;background:var(--line);border-radius:2px}
    .fwp-prog>div{height:100%;background:var(--accent);transition:width .3s}
    .fwp-c{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:7px;overflow:auto}
    .fwp-ph{font-size:15px;letter-spacing:2px;color:var(--dim);font-weight:700}
    .fwp-rest{color:var(--accent)}
    .fwp-nm{font-size:25px;font-weight:800}
    .fwp-big{font-size:74px;font-weight:800;line-height:1}
    .fwp-u{color:var(--dim);font-size:14px}
    .fwp-nx{color:var(--dim);font-size:15px}
    .fwp-cue{color:var(--dim);font-size:14px;max-width:340px;line-height:1.4}
    .fwp-mus{color:var(--accent);font-size:12px;font-weight:600;opacity:.9;max-width:340px}
    .fwp-desc{font-size:13px;line-height:1.45;text-align:left;background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:9px 11px}
    .fwp-imgs{display:flex;align-items:center;gap:6px;margin:2px 0}
    .fwp-img{position:relative;flex:1;max-width:150px}
    .fwp-img img{width:100%;border-radius:10px;display:block}
    .fwp-img span{position:absolute;bottom:4px;left:4px;font-size:9px;background:rgba(0,0,0,.6);color:#fff;padding:1px 5px;border-radius:4px}
    .fwp-arw{font-size:22px;color:var(--dim)}
    .fwp-done{background:var(--accent);color:#fff;border:none;border-radius:10px;padding:12px 26px;font-size:16px;font-weight:600;margin-top:6px;cursor:pointer}
    .fwp-ctrl{display:flex;gap:8px;justify-content:center;padding-top:8px}
    .fwp-ctrl button{flex:1;max-width:120px;background:var(--panel);border:1px solid var(--line);color:var(--txt);border-radius:10px;padding:13px;font-size:18px;cursor:pointer}
    .fwp-fin{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px}
    .fwp-fe{font-size:54px}
    .fwp-fs{color:var(--dim)}
    .fwp-doneb{background:var(--accent);color:#fff;border:none;border-radius:10px;padding:12px 30px;font-size:16px;margin-top:12px;cursor:pointer}
    .fdest{background:var(--panel2);border-radius:10px;padding:10px 12px;margin-bottom:8px}
    .fblurb{color:var(--dim);font-size:13px;margin-top:2px}
    .fnote{color:var(--dim);font-size:12.5px;margin-top:4px}
    .stamp{font-size:11px;color:var(--dim);margin:0 2px 10px}
    .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:14px;margin-bottom:12px}
    h2{font-size:13px;text-transform:uppercase;letter-spacing:1px;color:var(--dim);font-weight:600;margin-bottom:10px}
    textarea{width:100%;min-height:110px;background:var(--panel2);border:1px solid var(--line);border-radius:10px;color:var(--txt);padding:12px;font:16px/1.5 inherit;resize:vertical}
    textarea:focus{outline:none;border-color:var(--accent)}
    .savebtn{width:100%;margin-top:10px;background:var(--accent);border:none;color:#fff;font-size:16px;font-weight:600;border-radius:10px;padding:14px;cursor:pointer}
    .savebtn:disabled{opacity:.5}
    .toast{font-size:13px;color:var(--ok);margin-top:8px;min-height:18px}
    .toast.err{color:var(--warn)}
    .qrow{display:flex;gap:8px;align-items:baseline;padding:8px 2px;border-top:1px solid var(--line);font-size:14px}
    .qrow:first-of-type{border-top:none}
    .qwhen{color:var(--dim);font-size:12px;flex-shrink:0;font-variant-numeric:tabular-nums}
    .qtext{white-space:pre-wrap;word-break:break-word}
    .qrow.pending{opacity:.72}
    .qrow.pending .qwhen{color:var(--warn,#e0a030);font-weight:600}
    .hint{font-size:12px;color:var(--dim);margin-top:8px}
    .doc{border:1px solid var(--line);border-radius:10px;background:var(--panel2);margin-bottom:8px;overflow:hidden}
    .doc-head{display:flex;justify-content:space-between;align-items:center;gap:8px;padding:12px;cursor:pointer;font-weight:600;font-size:15px}
    .doc-head .at{color:var(--dim);font-size:12px;font-weight:400;flex-shrink:0}
    .doc-body{display:none;padding:2px 14px 14px;font-size:15px}
    .doc.open .doc-body{display:block}
    .doc-body h1{font-size:18px;margin:12px 0 6px}
    .doc-body h2{font-size:15px;text-transform:none;letter-spacing:0;color:var(--txt);margin:12px 0 6px}
    .doc-body h3{font-size:14px;margin:10px 0 4px}
    .doc-body p{margin:8px 0}
    .doc-body ul{margin:8px 0 8px 20px}
    .doc-body li{margin:3px 0}
    li.cl{list-style:none;margin-left:-18px}
    li.cl.done{color:var(--dim);text-decoration:line-through}
    .doc-body a{color:var(--accent)}
    .doc-body strong{color:#fff}
    .empty{color:var(--dim);font-size:14px;padding:6px 2px}
    /* Spegel-grupper (To Do-sektioner / List-tavlor) */
    .grp{border:1px solid var(--line);border-radius:10px;background:var(--panel);margin-bottom:8px;overflow:hidden}
    .grp-head{display:flex;align-items:center;gap:8px;padding:12px;cursor:pointer;font-weight:600;font-size:15px}
    .grp-head .n{margin-left:auto;color:var(--dim);font-size:12px;font-weight:500;border:1px solid var(--line);border-radius:999px;padding:1px 9px;flex-shrink:0}
    .grp-body{display:none;padding:0 10px 10px}
    .grp.open .grp-body{display:block}
    .mrow{border-top:1px solid var(--line);padding:9px 2px;font-size:14px}
    .mrow-head{display:flex;align-items:baseline;gap:7px;cursor:pointer;min-width:0}
    .mrow-head .pri{flex-shrink:0}
    .mrow-head .t{word-break:break-word}
    .mrow-head .due{margin-left:auto;color:var(--warn);font-size:11px;flex-shrink:0;font-variant-numeric:tabular-nums}
    .mrow.done .t{color:var(--dim);text-decoration:line-through}
    .mrow-body{display:none;padding:6px 2px 2px;color:var(--dim);font-size:13px;white-space:pre-wrap;word-break:break-word}
    .mrow.open .mrow-body{display:block}
    .mrow-body .cl{margin-top:6px;color:var(--txt)}
    .mrow-body .cl div{padding:2px 0}
    .mrow-body a{color:var(--accent)}
    .showdone{background:transparent;border:none;color:var(--dim);font-size:12px;padding:8px 2px;cursor:pointer;text-decoration:underline}
    /* Agera */
    .arow{display:flex;gap:8px;align-items:baseline;border-top:1px solid var(--line);padding:9px 2px;font-size:14px}
    .arow:first-of-type{border-top:none}
    .arow .ic{flex-shrink:0}
    .arow .det{display:block;color:var(--dim);font-size:12px}
    .arow.now .t{color:#fff;font-weight:600}
    .cal-ev{display:flex;gap:8px;align-items:baseline;border-top:1px solid var(--line);padding:8px 2px;font-size:14px}
    .cal-ev:first-of-type{border-top:none}
    .cal-ev .tid{color:var(--dim);font-size:12px;flex-shrink:0;font-variant-numeric:tabular-nums}
    /* 🎲 Spel — stora tryckytor, lekfullt men i pappens mörka identitet */
    .sp-roster{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:11px 14px;font-size:14px;margin-bottom:10px}
    .sp-roster span{color:var(--dim)}
    .sp-turn{text-align:center;font-size:15px;color:var(--warn);margin-bottom:10px}
    #sp-timer{min-height:0;margin-bottom:8px}
    .sp-timernum{text-align:center;font-size:24px;font-weight:800;font-variant-numeric:tabular-nums}
    .sp-timernum.low{color:var(--hi)}
    .sp-timerbar{height:6px;background:var(--panel2);border-radius:999px;overflow:hidden;margin-top:4px}
    .sp-timerbar span{display:block;height:100%;background:var(--accent);border-radius:999px;transition:width 1s linear}
    .sp-topbtns{display:flex;gap:6px}
    .sp-choosett{font-size:15px;font-weight:700;margin:2px 2px 12px}
    /* 🎲 Tärningsresan */
    .tq-board{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:10px;margin-bottom:10px}
    .tq-startgoal{display:flex;justify-content:space-between;font-size:11px;color:var(--dim);margin-bottom:6px}
    .tq-row{display:flex;gap:4px;margin-bottom:4px}
    .tq-cell{flex:1;aspect-ratio:1;border:1px solid;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:17px;min-width:0;overflow:hidden;transition:background .2s}
    .tq-cell.has-p{font-size:19px;box-shadow:0 0 0 2px rgba(255,255,255,.15) inset}
    .tq-legend{display:flex;flex-wrap:wrap;gap:3px 12px;font-size:10.5px;margin-top:8px}
    .sp-av{background:var(--panel2);border:1px solid var(--line);border-radius:8px;font-size:17px;width:34px;height:34px;flex-shrink:0;cursor:pointer;line-height:1}
    .sp-av:active{border-color:var(--accent)}
    /* 🏆 Ställnings-overlay */
    .sp-lbov{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:60;display:flex;align-items:center;justify-content:center;padding:20px}
    .sp-lbcard{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:18px;width:100%;max-width:380px}
    .sp-lbcard .sp-next{width:100%}
    /* 🎊 Festlig slutskärm: konfetti + prispall */
    .sp-finalcard{position:relative;overflow:hidden;text-align:center}
    .sp-conf{position:absolute;top:-28px;pointer-events:none;animation:spfall 2.8s linear infinite}
    @keyframes spfall{to{transform:translateY(460px) rotate(340deg);opacity:.1}}
    .sp-winner{font-size:22px;font-weight:800;margin:2px 0 16px}
    .sp-podium{display:flex;align-items:flex-end;justify-content:center;gap:8px;margin-bottom:10px}
    .sp-pod{flex:1;max-width:110px;background:var(--panel2);border:1px solid var(--line);border-radius:10px 10px 0 0;padding:10px 6px 12px;text-align:center}
    .sp-pod0{order:2;padding-bottom:34px;border-color:var(--warn);background:rgba(230,180,80,.10)}
    .sp-pod1{order:1;padding-bottom:20px}
    .sp-pod2{order:3}
    .sp-pod-medal{font-size:26px}
    .sp-pod-name{font-weight:700;font-size:14px;word-break:break-word}
    .sp-pod-pts{color:var(--dim);font-size:13px;font-variant-numeric:tabular-nums}
    .sp-finalcard .sp-score{text-align:left}
    .sp-player .sp-on{width:18px;height:18px;accent-color:var(--accent);flex-shrink:0}
    .sp-mode{display:flex;align-items:center;gap:12px;width:100%;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px 14px;margin-bottom:10px;color:var(--txt);font-size:16px;font-weight:600;text-align:left;cursor:pointer}
    .sp-mode:active{border-color:var(--accent);background:var(--panel2)}
    .sp-mode .big{font-size:28px;flex-shrink:0}
    .sp-mode .sub{display:block;font-size:12.5px;color:var(--dim);font-weight:400;margin-top:2px}
    .sp-top{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:10px}
    .sp-back{background:transparent;border:1px solid var(--line);color:var(--dim);border-radius:999px;padding:6px 14px;font-size:13px}
    .sp-prog{font-size:12px;color:var(--dim);font-variant-numeric:tabular-nums}
    .sp-hand{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:34px 18px;text-align:center}
    .sp-hand .who{font-size:26px;font-weight:800;margin:8px 0 2px}
    .sp-hand .lvl{color:var(--dim);font-size:13px}
    .sp-q{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:18px 16px;margin-bottom:10px}
    .sp-cat{display:inline-block;font-size:11px;color:var(--dim);border:1px solid var(--line);border-radius:999px;padding:2px 10px;margin-bottom:10px}
    .sp-qtext{font-size:19px;font-weight:700;line-height:1.35}
    .sp-emoji{font-size:52px;line-height:1.25;text-align:center;padding:14px 0 6px;letter-spacing:6px}
    .sp-opt{display:block;width:100%;background:var(--panel2);border:1px solid var(--line);border-radius:12px;color:var(--txt);font-size:16px;font-weight:600;text-align:left;padding:14px;margin-top:8px;cursor:pointer}
    .sp-opt:disabled{opacity:1}
    .sp-opt.hit{border-color:var(--ok);background:rgba(55,193,132,.14)}
    .sp-opt.miss{border-color:var(--hi);background:rgba(224,96,122,.12)}
    .sp-opt.dim{opacity:.45}
    .sp-fun{margin-top:12px;font-size:14px;color:var(--dim);border-top:1px solid var(--line);padding-top:10px}
    .sp-fun strong{color:var(--warn)}
    .sp-next{width:100%;margin-top:12px;background:var(--accent);border:none;color:#fff;font-size:16px;font-weight:700;border-radius:12px;padding:14px;cursor:pointer}
    .sp-ghost{width:100%;margin-top:8px;background:transparent;border:1px solid var(--line);color:var(--dim);font-size:14px;font-weight:600;border-radius:12px;padding:12px;cursor:pointer}
    .sp-score{display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--line);padding:10px 2px;font-size:16px}
    .sp-score .pts{font-weight:800;font-variant-numeric:tabular-nums}
    .sp-score.win{color:var(--warn)}
    .sp-final{font-size:44px;text-align:center;padding:8px 0}
    .sp-player{display:flex;align-items:center;gap:8px;border-top:1px solid var(--line);padding:9px 2px;font-size:15px}
    .sp-player:first-of-type{border-top:none}
    .sp-player .nm{font-weight:600}
    .sp-player select{margin-left:auto;background:var(--panel2);border:1px solid var(--line);color:var(--txt);border-radius:8px;padding:6px 8px;font-size:13px}
    .sp-player .rm{background:transparent;border:none;color:var(--dim);font-size:15px;padding:4px 6px;cursor:pointer}
    .sp-addrow{display:flex;gap:8px;margin-top:10px}
    .sp-addrow input{flex:1;background:var(--panel2);border:1px solid var(--line);border-radius:10px;color:var(--txt);padding:11px;font-size:15px}
    .sp-addrow button{background:var(--panel2);border:1px solid var(--line);color:var(--txt);border-radius:10px;padding:0 16px;font-size:20px}
    .sp-setrow{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:12px;font-size:14px;color:var(--dim)}
    .sp-setrow select{background:var(--panel2);border:1px solid var(--line);color:var(--txt);border-radius:8px;padding:7px 9px;font-size:14px}
    .sp-hint-txt{margin-top:10px;font-size:14px;color:var(--warn);text-align:center}
    .sp-answer{margin-top:10px;font-size:22px;font-weight:800;text-align:center}
    .sp-tally{display:flex;gap:10px;margin-top:10px}
    .sp-tally button{flex:1;border-radius:12px;padding:13px;font-size:15px;font-weight:700;cursor:pointer;border:1px solid var(--line)}
    .sp-tally .yes{background:rgba(55,193,132,.14);color:var(--ok);border-color:var(--ok)}
    .sp-tally .no{background:rgba(224,96,122,.10);color:var(--hi);border-color:var(--hi)}
    .sp-sf{display:flex;gap:10px;margin-top:12px}
    .sp-sf button{flex:1;border-radius:12px;padding:18px 8px;font-size:17px;font-weight:800;cursor:pointer;background:var(--panel2);border:1px solid var(--line);color:var(--txt)}
    .sp-sf button.hit{border-color:var(--ok);background:rgba(55,193,132,.14)}
    .sp-sf button.miss{border-color:var(--hi);background:rgba(224,96,122,.12)}
    /* Gate */
    #gate{max-width:340px;margin:26vh auto 0;padding:0 20px;text-align:center}
    #gate p{color:var(--dim);font-size:14px;margin-bottom:14px}
    #gate input{width:100%;background:var(--panel2);border:1px solid var(--line);border-radius:10px;color:var(--txt);padding:13px;font-size:16px;text-align:center}
    #gate button{width:100%;margin-top:10px;background:var(--accent);border:none;color:#fff;font-weight:600;border-radius:10px;padding:13px;font-size:16px}
    #gate .err{color:var(--warn);font-size:13px;margin-top:10px;min-height:16px}
  </style>
</head>
<body>
  <div id="gate">
    <p>🔐 Fält-pappen</p>
    <input id="gate-pw" type="password" placeholder="Nyckel" autocomplete="current-password" />
    <button id="gate-go">Öppna</button>
    <div class="err" id="gate-err"></div>
  </div>

  <div class="wrap" id="app" hidden>
    <header>
      <h1 id="hometitle" title="Till Inkorg">📥 Mobil-pappen</h1>
      <div class="hdr-r">
        <select id="navsel" class="navsel" aria-label="Meny">
          <option value="inkorg">✍️ Inkorg</option>
          <option value="todo">✅ To Do</option>
          <option value="listor">📋 Listor</option>
          <option value="agera">🎯 Agera</option>
          <option value="spel">🎲 Spel</option>
          <option value="recept">🍳 Recept</option>
          <option value="traning">🏋️ Träning</option>
          <option value="aktiviteter">🗺️ Aktiviteter</option>
        </select>
        <button class="refresh" id="refresh" title="Uppdatera" aria-label="Uppdatera">↻</button>
      </div>
    </header>

    <section id="tab-inkorg">
      <div class="card">
        <h2>✍️ Nytt ärende</h2>
        <textarea id="note" placeholder="Anteckna — hämtas av pappen när den är vaken. Diktera gärna (🎙 på tangentbordet)."></textarea>
        <button class="savebtn" id="save">Spara till pappen</button>
        <div class="toast" id="toast"></div>
      </div>
      <div class="card">
        <h2>⏳ Väntar på pappen</h2>
        <div id="queue"><div class="empty">Inget i kön.</div></div>
        <div class="hint">Ärenden ligger här tills desktop-pappen hämtat dem — då landar de i «📥 Från mobilen» i Agera för verifiering.</div>
      </div>
      <div class="card">
        <h2>📖 Läsunderlag från pappen</h2>
        <div id="feed"><div class="empty">Inget pushat än.</div></div>
      </div>
    </section>

    <section id="tab-todo" hidden>
      <div class="stamp" id="stamp-todo"></div>
      <div id="todo"><div class="empty">Hämtar spegel…</div></div>
    </section>

    <section id="tab-listor" hidden>
      <div class="stamp" id="stamp-listor"></div>
      <div id="listor"><div class="empty">Hämtar spegel…</div></div>
    </section>

    <section id="tab-agera" hidden>
      <div class="stamp" id="stamp-agera"></div>
      <div class="card"><h2>📅 Idag</h2><div id="acal"><div class="empty">Ingen kalenderdata.</div></div></div>
      <div class="card"><h2>🎯 Att agera på</h2><div id="alist"><div class="empty">Inget i speglingen.</div></div></div>
    </section>

    <section id="tab-spel" hidden>
      <div id="spel"><div class="empty">Hämtar frågebanken…</div></div>
    </section>

    <section id="tab-recept" hidden>
      <div id="recept"><div class="empty">Hämtar recept…</div></div>
    </section>

    <section id="tab-traning" hidden>
      <div id="traning"><div class="empty">Hämtar träningspass…</div></div>
    </section>

    <section id="tab-aktiviteter" hidden>
      <div id="aktiviteter"><div class="empty">Hämtar aktiviteter…</div></div>
    </section>
  </div>

  <script is:inline>
    (function () {
      var API = "/api/falt";
      var pw = localStorage.getItem("falt_pw") || "";
      var $ = function (id) { return document.getElementById(id); };
      var mirror = null;   // senaste hämtade spegel-snapshot (cache tills ↻ eller ny app-öppning)

      // Offline-motståndskraft: fältet används där uppkopplingen är svag (strand, bil, kök). Varje lyckad fetch
      // speglas till localStorage och hydreras därifrån FÖRST (stale-while-revalidate) så skalet renderar direkt
      // offline; nätet uppdaterar sen tyst. Envägs-designen står kvar (read-only spegling); bara läs-cache + outbox.
      function lsGet(k) { try { return JSON.parse(localStorage.getItem("falt_cache_" + k) || "null"); } catch (e) { return null; } }
      function lsSet(k, v) { try { localStorage.setItem("falt_cache_" + k, JSON.stringify(v)); } catch (e) {} }
      // Durabel outbox: osända anteckningar (offline vid spara) köas här, renderas med «väntar på synk»-badge och
      // flushas på online-eventet / nästa lyckade hydrering. Klient-id (cid) gör serverns insert idempotent → replay säkert.
      function outboxGet() { try { return JSON.parse(localStorage.getItem("falt_outbox") || "[]"); } catch (e) { return []; } }
      function outboxSet(a) { try { localStorage.setItem("falt_outbox", JSON.stringify(a)); } catch (e) {} }
      function mkCid() { return "c" + Date.now().toString(36) + Math.random().toString(36).slice(2, 7); }

      function esc(s) { return String(s).replace(/[&<>"']/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]; }); }
      // Mini-markdown: rubriker, **fet**, *kursiv*, [länk](url), punktlistor, stycken.
      function md(src) {
        var lines = String(src).split("\n"), out = [], inUl = false;
        function inline(s) {
          return esc(s)
            .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
            .replace(/\*([^*]+)\*/g, "<em>$1</em>")
            .replace(/\[([^\]]+)\]\((https?:[^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
        }
        for (var i = 0; i < lines.length; i++) {
          var l = lines[i];
          var h = l.match(/^(#{1,3})\s+(.*)/);
          var task = l.match(/^\s*[-*]\s+\[([ xX])\]\s+(.*)/);
          if (task) { // checklista: read-only här — bocka av i desktop-pappen
            if (!inUl) { out.push("<ul>"); inUl = true; }
            var done = task[1].toLowerCase() === "x";
            out.push('<li class="cl' + (done ? " done" : "") + '">' + (done ? "☑️" : "⬜️") + " " + inline(task[2]) + "</li>");
            continue;
          }
          var li = l.match(/^\s*[-*]\s+(.*)/);
          if (li) { if (!inUl) { out.push("<ul>"); inUl = true; } out.push("<li>" + inline(li[1]) + "</li>"); continue; }
          if (inUl) { out.push("</ul>"); inUl = false; }
          if (h) { out.push("<h" + h[1].length + ">" + inline(h[2]) + "</h" + h[1].length + ">"); continue; }
          if (!l.trim()) continue;
          out.push("<p>" + inline(l) + "</p>");
        }
        if (inUl) out.push("</ul>");
        return out.join("");
      }
      function fmtAt(iso) {
        try { return new Date(iso).toLocaleString("sv-SE", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }); } catch (e) { return ""; }
      }

      // ---------- Inkorg ----------
      function renderQueue(inbox) {
        var q = $("queue");
        var pend = outboxGet();   // osända anteckningar (offline) — visas överst med «väntar på synk»-badge
        var prows = pend.map(function (it) {
          return '<div class="qrow pending"><span class="qwhen">⏳ väntar på synk</span><span class="qtext">' + esc(it.text) + "</span></div>";
        });
        var rows = (inbox || []).slice().reverse().map(function (it) {
          return '<div class="qrow"><span class="qwhen">' + esc(fmtAt(it.at)) + '</span><span class="qtext">' + esc(it.text) + "</span></div>";
        });
        if (!prows.length && !rows.length) { q.innerHTML = '<div class="empty">Inget i kön — allt är hämtat. ✅</div>'; return; }
        q.innerHTML = prows.join("") + rows.join("");
      }
      function renderFeed(feed) {
        var f = $("feed");
        if (!feed || !feed.length) { f.innerHTML = '<div class="empty">Inget pushat än.</div>'; return; }
        f.innerHTML = feed.map(function (d) {
          return '<div class="doc"><div class="doc-head"><span>' + esc(d.title) + '</span><span class="at">' + esc(fmtAt(d.at)) + '</span></div><div class="doc-body">' + md(d.md) + "</div></div>";
        }).join("");
        f.querySelectorAll(".doc-head").forEach(function (h) {
          h.addEventListener("click", function () { h.parentElement.classList.toggle("open"); });
        });
      }

      // ---------- Spegel (To Do / Listor / Agera) ----------
      var PRI = { high: "🔴", medium: "🟡", low: "🟢", none: "▫️" };
      function stamp(el) { el.textContent = mirror && mirror.at ? "Ögonblicksbild från pappen " + fmtAt(mirror.at) + " — läsvy, redigera i desktop-pappen." : ""; }

      function renderTodo() {
        var host = $("todo"); stamp($("stamp-todo"));
        var secs = mirror && mirror.tasks && mirror.tasks.sections;
        if (!secs || !secs.length) { host.innerHTML = '<div class="empty">Ingen spegling än — öppna pappen på datorn en gång.</div>'; return; }
        host.innerHTML = secs.map(function (s, si) {
          var open = s.cards.filter(function (c) { return c.status !== "done"; });
          var done = s.cards.filter(function (c) { return c.status === "done"; });
          var rows = open.map(function (c, ci) { return cardRow(c, si + ":" + ci, false); }).join("");
          var doneRows = done.length
            ? '<button class="showdone" data-sec="' + si + '">visa ' + done.length + ' klara…</button><div class="donewrap" data-sec="' + si + '" hidden>' + done.map(function (c, ci) { return cardRow(c, si + ":d" + ci, true); }).join("") + "</div>"
            : "";
          return '<div class="grp"><div class="grp-head"><span>' + esc(s.name) + '</span><span class="n">' + open.length + '</span></div><div class="grp-body">' + (rows || '<div class="empty">Inga öppna kort.</div>') + doneRows + "</div></div>";
        }).join("");
        wireGroups(host);
        host.querySelectorAll(".showdone").forEach(function (b) {
          b.addEventListener("click", function (e) { e.stopPropagation(); host.querySelector('.donewrap[data-sec="' + b.dataset.sec + '"]').hidden = false; b.remove(); });
        });
      }
      function cardRow(c, key, isDone) {
        var cl = (c.checklist || []).map(function (p) { return "<div>" + (p.done ? "☑️" : "⬜️") + " " + esc(p.text) + "</div>"; }).join("");
        var body = (c.description ? esc(c.description) : "") + (cl ? '<div class="cl">' + cl + "</div>" : "");
        return '<div class="mrow' + (isDone ? " done" : "") + '"><div class="mrow-head"><span class="pri">' + (PRI[c.priority] || "▫️") + '</span><span class="t">' + esc(c.title) + "</span>" + (c.dueDate ? '<span class="due">' + esc(c.dueDate) + "</span>" : "") + "</div>" + (body ? '<div class="mrow-body">' + body + "</div>" : "") + "</div>";
      }
      function renderListor() {
        var host = $("listor"); stamp($("stamp-listor"));
        var boards = mirror && mirror.listor;
        if (!boards || !boards.length) { host.innerHTML = '<div class="empty">Ingen spegling än — öppna pappen på datorn en gång.</div>'; return; }
        host.innerHTML = boards.map(function (b) {
          var rows = b.items.map(function (i) {
            var body = (i.note ? md(i.note) : "") + (i.link ? '<p><a href="' + esc(i.link) + '" target="_blank" rel="noopener">🔗 ' + esc(i.link.slice(0, 60)) + "</a></p>" : "");
            return '<div class="mrow"><div class="mrow-head"><span class="pri">' + (i.starred ? "⭐" : "•") + '</span><span class="t">' + esc(i.title || "(utan titel)") + "</span></div>" + (body ? '<div class="mrow-body">' + body + "</div>" : "") + "</div>";
          }).join("");
          return '<div class="grp"><div class="grp-head"><span>' + esc(b.icon + " " + b.label) + '</span><span class="n">' + b.items.length + '</span></div><div class="grp-body">' + rows + "</div></div>";
        }).join("");
        wireGroups(host);
      }
      function wireGroups(host) {
        host.querySelectorAll(".grp-head").forEach(function (h) {
          h.addEventListener("click", function () { h.parentElement.classList.toggle("open"); });
        });
        host.querySelectorAll(".mrow-head").forEach(function (h) {
          h.addEventListener("click", function () { if (h.parentElement.querySelector(".mrow-body")) h.parentElement.classList.toggle("open"); });
        });
      }
      function renderAgera() {
        stamp($("stamp-agera"));
        var cal = $("acal"), list = $("alist");
        var evs = (mirror && mirror.cal) || [];
        if (evs.length) {
          cal.innerHTML = evs.map(function (ev) {
            var tid = ev.allDay ? "hela dagen" : (fmtAt(ev.start).split(" ").pop() + "–" + fmtAt(ev.end).split(" ").pop());
            return '<div class="cal-ev"><span class="tid">' + esc(tid) + "</span><span>" + esc(ev.title) + (ev.location ? ' <span class="det">📍 ' + esc(ev.location) + "</span>" : "") + "</span></div>";
          }).join("");
        } else cal.innerHTML = '<div class="empty">Ingen kalenderdata i speglingen.</div>';
        var items = (mirror && mirror.agera && mirror.agera.items) || [];
        if (items.length) {
          list.innerHTML = items.map(function (i) {
            return '<div class="arow' + (i.urgency === "now" ? " now" : "") + '"><span class="ic">' + esc(i.icon || "•") + '</span><span><span class="t">' + esc(i.title) + "</span>" + (i.detail ? '<span class="det">' + esc(i.detail) + "</span>" : "") + "</span></div>";
          }).join("");
        } else list.innerHTML = '<div class="empty">Inget i speglingen.</div>';
      }

      async function loadMirror(force) {
        if (mirror && !force) return;
        if (!mirror) { var c = lsGet("mirror"); if (c) mirror = c; }   // hydrera från cache först (offline-first)
        try {
          var r = await fetch(API + "?pw=" + encodeURIComponent(pw) + "&kind=mirror");
          if (!r.ok) throw new Error("http " + r.status);
          mirror = (await r.json()).mirror; lsSet("mirror", mirror);
        } catch (e) { if (mirror) return; throw e; }                  // hade cache → visa stale; annars låt callern hantera
      }
      function renderMirrorTabs() { renderTodo(); renderListor(); renderAgera(); }

      // ---------- 🎲 Spel ----------
      // Frågebanken pushas från desktop-pappen (data/quiz.json → falt:quiz i KV). Tre lägen:
      // Frågesport (skicka-mobilen-runt, nivå per spelare), Emoji-gåtor och Sant/Falskt.
      // Rotation: använda fråge-id:n sparas i localStorage så inget upprepas förrän poolen är slut.
      var quiz = null;
      var LVL = { latt: "🟢 Lätt (6–7 år)", mellan: "🟡 Mellan (9 år)", svar: "🔴 Svår (vuxen)" };
      var LVL_SHORT = { latt: "🟢", mellan: "🟡", svar: "🔴" };

      function loadQuiz(force) {
        if (quiz && !force) return Promise.resolve();
        if (!quiz) { var c = lsGet("quiz"); if (c) quiz = c; }         // offline-first: frågesporten spelbar utan nät
        return fetch(API + "?pw=" + encodeURIComponent(pw) + "&kind=quiz")
          .then(function (r) { if (!r.ok) throw new Error("http " + r.status); return r.json(); })
          .then(function (j) { quiz = j.quiz; lsSet("quiz", quiz); })
          .catch(function (e) { if (quiz) return; throw e; });
      }
      function shuffle(a) {
        var arr = a.slice();
        for (var i = arr.length - 1; i > 0; i--) { var j = Math.floor(Math.random() * (i + 1)); var t = arr[i]; arr[i] = arr[j]; arr[j] = t; }
        return arr;
      }
      function getUsed(k) { try { return JSON.parse(localStorage.getItem("falt_quiz_used_" + k) || "{}"); } catch (e) { return {}; } }
      function markUsed(k, ids) { var u = getUsed(k); ids.forEach(function (i) { u[i] = 1; }); localStorage.setItem("falt_quiz_used_" + k, JSON.stringify(u)); }
      function pickFrom(pool, n, k) {
        var used = getUsed(k);
        var fresh = pool.filter(function (q) { return !used[q.id]; });
        if (fresh.length < n) { localStorage.setItem("falt_quiz_used_" + k, "{}"); fresh = pool; } // poolen slut → börja om
        var picked = shuffle(fresh).slice(0, Math.min(n, fresh.length));
        markUsed(k, picked.map(function (q) { return q.id; }));
        return picked;
      }
      var AVATARS = ["🦊", "🐸", "🦄", "🐯", "🐙", "🦖", "🐼", "🦁", "🐷", "👾", "🤖", "👑"];
      function getPlayers() {
        try { var p = JSON.parse(localStorage.getItem("falt_quiz_players") || "null"); if (Array.isArray(p) && p.length) return p; } catch (e) {}
        return [{ name: "Mathilde", lvl: "latt", avatar: "🦄" }, { name: "Louisa", lvl: "mellan", avatar: "🦊" }, { name: "Pappa", lvl: "svar", avatar: "🦖" }, { name: "Mamma", lvl: "svar", avatar: "🐼" }];
      }
      function playerAvatar(p, i) { return p.avatar || AVATARS[i % AVATARS.length]; }
      function savePlayers(p) { localStorage.setItem("falt_quiz_players", JSON.stringify(p)); }
      // Globala spelare: EN lista (namn + nivå + "är med idag") som ALLA spel läser.
      // p.on !== false → med (gamla sparade listor utan on-fält räknas som med).
      function roster() { return getPlayers().filter(function (p) { return p.on !== false; }); }

      // Delad spelar-skärm: kryss = med idag, nivå per spelare, lägg till/ta bort.
      // opts: { extraHTML?, wireExtra?, cta, onCta } — Frågesporten skickar med frågor-per-spelare + start.
      function renderPlayersScreen(opts) {
        var host = sp();
        var players = getPlayers();
        function draw() {
          host.innerHTML = backBtnRow() +
            '<div class="card"><h2>👥 Spelare — kryssa i vilka som är med</h2>' +
            players.map(function (p, i) {
              return '<div class="sp-player"><input type="checkbox" class="sp-on" data-i="' + i + '"' + (p.on !== false ? " checked" : "") + ' title="Är med idag"><button class="sp-av" data-i="' + i + '" title="Byt avatar (spelpjäs i Tärningsresan)">' + playerAvatar(p, i) + '</button><span class="nm">' + esc(p.name) + '</span><select data-i="' + i + '">' +
                Object.keys(LVL).map(function (l) { return '<option value="' + l + '"' + (p.lvl === l ? " selected" : "") + ">" + LVL[l] + "</option>"; }).join("") +
                '</select><button class="rm" data-rm="' + i + '" title="Ta bort">✕</button></div>';
            }).join("") +
            '<div class="sp-addrow"><input id="sp-newname" placeholder="Lägg till spelare…" maxlength="20"><button id="sp-add">＋</button></div>' +
            '<div class="sp-setrow"><span>⏱ Tidtagare per fråga</span><select id="sp-timersel">' +
              [0, 10, 20, 30].map(function (s) { return '<option value="' + s + '"' + (timerSec() === s ? " selected" : "") + ">" + (s ? s + " sek" : "Av") + "</option>"; }).join("") +
            "</select></div>" +
            (opts.extraHTML || "") + "</div>" +
            '<button class="sp-next" id="sp-cta">' + opts.cta + "</button>";
          wireBack(host);
          host.querySelectorAll(".sp-on").forEach(function (c) {
            c.addEventListener("change", function () { players[+c.dataset.i].on = c.checked; savePlayers(players); });
          });
          host.querySelectorAll(".sp-player select").forEach(function (s) {
            s.addEventListener("change", function () { players[+s.dataset.i].lvl = s.value; savePlayers(players); });
          });
          host.querySelectorAll(".rm").forEach(function (b) {
            b.addEventListener("click", function () { players.splice(+b.dataset.rm, 1); savePlayers(players); draw(); });
          });
          host.querySelectorAll(".sp-av").forEach(function (b) {
            b.addEventListener("click", function () {
              var i = +b.dataset.i;
              var cur = AVATARS.indexOf(playerAvatar(players[i], i));
              players[i].avatar = AVATARS[(cur + 1) % AVATARS.length];
              savePlayers(players);
              b.textContent = players[i].avatar;
            });
          });
          function addP() {
            var v = host.querySelector("#sp-newname").value.trim();
            if (!v) return;
            players.push({ name: v, lvl: "mellan", on: true, avatar: AVATARS[players.length % AVATARS.length] }); savePlayers(players); draw();
          }
          host.querySelector("#sp-add").addEventListener("click", addP);
          host.querySelector("#sp-newname").addEventListener("keydown", function (e) { if (e.key === "Enter") addP(); });
          host.querySelector("#sp-timersel").addEventListener("change", function (e) { localStorage.setItem("falt_quiz_timer", e.target.value); });
          if (opts.wireExtra) opts.wireExtra(host);
          host.querySelector("#sp-cta").addEventListener("click", function () { opts.onCta(players); });
        }
        draw();
      }
      // ⏱ Global tidtagare (0 = av). Nedräkning + bar i #sp-timer; självdör om elementet
      // försvinner ur DOM (navigering) så gamla intervaller aldrig spökar.
      function timerSec() { return parseInt(localStorage.getItem("falt_quiz_timer") || "0", 10) || 0; }
      var _spTick = null;
      function spTimer(host, sec, onOut) {
        clearInterval(_spTick);
        var box = host.querySelector("#sp-timer");
        if (!box || !sec) return { stop: function () {} };
        var left = sec;
        function paint() {
          box.innerHTML = '<div class="sp-timernum' + (left <= 5 ? " low" : "") + '">' + left + '</div><div class="sp-timerbar"><span style="width:' + Math.round(left / sec * 100) + '%"></span></div>';
        }
        paint();
        _spTick = setInterval(function () {
          if (!document.contains(box)) { clearInterval(_spTick); return; }
          left--;
          if (left <= 0) { clearInterval(_spTick); box.innerHTML = '<div class="sp-timernum low">⏰</div>'; onOut(); return; }
          paint();
        }, 1000);
        return { stop: function () { clearInterval(_spTick); if (document.contains(box)) box.innerHTML = ""; } };
      }
      function scoreboardHTML(players, icon) {
        var sorted = players.slice().sort(function (a, b) { return b.score - a.score; });
        var top = sorted[0] ? sorted[0].score : 0;
        return '<div class="card"><div class="sp-final">' + (icon || "🏆") + "</div>" +
          sorted.map(function (p) {
            var win = p.score === top && top > 0;
            return '<div class="sp-score' + (win ? " win" : "") + '"><span>' + (win ? "👑 " : "") + esc(p.name) + '</span><span class="pts">' + p.score + " p</span></div>";
          }).join("") + "</div>";
      }

      var spelHost = null;
      function sp() { if (!spelHost) spelHost = $("spel"); return spelHost; }
      // Pågår ett spel? Sätts av alla spelskärmar (via wireBack), nollas på spelmenyn.
      // Upplåsnings-refreshen (visibilitychange → refreshAll) får ALDRIG rita om en pågående runda.
      var _spInGame = false;

      // ——— Spel-session: en pågående runda överlever omladdning ———
      // iOS slänger bakgrundsfliken ur minnet (app-byte, skärmlås) och en deploy tvingar
      // om-laddning → alla minnesvariabler (qGame, tq …) nollas. Därför speglas rundan
      // till localStorage och kan återuppstå via en «Fortsätt där ni var?»-ruta.
      //
      // Lägg till ETT nytt spel så här — då funkar «Fortsätt» automatiskt:
      //   1. håll rundan i ETT serialiserbart objekt (som qGame / tq),
      //   2. anropa spSave("nyckel", state) överst i spelets tur-/steg-render,
      //   3. registrera SP_RESUME["nyckel"] = { label: fn(state)→text, resume: fn(state) },
      //   4. lägg spClear() i spelets slutskärm (spelmenyn rensar redan automatiskt).
      var SP_SESSION_KEY = "falt_spel_session";
      var SP_SESSION_MAXAGE = 12 * 3600 * 1000; // pågående spel äldre än 12h glöms
      var SP_RESUME = {}; // nyckel → { label, resume }
      function spSave(key, state) {
        try { localStorage.setItem(SP_SESSION_KEY, JSON.stringify({ g: key, s: state, ts: Date.now() })); } catch (e) {}
      }
      function spClear() { try { localStorage.removeItem(SP_SESSION_KEY); } catch (e) {} }
      function spLoad() {
        try {
          var j = JSON.parse(localStorage.getItem(SP_SESSION_KEY) || "null");
          if (!j || !j.g || !j.s || !SP_RESUME[j.g]) return null;
          if (!j.ts || Date.now() - j.ts > SP_SESSION_MAXAGE) { spClear(); return null; }
          return j;
        } catch (e) { return null; }
      }
      // Visar «Fortsätt där ni var?» om en runda är sparad. true = banner ritad (hoppa över spelmenyn).
      function spShowResume() {
        var sess = spLoad();
        if (!sess) return false;
        var reg = SP_RESUME[sess.g];
        _spInGame = true; // skydda bannern från bakgrunds-refreshen tills valet är gjort
        var host = sp(), label = "ditt spel";
        try { label = reg.label(sess.s); } catch (e) {}
        host.innerHTML = '<div class="card" style="text-align:center">' +
          '<div class="sp-final">↩︎</div><div class="sp-winner">Fortsätt där ni var?</div>' +
          '<div style="color:#9aa7b4;margin:6px 0 2px">' + esc(label) + '</div>' +
          '<button class="sp-next" id="sp-resume-yes" style="margin-top:14px">▶︎ Fortsätt spelet</button>' +
          '<button class="sp-ghost" id="sp-resume-no">Nej — till spelmenyn</button></div>';
        host.querySelector("#sp-resume-yes").addEventListener("click", function () {
          try { reg.resume(sess.s); } catch (e) { spClear(); renderSpelHome(); }
        });
        host.querySelector("#sp-resume-no").addEventListener("click", function () { spClear(); renderSpelHome(); });
        return true;
      }

      function renderSpelHome() {
        _spInGame = false;
        spClear();
        var host = sp();
        if (!quiz || !quiz.questions || !quiz.questions.length) {
          host.innerHTML = '<div class="card"><div class="empty">Ingen frågebank än — öppna pappen på datorn, gå till 🎲 Frågesport och tryck «📲 Pusha till mobilen».</div></div>';
          return;
        }
        var nq = quiz.questions.length, ne = (quiz.emoji || []).length, ng = (quiz.gator || []).length;
        var act = roster();
        host.innerHTML =
          '<div class="card sp-roster"><span>👥 ' + (act.length ? act.map(function (p) { return esc(p.name); }).join(" · ") : "Inga spelare valda") + '</span><button class="sp-back" id="sp-players">Ändra</button></div>' +
          '<button class="sp-mode" data-go="/atelje"><span class="big">👗</span><span>Modeateljén<span class="sub">Designa egna outfits på dockor — mönster, material, färg och pynt. Spara i garderoben.</span></span></button>' +
          '<button class="sp-mode" data-go="/logik"><span class="big">🧠</span><span>Hjärngympa<span class="sub">Logik, matte & bokstäver — poäng, streak och rank. Nivåer för både små och stora.</span></span></button>' +
          '<button class="sp-mode" data-mode="quiz"><span class="big">🎯</span><span>Frågesport<span class="sub">Skicka mobilen runt — frågor på varje spelares nivå, poäng och vinnare!</span></span></button>' +
          '<button class="sp-mode" data-mode="tq"><span class="big">🎲</span><span>Tärningsresan<span class="sub">Slå tärningen, flytta din spelpjäs över spelplanen och svara i rutans kategori — först i mål vinner!</span></span></button>' +
          '<button class="sp-mode" data-mode="emoji"><span class="big">🙈</span><span>Emoji-gåtor<span class="sub">Gissa filmen eller ordet från emojis — perfekt på stranden.</span></span></button>' +
          (ng ? '<button class="sp-mode" data-mode="gator"><span class="big">🧩</span><span>Gåtor<span class="sub">Klassiska kluringar — läs högt och låt alla gissa!</span></span></button>' : "") +
          '<button class="sp-mode" data-mode="sf"><span class="big">⚖️</span><span>Sant eller falskt<span class="sub">Snabba påståenden — ropa svaret tillsammans!</span></span></button>' +
          ((quiz.vem || []).length ? '<button class="sp-mode" data-mode="vem"><span class="big">👨‍👩‍👧‍👧</span><span>Vem i familjen?<span class="sub">Läs kortet och peka på varandra — inga poäng, bara skratt.</span></span></button>' : "") +
          ((quiz.hellre || []).length ? '<button class="sp-mode" data-mode="hellre"><span class="big">🤔</span><span>Skulle du hellre…?<span class="sub">Omöjliga val — alla svarar i tur och ordning och får förklara varför!</span></span></button>' : "") +
          '<div class="stamp">Frågebank: ' + nq + ' frågor + ' + ne + ' emoji + ' + ng + ' gåtor' + (quiz.updatedAt ? " · uppdaterad " + fmtAt(quiz.updatedAt) : "") + ' — fyll på i desktop-pappen.</div>';
        host.querySelector("#sp-players").addEventListener("click", function () {
          renderPlayersScreen({ cta: "✔ Klar", onCta: renderSpelHome });
        });
        host.querySelectorAll(".sp-mode").forEach(function (b) {
          b.addEventListener("click", function () {
            if (b.dataset.go) { location.href = b.dataset.go; return; }
            if (b.dataset.mode === "quiz") renderQuizSetup();
            else if (b.dataset.mode === "tq") startTq();
            else if (b.dataset.mode === "emoji") startEmoji();
            else if (b.dataset.mode === "gator") startGator();
            else if (b.dataset.mode === "vem") startDeck("vem", "👨‍👩‍👧‍👧", "Vem i familjen?");
            else if (b.dataset.mode === "hellre") startDeck("hellre", "🤔", "Skulle du hellre…");
            else startSF();
          });
        });
      }
      // Topprad: ← meny, ↩︎ ångra (backar ett steg, poäng återställs), 🏆 ställning (preview mitt i).
      function backBtnRow(prog, flags) {
        flags = flags || {};
        return '<div class="sp-top"><span class="sp-topbtns"><button class="sp-back" id="sp-back">← Meny</button>' +
          (flags.undo ? '<button class="sp-back" id="sp-undo" title="Ångra — backa ett steg">↩︎</button>' : "") +
          (flags.lb ? '<button class="sp-back" id="sp-lb" title="Visa ställningen">🏆</button>' : "") +
          '</span><span class="sp-prog">' + (prog || "") + "</span></div>";
      }
      function wireBack(host) { _spInGame = true; host.querySelector("#sp-back").addEventListener("click", renderSpelHome); }
      function wireTop(host, o) {
        wireBack(host);
        o = o || {};
        var u = host.querySelector("#sp-undo");
        if (u && o.onUndo) u.addEventListener("click", o.onUndo);
        var lb = host.querySelector("#sp-lb");
        if (lb && o.players) lb.addEventListener("click", function () { showLB(o.players()); });
      }
      // 🏆 Ställnings-overlay (preview under spelets gång) — tryck var som helst för att stänga.
      function showLB(players) {
        var old = document.getElementById("sp-lbov"); if (old) old.remove();
        var ov = document.createElement("div");
        ov.id = "sp-lbov"; ov.className = "sp-lbov";
        var sorted = players.slice().sort(function (a, b) { return b.score - a.score; });
        var top = sorted[0] ? sorted[0].score : 0;
        ov.innerHTML = '<div class="sp-lbcard"><h2>🏆 Ställning just nu</h2>' +
          sorted.map(function (p, i) {
            var lead = p.score === top && top > 0;
            return '<div class="sp-score' + (lead ? " win" : "") + '"><span>' + (lead ? "🔥 " : (i + 1) + ". ") + esc(p.name) + '</span><span class="pts">' + p.score + " p</span></div>";
          }).join("") + '<button class="sp-next" style="margin-top:14px">Fortsätt spela</button></div>';
        ov.addEventListener("click", function () { ov.remove(); });
        document.body.appendChild(ov);
      }
      // 🎊 Festlig slutskärm: konfetti + vinnare + prispall. players → full pall, text → solo-läge.
      function confettiHTML() {
        var out = "", em = ["🎉", "✨", "🎊", "⭐", "🎈"];
        for (var k = 0; k < 18; k++) {
          out += '<span class="sp-conf" style="left:' + (k * 5.5 + 1) + "%;animation-delay:" + ((k % 6) * 0.4).toFixed(1) + "s;font-size:" + (14 + (k % 3) * 7) + 'px">' + em[k % 5] + "</span>";
        }
        return out;
      }
      function festiveBoardHTML(players, icon) {
        var sorted = players.slice().sort(function (a, b) { return b.score - a.score; });
        var top = sorted[0] ? sorted[0].score : 0;
        var winners = sorted.filter(function (p) { return p.score === top; });
        var medal = ["🥇", "🥈", "🥉"];
        return '<div class="card sp-finalcard">' + confettiHTML() +
          '<div class="sp-final">' + (icon || "🏆") + "</div>" +
          '<div class="sp-winner">' + (top > 0 ? winners.map(function (p) { return esc(p.name); }).join(" & ") + " vinner! 🎉" : "Oavgjort!") + "</div>" +
          '<div class="sp-podium">' + sorted.slice(0, 3).map(function (p, i) {
            return '<div class="sp-pod sp-pod' + i + '"><div class="sp-pod-medal">' + medal[i] + '</div><div class="sp-pod-name">' + esc(p.name) + '</div><div class="sp-pod-pts">' + p.score + " p</div></div>";
          }).join("") + "</div>" +
          sorted.slice(3).map(function (p, i) {
            return '<div class="sp-score"><span>' + (i + 4) + ". " + esc(p.name) + '</span><span class="pts">' + p.score + " p</span></div>";
          }).join("") + "</div>";
      }
      function festiveSoloHTML(text, icon) {
        return '<div class="card sp-finalcard">' + confettiHTML() + '<div class="sp-final">' + (icon || "🎉") + '</div><div class="sp-winner">' + text + "</div></div>";
      }

      // — Frågesport (setup = globala spelar-skärmen + frågor per spelare) —
      var qGame = null;
      function renderQuizSetup() {
        var per = parseInt(localStorage.getItem("falt_quiz_per") || "5", 10);
        renderPlayersScreen({
          extraHTML: '<div class="sp-setrow"><span>Frågor per spelare</span><select id="sp-per"><option' + (per === 3 ? " selected" : "") + '>3</option><option' + (per === 5 ? " selected" : "") + '>5</option><option' + (per === 7 ? " selected" : "") + '>7</option></select></div>',
          wireExtra: function (host) {
            host.querySelector("#sp-per").addEventListener("change", function (e) { per = parseInt(e.target.value, 10); localStorage.setItem("falt_quiz_per", String(per)); });
          },
          cta: "🎯 Starta frågesporten!",
          onCta: function (players) {
            var act = players.filter(function (p) { return p.on !== false; });
            if (!act.length) return;
            startQuizGame(act, per);
          },
        });
      }
      function startQuizGame(players, per) {
        var qs = quiz.questions;
        var queues = players.map(function (p) {
          var pool = qs.filter(function (q) { return q.level === p.lvl; });
          return pickFrom(pool, per, "q_" + p.lvl);
        });
        var seq = [];
        for (var r = 0; r < per; r++) for (var pi = 0; pi < players.length; pi++) { if (queues[pi][r]) seq.push({ pi: pi, q: queues[pi][r] }); }
        qGame = { players: players.map(function (p) { return { name: p.name, lvl: p.lvl, score: 0 }; }), seq: seq, i: 0, hist: [], curSnap: null };
        renderHandover();
      }
      // Ångra: backa till förra frågan — poängen som delades ut på den återställs.
      function quizUndo() {
        var g = qGame;
        if (!g || !g.hist.length) return;
        var s = g.hist.pop();
        g.i = s.i;
        g.players.forEach(function (p, k) { p.score = s.scores[k]; });
        renderQuestion();
      }
      function quizTop() { return { undo: qGame.hist.length > 0, lb: true }; }
      function quizWire(host) { wireTop(host, { onUndo: quizUndo, players: function () { return qGame.players; } }); }
      function renderHandover() {
        var host = sp(), g = qGame;
        if (g.i >= g.seq.length) return renderQuizEnd();
        spSave("quiz", g);
        var cur = g.seq[g.i], p = g.players[cur.pi];
        host.innerHTML = backBtnRow("Fråga " + (g.i + 1) + " av " + g.seq.length, quizTop()) +
          '<div class="sp-hand"><div style="font-size:40px">📱</div><div class="who">' + esc(p.name) + '</div><div class="lvl">' + LVL[p.lvl] + " · " + p.score + ' poäng</div><button class="sp-next" id="sp-ready" style="margin-top:18px">Jag är redo!</button></div>';
        quizWire(host);
        host.querySelector("#sp-ready").addEventListener("click", renderQuestion);
      }
      function renderQuestion() {
        var host = sp(), g = qGame, cur = g.seq[g.i], p = g.players[cur.pi], q = cur.q;
        g.curSnap = { i: g.i, scores: g.players.map(function (x) { return x.score; }) };
        spSave("quiz", g);
        var body;
        if (q.type === "sf") {
          body = '<div class="sp-sf"><button data-v="true">✅ SANT</button><button data-v="false">❌ FALSKT</button></div>';
        } else {
          // Blanda alternativens VISNINGSORDNING (data-v behåller original-index) — annars
          // lär sig alla att rätt svar oftast ligger först i banken.
          var order = shuffle(q.options.map(function (_, oi) { return oi; }));
          body = order.map(function (oi) { return '<button class="sp-opt" data-v="' + oi + '">' + esc(q.options[oi]) + "</button>"; }).join("");
        }
        host.innerHTML = backBtnRow(esc(p.name) + " · fråga " + (g.i + 1) + " av " + g.seq.length, quizTop()) +
          '<div id="sp-timer"></div>' +
          '<div class="sp-q"><span class="sp-cat">' + LVL_SHORT[q.level] + " " + esc(q.cat || "") + '</span><div class="sp-qtext">' + esc(q.q) + "</div>" + body + '<div id="sp-after"></div></div>';
        quizWire(host);
        var done = false, t = null;
        // btn=null → tiden gick ut (räknas som fel, rätta svaret visas).
        function answer(correct, btn, allBtns, rightBtn) {
          if (done) return; done = true;
          if (t) t.stop();
          if (correct) { p.score++; if (btn) btn.classList.add("hit"); }
          else { if (btn) btn.classList.add("miss"); if (rightBtn) rightBtn.classList.add("hit"); }
          allBtns.forEach(function (b) { b.disabled = true; if (b !== btn && !b.classList.contains("hit")) b.classList.add("dim"); });
          var after = host.querySelector("#sp-after");
          after.innerHTML = '<div class="sp-fun"><strong>' + (correct ? "🎉 Rätt!" : (btn ? "Neeej, nära!" : "⏰ Tiden ute!")) + "</strong>" +
            (q.fun ? " " + esc(q.fun) : "") + "</div>" +
            '<button class="sp-next" id="sp-nxt">' + (g.i + 1 < g.seq.length ? "Nästa →" : "Se resultatet 🏆") + "</button>";
          after.querySelector("#sp-nxt").addEventListener("click", function () {
            g.hist.push(g.curSnap);
            g.i++;
            var nxt = g.seq[g.i];
            if (!nxt) return renderQuizEnd();
            if (nxt.pi !== cur.pi) renderHandover(); else renderQuestion();
          });
        }
        if (q.type === "sf") {
          var sfB = host.querySelectorAll(".sp-sf button");
          sfB.forEach(function (b) {
            b.addEventListener("click", function () {
              var right = String(q.answer) === b.dataset.v;
              var rightBtn = null;
              sfB.forEach(function (x) { if (x.dataset.v === String(q.answer)) rightBtn = x; });
              answer(right, b, Array.prototype.slice.call(sfB), rightBtn);
            });
          });
        } else {
          var opts = host.querySelectorAll(".sp-opt");
          opts.forEach(function (b) {
            b.addEventListener("click", function () {
              var right = +b.dataset.v === q.answer;
              answer(right, b, Array.prototype.slice.call(opts), host.querySelector('.sp-opt[data-v="' + q.answer + '"]'));
            });
          });
        }
        t = spTimer(host, timerSec(), function () {
          var all, rightBtn;
          if (q.type === "sf") {
            all = Array.prototype.slice.call(host.querySelectorAll(".sp-sf button"));
            rightBtn = host.querySelector('.sp-sf button[data-v="' + q.answer + '"]');
          } else {
            all = Array.prototype.slice.call(host.querySelectorAll(".sp-opt"));
            rightBtn = host.querySelector('.sp-opt[data-v="' + q.answer + '"]');
          }
          answer(false, null, all, rightBtn);
        });
      }
      function renderQuizEnd() {
        var host = sp(), g = qGame;
        spClear(); // spelet är slut → inget att återuppta
        host.innerHTML = backBtnRow("", { undo: g.hist.length > 0 }) + festiveBoardHTML(g.players, "🏆") +
          '<button class="sp-next" id="sp-again">🎯 Spela igen (nya frågor)</button>' +
          '<button class="sp-ghost" id="sp-home">Till spelmenyn</button>';
        wireTop(host, { onUndo: quizUndo });
        host.querySelector("#sp-again").addEventListener("click", renderQuizSetup);
        host.querySelector("#sp-home").addEventListener("click", renderSpelHome);
      }
      // «Fortsätt»-stöd: återuppta till frågans handover-skärm (aktuell spelare & fråga).
      SP_RESUME.quiz = {
        label: function (s) { return "🎯 Frågesport — fråga " + Math.min((s.i || 0) + 1, s.seq.length) + " av " + s.seq.length; },
        resume: function (s) { qGame = s; renderHandover(); },
      };

      // — Emoji-gåtor: välj kategori (film/musik/bok/ord) + svårighetsgrad + egen valfri ⏱.
      // 2+ spelare → turbaserat m. poäng per spelare, annars gemensam räkning.
      var EMOJI_KIND = { film: "🎬 Gissa filmen", ord: "🧩 Gissa ordet", musik: "🎵 Gissa låten", bok: "📚 Gissa boken" };
      function emojiTimerSec() { return parseInt(localStorage.getItem("falt_timer_emoji") || "0", 10) || 0; }
      function emojiLvl() { var v = localStorage.getItem("falt_emoji_lvl"); return v === "latt" || v === "mellan" || v === "svar" ? v : "mix"; }
      function startEmoji(kind) {
        var all = (quiz.emoji || []);
        if (!all.length) return;
        var byKind = function (k) { return all.filter(function (c) { return (c.kind || "film") === k; }); };
        if (!kind) {
          return chooseScreen("🙈 Emoji-gåtor — vad vill ni gissa?", [
            { key: "film", icon: "🎬", label: "Filmer", sub: "Gissa filmen (" + byKind("film").length + " st)" },
            { key: "musik", icon: "🎵", label: "Musik", sub: "Gissa låten — nynna gärna! (" + byKind("musik").length + " st)" },
            { key: "bok", icon: "📚", label: "Böcker & sagor", sub: "Gissa boken (" + byKind("bok").length + " st)" },
            { key: "ord", icon: "🧩", label: "Sammansatta ord", sub: "Emojis ihop = ett ord (" + byKind("ord").length + " st)" },
            { key: "mix", icon: "🌀", label: "Blandat", sub: "Allt huller om buller" },
          ], startEmoji, {
            html: '<div class="card" style="padding:12px 14px">' +
              '<div class="sp-setrow" style="margin-top:0"><span>Svårighetsgrad</span><select id="sp-elvl">' +
              [["mix", "🌀 Blandat"], ["latt", "🟢 Lätt"], ["mellan", "🟡 Mellan"], ["svar", "🔴 Svår"]].map(function (o) { return '<option value="' + o[0] + '"' + (emojiLvl() === o[0] ? " selected" : "") + ">" + o[1] + "</option>"; }).join("") +
              "</select></div>" +
              '<div class="sp-setrow"><span>⏱ Tid per gåta (valfritt)</span><select id="sp-etimer">' +
              [0, 10, 20, 30].map(function (s) { return '<option value="' + s + '"' + (emojiTimerSec() === s ? " selected" : "") + ">" + (s ? s + " sek" : "Av") + "</option>"; }).join("") +
              "</select></div></div>",
            wire: function (h2) {
              h2.querySelector("#sp-etimer").addEventListener("change", function (e) { localStorage.setItem("falt_timer_emoji", e.target.value); });
              h2.querySelector("#sp-elvl").addEventListener("change", function (e) { localStorage.setItem("falt_emoji_lvl", e.target.value); });
            },
          });
        }
        var pool = kind === "mix" ? all : byKind(kind);
        var lvl = emojiLvl();
        if (lvl !== "mix") {
          var lp = pool.filter(function (c) { return (c.level || "mellan") === lvl; });
          if (lp.length) pool = lp; // finns inget på nivån i kategorin → behåll hela kategorin
        }
        if (!pool.length) pool = all;
        runEmoji({ kind: kind, cards: pickFrom(pool, 10, "emoji"), ps: roster().map(function (p) { return { name: p.name, score: 0 }; }), i: 0, hits: 0, hist: [], curSnap: null });
      }
      function runEmoji(st) {
        st.turns = st.ps.length >= 2;
        var cards = st.cards, ps = st.ps, host = sp();
        function advance() { st.hist.push(st.curSnap); st.i++; draw(); }
        function undo() { if (!st.hist.length) return; var s = st.hist.pop(); st.i = s.i; st.hits = s.hits; ps.forEach(function (p, k) { p.score = s.scores[k]; }); draw(); }
        function topFlags() { return { undo: st.hist.length > 0, lb: st.turns }; }
        function wire2(h2) { wireTop(h2, { onUndo: undo, players: st.turns ? function () { return ps; } : null }); }
        function draw() {
          st.curSnap = { i: st.i, hits: st.hits, scores: ps.map(function (p) { return p.score; }) };
          spSave("emoji", st);
          if (st.i >= cards.length) {
            spClear();
            host.innerHTML = backBtnRow("", topFlags()) +
              (st.turns ? festiveBoardHTML(ps, "🙈") : festiveSoloHTML("Ni klarade " + st.hits + " av " + cards.length + "!", "🙈")) +
              '<button class="sp-next" id="sp-again">Fler gåtor!</button><button class="sp-ghost" id="sp-home">Till spelmenyn</button>';
            wire2(host);
            host.querySelector("#sp-again").addEventListener("click", function () { startEmoji(st.kind); });
            host.querySelector("#sp-home").addEventListener("click", renderSpelHome);
            return;
          }
          var c = cards[st.i];
          var tp = st.turns ? ps[st.i % ps.length] : null;
          host.innerHTML = backBtnRow("Gåta " + (st.i + 1) + " av " + cards.length, topFlags()) +
            (tp ? '<div class="sp-turn">🎲 <b>' + esc(tp.name) + "</b> gissar! (" + tp.score + " p)</div>" : "") +
            '<div id="sp-timer"></div>' +
            '<div class="sp-q"><span class="sp-cat">' + (LVL_SHORT[c.level] || "") + " " + (EMOJI_KIND[c.kind || "film"] || EMOJI_KIND.film) + '</span><div class="sp-emoji">' + c.emoji + '</div><div id="sp-hintbox"></div><div id="sp-revbox"><button class="sp-ghost" id="sp-hint">💡 Ledtråd</button><button class="sp-next" id="sp-reveal">Visa svaret</button></div></div>';
          wire2(host);
          host.querySelector("#sp-hint").addEventListener("click", function () {
            host.querySelector("#sp-hintbox").innerHTML = '<div class="sp-hint-txt">💡 ' + esc(c.hint || "Ingen ledtråd") + "</div>";
          });
          host.querySelector("#sp-reveal").addEventListener("click", function () {
            if (t) t.stop();
            host.querySelector("#sp-revbox").innerHTML = '<div class="sp-answer">' + esc(c.answer) + '</div><div class="sp-tally"><button class="yes" id="sp-yes">✅ ' + (tp ? esc(tp.name) + " hade rätt!" : "Vi gissade rätt!") + '</button><button class="no" id="sp-no">Nästa →</button></div>';
            host.querySelector("#sp-yes").addEventListener("click", function () { if (tp) tp.score++; else st.hits++; advance(); });
            host.querySelector("#sp-no").addEventListener("click", advance);
          });
          // Tiden ute → visa svaret automatiskt (gissningen fick sin chans). Egen emoji-⏱, ej quiz-timern.
          var t = spTimer(host, emojiTimerSec(), function () { var rb = host.querySelector("#sp-reveal"); if (rb) rb.click(); });
        }
        draw();
      }
      SP_RESUME.emoji = {
        label: function (s) { return "🙈 Emoji-gåtor — gåta " + Math.min((s.i || 0) + 1, s.cards.length) + " av " + s.cards.length; },
        resume: function (s) { runEmoji(s); },
      };

      // — 🎲 Tärningsresan: fia-med-knuff × Trivial Pursuit. Slå tärning → flytta avatar över
      // spelplanen (28 rutor, serpentin) → svara i rutans kategori på din nivå. Rätt = stå kvar,
      // fel = tillbaka där du stod. Först förbi mål (rätt på målfrågan) vinner.
      var TQ_CATS = [
        { icon: "🐾", label: "Djur & natur", color: "#37c184", match: { "Djur": 1, "Naturen": 1 } },
        { icon: "🔬", label: "Smart", color: "#6c8cff", match: { "Rymden": 1, "Vetenskap": 1, "Matte": 1, "Teknik": 1, "Kroppen": 1, "Tid": 1 } },
        { icon: "🎬", label: "Film & musik", color: "#e0607a", match: { "Film & sagor": 1, "Musik": 1, "Konst": 1 } },
        { icon: "🌍", label: "Världen", color: "#e6b450", match: { "Geografi": 1, "Sverige": 1, "Historia": 1 } },
        { icon: "🍕", label: "Sport & mat", color: "#b07cff", match: { "Sport": 1, "Mat": 1, "Färger": 1 } },
        { icon: "🌀", label: "Blandat", color: "#9aa3b2", match: null },
      ];
      var TQ_N = 28, TQ_COLS = 7;
      var DICE = ["⚀", "⚁", "⚂", "⚃", "⚄", "⚅"];
      var tq = null; // { cells, players:[{name,lvl,avatar,pos}], turn, hist, winner }

      function startTq() {
        var ps = roster();
        if (!ps.length) { renderPlayersScreen({ cta: "✔ Klar", onCta: startTq }); return; }
        var base = [];
        for (var i = 0; i < TQ_N; i++) base.push(i % TQ_CATS.length); // jämn fördelning...
        tq = {
          cells: shuffle(base), // ...blandad per spelomgång
          players: ps.map(function (p, i) { return { name: p.name, lvl: p.lvl, avatar: playerAvatar(p, i), pos: -1 }; }),
          turn: 0, hist: [], winner: null,
        };
        tqTurn();
      }
      function tqUndo() {
        var g = tq;
        if (!g || !g.hist.length) return;
        var s = g.hist.pop();
        g.turn = s.turn;
        g.players.forEach(function (p, i) { p.pos = s.pos[i]; });
        g.winner = null;
        tqTurn();
      }
      function tqStandings() {
        return tq.players.map(function (p) { return { name: p.avatar + " " + p.name, score: p.pos + 1 }; });
      }
      function tqWire(host) { wireTop(host, { onUndo: tqUndo, players: tqStandings }); }
      function tqBoardHTML() {
        var g = tq;
        var cellsHtml = new Array(TQ_N);
        for (var i = 0; i < TQ_N; i++) {
          var cat = TQ_CATS[g.cells[i]];
          var here = g.players.filter(function (p) { return p.pos === i; }).map(function (p) { return p.avatar; }).join("");
          cellsHtml[i] = '<div class="tq-cell' + (here ? " has-p" : "") + '" style="background:' + cat.color + (here ? "44" : "22") + ';border-color:' + cat.color + '66">' + (here || cat.icon) + "</div>";
        }
        var out = "";
        for (var r = 0; r * TQ_COLS < TQ_N; r++) {
          var slice = cellsHtml.slice(r * TQ_COLS, r * TQ_COLS + TQ_COLS);
          if (r % 2 === 1) slice.reverse(); // serpentin-bana
          out += '<div class="tq-row">' + slice.join("") + "</div>";
        }
        var startAv = g.players.filter(function (p) { return p.pos < 0; }).map(function (p) { return p.avatar; }).join("");
        return '<div class="tq-board"><div class="tq-startgoal"><span>🏁 Start ' + startAv + "</span><span>Mål 🏆</span></div>" + out +
          '<div class="tq-legend">' + TQ_CATS.map(function (c) { return '<span style="color:' + c.color + '">' + c.icon + " " + esc(c.label) + "</span>"; }).join("") + "</div></div>";
      }
      function tqTurn() {
        var host = sp(), g = tq;
        var p = g.players[g.turn];
        spSave("tq", g); // turens start = committad ställning (positioner + vems tur)
        host.innerHTML = backBtnRow("", { undo: g.hist.length > 0, lb: true }) + tqBoardHTML() +
          '<div class="sp-hand" style="padding:16px"><div style="font-size:34px">' + p.avatar + '</div><div class="who" style="font-size:20px">' + esc(p.name) + '</div><div class="lvl">' + LVL[p.lvl] + " · " + (p.pos < 0 ? "vid start" : "ruta " + (p.pos + 1) + " av " + TQ_N) + '</div><button class="sp-next" id="tq-roll" style="margin-top:12px;font-size:18px">🎲 Slå tärningen!</button></div>';
        tqWire(host);
        host.querySelector("#tq-roll").addEventListener("click", tqRoll);
      }
      function tqRoll() {
        var g = tq, host = sp(), p = g.players[g.turn];
        g.hist.push({ turn: g.turn, pos: g.players.map(function (x) { return x.pos; }) });
        var btn = host.querySelector("#tq-roll");
        btn.disabled = true;
        var n = 1 + Math.floor(Math.random() * 6);
        var flips = 0;
        var anim = setInterval(function () {
          if (!document.contains(btn)) { clearInterval(anim); return; }
          btn.textContent = DICE[Math.floor(Math.random() * 6)];
          if (++flips >= 9) {
            clearInterval(anim);
            btn.textContent = DICE[n - 1] + "  Du slog " + n + "!";
            setTimeout(function () { tqMove(p, n); }, 700);
          }
        }, 90);
      }
      function tqMove(p, steps) {
        var g = tq;
        var from = p.pos;
        var target = Math.min(p.pos + steps, TQ_N); // TQ_N = förbi sista rutan = målförsök
        var cur = from;
        var iv = setInterval(function () {
          cur++;
          p.pos = Math.min(cur, TQ_N - 1);
          var b = sp().querySelector(".tq-board");
          if (!b) { clearInterval(iv); return; }
          b.outerHTML = tqBoardHTML();
          if (cur >= target) { clearInterval(iv); setTimeout(function () { tqQuestion(p, from, target); }, 400); }
        }, 230);
      }
      function tqQuestion(p, from, target) {
        var g = tq, host = sp();
        var atGoal = target >= TQ_N;
        var cat = atGoal ? TQ_CATS[5] : TQ_CATS[g.cells[target]];
        var pool = quiz.questions.filter(function (q) {
          return (cat.match ? cat.match[q.cat] : true) && q.level === p.lvl;
        });
        if (!pool.length) pool = quiz.questions.filter(function (q) { return q.level === p.lvl; });
        if (!pool.length) pool = quiz.questions;
        var q = pickFrom(pool, 1, "tq")[0];
        var body;
        if (q.type === "sf") {
          body = '<div class="sp-sf"><button data-v="true">✅ SANT</button><button data-v="false">❌ FALSKT</button></div>';
        } else {
          var order = shuffle(q.options.map(function (_, oi) { return oi; }));
          body = order.map(function (oi) { return '<button class="sp-opt" data-v="' + oi + '">' + esc(q.options[oi]) + "</button>"; }).join("");
        }
        host.innerHTML = backBtnRow(p.avatar + " " + esc(p.name) + (atGoal ? " · MÅLFRÅGA!" : " · ruta " + (target + 1)), { undo: true, lb: true }) +
          '<div class="sp-turn" style="color:' + cat.color + '">' + cat.icon + " " + esc(cat.label) + (atGoal ? " — svara rätt och VINN! 🏆" : "") + "</div>" +
          '<div id="sp-timer"></div>' +
          '<div class="sp-q"><span class="sp-cat">' + LVL_SHORT[q.level] + " " + esc(q.cat || "") + '</span><div class="sp-qtext">' + esc(q.q) + "</div>" + body + '<div id="sp-after"></div></div>';
        tqWire(host);
        var done = false, t = null;
        function finish(right, b) {
          if (done) return; done = true;
          if (t) t.stop();
          var allBtns = Array.prototype.slice.call(host.querySelectorAll(q.type === "sf" ? ".sp-sf button" : ".sp-opt"));
          var sel = q.type === "sf" ? '[data-v="' + q.answer + '"]' : '.sp-opt[data-v="' + q.answer + '"]';
          var rightBtn = host.querySelector(q.type === "sf" ? ".sp-sf button" + sel : sel);
          if (right) { if (b) b.classList.add("hit"); }
          else { if (b) b.classList.add("miss"); if (rightBtn) rightBtn.classList.add("hit"); }
          allBtns.forEach(function (x) { x.disabled = true; if (x !== b && !x.classList.contains("hit")) x.classList.add("dim"); });
          var msg;
          if (right && atGoal) { g.winner = p; msg = "🏆 I MÅL — " + esc(p.name) + " VINNER!"; }
          else if (right) msg = "🎉 Rätt — du står kvar på ruta " + (target + 1) + "!";
          else { p.pos = from; msg = (b ? "Neeej!" : "⏰ Tiden ute!") + " Tillbaka till " + (from < 0 ? "start" : "ruta " + (from + 1)) + "."; }
          host.querySelector("#sp-after").innerHTML = '<div class="sp-fun"><strong>' + msg + "</strong>" + (q.fun ? " " + esc(q.fun) : "") + '</div><button class="sp-next" id="sp-nxt">' + (g.winner ? "Prisceremonin 🏆" : "Nästa spelare →") + "</button>";
          host.querySelector("#sp-nxt").addEventListener("click", function () {
            if (g.winner) return tqEnd();
            g.turn = (g.turn + 1) % g.players.length;
            tqTurn();
          });
        }
        host.querySelectorAll(q.type === "sf" ? ".sp-sf button" : ".sp-opt").forEach(function (b) {
          b.addEventListener("click", function () {
            var right = q.type === "sf" ? String(q.answer) === b.dataset.v : +b.dataset.v === q.answer;
            finish(right, b);
          });
        });
        t = spTimer(host, timerSec(), function () { finish(false, null); });
      }
      function tqEnd() {
        var g = tq, host = sp();
        spClear(); // resan är slut → inget att återuppta
        var standings = g.players.map(function (p) {
          return { name: p.avatar + " " + p.name, score: p === g.winner ? TQ_N : p.pos + 1 };
        });
        host.innerHTML = backBtnRow() + festiveBoardHTML(standings, "🎲") +
          '<button class="sp-next" id="sp-again">🎲 Ny resa!</button><button class="sp-ghost" id="sp-home">Till spelmenyn</button>';
        wireBack(host);
        host.querySelector("#sp-again").addEventListener("click", startTq);
        host.querySelector("#sp-home").addEventListener("click", renderSpelHome);
      }
      // «Fortsätt»-stöd: återuppta till aktuell spelares tur (positioner intakta, spelaren slår om).
      SP_RESUME.tq = {
        label: function (s) {
          var avs = (s.players || []).map(function (p) { return p.avatar; }).join("");
          return "🎲 Tärningsresan — " + (s.players || []).length + " spelare" + (avs ? " " + avs : "");
        },
        resume: function (s) { tq = s; tqTurn(); },
      };

      // Liten val-skärm (kategori / svårighetsgrad / kortlek) — samma knappstil som spelmenyn.
      // extra = { html, wire } lägger valfria inställningar (t.ex. ⏱) under alternativen.
      function chooseScreen(title, options, onPick, extra) {
        var host = sp();
        host.innerHTML = backBtnRow() + '<div class="sp-choosett">' + title + "</div>" +
          options.map(function (o) {
            return '<button class="sp-mode" data-k="' + o.key + '"><span class="big">' + o.icon + "</span><span>" + o.label + (o.sub ? '<span class="sub">' + o.sub + "</span>" : "") + "</span></button>";
          }).join("") + ((extra && extra.html) || "");
        wireBack(host);
        host.querySelectorAll(".sp-mode").forEach(function (b) {
          b.addEventListener("click", function () { onPick(b.dataset.k); });
        });
        if (extra && extra.wire) extra.wire(host);
      }

      // — Klassiska gåtor: välj svårighetsgrad först; 2+ spelare → turbaserat m. poäng —
      function startGator(lvl) {
        var all = (quiz.gator || []);
        if (!all.length) return;
        if (!lvl) {
          return chooseScreen("🧩 Gåtor — välj svårighetsgrad", [
            { key: "mix", icon: "🌀", label: "Blandat", sub: "Lättast först — hela familjen" },
            { key: "latt", icon: "🟢", label: "Lätt", sub: "För de yngsta" },
            { key: "mellan", icon: "🟡", label: "Mellan", sub: "Klurigare" },
            { key: "svar", icon: "🔴", label: "Svår", sub: "För de vuxna" },
          ], startGator);
        }
        var pool = lvl === "mix" ? all : all.filter(function (g) { return g.level === lvl; });
        if (!pool.length) pool = all;
        var cards = pickFrom(pool, 8, "gator");
        var ord = { latt: 0, mellan: 1, svar: 2 };
        cards.sort(function (a, b) { return (ord[a.level] || 0) - (ord[b.level] || 0); });
        runGator({ lvl: lvl, cards: cards, ps: roster().map(function (p) { return { name: p.name, score: 0 }; }), i: 0, hits: 0, hist: [], curSnap: null });
      }
      function runGator(st) {
        st.turns = st.ps.length >= 2;
        var cards = st.cards, ps = st.ps, host = sp();
        function advance() { st.hist.push(st.curSnap); st.i++; draw(); }
        function undo() { if (!st.hist.length) return; var s = st.hist.pop(); st.i = s.i; st.hits = s.hits; ps.forEach(function (p, k) { p.score = s.scores[k]; }); draw(); }
        function topFlags() { return { undo: st.hist.length > 0, lb: st.turns }; }
        function wire2(h2) { wireTop(h2, { onUndo: undo, players: st.turns ? function () { return ps; } : null }); }
        function draw() {
          st.curSnap = { i: st.i, hits: st.hits, scores: ps.map(function (p) { return p.score; }) };
          spSave("gator", st);
          if (st.i >= cards.length) {
            spClear();
            host.innerHTML = backBtnRow("", topFlags()) +
              (st.turns ? festiveBoardHTML(ps, "🧩") : festiveSoloHTML("Ni knäckte " + st.hits + " av " + cards.length + " gåtor!", "🧩")) +
              '<button class="sp-next" id="sp-again">Fler gåtor!</button><button class="sp-ghost" id="sp-home">Till spelmenyn</button>';
            wire2(host);
            host.querySelector("#sp-again").addEventListener("click", function () { startGator(st.lvl); });
            host.querySelector("#sp-home").addEventListener("click", renderSpelHome);
            return;
          }
          var c = cards[st.i];
          var tp = st.turns ? ps[st.i % ps.length] : null;
          host.innerHTML = backBtnRow("Gåta " + (st.i + 1) + " av " + cards.length, topFlags()) +
            (tp ? '<div class="sp-turn">🎲 <b>' + esc(tp.name) + "</b> gissar först! (" + tp.score + " p)</div>" : "") +
            '<div id="sp-timer"></div>' +
            '<div class="sp-q"><span class="sp-cat">' + (LVL_SHORT[c.level] || "🧩") + ' Gåta</span><div class="sp-qtext">' + esc(c.q) + '</div><div id="sp-hintbox"></div><div id="sp-revbox"><button class="sp-ghost" id="sp-hint">💡 Ledtråd</button><button class="sp-next" id="sp-reveal">Visa svaret</button></div></div>';
          wire2(host);
          host.querySelector("#sp-hint").addEventListener("click", function () {
            host.querySelector("#sp-hintbox").innerHTML = '<div class="sp-hint-txt">💡 ' + esc(c.hint || "Ingen ledtråd — kämpa på!") + "</div>";
          });
          host.querySelector("#sp-reveal").addEventListener("click", function () {
            if (t) t.stop();
            host.querySelector("#sp-revbox").innerHTML = '<div class="sp-answer">' + esc(c.answer) + '</div><div class="sp-tally"><button class="yes" id="sp-yes">✅ ' + (tp ? esc(tp.name) + " klarade den!" : "Vi klarade den!") + '</button><button class="no" id="sp-no">Nästa →</button></div>';
            host.querySelector("#sp-yes").addEventListener("click", function () { if (tp) tp.score++; else st.hits++; advance(); });
            host.querySelector("#sp-no").addEventListener("click", advance);
          });
          var t = spTimer(host, timerSec(), function () { var rb = host.querySelector("#sp-reveal"); if (rb) rb.click(); });
        }
        draw();
      }
      SP_RESUME.gator = {
        label: function (s) { return "🧩 Gåtor — gåta " + Math.min((s.i || 0) + 1, s.cards.length) + " av " + s.cards.length; },
        resume: function (s) { runGator(s); },
      };

      // — Samtalskortlek (Vem i familjen? / Skulle du hellre…?): bara kort, inga poäng.
      // Hellre-leken har vuxenkort (c.adult) → välj publik först: familj / vuxet / blandat.
      function startDeck(key, icon, title, mode) {
        var all = (quiz[key] || []);
        if (!all.length) return;
        if (key === "hellre" && !mode) {
          return chooseScreen("🤔 Skulle du hellre… — välj kortlek", [
            { key: "familj", icon: "👨‍👩‍👧‍👧", label: "Familj", sub: "Barnvänliga dilemman" },
            { key: "vuxen", icon: "🍷", label: "Vuxet", sub: "För vuxensällskapet — kluriga livsval" },
            { key: "mix", icon: "🌀", label: "Blandat", sub: "Allt i samma lek" },
          ], function (m) { startDeck(key, icon, title, m); });
        }
        var pool = all;
        if (key === "hellre" && mode === "familj") pool = all.filter(function (c) { return !c.adult; });
        if (key === "hellre" && mode === "vuxen") pool = all.filter(function (c) { return c.adult; });
        if (!pool.length) pool = all;
        runDeck({ key: key, icon: icon, title: title, mode: mode, cards: pickFrom(pool, 12, key), i: 0 });
      }
      function runDeck(st) {
        var cards = st.cards, icon = st.icon, title = st.title, host = sp();
        function undo() { if (st.i > 0) { st.i--; draw(); } }
        function draw() {
          spSave("deck", st);
          if (st.i >= cards.length) {
            spClear();
            host.innerHTML = backBtnRow("", { undo: true }) + festiveSoloHTML("Slut på korten den här rundan!", icon) +
              '<button class="sp-next" id="sp-again">En runda till!</button><button class="sp-ghost" id="sp-home">Till spelmenyn</button>';
            wireTop(host, { onUndo: undo });
            host.querySelector("#sp-again").addEventListener("click", function () { startDeck(st.key, st.icon, st.title, st.mode); });
            host.querySelector("#sp-home").addEventListener("click", renderSpelHome);
            return;
          }
          var c = cards[st.i];
          var ps = roster();
          var tp = ps.length >= 2 ? ps[st.i % ps.length] : null;
          host.innerHTML = backBtnRow("Kort " + (st.i + 1) + " av " + cards.length, { undo: st.i > 0 }) +
            (tp ? '<div class="sp-turn">🎴 <b>' + esc(tp.name) + "</b> " + (st.key === "hellre" ? "svarar först!" : "läser kortet!") + "</div>" : "") +
            '<div class="sp-q" style="text-align:center;padding:30px 18px"><span class="sp-cat">' + icon + " " + esc(title) + '</span><div class="sp-qtext" style="font-size:22px">' + esc(c.q) + '</div></div>' +
            '<button class="sp-next" id="sp-nxt">Nästa kort →</button>';
          wireTop(host, { onUndo: undo });
          host.querySelector("#sp-nxt").addEventListener("click", function () { st.i++; draw(); });
        }
        draw();
      }
      SP_RESUME.deck = {
        label: function (s) { return (s.icon || "🎴") + " " + (s.title || "Kortlek") + " — kort " + Math.min((s.i || 0) + 1, s.cards.length) + " av " + s.cards.length; },
        resume: function (s) { runDeck(s); },
      };

      // — Sant eller falskt: 2+ spelare → var sin tur m. poäng, annars gemensam räkning —
      function startSF() {
        var pool = quiz.questions.filter(function (q) { return q.type === "sf"; });
        if (!pool.length) return;
        var ord = { latt: 0, mellan: 1, svar: 2 };
        var cards = pickFrom(pool, 10, "sf").sort(function (a, b) { return (ord[a.level] || 0) - (ord[b.level] || 0); });
        runSF({ cards: cards, ps: roster().map(function (p) { return { name: p.name, score: 0 }; }), i: 0, score: 0, hist: [], curSnap: null });
      }
      function runSF(st) {
        st.turns = st.ps.length >= 2;
        var cards = st.cards, ps = st.ps, host = sp();
        function advance() { st.hist.push(st.curSnap); st.i++; draw(); }
        function undo() { if (!st.hist.length) return; var s = st.hist.pop(); st.i = s.i; st.score = s.hits; ps.forEach(function (p, k) { p.score = s.scores[k]; }); draw(); }
        function topFlags() { return { undo: st.hist.length > 0, lb: st.turns }; }
        function wire2(h2) { wireTop(h2, { onUndo: undo, players: st.turns ? function () { return ps; } : null }); }
        function draw() {
          st.curSnap = { i: st.i, hits: st.score, scores: ps.map(function (p) { return p.score; }) };
          spSave("sf", st);
          if (st.i >= cards.length) {
            spClear();
            host.innerHTML = backBtnRow("", topFlags()) +
              (st.turns ? festiveBoardHTML(ps, "⚖️") : festiveSoloHTML(st.score + " av " + cards.length + " rätt!", "⚖️")) +
              '<button class="sp-next" id="sp-again">En runda till!</button><button class="sp-ghost" id="sp-home">Till spelmenyn</button>';
            wire2(host);
            host.querySelector("#sp-again").addEventListener("click", startSF);
            host.querySelector("#sp-home").addEventListener("click", renderSpelHome);
            return;
          }
          var q = cards[st.i];
          var tp = st.turns ? ps[st.i % ps.length] : null;
          host.innerHTML = backBtnRow("Påstående " + (st.i + 1) + " av " + cards.length + (st.turns ? "" : " · " + st.score + " rätt"), topFlags()) +
            (tp ? '<div class="sp-turn">🎲 <b>' + esc(tp.name) + "</b> svarar! (" + tp.score + " p)</div>" : "") +
            '<div id="sp-timer"></div>' +
            '<div class="sp-q"><span class="sp-cat">' + LVL_SHORT[q.level] + " " + esc(q.cat || "") + '</span><div class="sp-qtext">' + esc(q.q) + '</div><div class="sp-sf"><button data-v="true">✅ SANT</button><button data-v="false">❌ FALSKT</button></div><div id="sp-after"></div></div>';
          wire2(host);
          var done = false, t = null;
          // b=null → tiden ute (fel, rätta svaret markeras).
          function finish(right, b) {
            if (done) return; done = true;
            if (t) t.stop();
            if (right) { if (tp) tp.score++; else st.score++; if (b) b.classList.add("hit"); }
            else {
              if (b) b.classList.add("miss");
              host.querySelectorAll(".sp-sf button").forEach(function (x) { x.disabled = true; if (x.dataset.v === String(q.answer)) x.classList.add("hit"); });
            }
            host.querySelector("#sp-after").innerHTML = '<div class="sp-fun"><strong>' + (right ? "🎉 Rätt!" : (b ? "Neeej!" : "⏰ Tiden ute!")) + "</strong>" + (q.fun ? " " + esc(q.fun) : "") + '</div><button class="sp-next" id="sp-nxt">Nästa →</button>';
            host.querySelector("#sp-nxt").addEventListener("click", advance);
          }
          host.querySelectorAll(".sp-sf button").forEach(function (b) {
            b.addEventListener("click", function () { finish(String(q.answer) === b.dataset.v, b); });
          });
          t = spTimer(host, timerSec(), function () { finish(false, null); });
        }
        draw();
      }
      SP_RESUME.sf = {
        label: function (s) { return "⚖️ Sant eller falskt — påstående " + Math.min((s.i || 0) + 1, s.cards.length) + " av " + s.cards.length; },
        resume: function (s) { runSF(s); },
      };

      // ---------- Läs-moduler pushade från pappen (recept/träning/aktiviteter) ----------
      var blobCache = {};
      function loadBlob(kind, force) {
        if (!force && blobCache[kind]) return Promise.resolve(blobCache[kind]);
        if (!blobCache[kind]) { var c = lsGet("blob_" + kind); if (c) blobCache[kind] = c; }   // offline-first: recept/träning/aktiviteter direkt
        return fetch(API + "?pw=" + encodeURIComponent(pw) + "&kind=" + kind)
          .then(function (r) { if (!r.ok) throw new Error("http " + r.status); return r.json(); })
          .then(function (j) { blobCache[kind] = j[kind]; lsSet("blob_" + kind, j[kind]); return j[kind]; })
          .catch(function (e) { if (blobCache[kind]) return blobCache[kind]; throw e; });
      }
      function fstamp(n, updatedAt) { return '<div class="stamp">' + n + (updatedAt ? ' · uppdaterad ' + esc(String(updatedAt).slice(0, 10)) : '') + '</div>'; }

      function renderRecept(blob) {
        var host = $("recept");
        var list = (blob && blob.recipes) || [];
        if (!list.length) { host.innerHTML = '<div class="empty">Inga recept pushade än. Tryck 📲 i pappens Recept.</div>'; return; }
        var shelves = {};
        list.forEach(function (r) { var c = (r.category && r.category[0]) || "Övrigt"; (shelves[c] = shelves[c] || []).push(r); });
        var html = Object.keys(shelves).sort().map(function (c) {
          return '<h3 class="fshelf">' + esc(c) + ' <span class="fcount">' + shelves[c].length + '</span></h3>' + shelves[c].map(function (r) {
            var meta = [r.time_min ? ('⏱ ' + r.time_min + ' min') : '', r.servings ? ('🍽 ' + r.servings) : '', r.kid_score != null ? ('👶 ' + r.kid_score + '/10') : ''].filter(Boolean).join(' · ');
            return '<details class="fcard"><summary>' + esc(r.title) + '</summary><div class="fbody">' + (meta ? '<div class="fmeta">' + meta + '</div>' : '') + (r.vibe ? '<p class="fvibe">' + esc(r.vibe) + '</p>' : '') + md(r.body || '') + '</div></details>';
          }).join('');
        }).join('');
        host.innerHTML = fstamp(list.length + ' recept', blob.updatedAt) + html;
      }

      function exThumb(e) { var p = e.imgs && e.imgs[0]; return p ? '<img class="fthumb" src="/' + esc(p) + '" alt="" loading="lazy">' : ''; }
      function renderTraning(blob) {
        var host = $("traning");
        var d = (blob && blob.data) || {};
        var ex = d.exercises || {}, ws = d.workouts || [];
        if (!ws.length) { host.innerHTML = '<div class="empty">Inga träningspass pushade än. Tryck 📲 i pappens Hälsa.</div>'; return; }
        var html = ws.map(function (w, wi) {
          var steps = (w.steps || []).map(function (s) {
            var e = ex[s.ex] || {}; var name = e.n || s.ex;
            var amt = s.kind === "time" ? (s.val + " s") : (s.val + " reps");
            return '<li>' + exThumb(e) + '<span class="fstep-t">' + esc(name) + ' — ' + esc(amt) + (s.rest ? (' · vila ' + s.rest + ' s') : '') + (e.c ? '<span class="fcue">' + esc(e.c) + '</span>' : '') + '</span></li>';
          }).join('');
          return '<details class="fcard"><summary>' + (w.icon ? esc(w.icon) + ' ' : '') + esc(w.name) + (w.focus ? ' <span class="ftag">' + esc(w.focus) + '</span>' : '') + '</summary><div class="fbody"><button class="fkor" data-wi="' + wi + '">▶ Kör passet</button><ol class="fsteps ftsteps">' + steps + '</ol></div></details>';
        }).join('');
        host.innerHTML = fstamp(ws.length + ' pass', blob.updatedAt) + html;
        host.querySelectorAll('.fkor').forEach(function (b) { b.addEventListener('click', function () { startFaltWorkout(ws[+b.dataset.wi], ex); }); });
      }

      // ---------- Mobil pass-player (timer-guidad, som pappens desktop-player) ----------
      var _fwp = null;
      function startFaltWorkout(w, ex) {
        if (!(w.steps || []).length) return;
        _fwp = { w: w, ex: ex, steps: w.steps, i: 0, phase: "ready", remaining: 5, timer: null, paused: false };
        var box = document.getElementById("fwplayer");
        if (!box) { box = document.createElement("div"); box.id = "fwplayer"; box.className = "fwp"; document.body.appendChild(box); }
        fwpRender(); fwpRun(fwpWork);
      }
      function fwpStop() { if (_fwp && _fwp.timer) { clearInterval(_fwp.timer); _fwp.timer = null; } }
      function fwpRun(onDone) {
        fwpStop();
        _fwp.timer = setInterval(function () {
          if (!_fwp || _fwp.paused) return;
          _fwp.remaining--; fwpTick();
          if (_fwp.remaining <= 0) { fwpStop(); if (navigator.vibrate) navigator.vibrate(40); onDone(); }
        }, 1000);
      }
      function fwpWork() {
        var s = _fwp.steps[_fwp.i]; _fwp.phase = "work";
        if (s.kind === "time") { _fwp.remaining = s.val; fwpRender(); fwpRun(fwpAfter); }
        else { fwpStop(); fwpRender(); }
      }
      function fwpAfter() {
        var s = _fwp.steps[_fwp.i];
        if (s.rest > 0 && _fwp.i < _fwp.steps.length - 1) { _fwp.phase = "rest"; _fwp.remaining = s.rest; fwpRender(); fwpRun(fwpNext); }
        else fwpNext();
      }
      function fwpNext() { _fwp.i++; if (_fwp.i >= _fwp.steps.length) return fwpFinish(); fwpWork(); }
      function fwpPrev() { fwpStop(); if (_fwp.phase === "rest") { fwpWork(); return; } _fwp.i = Math.max(0, _fwp.i - 1); fwpWork(); }
      function fwpSkip() { fwpStop(); if (_fwp.phase === "ready") return fwpWork(); if (_fwp.phase === "rest") return fwpNext(); fwpAfter(); }
      function fwpPause() { if (!_fwp) return; _fwp.paused = !_fwp.paused; var b = document.getElementById("fwp-pause"); if (b) b.textContent = _fwp.paused ? "▶" : "⏸"; }
      function fwpQuit() { fwpStop(); _fwp = null; var b = document.getElementById("fwplayer"); if (b) b.remove(); }
      function fwpTick() { var t = document.getElementById("fwp-big"); if (t) t.textContent = _fwp.remaining; var bar = document.getElementById("fwp-bar"); if (bar) bar.style.width = (100 * _fwp.i / _fwp.steps.length) + "%"; }
      function fwpImgs(e) {
        var imgs = (e.imgs || []).slice(0, 3); if (!imgs.length) return '';
        var cells = imgs.map(function (p, i) { return '<div class="fwp-img"><img src="/' + esc(p) + '" alt=""><span>' + (imgs.length > 1 ? (i === 0 ? "start" : "slut") : "") + '</span></div>'; });
        return '<div class="fwp-imgs">' + cells.join('<span class="fwp-arw">→</span>') + '</div>';
      }
      function fwpMus(e) { return (e && e.muscles && e.muscles.length) ? '<div class="fwp-mus">Tränar: ' + e.muscles.map(esc).join(' · ') + '</div>' : ''; }
      // "Läs på övningen": muskler + bild + cue + hela beskrivningen. Visas under GÖR DIG REDO och VILA
      // så man hinner förbereda sig INNAN timern startar — särskilt när bild saknas och allt är text.
      function fwpStudy(e) {
        if (!e) return '';
        var sh = e.show || {};
        var mus = fwpMus(e);
        var imgs = (sh.playerImg !== false) ? fwpImgs(e) : '';
        var cue = (sh.playerCue !== false && e.c) ? '<div class="fwp-cue">' + esc(e.c) + '</div>' : '';
        var desc = (sh.playerDesc && e.desc) ? '<div class="fwp-cue fwp-desc">' + esc(e.desc) + '</div>' : '';
        return mus + imgs + cue + desc;
      }
      function fwpRender() {
        var box = document.getElementById("fwplayer"); if (!box || !_fwp) return;
        var s = _fwp.steps[_fwp.i]; var e = _fwp.ex[s.ex] || { n: s.ex, c: "" }; var sh = e.show || {};
        var nx = _fwp.steps[_fwp.i + 1] ? (_fwp.ex[_fwp.steps[_fwp.i + 1].ex] || null) : null;
        var next = nx ? (nx.n || '') : "Klart!";
        var pct = 100 * _fwp.i / _fwp.steps.length;
        var center = "";
        if (_fwp.phase === "ready") {
          center = '<div class="fwp-ph">GÖR DIG REDO</div><div class="fwp-big" id="fwp-big">' + _fwp.remaining + '</div><div class="fwp-nx">Först ut: <b>' + esc(e.n) + '</b></div>' + fwpStudy(e);
        } else if (_fwp.phase === "rest") {
          center = '<div class="fwp-ph fwp-rest">VILA</div><div class="fwp-big" id="fwp-big">' + _fwp.remaining + '</div>' +
            (nx ? '<div class="fwp-nx">Nästa: <b>' + esc(next) + '</b></div>' + fwpStudy(nx) : '<div class="fwp-nx">Sista övningen klar strax 💪</div>');
        } else {
          var imgs = (sh.playerImg !== false) ? fwpImgs(e) : '';
          var cue = (sh.playerCue !== false && e.c) ? '<div class="fwp-cue">' + esc(e.c) + '</div>' : '';
          var desc = (sh.playerDesc && e.desc) ? '<div class="fwp-cue fwp-desc">' + esc(e.desc) + '</div>' : '';
          center = '<div class="fwp-nm">' + esc(e.n) + '</div>' + fwpMus(e) + imgs +
            (s.kind === "time"
              ? '<div class="fwp-big" id="fwp-big">' + _fwp.remaining + '</div><div class="fwp-u">sekunder</div>'
              : '<div class="fwp-big">×' + s.val + '</div><div class="fwp-u">reps</div><button class="fwp-done" id="fwp-done">Klar ✓</button>') + cue + desc;
        }
        box.innerHTML =
          '<div class="fwp-top"><button class="fwp-x" id="fwp-quit">✕</button><div class="fwp-ti">' + esc(_fwp.w.icon || '') + ' ' + esc(_fwp.w.name) + ' · ' + Math.min(_fwp.i + 1, _fwp.steps.length) + '/' + _fwp.steps.length + '</div><div class="fwp-prog"><div id="fwp-bar" style="width:' + pct + '%"></div></div></div>' +
          '<div class="fwp-c">' + center + '</div>' +
          '<div class="fwp-ctrl"><button id="fwp-prev">◀</button>' + ((_fwp.phase !== "work" || s.kind === "time") ? '<button id="fwp-pause">' + (_fwp.paused ? "▶" : "⏸") + '</button>' : '') + '<button id="fwp-skip">▶▶</button></div>';
        box.querySelector("#fwp-quit").onclick = fwpQuit;
        box.querySelector("#fwp-prev").onclick = fwpPrev;
        box.querySelector("#fwp-skip").onclick = fwpSkip;
        var p = box.querySelector("#fwp-pause"); if (p) p.onclick = fwpPause;
        var dn = box.querySelector("#fwp-done"); if (dn) dn.onclick = function () { if (navigator.vibrate) navigator.vibrate(40); fwpAfter(); };
      }
      function fwpFinish() {
        var box = document.getElementById("fwplayer"); if (!box) return; fwpStop();
        box.innerHTML = '<div class="fwp-fin"><div class="fwp-fe">💪</div><h2>Bra jobbat!</h2><div class="fwp-fs">' + esc(_fwp.w.name) + ' avklarat</div><button class="fwp-doneb" id="fwp-close">Klar</button></div>';
        box.querySelector("#fwp-close").onclick = fwpQuit;
      }

      function renderAkt(blob) {
        var host = $("aktiviteter");
        var d = (blob && blob.data) || {};
        var dests = d.destinations || [], acts = d.activities || [];
        if (!dests.length && !acts.length) { host.innerHTML = '<div class="empty">Inga aktiviteter pushade än. Tryck 📲 i pappens Aktiviteter.</div>'; return; }
        var html = dests.map(function (dst) {
          return '<div class="fdest">' + (dst.emoji ? esc(dst.emoji) + ' ' : '') + '<b>' + esc(dst.name) + '</b>' + (dst.blurb ? '<div class="fblurb">' + esc(dst.blurb) + '</div>' : '') + '</div>';
        }).join('');
        html += acts.map(function (a) {
          var meta = [a.type, a.duration, a.driveMin != null ? ('🚗 ' + a.driveMin + ' min') : '', a.priceAdult != null ? ('vuxen ' + a.priceAdult + (a.priceChild != null ? ' / barn ' + a.priceChild : '')) : ''].filter(Boolean).join(' · ');
          var days = (a.days && a.days.length) ? ('Dagar: ' + a.days.join(', ')) : '';
          return '<details class="fcard"><summary>' + (a.icon ? esc(a.icon) + ' ' : '') + esc(a.name) + '</summary><div class="fbody">' + (meta ? '<div class="fmeta">' + esc(meta) + '</div>' : '') + (a.hours ? '<div>🕐 ' + esc(a.hours) + '</div>' : '') + (days ? '<div>' + esc(days) + '</div>' : '') + (a.priceNote ? '<div class="fnote">' + esc(a.priceNote) + '</div>' : '') + '</div></details>';
        }).join('');
        host.innerHTML = fstamp(acts.length + ' aktiviteter', blob.updatedAt) + html;
      }

      // ---------- Flikar ----------
      var curTab = "inkorg";
      function showTab(name) {
        curTab = name;
        ["inkorg", "todo", "listor", "agera", "spel", "recept", "traning", "aktiviteter"].forEach(function (t) { $("tab-" + t).hidden = t !== name; });
        var ns = $("navsel"); if (ns && ns.value !== name) ns.value = name;
        if (name === "spel") loadQuiz().then(function () { if (!spShowResume()) renderSpelHome(); }).catch(function () { sp().innerHTML = '<div class="card"><div class="empty">Kunde inte hämta frågebanken (offline?).</div></div>'; });
        else if (name === "recept") loadBlob("recipes").then(renderRecept).catch(function () { $("recept").innerHTML = '<div class="empty">Kunde inte hämta recept (offline?).</div>'; });
        else if (name === "traning") loadBlob("workouts").then(renderTraning).catch(function () { $("traning").innerHTML = '<div class="empty">Kunde inte hämta träningspass (offline?).</div>'; });
        else if (name === "aktiviteter") loadBlob("activities").then(renderAkt).catch(function () { $("aktiviteter").innerHTML = '<div class="empty">Kunde inte hämta aktiviteter (offline?).</div>'; });
        else if (name !== "inkorg") loadMirror().then(renderMirrorTabs).catch(function () {});
      }
      $("navsel").addEventListener("change", function () { showTab(this.value); });
      $("hometitle").addEventListener("click", function () { showTab("inkorg"); });

      async function hydrate() {
        var c = lsGet("state"); if (c) { renderQueue(c.inbox); renderFeed(c.feed); }   // offline-first: rita cache innan nätet svarar
        var r = await fetch(API + "?pw=" + encodeURIComponent(pw) + "&kind=state");
        if (r.status === 401) throw new Error("pw");
        if (!r.ok) throw new Error("http " + r.status);
        var j = await r.json();
        lsSet("state", { inbox: j.inbox, feed: j.feed });
        renderQueue(j.inbox); renderFeed(j.feed);
        flushOutbox();   // nätet svarar → försök tömma osända anteckningar
      }
      function refreshAll() {
        hydrate().catch(function () {});
        loadMirror(true).then(renderMirrorTabs).catch(function () {});
        // Rita bara om spelmenyn om inget spel pågår — annars tappas pågående fråga vid skärmlås/upplåsning.
        loadQuiz(true).then(function () { if (curTab === "spel" && !_spInGame) renderSpelHome(); }).catch(function () {});
        if (curTab === "recept") loadBlob("recipes", true).then(renderRecept).catch(function () {});
        if (curTab === "traning") loadBlob("workouts", true).then(renderTraning).catch(function () {});
        if (curTab === "aktiviteter") loadBlob("activities", true).then(renderAkt).catch(function () {});
      }

      async function save() {
        var ta = $("note"), btn = $("save"), toast = $("toast");
        var text = ta.value.trim();
        if (!text) return;
        btn.disabled = true; toast.textContent = ""; toast.className = "toast";
        var cid = mkCid();
        try {
          var r = await fetch(API + "?kind=note", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ pw: pw, text: text, id: cid }) });
          if (!r.ok) throw new Error("http " + r.status);
          ta.value = ""; localStorage.removeItem("falt_draft");
          toast.textContent = "✅ Sparad — hämtas av pappen.";
          hydrate().catch(function () {});
        } catch (e) {
          // Offline/fel → köa durabelt (replay säkert via cid-idempotens) i st.f. att bara lämna texten i rutan.
          var ob = outboxGet(); ob.push({ cid: cid, text: text, at: new Date().toISOString() }); outboxSet(ob);
          ta.value = ""; localStorage.removeItem("falt_draft");
          toast.textContent = "📥 Sparad lokalt — synkas automatiskt när du är online igen.";
          var cs = lsGet("state"); renderQueue(cs ? cs.inbox : []);
        }
        btn.disabled = false;
      }

      // Töm osända anteckningar sekventiellt. Failade ligger kvar och försöker igen; cid gör serverns insert idempotent.
      var _flushing = false;
      async function flushOutbox() {
        if (_flushing) return;
        var ob = outboxGet(); if (!ob.length) return;
        _flushing = true;
        var rest = [];
        for (var i = 0; i < ob.length; i++) {
          var it = ob[i];
          try {
            var r = await fetch(API + "?kind=note", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ pw: pw, text: it.text, id: it.cid }) });
            if (!r.ok) throw new Error("http " + r.status);
          } catch (e) { rest.push(it); }
        }
        outboxSet(rest); _flushing = false;
        var cs = lsGet("state"); renderQueue(cs ? cs.inbox : []);   // uppdatera badge-läget (utan att kalla hydrate → ingen rekursion)
      }

      function openApp() { $("gate").hidden = true; $("app").hidden = false; hydrate().catch(function () {}); if (spLoad()) showTab("spel"); }

      async function tryOpen(code) {
        pw = code;
        try { await hydrate(); localStorage.setItem("falt_pw", pw); openApp(); }
        catch (e) {
          localStorage.removeItem("falt_pw");
          $("gate-err").textContent = e.message === "pw" ? "Fel nyckel." : "Kunde inte nå servern.";
        }
      }

      $("gate-go").addEventListener("click", function () { tryOpen($("gate-pw").value.trim()); });
      $("gate-pw").addEventListener("keydown", function (e) { if (e.key === "Enter") tryOpen($("gate-pw").value.trim()); });
      $("save").addEventListener("click", save);
      $("refresh").addEventListener("click", refreshAll);
      document.addEventListener("visibilitychange", function () { if (!document.hidden && !$("app").hidden) refreshAll(); });
      window.addEventListener("online", flushOutbox);   // nätet tillbaka → skicka osända anteckningar
      // Utkast överlever app-byten/krascher (rensas vid lyckad spara).
      $("note").addEventListener("input", function () { localStorage.setItem("falt_draft", $("note").value); });
      var draft = localStorage.getItem("falt_draft"); if (draft) $("note").value = draft;

      // Offline-first öppning: känd session + cachead state → öppna direkt (hydrering/flush sker inne i openApp).
      // Utan cache faller vi tillbaka till nät-verifiering (loggar ut om nyckeln vägras eller nätet saknas).
      if (pw) {
        if (lsGet("state")) { openApp(); flushOutbox(); }
        else { hydrate().then(openApp).catch(function () { localStorage.removeItem("falt_pw"); $("gate-pw").focus(); }); }
      }
      else { $("gate-pw").focus(); }

      // Service worker: cache-first-skal så appen (installerad till hemskärmen) öppnas offline utan browserns felsida.
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () { navigator.serviceWorker.register("/falt-sw.js", { scope: "/falt" }).catch(function () {}); });
      }
    })();
  </script>
</body>
</html>
