            <div id="sfx-slot"></div>
          </div>
        </div>
      </div>
      <p id="cf-engine" class="mt-6 text-xs text-stone-500"></p>
      <section id="cf-comments" class="mt-10 border-t border-[#22222e] pt-7">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-center gap-1.5">
            <button class="cf-ctab cf-ctab-on" data-cscope="theme">💬 This forge</button>
            <button class="cf-ctab" data-cscope="global">🌐 Concept Forge</button>
          </div>
          <span class="text-xs text-stone-500"><span id="cf-cmt-count">0</span> comments</span>
        </div>
        <div class="mb-5 rounded-2xl border border-[#22222e] bg-[#13131c] p-4">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-stretch">
            <input id="cf-cmt-handle" maxlength="24" placeholder="name (optional)" class="cf-cinput sm:w-40" />
            <div class="relative flex-1">
              <button type="button" id="cf-emoji-btn" class="cf-emoji-btn" title="Emoji" aria-label="Emoji" tabindex="-1"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M8.5 14.3c.9 1.1 2.1 1.7 3.5 1.7s2.6-.6 3.5-1.7"/><path d="M9 9.6v.5M15 9.6v.5"/></svg></button>
              <div id="cf-emoji-pop" class="cf-emoji-pop hidden">${['😂','❤️','🔥','👍','😍','🙏','😭','🎉','💯','👀'].map((e) => `<button type="button" class="cf-emoji" data-emoji="${e}" tabindex="-1">${e}</button>`).join('')}</div>
              <textarea id="cf-cmt-body" maxlength="280" rows="1" placeholder="Drop a thought on this forge…" class="cf-cinput w-full resize-none pl-9"></textarea>
            </div>
            <button id="cf-cmt-post" class="flex-none rounded-lg bg-[#c6ff00] px-4 py-2 text-sm font-black text-[#0a0a0f] transition hover:brightness-110 disabled:opacity-50">Post</button>
          </div>
          <div class="mt-1.5 flex items-center justify-between"><span id="cf-cmt-msg" class="text-xs text-stone-500"></span><span id="cf-cmt-chars" class="text-[10px] text-stone-600">0/280</span></div>
        </div>
        <div id="cf-cmt-list" class="flex flex-col gap-2.5"></div>
      </section>`;
    renderAll();
    result.classList.remove('hidden');
    requestAnimationFrame(positionSwipeArrows);
    const regen = document.getElementById('regen-btn');
    if (regen) regen.addEventListener('click', () => { if (state && state.theme) generateFresh(state.theme); });
    wireConceptActions();
    initComments();   // kommentarssektion: per-koncept-fliken laddas (global ett klick bort)
    state.spun = false;   // Game är default-vyn; symbol-jobbet (eller persistade symboler) fyller rullen progressivt
    updateSwipeVis();
  }

  // Auto-rotera Mood↔Game var 7:e sek så nya användare upptäcker Game-vyn — slutar permanent
  // vid första egna interaktion (vy-klick/snurr), pausar när fliken är dold, hoppar över Loop.
  // Rotationen fortsätter tills användaren AKTIVT väljer en vy via Mood/Game-knapparna (data-vis).
  // Ett klick mitt på bilden (snurr) räcker inte. Pausar artigt när fliken är dold / mitt i snurr.
  let viewAutoTimer = null, viewTouched = false;
  function startViewAuto() {
    clearInterval(viewAutoTimer);
    viewAutoTimer = setInterval(() => {
      if (viewTouched || document.hidden || state.spinning) return;
      const canGame = ((cur('symbols') || []).length > 0);
      if (state.visualMode === 'game') state.visualMode = 'mood';
      else if (canGame) { state.visualMode = 'game'; ensureSymbols(); }
      else return;   // inga symboler än → stanna på Mood tills de kommit
      renderImage(false);
    }, 7000);
  }
  function stopViewAuto() { viewTouched = true; clearInterval(viewAutoTimer); }

  // Lås textsektionens höjd till bilddelens höjd (alltid enhetlig ruta, scroll inuti när innehållet är längre).
  // Hero är nu full-bredd ovanför texten → ingen höjd-matchning behövs. Texten har egen maxhöjd + scroll (lg:max-h).
  function syncPanelHeight() { /* no-op (bevarad så befintliga anrop inte kraschar) */ }

  // delegation (result-elementet är stabilt; lyssnaren sätts en gång)
  result.addEventListener('click', (e) => {
    const tb = e.target.closest('[data-tab]');
    if (tb) { const t = tb.dataset.tab; result.querySelectorAll('[data-tab]').forEach((x) => x.classList.toggle('active', x.dataset.tab === t)); result.querySelectorAll('[data-panel]').forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== t)); return; }
    const vs = e.target.closest('[data-vis]'); if (vs) { stopViewAuto(); state.visualMode = vs.dataset.vis; renderImage(false); if (vs.dataset.vis === 'game') ensureSymbols(); return; }
    const sp = e.target.closest('[data-spin]'); if (sp) { spinMockup(); return; }
    const rs = e.target.closest('[data-reshape]'); if (rs) { reshapeSoundtrack(); return; }
    const rf = e.target.closest('[data-refresh]');
    if (rf) {
      // Tap-again-bekräftelse: första trycket beväpnar (gulorange), andra inom 2,5 s kör. Hindrar dyra mistryck.
      // data-noconfirm = förstagångs-åtgärder (t.ex. ▶ Loop) som ska starta direkt på ett klick.
      if (rf.getAttribute('data-noconfirm') !== '1' && rf.getAttribute('data-armed') !== '1') {
        rf.setAttribute('data-armed', '1'); rf.classList.add('cf-confirm'); rf.title = 'Tap again to confirm';
        clearTimeout(rf._armT); rf._armT = setTimeout(() => { rf.removeAttribute('data-armed'); rf.classList.remove('cf-confirm'); }, 2500);
        return;
      }
      clearTimeout(rf._armT); rf.removeAttribute('data-armed'); rf.classList.remove('cf-confirm');
      refresh(rf.dataset.refresh); return;
    }
    const nv = e.target.closest('[data-nav]'); if (nv) { nav(nv.dataset.nav, +nv.dataset.d); return; }
    const cs = e.target.closest('[data-cscope]'); if (cs) { setCmtScope(cs.dataset.cscope); return; }
    const cvt = e.target.closest('[data-cvote]'); if (cvt) { voteComment(cvt.dataset.cvote, cvt.dataset.vscope); return; }
    const cdl = e.target.closest('[data-cdel]'); if (cdl) { deleteComment(cdl.dataset.cdel, cdl.dataset.dscope); return; }
    const cmn = e.target.closest('[data-cmenu]'); if (cmn) { e.stopPropagation(); toggleCmtMenu(cmn.dataset.cmenu); return; }
    const ced = e.target.closest('[data-cedit]'); if (ced) { startEditComment(ced.dataset.cedit); return; }
    const csv = e.target.closest('[data-cedit-save]'); if (csv) { saveEditComment(csv.dataset.ceditSave, csv.dataset.escope); return; }
    if (e.target.closest('[data-cedit-cancel]')) { cancelEditComment(); return; }
    const cdo = e.target.closest('[data-cdelown]'); if (cdo) { deleteOwnComment(cdo.dataset.cdelown, cdo.dataset.escope); return; }
    if (e.target.closest('#cf-emoji-btn')) { toggleEmojiPop(); return; }
    const emo = e.target.closest('[data-emoji]'); if (emo) { insertEmoji(emo.dataset.emoji); return; }
    if (e.target.closest('#cf-cmt-post')) { postComment(); return; }
  });

  // ---------- Kommentarer / chatt (Reddit-likt, två scopes: per koncept + global app-feedback) ----------
  let cmtScope = 'theme';   // 'theme' (aktuellt koncept) | 'global'
  const MOD_TOKEN = (() => { try { return localStorage.getItem('forge-mod') || ''; } catch (e) { return ''; } })();   // Carl sätter denna en gång → radera-knappar
  // Per-browser författar-id → avgör "min kommentar" (edit/delete). Servern verifierar ägarskap; id:t läcker aldrig ut i GET.
  const AUTHOR_ID = (() => { try { let a = localStorage.getItem('forge-author'); if (!a) { a = 'u' + Math.random().toString(36).slice(2, 12) + Date.now().toString(36); localStorage.setItem('forge-author', a); } return a; } catch (e) { return 'anon'; } })();
  let editingId = null, lastCmtList = [];   // kommentar som redigeras inline + senaste renderade listan (lokal re-render)
  function scopeId() { return cmtScope === 'global' ? 'global' : (state && state.id ? state.id : null); }
  function relTime(ts) {
    const s = Math.max(1, Math.round((Date.now() - ts) / 1000));
    if (s < 60) return s + 's ago';
    const m = Math.round(s / 60); if (m < 60) return m + 'm ago';
    const h = Math.round(m / 60); if (h < 24) return h + 'h ago';
    return Math.round(h / 24) + 'd ago';
  }
  function hashStr(s) { let h = 0; s = s || ''; for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0; return h; }
  // Profil-avatar = en av aktuella forgens reel-symboler (slumpad men stabil per kommentar-id). Fallback: färgad initial.
  function commentAvatar(c) {
    const syms = (cur('symbols') || []).filter((s) => s && s.url);
    if (syms.length) {
      const url = syms[hashStr(c.id) % syms.length].url;
      return `<div class="cf-cmt-av"><img src="${esc(url)}" alt="" loading="lazy" /></div>`;
    }
    const initial = esc((((c.handle || 'a').trim()[0]) || 'a').toUpperCase());
    return `<div class="cf-cmt-av cf-cmt-av-fb" style="background:hsl(${hashStr(c.handle || c.id) % 360} 45% 30%)">${initial}</div>`;
  }
  function renderComments(list) {
    const el = document.getElementById('cf-cmt-list'); if (!el) return;
    const cnt = document.getElementById('cf-cmt-count'); if (cnt) cnt.textContent = list.length;
    if (!list.length) { el.innerHTML = `<p class="py-6 text-center text-sm text-stone-600">No comments yet — be the first.</p>`; return; }
    lastCmtList = list;
    const sorted = [...list].sort((a, b) => (b.votes || 0) - (a.votes || 0) || b.ts - a.ts);   // flest röster, sen nyast
    const topId = sorted[0] && (sorted[0].votes || 0) > 0 ? sorted[0].id : null;
    el.innerHTML = sorted.map((c) => {
      const own = !!c.mine, editing = c.id === editingId;
      const sc = esc(c._scope || '');
      const meta = `<div class="cf-cmt-meta"><span class="cf-cmt-handle">${esc(c.handle || 'anon')}</span> <span class="cf-cmt-tag ${c._app ? 'cf-tag-app' : 'cf-tag-forge'}" title="${c._app ? 'About Concept Forge' : 'About this forge'}">${esc(c._tag || '')}</span> · ${relTime(c.ts)}${c.edited ? ' · <span class="cf-cmt-edited">edited</span>' : ''}${c.id === topId ? ' · <span style="color:#c6ff00">top</span>' : ''}</div>`;
      const content = editing
        ? `<div class="cf-cmt-edit"><textarea class="cf-cinput w-full resize-none" maxlength="280" data-cedit-body="${esc(c.id)}">${esc(c.body || '')}</textarea><div class="mt-1.5 flex items-center gap-2"><button class="cf-cmt-save" data-cedit-save="${esc(c.id)}" data-escope="${sc}">Save</button><button class="cf-cmt-cancel" data-cedit-cancel="1">Cancel</button></div></div>`
        : `<div class="cf-cmt-text">${esc(c.body || '')}</div>`;
      const ownMenu = own && !editing
        ? `<div class="cf-cmt-own"><button class="cf-cmt-menu-btn" data-cmenu="${esc(c.id)}" title="Options" aria-label="Options">⋯</button><div class="cf-cmt-menu hidden" data-menu-for="${esc(c.id)}"><button data-cedit="${esc(c.id)}">✎ Edit</button><button class="cf-cmt-menu-del" data-cdelown="${esc(c.id)}" data-escope="${sc}">🗑 Delete</button></div></div>`
        : '';
      const modDel = (MOD_TOKEN && !own) ? `<button class="cf-cmt-del" data-cdel="${esc(c.id)}" data-dscope="${sc}" title="Delete (mod)">✕</button>` : '';
      return `
      <div class="cf-cmt${c.id === topId ? ' cf-cmt-top' : ''}${own ? ' cf-cmt-mine' : ''}">
        <div class="cf-cmt-vote${c.voted ? ' on' : ''}" data-cvote="${esc(c.id)}" data-vscope="${sc}" role="button" title="Upvote"><span class="cf-cmt-arrow">▲</span><b>${c.votes || 0}</b></div>
        ${commentAvatar(c)}
        <div class="cf-cmt-body">${meta}${content}</div>
        ${ownMenu}${modDel}
      </div>`;
    }).join('');
  }
  // @-tagg för aktuell forge: "@" + titel utan mellanslag (t.ex. @slurpheist). App-kommentarer = @forgeapp.
  function forgeName() { const t = cur('title') || {}; return (t.names && t.names[0]) || (state && state.theme) || 'forge'; }
  function forgeTag() { return '@' + forgeName().toLowerCase().replace(/[^a-z0-9&]+/g, ''); }
  async function fetchScope(scope) {
    try { const r = await fetch('/api/comments?scope=' + encodeURIComponent(scope) + '&author=' + encodeURIComponent(AUTHOR_ID) + '&cb=' + Date.now()); const j = await r.json(); return Array.isArray(j.list) ? j.list : []; } catch (e) { return []; }
  }
  let cmtReqSeq = 0;
  async function loadComments() {
    const el = document.getElementById('cf-cmt-list'); if (!el) return;
    const cnt = document.getElementById('cf-cmt-count');
    const seq = ++cmtReqSeq;
    try {
      let items;
      if (cmtScope === 'global') {
        // Rena app-flödet: bara @forgeapp-kommentarer.
        items = (await fetchScope('global')).map((c) => ({ ...c, _scope: 'global', _tag: '@forgeapp', _app: true }));
      } else {
        const id = scopeId();
        if (!id) { el.innerHTML = `<p class="py-6 text-center text-sm text-stone-600">Comments unlock once this concept is saved.</p>`; if (cnt) cnt.textContent = '0'; return; }
        // This forge = denna forges egna kommentarer + ALLA app-kommentarer, mergade.
        const ftag = forgeTag();
        const [local, glob] = await Promise.all([fetchScope(id), fetchScope('global')]);
        items = local.map((c) => ({ ...c, _scope: id, _tag: ftag, _app: false }))
          .concat(glob.map((c) => ({ ...c, _scope: 'global', _tag: '@forgeapp', _app: true })));
      }
      if (seq !== cmtReqSeq) return;   // en nyare laddning vann → ignorera detta svar
      renderComments(items);
    } catch (e) { renderComments([]); }
  }
  function setCmtScope(s) {
    cmtScope = (s === 'global') ? 'global' : 'theme';
    document.querySelectorAll('#cf-comments [data-cscope]').forEach((b) => b.classList.toggle('cf-ctab-on', b.dataset.cscope === cmtScope));
    const body = document.getElementById('cf-cmt-body');
    if (body) body.placeholder = cmtScope === 'global' ? 'Feedback on Concept Forge itself…' : 'Drop a thought on this forge…';
    loadComments();
  }
  function updateCharCount() {
    const b = document.getElementById('cf-cmt-body'), c = document.getElementById('cf-cmt-chars');
    if (b && c) c.textContent = (b.value || '').length + '/280';
  }
  function insertEmoji(ch) {
    const b = document.getElementById('cf-cmt-body'); if (!b || !ch) return;
    if ((b.value || '').length + ch.length > 280) return;   // respektera 280-taket (programmatisk insert kringgår maxlength)
    const s = (b.selectionStart != null) ? b.selectionStart : b.value.length;
    const e = (b.selectionEnd != null) ? b.selectionEnd : b.value.length;
    b.value = b.value.slice(0, s) + ch + b.value.slice(e);
    const pos = s + ch.length; b.focus(); try { b.setSelectionRange(pos, pos); } catch (_) {}
    updateCharCount();
  }
  function closeEmojiPop() { const p = document.getElementById('cf-emoji-pop'), b = document.getElementById('cf-emoji-btn'); if (p) p.classList.add('hidden'); if (b) b.classList.remove('on'); }
  function toggleEmojiPop() { const p = document.getElementById('cf-emoji-pop'), b = document.getElementById('cf-emoji-btn'); if (!p) return; const nowHidden = p.classList.toggle('hidden'); if (b) b.classList.toggle('on', !nowHidden); }
  // Stäng emoji-popovern vid klick utanför / Escape.
  document.addEventListener('click', (e) => {
    if (!e.target.closest('#cf-emoji-pop') && !e.target.closest('#cf-emoji-btn')) closeEmojiPop();
    if (!e.target.closest('.cf-cmt-menu') && !e.target.closest('[data-cmenu]')) closeCmtMenus();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeEmojiPop(); });
  async function postComment() {
    const bodyEl = document.getElementById('cf-cmt-body'), handleEl = document.getElementById('cf-cmt-handle');
    const msg = document.getElementById('cf-cmt-msg'), btn = document.getElementById('cf-cmt-post');
    if (!bodyEl) return;
    const text = (bodyEl.value || '').trim();
    if (!text) { bodyEl.focus(); return; }
    const id = scopeId();
    if (!id) { if (msg) { msg.textContent = 'Hang on — the concept is still saving. Try again in a moment.'; msg.style.color = '#ff6b9d'; } return; }
    if (btn) btn.disabled = true; if (msg) { msg.textContent = 'Posting…'; msg.style.color = ''; }
    try {
      const r = await fetch('/api/comments?scope=' + encodeURIComponent(id), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ handle: (handleEl && handleEl.value) || '', body: text, authorId: AUTHOR_ID }) });
      const j = await r.json();
      if (j.error) {
        const m = j.error === 'rate_limited' ? 'Whoa, slow down — too many posts. Try again shortly.' : j.error === 'blocked' ? 'That one tripped the filter.' : j.error === 'empty' ? 'Say something first.' : 'Could not post — try again.';
        if (msg) { msg.textContent = m; msg.style.color = '#ff6b9d'; }
      } else {
        bodyEl.value = ''; updateCharCount(); if (msg) msg.textContent = '';
        await loadComments();
      }
    } catch (e) { if (msg) { msg.textContent = 'Network hiccup — try again.'; msg.style.color = '#ff6b9d'; } }
    if (btn) btn.disabled = false;
  }
  async function voteComment(cid, scope) {
    const sc = scope || scopeId(); if (!sc) return;
    try { await fetch('/api/comments?scope=' + encodeURIComponent(sc) + '&vote=' + encodeURIComponent(cid), { method: 'POST' }); await loadComments(); } catch (e) {}
  }
  async function deleteComment(cid, scope) {
    const sc = scope || scopeId(); if (!sc || !MOD_TOKEN) return;
    try { await fetch('/api/comments?scope=' + encodeURIComponent(sc) + '&id=' + encodeURIComponent(cid) + '&token=' + encodeURIComponent(MOD_TOKEN), { method: 'DELETE' }); await loadComments(); } catch (e) {}
  }
  // ---- Egen kommentar: ⋯-meny (Edit / Delete) ----
  function closeCmtMenus() { document.querySelectorAll('#cf-cmt-list .cf-cmt-menu').forEach((m) => m.classList.add('hidden')); document.querySelectorAll('#cf-cmt-list .cf-cmt-menu-btn').forEach((b) => b.classList.remove('on')); }
  function toggleCmtMenu(id) {
    const menu = document.querySelector(`#cf-cmt-list .cf-cmt-menu[data-menu-for="${id}"]`);
    const btn = document.querySelector(`#cf-cmt-list .cf-cmt-menu-btn[data-cmenu="${id}"]`);
    const willOpen = menu && menu.classList.contains('hidden');
    closeCmtMenus();
    if (willOpen) { menu.classList.remove('hidden'); if (btn) btn.classList.add('on'); }
  }
  function startEditComment(id) { closeCmtMenus(); editingId = id; renderComments(lastCmtList); const ta = document.querySelector(`[data-cedit-body="${id}"]`); if (ta) { ta.focus(); try { ta.setSelectionRange(ta.value.length, ta.value.length); } catch (e) {} } }
  function cancelEditComment() { editingId = null; renderComments(lastCmtList); }
  async function saveEditComment(id, scope) {
    const ta = document.querySelector(`[data-cedit-body="${id}"]`); if (!ta) return;
    const text = (ta.value || '').trim(); if (!text) { ta.focus(); return; }
    const sc = scope || scopeId(); if (!sc) return;
    try {
      const r = await fetch('/api/comments?scope=' + encodeURIComponent(sc) + '&edit=' + encodeURIComponent(id), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ authorId: AUTHOR_ID, body: text }) });
      const j = await r.json();
      editingId = null;
      if (j && j.error) { renderComments(lastCmtList); } else { await loadComments(); }
    } catch (e) { editingId = null; renderComments(lastCmtList); }
  }
  async function deleteOwnComment(cid, scope) {
    const sc = scope || scopeId(); if (!sc) return;
    closeCmtMenus();
    try { await fetch('/api/comments?scope=' + encodeURIComponent(sc) + '&id=' + encodeURIComponent(cid) + '&author=' + encodeURIComponent(AUTHOR_ID), { method: 'DELETE' }); await loadComments(); } catch (e) {}
  }
  function initComments() {
    cmtScope = 'theme';
    const body = document.getElementById('cf-cmt-body');
    if (body) {
      body.addEventListener('input', updateCharCount);
      body.addEventListener('keydown', (e) => { if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) { e.preventDefault(); postComment(); } });
    }
    document.querySelectorAll('#cf-comments [data-cscope]').forEach((b) => b.classList.toggle('cf-ctab-on', b.dataset.cscope === 'theme'));
    updateCharCount();
    loadComments();
  }

  // ---------- Flows ----------
  async function generateFresh(theme) {
    lastTheme = theme; closeRecent(); startLoading();
    creditsPopupShown = false;   // en credits-ruta per generering
    let concept;
    try { const res = await fetch('/api/concept', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme }) }); concept = await res.json(); }
    catch (err) { stopLoading(); result.innerHTML = `<p class="text-stone-400">Something broke: ${esc(String(err))}. Try again.</p>`; result.classList.remove('hidden'); return; }
    stopLoading();
    if (concept && concept.limit) { showLimitPopup(); return; }
    if (concept && concept.creditsOut) { notifyCreditsOut('concept'); return; }   // hård fail: konceptet kunde inte genereras → vänlig ruta + galleri
    if (!concept || concept.note === 'error') { result.innerHTML = `<div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-6 text-stone-300">⚠️ Generation hiccupped${concept && concept.error ? ' (' + esc(concept.error) + ')' : ''}. Hit <strong class="text-[#c6ff00]">Forge it</strong> again.</div>`; result.classList.remove('hidden'); return; }
    if (!concept.theme) concept.theme = theme;
    initState(concept);
    buildResult(false);              // text + tomma slots syns direkt
    setSoundtrackMsg('Composing soundtrack with Suno…');
    // Bild, SFX och soundtrack hämtas parallellt och renderas var för sig när de blir klara.
    render('image', true);
    const jobs = [
      (async () => {
        const imageSize = state.aspect === '16:9' ? 'landscape_16_9' : 'square_hd';
        try { const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: state.imagePrompt, imageSize }) }); const j = await r.json(); if (j.url) pushVersion('image', { url: j.url, engine: j.engine }); else if (j.creditsOut) notifyCreditsOut('image'); } catch (e) {}
        render('image', false);
        // Auto-loop: animera key art till en attract-loop som spelas på BÅDE Mood och Game. Kostar Luma-credits
        // men gör varje koncept levande. Kör efter bilden (Luma animerar key art). Faller graciöst till statisk bild om det failar.
        if ((cur('image') || {}).url) {
          state.animBusy = true; render('image', false);
          const an = await fetchAnimation();
          state.animBusy = false;
          if (an) pushVersion('animation', an);
          render('image', false);
        }
      })(),
      (async () => { const sfx = await fetchSfx(); if (sfx.length) { state.versions.sfx = [sfx]; state.idx.sfx = 0; } renderSfx(); })(),
      (async () => { const st = await fetchSoundtrack(); if (st) { state.versions.soundtrack = [st]; state.idx.soundtrack = 0; renderSoundtrack(); autoplaySoundtrack(); } else renderSoundtrack(); })(),
      // Temade reel-symboler (billiga Flux schnell-ikoner) hämtas eagert så varje sparat koncept har en riktig
      // produktionslik rulle i Game-vyn (default) — inte bara A/K/Q/J/10. Re-renderar Game när de landar.
      (async () => { const syms = await fetchSymbols(); if (syms.length) { state.versions.symbols = [syms]; state.idx.symbols = 0; computeGrid(); if (state.visualMode === 'game') renderImage(false); } })(),
    ];
    await Promise.allSettled(jobs);
    persist();
  }

  // Autospela soundtracket på 50 % volym (nya sökningar + val ur Recent).
  function autoplaySoundtrack() {
    const a = document.querySelector('#soundtrack-slot audio');
    if (a) { a.volume = 0.5; a.play().catch(() => {}); }
  }
  async function loadSearch(id, opts = {}) {
    closeRecent();
    let data;
    try { const r = await fetch('/api/gallery?id=' + encodeURIComponent(id)); if (!r.ok) return; data = await r.json(); } catch (e) { return; }
    if (!data || !data.state) return;
    state = hydrate(Object.assign({ id: data.id }, data.state));
    lastTheme = state.theme || '';
    // featured + delad länk: håll sökfältet tomt så autocomplete + egen input funkar
    if (!opts.featured && !opts.share) input.value = state.theme || input.value;
    buildResult(true);
    if (opts.featured) {
      // Landnings-showcase: ingen ljud-autoplay, ingen scroll (hero ska synas), liten exempel-tagg
      const tag = document.createElement('div');
      tag.className = 'mb-3 flex flex-wrap items-center gap-2 text-xs text-stone-500';
      tag.innerHTML = '<span class="rounded-full border border-[#2a2a3a] px-2 py-0.5 font-semibold text-[#ff2d78]">✨ Example</span>';
      result.prepend(tag);
    } else if (opts.share) {
      // Ankom via delad länk: visa konceptet, scrolla dit, men starta inte ljud automatiskt
      window.scrollTo({ top: result.offsetTop - 20, behavior: 'smooth' });
    } else {
      autoplaySoundtrack();
      window.scrollTo({ top: result.offsetTop - 20, behavior: 'smooth' });
    }
  }

  // ---------- Upvote (en röst/IP, togglbar) + dela-länk ----------
  const hasVotedLocal = (id) => { try { return JSON.parse(localStorage.getItem('forge-voted') || '[]').includes(id); } catch (e) { return false; } };
  const persistVotedLocal = (id, on) => { try { const s = new Set(JSON.parse(localStorage.getItem('forge-voted') || '[]')); on ? s.add(id) : s.delete(id); localStorage.setItem('forge-voted', JSON.stringify([...s])); } catch (e) {} };
  function wireConceptActions() {
    const upBtn = document.getElementById('cf-upvote'), shareBtn = document.getElementById('cf-share'), countEl = document.getElementById('cf-votecount');
    if (!upBtn || !state) return;
    const id = state.id, theme = state.theme || '';
    const g = galleryList.find((m) => m.id === id);
    let votes = (g && g.votes) || 0, voted = hasVotedLocal(id);
    const apply = () => { countEl.textContent = votes; upBtn.classList.toggle('cf-voted', voted); };
    apply();
    // Reconcila mot servern (rätt antal + per-IP röst-status, täcker även delade-länk-besök)
    fetch('/api/vote?id=' + encodeURIComponent(id)).then((r) => r.json()).then((j) => {
      if (typeof j.votes === 'number') { votes = j.votes; voted = !!j.voted; apply(); persistVotedLocal(id, voted); const gg = galleryList.find((m) => m.id === id); if (gg) gg.votes = votes; }
    }).catch(() => {});
    upBtn.onclick = async () => {
      voted = !voted; votes = Math.max(0, votes + (voted ? 1 : -1)); apply(); persistVotedLocal(id, voted);   // optimistiskt
      try {
        const r = await fetch('/api/vote', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
        const j = await r.json();
        if (typeof j.votes === 'number') { votes = j.votes; voted = !!j.voted; apply(); persistVotedLocal(id, voted); const gg = galleryList.find((m) => m.id === id); if (gg) gg.votes = votes; }
      } catch (e) {}
    };
    shareBtn.onclick = async () => {
      const url = location.origin + '/forge?c=' + encodeURIComponent(id);
      try {
        if (navigator.share) { await navigator.share({ title: 'Concept Forge', text: theme ? ('“' + theme + '” on Concept Forge') : 'Concept Forge', url }); }
        else { await navigator.clipboard.writeText(url); const o = shareBtn.innerHTML; shareBtn.innerHTML = '✓ Copied'; setTimeout(() => { shareBtn.innerHTML = o; }, 1600); }
      } catch (e) {}
    };
  }
  // Förvalt koncept på landningen så nya besökare ser direkt vad Forge gör (laddas ur galleriet = gratis/direkt, ingen credit).
  const FEATURED_THEME = 'viking metal feast';   // "Mead & Mayhem" — curera bästa exemplet här; fallback = senaste i galleriet
  function loadFeatured() {
    if (!result.classList.contains('hidden')) return;   // något visas redan
    if (!galleryList.length) return;                     // tomt galleri (t.ex. :4321) → behåll tom hero
    const id = findCachedId(normalize(FEATURED_THEME)) || galleryList[0].id;
    if (id) loadSearch(id, { featured: true });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const theme = input.value.trim(); if (!theme) return;
    const id = findCachedId(normalize(theme));
    if (id) loadSearch(id); else generateFresh(theme);
  });

  document.getElementById('surprise').addEventListener('click', () => { input.value = SURPRISES[Math.floor(Math.random() * SURPRISES.length)]; form.requestSubmit(); });
  const chipsEl = document.getElementById('chips');
  function renderChips() {
    const pool = [...SURPRISES]; const pick = [];
    for (let i = 0; i < 12 && pool.length; i++) pick.push(pool.splice(Math.floor(Math.random() * pool.length), 1)[0]);
    chipsEl.innerHTML = pick.map((t) => `<button type="button" class="chip shrink-0 rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">${t}</button>`).join('');
    chipsEl.scrollLeft = 0;
  }
  chipsEl.addEventListener('click', (e) => { const c = e.target.closest('.chip'); if (c) { input.value = c.textContent; form.requestSubmit(); } });
  // ↻: shuffla alltid in en ny uppsättning förslag (chipsen scrollar själva via overflow-x).
  document.getElementById('chip-more').addEventListener('click', renderChips);
  renderChips();

  // ---------- Google-style autocomplete: dropdown vid fokus på tomt sökfält ----------
  // Recent (redan forgeade koncept ur galleriet) ligger överst — gratis att öppna, så de
  // promotar credits som redan spenderats. Därunder några färska förslag att forga.
  const acPanel = document.getElementById('ac-panel');
  const ICO_CLOCK = '<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 flex-shrink-0 text-stone-500"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 7.5V12l3 1.8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  const ICO_SEARCH = '<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 flex-shrink-0 text-stone-500"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="M20 20l-3.6-3.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>';
  function buildAc() {
    const recent = galleryList.slice(0, 8);
    const taken = new Set(recent.map((m) => normalize(m.theme || '')));
    const suggs = SURPRISES.filter((s) => !taken.has(normalize(s))).slice(0, 5);
    const row = (ico, label, attr, trail = '') => `<div class="ac-item flex items-center gap-3 rounded-lg px-3 py-2.5 cursor-pointer hover:bg-[#1d212c]" ${attr}>${ico}<span class="min-w-0 flex-1 truncate text-sm text-stone-200">${esc(label)}</span>${trail}</div>`;
    let html = recent.map((m) => row(ICO_CLOCK, m.theme, `data-id="${esc(m.id)}"`, `<span class="flex-none text-xs tabular-nums text-stone-500">▲ ${m.votes || 0}</span>`)).join('');
    if (recent.length && suggs.length) html += '<div class="my-1 border-t border-[#2a2a3a]"></div>';
    html += suggs.map((s) => row(ICO_SEARCH, s, `data-q="${esc(s)}"`)).join('');
    acPanel.innerHTML = html;
    acPanel.querySelectorAll('.ac-item').forEach((el) => el.addEventListener('mousedown', (ev) => {
      ev.preventDefault();  // håll kvar fokus så klicket hinner registreras före blur
      closeAc();
      if (el.dataset.id) loadSearch(el.dataset.id);
      else if (el.dataset.q) { input.value = el.dataset.q; form.requestSubmit(); }
    }));
  }
  function openAc() { if (input.value.trim()) return; buildAc(); if (acPanel.innerHTML.trim()) { stopRecentPulse(); acPanel.classList.remove('hidden'); } }
  function closeAc() { acPanel.classList.add('hidden'); }
  input.addEventListener('focus', openAc);
  input.addEventListener('input', () => { input.value.trim() ? closeAc() : openAc(); });
  input.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAc(); });
  document.addEventListener('click', (e) => { if (e.target !== input && !e.target.closest('#ac-panel')) closeAc(); });

  const shareId = new URL(location.href).searchParams.get('c');   // delad länk: /forge?c=<id>
  refreshGallery().then(() => { if (shareId) loadSearch(shareId, { share: true }); else loadFeatured(); });
</script>
