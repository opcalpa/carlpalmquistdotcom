---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Concept Forge — slot ideation engine"
  description="Type a vibe, get a complete slot game concept: name, art direction, mechanic, a music brief with a generated soundtrack, and marketing hooks. A demo by Carl Palmquist."
>
  <main class="min-h-screen bg-[#0a0a0f] text-stone-100 font-sans">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:py-12">

      <!-- Header -->
      <header class="mb-7">
        <p class="mb-3 inline-flex items-center gap-2 rounded-full border border-[#2a2a3a] bg-[#15151f] px-3 py-1 text-xs font-medium tracking-wide text-stone-400">
          <span class="h-1.5 w-1.5 rounded-full bg-[#c6ff00]"></span>
          A Carl Palmquist demo · slot ideation accelerator
        </p>
        <h1 class="text-5xl font-black uppercase leading-[0.95] tracking-tight sm:text-6xl">
          Concept <span class="text-[#c6ff00]">Forge</span>
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-400">
          Throw it a vibe. It hands back a complete game concept — names, art direction, mechanic,
          a <span class="font-semibold text-[#ff2d78]">music brief with a generated soundtrack</span>,
          and launch hooks. The slow part of a content factory is going from idea to greenlight.
          This compresses it to seconds.
        </p>
      </header>

      <!-- Input -->
      <form id="forge-form" class="mb-6">
        <div class="flex flex-col gap-3 sm:flex-row">
          <input
            id="theme"
            type="text"
            autocomplete="off"
            placeholder="neon yakuza with a country vibe…"
            class="flex-1 rounded-xl border border-[#2a2a3a] bg-[#15151f] px-4 py-3.5 text-lg text-stone-100 placeholder-stone-500 outline-none focus:border-[#c6ff00]"
          />
          <button
            id="generate"
            type="submit"
            class="rounded-xl bg-[#c6ff00] px-7 py-3.5 text-lg font-black uppercase tracking-tight text-black transition hover:bg-[#d6ff3a] disabled:opacity-50"
          >
            Forge it
          </button>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
          <button type="button" id="surprise" class="text-[#ff2d78] hover:underline">⚡ Surprise me</button>
          <span class="text-stone-600">·</span>
          <span class="text-stone-500">try:</span>
          <button type="button" class="chip rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">haunted disco</button>
          <button type="button" class="chip rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">viking metal feast</button>
          <button type="button" class="chip rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">deep sea treasure cult</button>
          <div class="relative ml-auto" id="recent-wrap">
            <button type="button" id="recent-btn" class="rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">⟲ Recent <span id="recent-count" class="text-stone-500"></span> ▾</button>
            <div id="recent-panel" class="hidden absolute right-0 z-20 mt-2 w-80 max-h-96 overflow-auto rounded-xl border border-[#2a2a3a] bg-[#15151f] p-2 shadow-2xl"></div>
          </div>
        </div>
      </form>

      <!-- Loading -->
      <div id="loading" class="hidden py-16 text-center">
        <div class="mx-auto mb-4 h-8 w-8 animate-spin rounded-full border-2 border-[#2a2a3a] border-t-[#c6ff00]"></div>
        <p id="loading-msg" class="text-stone-400">Sketching characters…</p>
      </div>

      <!-- Results -->
      <section id="result" class="hidden"></section>

      <!-- Footer note -->
      <footer class="mt-14 border-t border-[#1c1c28] pt-6 text-xs leading-relaxed text-stone-500">
        <p><span class="font-semibold text-stone-400">Ideation accelerator, not an art generator.</span>
        It produces direction and briefs for humans to refine — the model never ships the final asset.
        That keeps it on the right side of regulatory art audits.</p>
        <p class="mt-2">Built with Claude Code in an evening and deployed on this site. — Carl Palmquist</p>
      </footer>
    </div>
  </main>
</Layout>

<style is:global>
  .cf-tab {
    display: inline-block; padding: 7px 13px; border-radius: 9px; font-size: 12px;
    font-weight: 800; letter-spacing: -0.01em; text-transform: uppercase;
    border: 1px solid #2a2a3a; color: #d6d3d1; background: transparent; cursor: pointer;
  }
  .cf-tab:hover { border-color: #c6ff00; }
  .cf-tab.active { background: #c6ff00; color: #000; border-color: #c6ff00; }
</style>

<script is:inline>
  const form = document.getElementById('forge-form');
  const input = document.getElementById('theme');
  const btn = document.getElementById('generate');
  const loading = document.getElementById('loading');
  const loadingMsg = document.getElementById('loading-msg');
  const result = document.getElementById('result');
  const recentBtn = document.getElementById('recent-btn');
  const recentPanel = document.getElementById('recent-panel');
  const recentCount = document.getElementById('recent-count');

  const SURPRISES = [
    'neon yakuza synthwave heist', 'haunted disco inferno', 'viking metal feast',
    'deep sea treasure cult', 'cyberpunk samurai noodle bar', 'wild west bank robbery at dawn',
    'baroque vampire opera', 'arctic monster hunt', 'lucha libre luchador showdown',
    'egyptian afterlife game show', 'jurassic jungle bounty', 'voodoo new orleans jazz funeral',
  ];
  const LOADING_MSGS = [
    'Sketching characters…', 'Inking the key art…', 'Designing the bonus round…',
    'Stress-testing the max win…', 'Writing the launch hooks…',
  ];

  const esc = (s) => String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  const normalize = (s) => String(s || '').trim().toLowerCase().replace(/\s+/g, ' ');

  let lastTheme = '';

  // ---------- History / cache (localStorage) ----------
  const HKEY = 'cf:hist';
  const RKEY = (id) => 'cf:res:' + id;
  const CAP = 24;
  const loadHist = () => { try { return JSON.parse(localStorage.getItem(HKEY) || '[]'); } catch { return []; } };
  const resGet = (id) => { try { return JSON.parse(localStorage.getItem(RKEY(id)) || 'null'); } catch { return null; } };
  const resDel = (id) => { try { localStorage.removeItem(RKEY(id)); } catch {} };

  function findCachedId(key) {
    const hist = loadHist();
    const m = hist.find((h) => h.key === key);
    return m && resGet(m.id) ? m.id : null;
  }

  function addEntry(theme, concept, audio) {
    const id = 'e' + Date.now();
    const meta = { id, theme, key: normalize(theme), ts: Date.now(), thumb: concept.image_url || '' };
    const hist = loadHist();
    hist.unshift(meta);
    while (hist.length > CAP) { const o = hist.pop(); resDel(o.id); }
    let stored = false, tries = 0;
    while (!stored && tries < 10) {
      try { localStorage.setItem(RKEY(id), JSON.stringify({ theme, concept, audio })); stored = true; }
      catch (e) {
        let evicted = false;
        for (let i = hist.length - 1; i >= 0; i--) { if (hist[i].id !== id) { resDel(hist[i].id); hist.splice(i, 1); evicted = true; break; } }
        if (!evicted) break;
      }
      tries++;
    }
    try { localStorage.setItem(HKEY, JSON.stringify(hist)); } catch {}
    renderRecent();
  }

  function delEntry(id) {
    const hist = loadHist().filter((h) => h.id !== id);
    resDel(id);
    try { localStorage.setItem(HKEY, JSON.stringify(hist)); } catch {}
    renderRecent();
  }

  function clearHist() {
    loadHist().forEach((h) => resDel(h.id));
    try { localStorage.removeItem(HKEY); } catch {}
    renderRecent();
  }

  function timeAgo(ts) {
    const s = Math.floor((Date.now() - ts) / 1000);
    if (s < 60) return 'just now';
    if (s < 3600) return Math.floor(s / 60) + 'm ago';
    if (s < 86400) return Math.floor(s / 3600) + 'h ago';
    return Math.floor(s / 86400) + 'd ago';
  }

  function renderRecent() {
    const hist = loadHist();
    recentCount.textContent = hist.length ? '(' + hist.length + ')' : '';
    if (!hist.length) {
      recentPanel.innerHTML = '<p class="px-2 py-3 text-xs text-stone-500">No history yet. Forge something.</p>';
      return;
    }
    recentPanel.innerHTML = hist.map((m) => `
      <div class="recent-item flex items-center gap-2 rounded-lg px-2 py-1.5 hover:bg-[#1d212c] cursor-pointer" data-id="${esc(m.id)}">
        ${m.thumb ? `<img src="${esc(m.thumb)}" class="h-9 w-9 flex-shrink-0 rounded object-cover" />` : '<div class="h-9 w-9 flex-shrink-0 rounded bg-[#222]"></div>'}
        <div class="min-w-0 flex-1">
          <div class="truncate text-sm text-stone-200">${esc(m.theme)}</div>
          <div class="text-[10px] text-stone-500">${timeAgo(m.ts)}</div>
        </div>
        <button class="flex-shrink-0 px-1 text-stone-600 hover:text-[#ff2d78]" data-del="${esc(m.id)}" title="Remove">✕</button>
      </div>`).join('') +
      `<div class="mt-1 border-t border-[#2a2a3a] pt-1"><button id="recent-clear" class="w-full rounded-lg px-2 py-1.5 text-left text-xs text-stone-500 hover:text-[#ff2d78]">Clear all</button></div>`;
    recentPanel.querySelectorAll('.recent-item').forEach((el) => {
      el.addEventListener('click', (ev) => { if (ev.target.closest('[data-del]')) return; loadCachedById(el.dataset.id); });
    });
    recentPanel.querySelectorAll('[data-del]').forEach((b) => {
      b.addEventListener('click', (ev) => { ev.stopPropagation(); delEntry(b.dataset.del); });
    });
    const clr = document.getElementById('recent-clear');
    if (clr) clr.addEventListener('click', clearHist);
  }

  const closeRecent = () => recentPanel.classList.add('hidden');
  recentBtn.addEventListener('click', (e) => { e.stopPropagation(); recentPanel.classList.toggle('hidden'); });
  document.addEventListener('click', (e) => { if (!e.target.closest('#recent-wrap')) closeRecent(); });

  // ---------- UI helpers ----------
  document.getElementById('surprise').addEventListener('click', () => {
    input.value = SURPRISES[Math.floor(Math.random() * SURPRISES.length)];
    form.requestSubmit();
  });
  document.querySelectorAll('.chip').forEach((c) =>
    c.addEventListener('click', () => { input.value = c.textContent; form.requestSubmit(); })
  );

  let msgTimer;
  function startLoading() {
    result.classList.add('hidden');
    loading.classList.remove('hidden');
    btn.disabled = true;
    let i = 0;
    loadingMsg.textContent = LOADING_MSGS[0];
    msgTimer = setInterval(() => { i = (i + 1) % LOADING_MSGS.length; loadingMsg.textContent = LOADING_MSGS[i]; }, 1500);
  }
  function stopLoading() { clearInterval(msgTimer); loading.classList.add('hidden'); btn.disabled = false; }

  function rows(pairs) {
    return pairs.filter((r) => r[1]).map((r) =>
      `<div class="mb-3 last:mb-0"><dt class="text-[11px] uppercase tracking-wide text-stone-500">${esc(r[0])}</dt><dd class="mt-0.5 text-sm leading-relaxed text-stone-200">${esc(r[1])}</dd></div>`
    ).join('');
  }

  function buildResult(c, fromCache) {
    const names = Array.isArray(c.names) ? c.names : [];
    const primary = names[0] || 'Untitled';
    const alts = names.slice(1);
    const art = c.art || {}, mech = c.mechanic || {}, math = c.math || {}, music = c.music || {};
    const hooks = Array.isArray(c.hooks) ? c.hooks : [];

    const tabs = [
      ['art', 'Art direction', rows([['Style', art.style], ['Palette', art.palette], ['Hero characters', art.hero_characters], ['Mood', art.mood]])],
      ['mech', 'Mechanic', rows([['Base game', mech.base_game], ['Signature feature', mech.signature_feature], ['Bonus round', mech.bonus_round], ['Volatility', math.volatility], ['Suggested max win', math.suggested_max_win]])],
      ['music', 'Music & audio', rows([['Genre', music.genre], ['Instrumentation', music.instrumentation], ['Base vs bonus', music.base_vs_bonus], ['Tempo', music.bpm], ['Reference vibe', music.reference_vibe]])],
      ['hooks', 'Hooks', `<ul class="space-y-2.5">${hooks.map((h) => `<li class="flex gap-2 text-sm leading-relaxed text-stone-200"><span class="text-[#c6ff00]">▸</span><span>${esc(h)}</span></li>`).join('')}</ul>`],
    ];

    const imageBlock = c.image_url
      ? `<img src="${esc(c.image_url)}" alt="Moodboard for ${esc(primary)}" class="aspect-square w-full rounded-2xl border border-[#22222e] object-cover" />`
      : `<div class="flex aspect-square w-full items-center justify-center rounded-2xl border border-dashed border-[#2a2a3a] bg-[#13131c] p-6 text-center text-xs text-stone-500">Moodboard prompt ready, image API not wired in this run.<br/><span class="mt-2 block text-stone-600">${esc(c.image_prompt || '')}</span></div>`;

    const strip = fromCache
      ? `<div class="mb-3 flex items-center gap-3 text-xs"><span class="rounded-full bg-[#c6ff00]/15 px-2.5 py-1 font-semibold text-[#c6ff00]">⚡ From cache · no credits used</span><button id="regen-btn" type="button" class="text-stone-400 hover:text-[#ff2d78]">↻ Generate fresh</button></div>`
      : `<div class="mb-3 text-xs"><span class="rounded-full bg-[#1d212c] px-2.5 py-1 text-stone-400">✓ Saved · re-running this vibe is free</span></div>`;

    const engineLine = c.engine ? `<p class="mt-6 text-xs text-stone-500">${[
      'Concept by ' + esc(c.engine),
      c.image_url && c.engine_image ? 'art by ' + esc(c.engine_image) : '',
      'SFX by ElevenLabs',
    ].filter(Boolean).join(' &nbsp;·&nbsp; ')} &nbsp;—&nbsp; right model for each step.</p>` : '';

    result.innerHTML = `
      ${strip}
      <div class="mb-4 flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <h2 class="text-4xl font-black uppercase tracking-tight text-[#c6ff00] sm:text-5xl">${esc(primary)}</h2>
        ${alts.map((n) => `<span class="rounded-full border border-[#2a2a3a] px-3 py-1 text-sm text-stone-400">${esc(n)}</span>`).join('')}
      </div>
      <p class="mb-6 max-w-3xl text-lg italic text-stone-300">“${esc(c.logline || '')}”</p>

      <div class="grid items-start gap-5 lg:grid-cols-[minmax(0,44%)_1fr]">
        <div class="space-y-4 lg:sticky lg:top-5 self-start">
          ${imageBlock}
          <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-4">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">🎵 Soundtrack</span>
              <span id="st-engine" class="text-[10px] text-stone-600"></span>
            </div>
            <div id="soundtrack-slot"><div class="flex items-center gap-2 py-2 text-xs text-stone-500"><span class="h-3 w-3 animate-spin rounded-full border-2 border-[#2a2a3a] border-t-[#ff2d78]"></span> Composing soundtrack…</div></div>
            <div class="mt-4 mb-2 text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">SFX</div>
            <div id="sfx-slot"><div class="py-1 text-xs text-stone-500">Generating sound effects…</div></div>
          </div>
        </div>

        <div>
          <div class="mb-4 flex flex-wrap gap-2">
            ${tabs.map((t, i) => `<button class="cf-tab${i === 0 ? ' active' : ''}" data-tab="${t[0]}">${esc(t[1])}</button>`).join('')}
          </div>
          <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-6" style="min-height:420px">
            ${tabs.map((t, i) => `<div data-panel="${t[0]}" class="${i === 0 ? '' : 'hidden'}"><dl>${t[2]}</dl></div>`).join('')}
          </div>
        </div>
      </div>
      ${engineLine}
      ${c.note ? `<p class="mt-2 text-xs text-stone-600">${c.note === 'no_api_key' ? 'Showing a curated sample (no API key set yet).' : c.note === 'fallback' ? 'API hiccup — showing a curated sample.' : ''}</p>` : ''}`;

    result.classList.remove('hidden');

    result.querySelectorAll('[data-tab]').forEach((b) => {
      b.addEventListener('click', () => {
        const t = b.dataset.tab;
        result.querySelectorAll('[data-tab]').forEach((x) => x.classList.toggle('active', x.dataset.tab === t));
        result.querySelectorAll('[data-panel]').forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== t));
      });
    });
    const regen = document.getElementById('regen-btn');
    if (regen) regen.addEventListener('click', () => { if (lastTheme) generateFresh(lastTheme); });
  }

  function fillSoundtrack(url, engine, note) {
    const st = document.getElementById('soundtrack-slot');
    const stEng = document.getElementById('st-engine');
    if (stEng) stEng.textContent = engine || '';
    if (!st) return;
    st.innerHTML = url
      ? `<audio controls src="${esc(url)}" class="w-full"></audio>`
      : `<p class="text-xs text-stone-600">Soundtrack unavailable${note === 'no_eleven_key' ? ' (no key set)' : ' — hit ↻ Generate fresh'}.</p>`;
  }

  function setSoundtrackMsg(t) {
    const st = document.getElementById('soundtrack-slot');
    if (st) st.innerHTML = `<div class="flex items-center gap-2 py-2 text-xs text-stone-500"><span class="h-3 w-3 animate-spin rounded-full border-2 border-[#2a2a3a] border-t-[#ff2d78]"></span> ${esc(t)}</div>`;
  }

  function fillSfx(sfx) {
    const fx = document.getElementById('sfx-slot');
    if (!fx) return;
    if (!(sfx && sfx.length)) { fx.innerHTML = `<p class="text-xs text-stone-600">No SFX generated.</p>`; return; }
    // Kompakta runda play-knappar — SFX är korta, ingen scrubber behövs.
    fx.innerHTML = `<div class="flex flex-wrap gap-2">${sfx.map((s, i) => `
      <button type="button" class="sfx-chip inline-flex items-center gap-2 rounded-full border border-[#2a2a3a] bg-[#15151f] py-1 pl-1 pr-3 text-xs text-stone-300 hover:border-[#ff2d78]" data-sfx="${i}">
        <span class="sfx-ic flex h-6 w-6 items-center justify-center rounded-full bg-[#ff2d78] text-[11px] text-black">▶</span>
        <span>${esc(s.label)}</span>
      </button>
      <audio data-sfxaudio="${i}" src="${esc(s.url)}" preload="none"></audio>`).join('')}</div>`;
    const auds = fx.querySelectorAll('audio[data-sfxaudio]');
    const reset = () => { auds.forEach((o) => { o.pause(); o.currentTime = 0; }); fx.querySelectorAll('.sfx-ic').forEach((x) => (x.textContent = '▶')); };
    fx.querySelectorAll('.sfx-chip').forEach((chip) => {
      const i = chip.dataset.sfx;
      const au = fx.querySelector(`audio[data-sfxaudio="${i}"]`);
      const ic = chip.querySelector('.sfx-ic');
      chip.addEventListener('click', () => {
        const wasPlaying = !au.paused;
        reset();
        if (wasPlaying) return;
        au.play(); ic.textContent = '⏸';
        au.onended = () => { ic.textContent = '▶'; };
      });
    });
  }

  // Cache-hit: fyll båda direkt från sparad data.
  function fillAudio(a) {
    a = a || {};
    fillSoundtrack(a.soundtrack_url, a.soundtrack_engine, a.note);
    fillSfx(a.sfx);
  }

  async function loadSfx(concept) {
    let sfx = [];
    try {
      const r = await fetch('/api/audio', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sfx: concept.sfx }) });
      const j = await r.json();
      sfx = j.sfx || [];
    } catch (e) {}
    fillSfx(sfx);
    return sfx;
  }

  async function pollSuno(taskId) {
    const maxMs = 120000, interval = 4000;
    let waited = 0;
    while (waited < maxMs) {
      await new Promise((r) => setTimeout(r, interval));
      waited += interval;
      setSoundtrackMsg('Composing soundtrack with Suno… ' + Math.floor(waited / 1000) + 's');
      try {
        const r = await fetch('/api/soundtrack?taskId=' + encodeURIComponent(taskId));
        const j = await r.json();
        if (j.status === 'done' && j.url) return j.url;
        if (j.status === 'failed') return null;
      } catch (e) {}
    }
    return null;
  }

  async function loadSoundtrack(concept) {
    const prompt = concept.soundtrack_prompt || concept.theme || '';
    if (!prompt) { fillSoundtrack(null, null); return { url: null, engine: null }; }
    // Suno primär
    try {
      setSoundtrackMsg('Composing soundtrack with Suno…');
      const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt }) });
      const j = await r.json();
      if (j.taskId) {
        const url = await pollSuno(j.taskId);
        if (url) { fillSoundtrack(url, 'Suno V5'); return { url, engine: 'Suno V5' }; }
      }
    } catch (e) {}
    // fal fallback
    setSoundtrackMsg('Composing soundtrack…');
    try {
      const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt, engine: 'fal' }) });
      const j = await r.json();
      if (j.url) { fillSoundtrack(j.url, j.engine || 'Stable Audio (fal.ai)'); return { url: j.url, engine: j.engine }; }
    } catch (e) {}
    fillSoundtrack(null, null);
    return { url: null, engine: null };
  }

  async function generateFresh(theme) {
    lastTheme = theme;
    closeRecent();
    startLoading();
    let concept;
    try {
      const res = await fetch('/api/concept', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme }) });
      concept = await res.json();
    } catch (err) {
      stopLoading();
      result.innerHTML = `<p class="text-stone-400">Something broke: ${esc(String(err))}. Try again.</p>`;
      result.classList.remove('hidden');
      return;
    }
    stopLoading();
    buildResult(concept, false);
    const [sfx, st] = await Promise.all([loadSfx(concept), loadSoundtrack(concept)]);
    addEntry(theme, concept, { sfx, soundtrack_url: st.url, soundtrack_engine: st.engine });
  }

  function loadCachedById(id) {
    const data = resGet(id);
    if (!data) return;
    lastTheme = data.theme || '';
    input.value = data.theme || input.value;
    closeRecent();
    buildResult(data.concept, true);
    fillAudio(data.audio);
    window.scrollTo({ top: result.offsetTop - 20, behavior: 'smooth' });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const theme = input.value.trim();
    if (!theme) return;
    const id = findCachedId(normalize(theme));
    if (id) loadCachedById(id);
    else generateFresh(theme);
  });

  renderRecent();
</script>
