    return null;
  }

  // ---------- Game-mockup: kodat reel-grid (struktur i HTML/CSS, AI-symboler droppas in) ----------
  const LETTERS = ['A', 'K', 'Q', 'J', '10'];
  function hashHue(s) { let h = 0; s = String(s || ''); for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0; return h % 360; }
  function gridDims() {
    const m = (cur('mechanic') || {}).mechanic || {};
    const g = String(m.grid || '').match(/(\d+)\s*[x×]\s*(\d+)/i);
    let cols = 5, rows = 4;
    if (g) { cols = Math.min(7, Math.max(3, +g[1])); rows = Math.min(6, Math.max(3, +g[2])); }
    return { cols, rows };
  }
  // Bygg cell-arrangemanget en gång (stabilt mellan renders) — SPIN reshufflar.
  // ~45 % av cellerna blir temade symboler (jämnt fördelat), resten stiliserade bokstavsbrickor.
  function computeGrid() {
    const { cols, rows } = gridDims();
    const total = cols * rows;
    const syms = (cur('symbols') || []).filter((s) => s && s.url);
    const pool = [];
    if (syms.length) {
      const per = Math.max(2, Math.round((total * 0.45) / syms.length));
      syms.forEach((s) => { for (let k = 0; k < per; k++) pool.push({ t: 's', url: s.url, label: s.label }); });
    }
    let li = 0;
    while (pool.length < total) pool.push({ t: 'l', ch: LETTERS[li++ % LETTERS.length] });
    for (let i = pool.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); const tmp = pool[i]; pool[i] = pool[j]; pool[j] = tmp; }
    state.grid = { cols, rows, cells: pool.slice(0, total) };
  }
  function volBars(v) {
    const map = { 'low': 2, 'medium': 3, 'med': 3, 'high': 4, 'very high': 5, 'extreme': 5 };
    const n = map[String(v || '').trim().toLowerCase()] || 4;
    let s = ''; for (let i = 0; i < 5; i++) s += `<i class="${i < n ? 'on' : ''}"></i>`; return s;
  }
  function buildMockupHTML() {
    if (!state.grid) computeGrid();
    const g = state.grid; if (!g) return '';
    const name = (cur('title') || {}).names && (cur('title').names[0]) || state.theme || 'Untitled';
    const m = cur('mechanic') || { mechanic: {}, math: {} };
    const buy = (m.mechanic || {}).bonus_buy || '', vol = (m.math || {}).volatility;
    const hue = hashHue(state.theme);
    const bg = (cur('image') || {}).url;   // key art = mood-miljö + karaktär bakom hjulen
    const cells = g.cells.map((c) => c.t === 's'
      ? `<div class="cf-cell"><img src="${esc(c.url)}" alt="${esc(c.label)}" loading="lazy" onerror="this.parentNode.classList.add('cf-letter');this.parentNode.textContent='★'" /></div>`
      : `<div class="cf-cell cf-letter">${esc(c.ch)}</div>`).join('');
    return `<div class="cf-slot" style="--hue:${hue}">
      ${bg ? `<div class="cf-slot-bg" style="background-image:url('${esc(bg)}')"></div><div class="cf-slot-scrim"></div>` : `<div class="cf-slot-fallbg"></div>`}
      <div class="cf-slot-inner">
        <div class="cf-slot-top">
          <span class="cf-slot-title">${esc(name)}</span>
          ${state.featureName ? `<span class="cf-slot-feat">⚡ ${esc(state.featureName)}</span>` : ''}
        </div>
        <div class="cf-reels">
          <div class="cf-frame"><div class="cf-grid${state.spinning ? ' cf-spinning' : ''}" style="grid-template-columns:repeat(${g.cols},1fr);grid-template-rows:repeat(${g.rows},1fr)">${cells}</div></div>
        </div>
        <div class="cf-hud">
          <span class="cf-ic">☰</span>
          ${buy ? `<div class="cf-buy">Buy<b>Bonus</b><span style="font-size:8px">${esc(buy)}</span></div>` : ''}
          <div class="cf-meter"><span>Balance</span><b>10,000</b></div>
          <div class="cf-meter"><span>Volatility</span><span class="cf-vol">${volBars(vol)}</span></div>
          <div class="cf-bet"><span class="cf-step">−</span><div class="cf-meter" style="align-items:center"><span>Bet</span><b>2.00</b></div><span class="cf-step">+</span></div>
          <button class="cf-spinbtn${state.spinning ? ' cf-spinning' : (state.spun ? '' : ' cf-invite')}" data-spin title="Spin">⟳</button>
          <span class="cf-ic">A</span>
        </div>
      </div>
    </div>`;
  }
  let spinTimer, spinCount = 0;
  // Hitta ett SFX på etikett-nyckelord (Reel spin / Bonus trigger / Big win), med index-reserv.
  function sfxByHint(hint, fallbackIdx) {
    const list = cur('sfx') || [];
    return list.find((s) => s && (s.label || '').toLowerCase().includes(hint)) || list[fallbackIdx] || null;
  }
  function playSfxObj(s, delay) {
    if (!s || !s.url) return;
    const fire = () => { try { const a = new Audio(s.url); a.volume = 0.6; a.play().catch(() => {}); } catch (e) {} };
    delay ? setTimeout(fire, delay) : fire();
  }
  function spinMockup() {
    if (state.spinning) return;
    state.spun = true; stopViewAuto();   // Play/SPIN = aktivt val av Game → lås vyn (slutar auto-rotera, precis som Game-knappen)
    state.spinning = true; spinCount++; computeGrid(); renderImage(false);
    // Eskalerande utfall: reel varje snurr, bonus varannan, big win vart fjärde — lätt staggrat.
    playSfxObj(sfxByHint('spin', 0));
    if (spinCount % 2 === 0) playSfxObj(sfxByHint('bonus', 1), 180);
    if (spinCount % 4 === 0) playSfxObj(sfxByHint('big', 2), 360);
    clearTimeout(spinTimer);
    spinTimer = setTimeout(() => { state.spinning = false; renderImage(false); }, 440);
  }
  async function fetchSymbols() {
    const prompts = state.symbolPrompts || [];
    if (!prompts.length) return [];
    try { const r = await fetch('/api/symbols', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ symbols: prompts }) }); const j = await r.json(); return Array.isArray(j.symbols) ? j.symbols : []; } catch (e) { return []; }
  }
  // Lazy: symbolerna genereras först när man öppnar Game-vyn (spar credits vid vanlig forge).
  async function ensureSymbols() {
    if (state.symbolsBusy) return;
    if ((cur('symbols') || []).length) return;          // redan genererade
    if (!(state.symbolPrompts || []).length) return;    // inget att generera
    state.symbolsBusy = true; renderImage(false);
    const syms = await fetchSymbols();
    if (syms.length) { state.versions.symbols = [syms]; state.idx.symbols = 0; }
    state.symbolsBusy = false; computeGrid();
    if (state.visualMode === 'game') renderImage(false);
    persist();
  }
  async function reshapeSoundtrack() {
    const more = (document.getElementById('st-more') || {}).value || '';
    const less = (document.getElementById('st-less') || {}).value || '';
    const steer = [more.trim() ? 'more: ' + more.trim() : '', less.trim() ? 'less: ' + less.trim() : ''].filter(Boolean).join('; ');
    if (!steer) return;
    render('soundtrack', true); setSoundtrackMsg('Reshaping soundtrack…');
    const st = await fetchSoundtrack(steer); if (st) pushVersion('soundtrack', st);
    render('soundtrack', false); persist();
  }

  // ---------- Refresh / nav ----------
  async function refresh(comp) {
    if (comp === 'animation') state.animBusy = true;
    if (comp === 'gameview') state.gameBusy = true;
    if (comp === 'symbols') { state.symbolsBusy = true; state.visualMode = 'game'; }
    render(comp, true);
    try {
      if (['title', 'art', 'mechanic', 'music', 'hooks'].includes(comp)) {
        const r = await fetch('/api/section', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme: state.theme, section: comp, concept: flatConcept() }) });
        const j = await r.json();
        if (!j.error) {
          if (comp === 'title') pushVersion('title', { names: j.names || [], logline: j.logline || '' });
          else if (comp === 'art') pushVersion('art', j.art || {});
          else if (comp === 'mechanic') pushVersion('mechanic', { mechanic: j.mechanic || {}, math: j.math || {} });
          else if (comp === 'music') pushVersion('music', { music: j.music || {}, soundtrack_prompt: j.soundtrack_prompt || '', sfxPrompts: j.sfx || [] });
          else if (comp === 'hooks') pushVersion('hooks', j.hooks || []);
        }
      } else if (comp === 'image') {
        const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: state.imagePrompt }) });
        const j = await r.json(); if (j.url) pushVersion('image', { url: j.url, engine: j.engine });
      } else if (comp === 'soundtrack') {
        const st = await fetchSoundtrack(); if (st) pushVersion('soundtrack', st);
      } else if (comp === 'sfx') {
        const sfx = await fetchSfx(); if (sfx.length) pushVersion('sfx', sfx);
      } else if (comp === 'animation') {
        const an = await fetchAnimation(); if (an) { pushVersion('animation', an); state.visualMode = 'loop'; }
      } else if (comp === 'gameview') {
        const g = await fetchGameview();
        if (g) { pushVersion('gameview', g); state.visualMode = 'game'; }
        else { pushVersion('gameview', { url: null }); state.visualMode = 'mood'; }   // blockerad → rensa ev. svart, flippa till Mood
      } else if (comp === 'symbols') {
        const syms = await fetchSymbols();
        if (syms.length) { pushVersion('symbols', syms); computeGrid(); }
        state.visualMode = 'game';
      }
    } catch (e) {}
    state.animBusy = false; state.gameBusy = false; state.symbolsBusy = false;
    render(comp, false);
    persist();
  }
  function nav(comp, d) {
    const n = state.versions[comp].length; let i = state.idx[comp] + d;
    i = Math.max(0, Math.min(n - 1, i)); state.idx[comp] = i; render(comp, false);
  }

  // ---------- Persist ----------
  // Liten, varaktig tumnagel (64px JPEG data-URI) från nuvarande key art → galleri-indexet.
  // Funkar på data:-bilder (inlinade, same-origin) och CORS-vänliga URL:er; faller mjukt till null.
  async function makeThumb() {
    const im = cur('image'); if (!im || !im.url) return null;
    try {
      const img = new Image(); img.crossOrigin = 'anonymous';
      await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = im.url; });
      const cv = document.createElement('canvas'); cv.width = 64; cv.height = 64;
      cv.getContext('2d').drawImage(img, 0, 0, 64, 64);
      return cv.toDataURL('image/jpeg', 0.7);
    } catch (e) { return null; }
  }
  async function persist() {
    let thumb = null; try { thumb = await makeThumb(); } catch (e) {}
    try {
      const r = await fetch('/api/gallery', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: state.id, theme: state.theme, thumb, state: { theme: state.theme, imagePrompt: state.imagePrompt, conceptEngine: state.conceptEngine, featureName: state.featureName, featureIntro: state.featureIntro, symbolPrompts: state.symbolPrompts, versions: state.versions, idx: state.idx } }) });
      const j = await r.json(); if (j.id) state.id = j.id;
    } catch (e) {}
    refreshGallery();
  }

  // ---------- Build skeleton ----------
  function buildResult(fromCache) {
    // Samma rad oavsett om resultatet är nytt eller hämtat ur galleriet — användaren ska aldrig
    // behöva tänka på cache-state. En tydlig re-roll (samma tema, ny tolkning) finns alltid.
    const strip = `<div class="mb-3 flex items-center gap-3 text-xs"><button id="regen-btn" type="button" class="inline-flex items-center gap-1.5 rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 transition hover:border-[#ff2d78] hover:text-[#ff2d78]">↻ Re-roll this theme</button><span class="text-stone-600">Images, audio &amp; versions are saved automatically</span></div>`;
    const tabs = [['tldr', 'TL;DR'], ['art', 'Art direction'], ['mechanic', 'Mechanic'], ['music', 'Music & audio'], ['hooks', 'Hooks']];
    result.innerHTML = `
      ${strip}
      <div id="cf-title" class="mb-4"></div>
      <div class="grid items-stretch gap-5 lg:grid-cols-[minmax(0,44%)_1fr]">
        <div id="cf-image" class="lg:col-start-1 lg:row-start-1"></div>
        <div class="flex min-h-0 flex-col lg:col-start-2 lg:row-start-1">
          <div class="mb-3 flex flex-wrap gap-2">${tabs.map((t, i) => `<button class="cf-tab${i === 0 ? ' active' : ''}" data-tab="${t[0]}">${esc(t[1])}</button>`).join('')}</div>
          <div data-panelbox class="cf-scrollfade no-scrollbar min-h-0 flex-1 overflow-auto rounded-2xl border border-[#22222e] bg-[#13131c] p-6">
            ${tabs.map((t, i) => `<div data-panel="${t[0]}" class="${i === 0 ? '' : 'hidden'}"><div id="cf-panel-${t[0]}"></div></div>`).join('')}
          </div>
        </div>
        <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-4 lg:col-start-1 lg:row-start-2">
          <div class="mb-2 flex items-center justify-between">
            <span class="text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">🎵 Soundtrack</span>
            <span class="flex items-center gap-2"><span id="st-engine" class="text-[10px] text-stone-600"></span><span id="cf-st-ctrl"></span></span>
          </div>
          <div id="soundtrack-slot"></div>
        </div>
        <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-4 lg:col-start-2 lg:row-start-2">
          <div class="mb-2 flex items-center justify-between"><span class="text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">🔊 SFX</span><span id="cf-sfx-ctrl"></span></div>
          <div id="sfx-slot"></div>
        </div>
      </div>
      <p id="cf-engine" class="mt-6 text-xs text-stone-500"></p>`;
    renderAll();
    result.classList.remove('hidden');
    requestAnimationFrame(syncPanelHeight);
    const regen = document.getElementById('regen-btn');
    if (regen) regen.addEventListener('click', () => { if (state && state.theme) generateFresh(state.theme); });
    state.spun = false; viewTouched = false; startViewAuto();   // bjud in att upptäcka Game-vyn
    updateSwipeVis();
  }

  // Auto-rotera Mood↔Game var 7:e sek så nya användare upptäcker Game-vyn — slutar permanent
  // vid första egna interaktion (vy-klick/snurr), pausar när fliken är dold, hoppar över Loop.
  // Rotationen fortsätter tills användaren AKTIVT väljer en vy via Mood/Game-knapparna (data-vis).
  // Ett klick mitt på bilden (snurr) räcker inte. Pausar artigt när fliken är dold / mitt i snurr.
  let viewAutoTimer = null, viewTouched = false;
  function startViewAuto() {
    clearInterval(viewAutoTimer);
    viewAutoTimer = setInterval(() => {
      if (viewTouched || document.hidden || state.spinning) return;
      const canGame = ((cur('symbols') || []).length > 0);
      if (state.visualMode === 'game') state.visualMode = 'mood';
      else if (canGame) { state.visualMode = 'game'; ensureSymbols(); }
      else return;   // inga symboler än → stanna på Mood tills de kommit
      renderImage(false);
    }, 7000);
  }
  function stopViewAuto() { viewTouched = true; clearInterval(viewAutoTimer); }

  // Lås textsektionens höjd till bilddelens höjd (alltid enhetlig ruta, scroll inuti när innehållet är längre).
  function syncPanelHeight() {
    const img = document.getElementById('cf-image');
    const panel = document.querySelector('#result [data-panelbox]');
    if (!img || !panel) return;
    if (!window.matchMedia('(min-width:1024px)').matches) { panel.style.height = ''; panel.style.maxHeight = ''; return; }
    const tabs = panel.previousElementSibling;
    const tabsH = tabs ? tabs.offsetHeight : 0;
    const h = Math.max(240, Math.round(img.offsetHeight - tabsH - 12));   // 12 = tabs-radens mb-3
    panel.style.height = h + 'px';
    panel.style.maxHeight = h + 'px';
  }
  window.addEventListener('resize', syncPanelHeight);

  // delegation (result-elementet är stabilt; lyssnaren sätts en gång)
  result.addEventListener('click', (e) => {
    const tb = e.target.closest('[data-tab]');
    if (tb) { const t = tb.dataset.tab; result.querySelectorAll('[data-tab]').forEach((x) => x.classList.toggle('active', x.dataset.tab === t)); result.querySelectorAll('[data-panel]').forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== t)); return; }
    const vs = e.target.closest('[data-vis]'); if (vs) { stopViewAuto(); state.visualMode = vs.dataset.vis; renderImage(false); if (vs.dataset.vis === 'game') ensureSymbols(); return; }
    const sp = e.target.closest('[data-spin]'); if (sp) { spinMockup(); return; }
    const rs = e.target.closest('[data-reshape]'); if (rs) { reshapeSoundtrack(); return; }
    const rf = e.target.closest('[data-refresh]');
    if (rf) {
      // Tap-again-bekräftelse: första trycket beväpnar (gulorange), andra inom 2,5 s kör. Hindrar dyra mistryck.
      if (rf.getAttribute('data-armed') !== '1') {
        rf.setAttribute('data-armed', '1'); rf.classList.add('cf-confirm'); rf.title = 'Tap again to confirm';
        clearTimeout(rf._armT); rf._armT = setTimeout(() => { rf.removeAttribute('data-armed'); rf.classList.remove('cf-confirm'); }, 2500);
        return;
      }
      clearTimeout(rf._armT); rf.removeAttribute('data-armed'); rf.classList.remove('cf-confirm');
      refresh(rf.dataset.refresh); return;
    }
    const nv = e.target.closest('[data-nav]'); if (nv) { nav(nv.dataset.nav, +nv.dataset.d); return; }
  });

  // ---------- Flows ----------
  async function generateFresh(theme) {
    lastTheme = theme; closeRecent(); startLoading();
    let concept;
    try { const res = await fetch('/api/concept', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme }) }); concept = await res.json(); }
    catch (err) { stopLoading(); result.innerHTML = `<p class="text-stone-400">Something broke: ${esc(String(err))}. Try again.</p>`; result.classList.remove('hidden'); return; }
    stopLoading();
    if (concept && concept.limit) { showLimitPopup(); return; }
    if (!concept || concept.note === 'error') { result.innerHTML = `<div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-6 text-stone-300">⚠️ Generation hiccupped${concept && concept.error ? ' (' + esc(concept.error) + ')' : ''}. Hit <strong class="text-[#c6ff00]">Forge it</strong> again.</div>`; result.classList.remove('hidden'); return; }
    if (!concept.theme) concept.theme = theme;
    initState(concept);
    buildResult(false);              // text + tomma slots syns direkt
    setSoundtrackMsg('Composing soundtrack with Suno…');
    // Bild, SFX och soundtrack hämtas parallellt och renderas var för sig när de blir klara.
    render('image', true);
    const jobs = [
      (async () => {
        try { const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: state.imagePrompt }) }); const j = await r.json(); if (j.url) pushVersion('image', { url: j.url, engine: j.engine }); } catch (e) {}
        render('image', false);
      })(),
      (async () => { const sfx = await fetchSfx(); if (sfx.length) { state.versions.sfx = [sfx]; state.idx.sfx = 0; } renderSfx(); })(),
      (async () => { const st = await fetchSoundtrack(); if (st) { state.versions.soundtrack = [st]; state.idx.soundtrack = 0; renderSoundtrack(); autoplaySoundtrack(); } else renderSoundtrack(); })(),
      // Temade reel-symboler genereras nu eagert (billiga Flux schnell-ikoner) så varje sparat koncept
      // har en riktig produktionslik rulle i Game-vyn — inte bara A/K/Q/J/10. Kör i bakgrunden, blockar inte resultatet.
      (async () => { const syms = await fetchSymbols(); if (syms.length) { state.versions.symbols = [syms]; state.idx.symbols = 0; computeGrid(); if (state.visualMode === 'game') renderImage(false); } })(),
    ];
    await Promise.allSettled(jobs);
    persist();
  }

  // Autospela soundtracket på 50 % volym (nya sökningar + val ur Recent).
  function autoplaySoundtrack() {
    const a = document.querySelector('#soundtrack-slot audio');
    if (a) { a.volume = 0.5; a.play().catch(() => {}); }
  }
  async function loadSearch(id) {
    closeRecent();
    let data;
    try { const r = await fetch('/api/gallery?id=' + encodeURIComponent(id)); if (!r.ok) return; data = await r.json(); } catch (e) { return; }
    if (!data || !data.state) return;
    state = hydrate(Object.assign({ id: data.id }, data.state));
    lastTheme = state.theme || ''; input.value = state.theme || input.value;
    buildResult(true);
    autoplaySoundtrack();
    window.scrollTo({ top: result.offsetTop - 20, behavior: 'smooth' });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const theme = input.value.trim(); if (!theme) return;
    const id = findCachedId(normalize(theme));
    if (id) loadSearch(id); else generateFresh(theme);
  });

  document.getElementById('surprise').addEventListener('click', () => { input.value = SURPRISES[Math.floor(Math.random() * SURPRISES.length)]; form.requestSubmit(); });
  const chipsEl = document.getElementById('chips');
  function renderChips() {
    const pool = [...SURPRISES]; const pick = [];
    for (let i = 0; i < 12 && pool.length; i++) pick.push(pool.splice(Math.floor(Math.random() * pool.length), 1)[0]);
    chipsEl.innerHTML = pick.map((t) => `<button type="button" class="chip shrink-0 rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">${t}</button>`).join('');
    chipsEl.scrollLeft = 0;
  }
  chipsEl.addEventListener('click', (e) => { const c = e.target.closest('.chip'); if (c) { input.value = c.textContent; form.requestSubmit(); } });
  // ↻: shuffla alltid in en ny uppsättning förslag (chipsen scrollar själva via overflow-x).
  document.getElementById('chip-more').addEventListener('click', renderChips);
  renderChips();

  // ---------- Google-style autocomplete: dropdown vid fokus på tomt sökfält ----------
  // Recent (redan forgeade koncept ur galleriet) ligger överst — gratis att öppna, så de
  // promotar credits som redan spenderats. Därunder några färska förslag att forga.
  const acPanel = document.getElementById('ac-panel');
  const ICO_CLOCK = '<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 flex-shrink-0 text-stone-500"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M12 7.5V12l3 1.8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  const ICO_SEARCH = '<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 flex-shrink-0 text-stone-500"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="M20 20l-3.6-3.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>';
  function buildAc() {
    const recent = galleryList.slice(0, 8);
    const taken = new Set(recent.map((m) => normalize(m.theme || '')));
    const suggs = SURPRISES.filter((s) => !taken.has(normalize(s))).slice(0, 5);
    const row = (ico, label, attr) => `<div class="ac-item flex items-center gap-3 rounded-lg px-3 py-2.5 cursor-pointer hover:bg-[#1d212c]" ${attr}>${ico}<span class="truncate text-sm text-stone-200">${esc(label)}</span></div>`;
    let html = recent.map((m) => row(ICO_CLOCK, m.theme, `data-id="${esc(m.id)}"`)).join('');
    if (recent.length && suggs.length) html += '<div class="my-1 border-t border-[#2a2a3a]"></div>';
    html += suggs.map((s) => row(ICO_SEARCH, s, `data-q="${esc(s)}"`)).join('');
    acPanel.innerHTML = html;
    acPanel.querySelectorAll('.ac-item').forEach((el) => el.addEventListener('mousedown', (ev) => {
      ev.preventDefault();  // håll kvar fokus så klicket hinner registreras före blur
      closeAc();
      if (el.dataset.id) loadSearch(el.dataset.id);
      else if (el.dataset.q) { input.value = el.dataset.q; form.requestSubmit(); }
    }));
  }
  function openAc() { if (input.value.trim()) return; buildAc(); if (acPanel.innerHTML.trim()) { stopRecentPulse(); acPanel.classList.remove('hidden'); } }
  function closeAc() { acPanel.classList.add('hidden'); }
  input.addEventListener('focus', openAc);
  input.addEventListener('input', () => { input.value.trim() ? closeAc() : openAc(); });
  input.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAc(); });
  document.addEventListener('click', (e) => { if (e.target !== input && !e.target.closest('#ac-panel')) closeAc(); });

  refreshGallery();
</script>
