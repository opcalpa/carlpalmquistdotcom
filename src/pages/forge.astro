          <div data-panelbox class="cf-scrollfade no-scrollbar overflow-auto rounded-2xl border border-[#22222e] bg-[#13131c] p-6 lg:max-h-[68vh]">
            ${tabs.map((t, i) => `<div data-panel="${t[0]}" class="${i === 0 ? '' : 'hidden'}"><div id="cf-panel-${t[0]}"></div></div>`).join('')}
          </div>
        </div>
        <div class="flex flex-col gap-4">
          <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-4">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">🎵 Soundtrack</span>
              <span class="flex items-center gap-2"><span id="st-engine" class="text-[10px] text-stone-600"></span><span id="cf-st-ctrl"></span></span>
            </div>
            <div id="soundtrack-slot"></div>
          </div>
          <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-4">
