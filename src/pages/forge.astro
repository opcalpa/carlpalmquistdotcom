---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Concept Forge — slot ideation engine"
  description="Type a vibe, get a complete slot game concept: name, art direction, mechanic, a music brief with a generated soundtrack, and marketing hooks. A demo by Carl Palmquist."
>
  <main class="min-h-screen bg-[#0a0a0f] text-stone-100 font-sans">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:py-12">

      <header class="mb-7">
        <p class="mb-3 inline-flex items-center gap-2 rounded-full border border-[#2a2a3a] bg-[#15151f] px-3 py-1 text-xs font-medium tracking-wide text-stone-400">
          <span class="h-1.5 w-1.5 rounded-full bg-[#c6ff00]"></span>
          A Carl Palmquist demo · slot ideation accelerator
        </p>
        <h1 class="text-5xl font-black uppercase leading-[0.95] tracking-tight sm:text-6xl">
          Concept <span class="text-[#c6ff00]">Forge</span>
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-400">
          Throw it a vibe. It hands back a complete game concept — names, art direction, mechanic,
          a <span class="font-semibold text-[#ff2d78]">music brief with a generated soundtrack</span>,
          and launch hooks. Re-roll any piece on its own and flip between versions.
        </p>
      </header>

      <form id="forge-form" class="mb-6">
        <div class="flex flex-col gap-3 sm:flex-row">
          <input id="theme" type="text" autocomplete="off" placeholder="neon yakuza with a country vibe…"
            class="flex-1 rounded-xl border border-[#2a2a3a] bg-[#15151f] px-4 py-3.5 text-lg text-stone-100 placeholder-stone-500 outline-none focus:border-[#c6ff00]" />
          <button id="generate" type="submit"
            class="rounded-xl bg-[#c6ff00] px-7 py-3.5 text-lg font-black uppercase tracking-tight text-black transition hover:bg-[#d6ff3a] disabled:opacity-50">Forge it</button>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
          <button type="button" id="surprise" class="text-[#ff2d78] hover:underline">⚡ Surprise me</button>
          <span class="text-stone-600">·</span>
          <span class="text-stone-500">try:</span>
          <span id="chips" class="flex flex-wrap items-center gap-2"></span>
          <button type="button" id="chip-shuffle" class="rounded-full border border-[#2a2a3a] px-2 py-1 text-stone-400 hover:border-[#c6ff00]" title="Fler förslag">↻</button>
          <div class="relative ml-auto" id="recent-wrap">
            <button type="button" id="recent-btn" class="rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">⟲ Recent <span id="recent-count" class="text-stone-500"></span> ▾</button>
            <div id="recent-panel" class="hidden absolute right-0 z-20 mt-2 w-80 max-h-96 overflow-auto rounded-xl border border-[#2a2a3a] bg-[#15151f] p-2 shadow-2xl"></div>
          </div>
        </div>
      </form>

      <div id="loading" class="hidden py-16 text-center">
        <div class="mx-auto mb-4 h-8 w-8 animate-spin rounded-full border-2 border-[#2a2a3a] border-t-[#c6ff00]"></div>
        <p id="loading-msg" class="text-stone-400">Sketching characters…</p>
      </div>

      <section id="result" class="hidden"></section>

      <footer class="mt-14 border-t border-[#1c1c28] pt-6 text-xs leading-relaxed text-stone-500">
        <p><span class="font-semibold text-stone-400">Ideation accelerator, not an art generator.</span>
        It produces direction and briefs for humans to refine — the model never ships the final asset.
        That keeps it on the right side of regulatory art audits.</p>
        <p class="mt-2">Built with Claude Code in an evening and deployed on this site. — Carl Palmquist</p>
      </footer>
    </div>
  </main>
</Layout>

<style is:global>
  .cf-tab { display:inline-block; padding:7px 13px; border-radius:9px; font-size:12px; font-weight:800; letter-spacing:-0.01em; text-transform:uppercase; border:1px solid #2a2a3a; color:#d6d3d1; background:transparent; cursor:pointer; }
  .cf-tab:hover { border-color:#c6ff00; }
  .cf-tab.active { background:#c6ff00; color:#000; border-color:#c6ff00; }
  .cf-ctrl { display:inline-flex; align-items:center; gap:4px; vertical-align:middle; }
  .cf-mini { display:inline-flex; align-items:center; justify-content:center; height:22px; min-width:22px; padding:0 5px; border:1px solid #2a2a3a; border-radius:6px; background:#15151f; color:#9aa3b2; font-size:12px; line-height:1; cursor:pointer; font-family:inherit; }
  .cf-mini:hover:not(:disabled) { border-color:#c6ff00; color:#e6e8ee; }
  .cf-mini:disabled { opacity:.35; cursor:default; }
  .cf-refresh { color:#c6ff00; }
  .cf-ver { font-size:10px; color:#5b6675; min-width:26px; text-align:center; }
  .cf-spin { display:inline-block; width:11px; height:11px; border:2px solid #2a2a3a; border-top-color:#c6ff00; border-radius:50%; animation:cfspin .7s linear infinite; }
  @keyframes cfspin { to { transform:rotate(360deg); } }
</style>

<script is:inline>
  const form = document.getElementById('forge-form');
  const input = document.getElementById('theme');
  const btn = document.getElementById('generate');
  const loading = document.getElementById('loading');
  const loadingMsg = document.getElementById('loading-msg');
  const result = document.getElementById('result');
  const recentBtn = document.getElementById('recent-btn');
  const recentPanel = document.getElementById('recent-panel');
  const recentCount = document.getElementById('recent-count');

  const SURPRISES = ['neon yakuza synthwave heist','haunted disco inferno','viking metal feast','deep sea treasure cult','cyberpunk samurai noodle bar','wild west bank robbery at dawn','baroque vampire opera','arctic monster hunt','lucha libre luchador showdown','egyptian afterlife game show','jurassic jungle bounty','voodoo new orleans jazz funeral','haunted carnival freakshow','retro arcade hacker den','greek underworld boxing','candy factory sugar rush','pirate ghost ship raid','dumpling dojo kung fu','space western bounty hunter','gothic cathedral exorcism','tropical tiki volcano party','steampunk airship robbery','zombie football hooligans','samurai cyber dragon','wild safari jackpot stampede','noir detective speakeasy','frost giant ragnarok','day of the dead mariachi fiesta','toxic sewer mutant rave','medieval dragon siege','street graffiti monster crew','sushi conveyor chaos'];
  const LOADING_MSGS = ['Sketching characters…','Inking the key art…','Designing the bonus round…','Stress-testing the max win…','Writing the launch hooks…'];

  const esc = (s) => String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  const normalize = (s) => String(s || '').trim().toLowerCase().replace(/\s+/g,' ');

  let lastTheme = '';
  let state = null;
  const VCAP = 6;

  // ---------- Delat gallery (server, Cloudflare KV) ----------
  let galleryList = [];
  async function refreshGallery() {
    try { const r = await fetch('/api/gallery'); const j = await r.json(); galleryList = Array.isArray(j.list) ? j.list : []; }
    catch (e) { galleryList = []; }
    renderRecent();
  }
  const findCachedId = (key) => { const m = galleryList.find((x) => x.key === key); return m ? m.id : null; };
  async function delEntry(id) { try { await fetch('/api/gallery?id=' + encodeURIComponent(id), { method: 'DELETE' }); } catch (e) {} refreshGallery(); }
  async function clearHist() { try { await fetch('/api/gallery?all=1', { method: 'DELETE' }); } catch (e) {} refreshGallery(); }

  function timeAgo(ts) {
    const s = Math.floor((Date.now() - ts) / 1000);
    if (s < 60) return 'just now';
    if (s < 3600) return Math.floor(s / 60) + 'm ago';
    if (s < 86400) return Math.floor(s / 3600) + 'h ago';
    return Math.floor(s / 86400) + 'd ago';
  }
  function renderRecent() {
    const hist = galleryList;
    recentCount.textContent = hist.length ? '(' + hist.length + ')' : '';
    if (!hist.length) { recentPanel.innerHTML = '<p class="px-2 py-3 text-xs text-stone-500">No saved concepts yet.</p>'; return; }
    recentPanel.innerHTML = hist.map((m) => `
      <div class="recent-item flex items-center gap-2 rounded-lg px-2 py-1.5 hover:bg-[#1d212c] cursor-pointer" data-id="${esc(m.id)}">
        ${m.thumb ? `<img src="${esc(m.thumb)}" onerror="this.style.display='none'" class="h-9 w-9 flex-shrink-0 rounded object-cover" />` : '<div class="h-9 w-9 flex-shrink-0 rounded bg-[#222]"></div>'}
        <div class="min-w-0 flex-1"><div class="truncate text-sm text-stone-200">${esc(m.theme)}</div><div class="text-[10px] text-stone-500">${timeAgo(m.ts)}</div></div>
        <button class="flex-shrink-0 px-1 text-stone-600 hover:text-[#ff2d78]" data-del="${esc(m.id)}" title="Remove">✕</button>
      </div>`).join('') +
      `<div class="mt-1 border-t border-[#2a2a3a] pt-1"><button id="recent-clear" class="w-full rounded-lg px-2 py-1.5 text-left text-xs text-stone-500 hover:text-[#ff2d78]">Clear all</button></div>`;
    recentPanel.querySelectorAll('.recent-item').forEach((el) => el.addEventListener('click', (ev) => { if (ev.target.closest('[data-del]')) return; loadSearch(el.dataset.id); }));
    recentPanel.querySelectorAll('[data-del]').forEach((b) => b.addEventListener('click', (ev) => { ev.stopPropagation(); delEntry(b.dataset.del); }));
    const clr = document.getElementById('recent-clear');
    if (clr) clr.addEventListener('click', clearHist);
  }
  const closeRecent = () => recentPanel.classList.add('hidden');
  recentBtn.addEventListener('click', (e) => { e.stopPropagation(); recentPanel.classList.toggle('hidden'); });
  document.addEventListener('click', (e) => { if (!e.target.closest('#recent-wrap')) closeRecent(); });

  // ---------- Loading ----------
  let msgTimer;
  const holdAudio = new Audio('/hold-music.mp3'); holdAudio.loop = true; holdAudio.volume = 0.45;
  function startLoading() { result.classList.add('hidden'); loading.classList.remove('hidden'); btn.disabled = true; try { holdAudio.currentTime = 0; holdAudio.play().catch(() => {}); } catch (e) {} let i = 0; loadingMsg.textContent = LOADING_MSGS[0]; msgTimer = setInterval(() => { i = (i + 1) % LOADING_MSGS.length; loadingMsg.textContent = LOADING_MSGS[i]; }, 1500); }
  function stopLoading() { clearInterval(msgTimer); loading.classList.add('hidden'); btn.disabled = false; try { holdAudio.pause(); } catch (e) {} }

  // ---------- Version state ----------
  function initState(c) {
    state = {
      id: null, theme: c.theme || lastTheme || '', imagePrompt: c.image_prompt || c.theme || lastTheme || '', conceptEngine: c.engine || '',
      featureName: c.feature_name || '', featureIntro: Array.isArray(c.feature_intro) ? c.feature_intro : [],
      versions: {
        title: [{ names: c.names || [], logline: c.logline || '' }],
        art: [c.art || {}],
        mechanic: [{ mechanic: c.mechanic || {}, math: c.math || {} }],
        music: [{ music: c.music || {}, soundtrack_prompt: c.soundtrack_prompt || '', sfxPrompts: c.sfx || [] }],
        hooks: [c.hooks || []],
        image: c.image_url ? [{ url: c.image_url, engine: c.engine_image || null }] : [],
        soundtrack: [], sfx: [], animation: [], gameview: [],
      },
      idx: { title: 0, art: 0, mechanic: 0, music: 0, hooks: 0, image: 0, soundtrack: 0, sfx: 0, animation: 0, gameview: 0 },
      visualMode: 'mood', animBusy: false, gameBusy: false,
    };
  }
  const cur = (comp) => (state.versions[comp] || [])[state.idx[comp]];
  function pushVersion(comp, value) { const a = state.versions[comp] || (state.versions[comp] = []); a.push(value); while (a.length > VCAP) a.shift(); state.idx[comp] = a.length - 1; }
  function flatConcept() {
    const t = cur('title') || {}, m = cur('mechanic') || { mechanic: {}, math: {} }, mu = cur('music') || { music: {} };
    return { names: t.names, logline: t.logline, art: cur('art') || {}, mechanic: m.mechanic, math: m.math, music: mu.music, hooks: cur('hooks') || [] };
  }

  // ---------- Controls ----------
  function ctrl(comp, busy) {
    const n = state.versions[comp].length, i = state.idx[comp];
    const nav = n > 1 ? `<button class="cf-mini" data-nav="${comp}" data-d="-1" ${i <= 0 ? 'disabled' : ''}>‹</button><span class="cf-ver">${i + 1}/${n}</span><button class="cf-mini" data-nav="${comp}" data-d="1" ${i >= n - 1 ? 'disabled' : ''}>›</button>` : '';
    return `<span class="cf-ctrl">${nav}<button class="cf-mini cf-refresh" data-refresh="${comp}" title="Regenerate this">${busy ? '<span class="cf-spin"></span>' : '↻'}</button></span>`;
  }

  // ---------- Per-component render ----------
  function rows(pairs) { return pairs.filter((r) => r[1]).map((r) => `<div class="mb-3 last:mb-0"><dt class="text-[11px] uppercase tracking-wide text-stone-500">${esc(r[0])}</dt><dd class="mt-0.5 text-sm leading-relaxed text-stone-200">${esc(r[1])}</dd></div>`).join(''); }

  function renderTitle(busy) {
    const el = document.getElementById('cf-title'); if (!el) return;
    const v = cur('title') || { names: [], logline: '' }; const names = v.names || []; const primary = names[0] || 'Untitled'; const alts = names.slice(1);
    el.innerHTML = `<div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <h2 class="text-4xl font-black uppercase tracking-tight text-[#c6ff00] sm:text-5xl">${esc(primary)}</h2>
        ${alts.map((n) => `<span class="rounded-full border border-[#2a2a3a] px-3 py-1 text-sm text-stone-400">${esc(n)}</span>`).join('')}
        ${ctrl('title', busy)}
      </div>
      <p class="mt-2 max-w-3xl text-lg italic text-stone-300">“${esc(v.logline || '')}”</p>
      ${state.featureName ? `<p class="mt-2 text-xs font-semibold uppercase tracking-wide text-[#ff2d78]">⚡ ${esc(state.featureName)}</p>` : ''}`;
  }
  function renderFeatureIntro() {
    const el = document.getElementById('cf-intro'); if (!el) return;
    const cards = (state.featureIntro || []).slice(0, 3);
    if (!cards.length) { el.innerHTML = ''; return; }
    const labels = ['Mechanic', 'Bonus', 'Max win'], accent = ['#c6ff00', '#ff2d78', '#c6ff00'];
    el.innerHTML = `<div class="grid gap-2 sm:grid-cols-3">${cards.map((c, i) => `
      <div class="rounded-xl border border-[#22222e] bg-[#13131c] p-3 ${i === 2 ? 'ring-1 ring-[#c6ff00]/40' : ''}">
        <div class="mb-1 text-[10px] font-black uppercase tracking-wide" style="color:${accent[i] || '#c6ff00'}">${labels[i] || ''}</div>
        <div class="text-xs leading-relaxed text-stone-200">${esc(c)}</div>
      </div>`).join('')}</div>`;
  }
  function renderImage(busy) {
    const el = document.getElementById('cf-image'); if (!el) return;
    const mood = cur('image') || { url: null };
    const game = cur('gameview');
    const an = cur('animation');
    const hasGame = !!(game && game.url), hasLoop = !!(an && an.url);
    const animBusy = state.animBusy, gameBusy = state.gameBusy;
    const on = 'style="color:#c6ff00"';
    let mode = state.visualMode || 'mood';
    if (mode === 'game' && !hasGame) mode = 'mood';
    if (mode === 'loop' && !hasLoop) mode = 'mood';
    let media;
    if (mode === 'loop') media = `<video src="${esc(an.url)}" autoplay muted loop playsinline class="aspect-square w-full rounded-2xl border border-[#22222e] object-cover"></video>`;
    else if (mode === 'game') media = `<div class="relative aspect-square w-full overflow-hidden rounded-2xl border border-[#22222e] bg-[#13131c]"><div class="absolute inset-0 flex items-center justify-center p-6 text-center text-xs text-stone-500">Game view failed to load. Hit ↻ to re-roll.</div><img src="${esc(game.url)}" alt="Game view" class="absolute inset-0 h-full w-full object-cover" onerror="this.style.display='none'" /></div>`;
    else media = mood.url ? `<img src="${esc(mood.url)}" alt="Key art" class="aspect-square w-full rounded-2xl border border-[#22222e] object-cover" />` : `<div class="flex aspect-square w-full items-center justify-center rounded-2xl border border-dashed border-[#2a2a3a] bg-[#13131c] p-6 text-center text-xs text-stone-500">${busy ? '🎨 Painting key art…' : 'No image yet.'}</div>`;
    const pill = (m, label) => `<button class="cf-mini" data-vis="${m}" ${mode === m ? on : ''}>${label}</button>`;
    let pills = pill('mood', 'Mood');
    pills += hasGame ? pill('game', 'Game') : (gameBusy ? `<span class="cf-mini" style="opacity:.6">Game…</span>` : `<button class="cf-mini" data-refresh="gameview" ${mood.url ? '' : 'disabled'}>+ Game</button>`);
    pills += hasLoop ? pill('loop', 'Loop') : (animBusy ? `<span class="cf-mini" style="opacity:.6">Loop…</span>` : `<button class="cf-mini" data-refresh="animation" ${mood.url ? '' : 'disabled'}>▶ Loop</button>`);
    let reroll = '';
    if (mode === 'mood') reroll = ctrl('image', busy && !gameBusy && !animBusy);
    else if (mode === 'game') reroll = `<button class="cf-mini cf-refresh" data-refresh="gameview" title="Re-roll game view">${gameBusy ? '<span class="cf-spin"></span>' : '↻'}</button>`;
    else reroll = `<button class="cf-mini cf-refresh" data-refresh="animation" title="Re-roll loop">${animBusy ? '<span class="cf-spin"></span>' : '↻'}</button>`;
    const note = animBusy ? `<div class="absolute inset-x-2 bottom-2 rounded bg-black/70 px-2 py-1 text-center text-[11px] text-[#c6ff00]">Animating with Luma Ray 2… ~1-2 min</div>`
      : (gameBusy ? `<div class="absolute inset-x-2 bottom-2 rounded bg-black/70 px-2 py-1 text-center text-[11px] text-[#c6ff00]">Rendering game view…</div>` : '');
    el.innerHTML = `<div class="relative">${media}<div class="absolute right-2 top-2 flex flex-wrap items-center justify-end gap-1">${reroll}<span class="cf-ctrl">${pills}</span></div>${note}</div>`;
  }
  function renderTab(comp, busy) {
    const el = document.getElementById('cf-panel-' + comp); if (!el) return;
    let inner = '';
    if (comp === 'art') { const v = cur('art') || {}; inner = rows([['Style', v.style], ['Palette', v.palette], ['Hero characters', v.hero_characters], ['Mood', v.mood]]); }
    else if (comp === 'mechanic') { const v = cur('mechanic') || { mechanic: {}, math: {} }; const m = v.mechanic || {}, ma = v.math || {}; inner = rows([['Grid', m.grid], ['Type', m.type], ['Base game', m.base_game], ['Signature feature', m.signature_feature], ['Bonus round', m.bonus_round], ['Bonus buy', m.bonus_buy], ['Volatility', ma.volatility], ['RTP', ma.rtp], ['Max win', ma.suggested_max_win]]); }
    else if (comp === 'music') { const v = (cur('music') || {}).music || {}; inner = rows([['Genre', v.genre], ['Instrumentation', v.instrumentation], ['Base vs bonus', v.base_vs_bonus], ['Tempo', v.bpm], ['Reference vibe', v.reference_vibe]]); }
    else if (comp === 'hooks') { const v = cur('hooks') || []; inner = `<ul class="space-y-2.5">${v.map((h) => `<li class="flex gap-2 text-sm leading-relaxed text-stone-200"><span class="text-[#c6ff00]">▸</span><span>${esc(h)}</span></li>`).join('')}</ul>`; }
    el.innerHTML = `<div class="mb-3 flex justify-end">${ctrl(comp, busy)}</div>${inner}`;
  }
  function setSoundtrackMsg(t) { const st = document.getElementById('soundtrack-slot'); if (st) st.innerHTML = `<div class="flex items-center gap-2 py-2 text-xs text-stone-500"><span class="h-3 w-3 animate-spin rounded-full border-2 border-[#2a2a3a] border-t-[#ff2d78]"></span> ${esc(t)}</div>`; }
  function renderSoundtrack(busy) {
    const st = document.getElementById('soundtrack-slot'), eng = document.getElementById('st-engine'), c = document.getElementById('cf-st-ctrl');
    const v = cur('soundtrack');
    if (eng) eng.textContent = (v && v.engine) || '';
    if (c) c.innerHTML = ctrl('soundtrack', busy);   // ↻ alltid synlig, även när tomt → kan (om)generera
    if (!st) return;
    if (v && v.url) st.innerHTML = `<audio controls loop src="${esc(v.url)}" class="w-full"></audio>
      <div class="mt-2 flex flex-wrap items-center gap-1.5">
        <input id="st-more" type="text" placeholder="more: …" class="min-w-0 flex-1 rounded border border-[#2a2a3a] bg-[#15151f] px-2 py-1 text-xs text-stone-200 placeholder:text-stone-600" />
        <input id="st-less" type="text" placeholder="less: …" class="min-w-0 flex-1 rounded border border-[#2a2a3a] bg-[#15151f] px-2 py-1 text-xs text-stone-200 placeholder:text-stone-600" />
        <button type="button" data-reshape class="cf-mini cf-refresh" ${busy ? 'disabled' : ''}>${busy ? '<span class="cf-spin"></span>' : '↻ Reshape'}</button>
      </div>`;
    else if (!busy) st.innerHTML = `<p class="text-xs text-stone-600">Soundtrack unavailable.</p>`;
  }
  function renderSfx(busy) {
    const fx = document.getElementById('sfx-slot'), c = document.getElementById('cf-sfx-ctrl');
    const list = cur('sfx') || [];
    if (c) c.innerHTML = ctrl('sfx', busy);   // ↻ alltid synlig, även vid "No SFX." → kan (om)generera
    if (!fx) return;
    if (!list.length) { if (!busy) fx.innerHTML = `<p class="text-xs text-stone-600">No SFX.</p>`; return; }
    fx.innerHTML = `<div class="flex flex-wrap gap-2">${list.map((s, i) => `
      <button type="button" class="sfx-chip inline-flex items-center gap-2 rounded-full border border-[#2a2a3a] bg-[#15151f] py-1 pl-1 pr-3 text-xs text-stone-300 hover:border-[#ff2d78]" data-sfx="${i}">
        <span class="sfx-ic flex h-6 w-6 items-center justify-center rounded-full bg-[#ff2d78] text-[11px] text-black">▶</span><span>${esc(s.label)}</span>
      </button><audio data-sfxaudio="${i}" src="${esc(s.url)}" preload="none"></audio>`).join('')}</div>`;
    const auds = fx.querySelectorAll('audio[data-sfxaudio]');
    const reset = () => { auds.forEach((o) => { o.pause(); o.currentTime = 0; }); fx.querySelectorAll('.sfx-ic').forEach((x) => (x.textContent = '▶')); };
    fx.querySelectorAll('.sfx-chip').forEach((chip) => {
      const au = fx.querySelector(`audio[data-sfxaudio="${chip.dataset.sfx}"]`), ic = chip.querySelector('.sfx-ic');
      chip.addEventListener('click', () => { const playing = !au.paused; reset(); if (playing) return; au.play(); ic.textContent = '⏸'; au.onended = () => { ic.textContent = '▶'; }; });
    });
  }
  function renderEngine() {
    const el = document.getElementById('cf-engine'); if (!el) return;
    const im = cur('image') || {}, so = cur('soundtrack') || {}, an = cur('animation') || {};
    el.innerHTML = [`Concept by ${esc(state.conceptEngine || 'Claude')}`, im.engine ? 'art by ' + esc(im.engine) : '', an.engine ? 'motion by ' + esc(an.engine) : '', so.engine ? 'soundtrack by ' + esc(so.engine) : '', 'SFX by ElevenLabs'].filter(Boolean).join(' &nbsp;·&nbsp; ') + ' &nbsp;—&nbsp; right model for each step.';
  }
  function render(comp, busy) {
    if (comp === 'title') renderTitle(busy);
    else if (comp === 'image' || comp === 'animation' || comp === 'gameview') { renderImage(busy); renderEngine(); }
    else if (comp === 'soundtrack') { renderSoundtrack(busy); renderEngine(); }
    else if (comp === 'sfx') renderSfx(busy);
    else renderTab(comp, busy);
  }
  function renderAll() { renderTitle(); renderFeatureIntro(); renderImage(); ['art', 'mechanic', 'music', 'hooks'].forEach((t) => renderTab(t)); renderSoundtrack(); renderSfx(); renderEngine(); }

  // ---------- Audio fetchers ----------
  async function pollSuno(taskId) {
    let waited = 0; const interval = 4000, maxMs = 120000;
    while (waited < maxMs) {
      await new Promise((r) => setTimeout(r, interval)); waited += interval;
      setSoundtrackMsg('Composing soundtrack with Suno… ' + Math.floor(waited / 1000) + 's');
      try { const r = await fetch('/api/soundtrack?taskId=' + encodeURIComponent(taskId)); const j = await r.json(); if (j.status === 'done' && j.url) return j.url; if (j.status === 'failed') return null; } catch (e) {}
    }
    return null;
  }
  async function fetchSoundtrack(steer) {
    let prompt = (cur('music') || {}).soundtrack_prompt || state.theme || '';
    if (steer) prompt = prompt + ', ' + steer;
    if (!prompt) return null;
    try { const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt }) }); const j = await r.json(); if (j.taskId) { const url = await pollSuno(j.taskId); if (url) return { url, engine: 'Suno V5' }; } } catch (e) {}
    try { const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt, engine: 'fal' }) }); const j = await r.json(); if (j.url) return { url: j.url, engine: j.engine || 'Stable Audio (fal.ai)' }; } catch (e) {}
    return null;
  }
  async function fetchSfx() {
    try { const r = await fetch('/api/audio', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sfx: (cur('music') || {}).sfxPrompts || [] }) }); const j = await r.json(); return j.sfx || []; } catch (e) { return []; }
  }

  // ---------- Animation (key art -> attract-loop via Luma Ray 2) ----------
  function motionPrompt() {
    const base = (state.imagePrompt || state.theme || '').slice(0, 400);
    return `Subtle cinematic attract-mode loop of this slot key art. Ambient motion only: slowly drifting particles, soft neon and light shimmer, faint haze, the main character breathes and shifts almost imperceptibly with occasional small idle movement. Keep the composition identical, no camera cut, seamless loop. Scene: ${base}`;
  }
  async function pollAnimate(id) {
    let waited = 0; const interval = 5000, maxMs = 200000;
    while (waited < maxMs) {
      await new Promise((r) => setTimeout(r, interval)); waited += interval;
      try { const r = await fetch('/api/animate?id=' + encodeURIComponent(id)); const j = await r.json(); if (j.status === 'done' && j.url) return j.url; if (j.status === 'failed') return null; } catch (e) {}
    }
    return null;
  }
  function gameMotionPrompt() {
    return `Subtle live-gameplay loop of this slot game screen. Ambient motion only: reel symbols shimmer and gently pulse with soft glow, the character mascot makes small idle movements, neon UI elements flicker softly. No spinning reels, no camera cut, keep the layout identical, seamless loop.`;
  }
  async function fetchAnimation() {
    const fromGame = state.visualMode === 'game' && !!(cur('gameview') || {}).url;
    const src = fromGame ? cur('gameview') : cur('image');
    if (!src || !src.url) return null;
    const prompt = fromGame ? gameMotionPrompt() : motionPrompt();
    try {
      const r = await fetch('/api/animate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ imageUrl: src.url, prompt }) });
      const j = await r.json(); if (!j.requestId) return null;
      const url = await pollAnimate(j.requestId); if (url) return { url, engine: j.engine || 'Luma Ray 2' };
    } catch (e) {}
    return null;
  }

  // ---------- Game-view (hur sökningen ser ut i spelläge, Hacksaw-stil) ----------
  function gamePrompt() {
    const a = cur('art') || {};
    const base = (state.imagePrompt || state.theme || '').slice(0, 340);
    // Scen-baserad: ber om "reel grid" men inramat som art (inte explicit gambling-UI), annars safety-blockar Flux.
    return `In-game art for a mobile slot game showing a grid of glowing themed symbols and stylised A K Q J letter tiles, a character beside the grid, a small control bar at the bottom, bold comic graphic-novel style with thick ink linework and halftone shading, ${a.palette || ''}, bright high-contrast colourful glowing. No real brands, no copyrighted characters, no real text. Scene: ${base}`.slice(0, 720);
  }
  async function fetchGameview() {
    try { const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: gamePrompt() }) }); const j = await r.json(); if (j.url) return { url: j.url, engine: j.engine }; } catch (e) {}
    return null;
  }
  async function reshapeSoundtrack() {
    const more = (document.getElementById('st-more') || {}).value || '';
    const less = (document.getElementById('st-less') || {}).value || '';
    const steer = [more.trim() ? 'more: ' + more.trim() : '', less.trim() ? 'less: ' + less.trim() : ''].filter(Boolean).join('; ');
    if (!steer) return;
    render('soundtrack', true); setSoundtrackMsg('Reshaping soundtrack…');
    const st = await fetchSoundtrack(steer); if (st) pushVersion('soundtrack', st);
    render('soundtrack', false); persist();
  }

  // ---------- Refresh / nav ----------
  async function refresh(comp) {
    if (comp === 'animation') state.animBusy = true;
    if (comp === 'gameview') state.gameBusy = true;
    render(comp, true);
    try {
      if (['title', 'art', 'mechanic', 'music', 'hooks'].includes(comp)) {
        const r = await fetch('/api/section', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme: state.theme, section: comp, concept: flatConcept() }) });
        const j = await r.json();
        if (!j.error) {
          if (comp === 'title') pushVersion('title', { names: j.names || [], logline: j.logline || '' });
          else if (comp === 'art') pushVersion('art', j.art || {});
          else if (comp === 'mechanic') pushVersion('mechanic', { mechanic: j.mechanic || {}, math: j.math || {} });
          else if (comp === 'music') pushVersion('music', { music: j.music || {}, soundtrack_prompt: j.soundtrack_prompt || '', sfxPrompts: j.sfx || [] });
          else if (comp === 'hooks') pushVersion('hooks', j.hooks || []);
        }
      } else if (comp === 'image') {
        const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: state.imagePrompt }) });
        const j = await r.json(); if (j.url) pushVersion('image', { url: j.url, engine: j.engine });
      } else if (comp === 'soundtrack') {
        const st = await fetchSoundtrack(); if (st) pushVersion('soundtrack', st);
      } else if (comp === 'sfx') {
        const sfx = await fetchSfx(); if (sfx.length) pushVersion('sfx', sfx);
      } else if (comp === 'animation') {
        const an = await fetchAnimation(); if (an) { pushVersion('animation', an); state.visualMode = 'loop'; }
      } else if (comp === 'gameview') {
        const g = await fetchGameview();
        if (g) { pushVersion('gameview', g); state.visualMode = 'game'; }
        else { pushVersion('gameview', { url: null }); state.visualMode = 'mood'; }   // blockerad → rensa ev. svart, flippa till Mood
      }
    } catch (e) {}
    state.animBusy = false; state.gameBusy = false;
    render(comp, false);
    persist();
  }
  function nav(comp, d) {
    const n = state.versions[comp].length; let i = state.idx[comp] + d;
    i = Math.max(0, Math.min(n - 1, i)); state.idx[comp] = i; render(comp, false);
  }

  // ---------- Persist ----------
  async function persist() {
    try {
      const r = await fetch('/api/gallery', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: state.id, theme: state.theme, state: { theme: state.theme, imagePrompt: state.imagePrompt, conceptEngine: state.conceptEngine, featureName: state.featureName, featureIntro: state.featureIntro, versions: state.versions, idx: state.idx } }) });
      const j = await r.json(); if (j.id) state.id = j.id;
    } catch (e) {}
    refreshGallery();
  }

  // ---------- Build skeleton ----------
  function buildResult(fromCache) {
    const strip = fromCache
      ? `<div class="mb-3 flex items-center gap-3 text-xs"><span class="rounded-full bg-[#c6ff00]/15 px-2.5 py-1 font-semibold text-[#c6ff00]">⚡ Loaded from gallery</span><button id="regen-btn" type="button" class="text-stone-400 hover:text-[#ff2d78]">↻ Generate a fresh concept</button></div>`
      : `<div class="mb-3 text-xs"><span class="rounded-full bg-[#1d212c] px-2.5 py-1 text-stone-400">✓ Saved · re-rolls and versions are kept</span></div>`;
    const tabs = [['art', 'Art direction'], ['mechanic', 'Mechanic'], ['music', 'Music & audio'], ['hooks', 'Hooks']];
    result.innerHTML = `
      ${strip}
      <div id="cf-title" class="mb-4"></div>
      <div id="cf-intro" class="mb-4"></div>
      <div class="grid items-start gap-5 lg:grid-cols-[minmax(0,44%)_1fr]">
        <div class="space-y-4 lg:sticky lg:top-5 self-start">
          <div id="cf-image"></div>
          <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-4">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">🎵 Soundtrack</span>
              <span class="flex items-center gap-2"><span id="st-engine" class="text-[10px] text-stone-600"></span><span id="cf-st-ctrl"></span></span>
            </div>
            <div id="soundtrack-slot"></div>
            <div class="mt-4 mb-2 flex items-center justify-between"><span class="text-[11px] font-black uppercase tracking-wide text-[#ff2d78]">SFX</span><span id="cf-sfx-ctrl"></span></div>
            <div id="sfx-slot"></div>
          </div>
        </div>
        <div>
          <div class="mb-4 flex flex-wrap gap-2">${tabs.map((t, i) => `<button class="cf-tab${i === 0 ? ' active' : ''}" data-tab="${t[0]}">${esc(t[1])}</button>`).join('')}</div>
          <div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-6" style="min-height:420px">
            ${tabs.map((t, i) => `<div data-panel="${t[0]}" class="${i === 0 ? '' : 'hidden'}"><div id="cf-panel-${t[0]}"></div></div>`).join('')}
          </div>
        </div>
      </div>
      <p id="cf-engine" class="mt-6 text-xs text-stone-500"></p>`;
    renderAll();
    result.classList.remove('hidden');
    const regen = document.getElementById('regen-btn');
    if (regen) regen.addEventListener('click', () => { if (state && state.theme) generateFresh(state.theme); });
  }

  // delegation (result-elementet är stabilt; lyssnaren sätts en gång)
  result.addEventListener('click', (e) => {
    const tb = e.target.closest('[data-tab]');
    if (tb) { const t = tb.dataset.tab; result.querySelectorAll('[data-tab]').forEach((x) => x.classList.toggle('active', x.dataset.tab === t)); result.querySelectorAll('[data-panel]').forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== t)); return; }
    const vs = e.target.closest('[data-vis]'); if (vs) { state.visualMode = vs.dataset.vis; renderImage(false); return; }
    const rs = e.target.closest('[data-reshape]'); if (rs) { reshapeSoundtrack(); return; }
    const rf = e.target.closest('[data-refresh]'); if (rf) { refresh(rf.dataset.refresh); return; }
    const nv = e.target.closest('[data-nav]'); if (nv) { nav(nv.dataset.nav, +nv.dataset.d); return; }
  });

  // ---------- Flows ----------
  async function generateFresh(theme) {
    lastTheme = theme; closeRecent(); startLoading();
    let concept;
    try { const res = await fetch('/api/concept', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme }) }); concept = await res.json(); }
    catch (err) { stopLoading(); result.innerHTML = `<p class="text-stone-400">Something broke: ${esc(String(err))}. Try again.</p>`; result.classList.remove('hidden'); return; }
    stopLoading();
    if (!concept || concept.note === 'error') { result.innerHTML = `<div class="rounded-2xl border border-[#22222e] bg-[#13131c] p-6 text-stone-300">⚠️ Generation hiccupped${concept && concept.error ? ' (' + esc(concept.error) + ')' : ''}. Hit <strong class="text-[#c6ff00]">Forge it</strong> again.</div>`; result.classList.remove('hidden'); return; }
    if (!concept.theme) concept.theme = theme;
    initState(concept);
    buildResult(false);              // text + tomma slots syns direkt
    setSoundtrackMsg('Composing soundtrack with Suno…');
    // Bild, SFX och soundtrack hämtas parallellt och renderas var för sig när de blir klara.
    render('image', true);
    const jobs = [
      (async () => {
        try { const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: state.imagePrompt }) }); const j = await r.json(); if (j.url) pushVersion('image', { url: j.url, engine: j.engine }); } catch (e) {}
        render('image', false);
      })(),
      (async () => {
        state.gameBusy = true; render('gameview', true);
        const g = await fetchGameview(); if (g) pushVersion('gameview', g);
        state.gameBusy = false; render('gameview', false);
      })(),
      (async () => { const sfx = await fetchSfx(); if (sfx.length) { state.versions.sfx = [sfx]; state.idx.sfx = 0; } renderSfx(); })(),
      (async () => { const st = await fetchSoundtrack(); if (st) { state.versions.soundtrack = [st]; state.idx.soundtrack = 0; renderSoundtrack(); const a = document.querySelector('#soundtrack-slot audio'); if (a) a.play().catch(() => {}); } else renderSoundtrack(); })(),
    ];
    await Promise.allSettled(jobs);
    persist();
  }

  async function loadSearch(id) {
    closeRecent();
    let data;
    try { const r = await fetch('/api/gallery?id=' + encodeURIComponent(id)); if (!r.ok) return; data = await r.json(); } catch (e) { return; }
    if (!data || !data.state) return;
    state = Object.assign({ id: data.id }, data.state);
    lastTheme = state.theme || ''; input.value = state.theme || input.value;
    buildResult(true);
    window.scrollTo({ top: result.offsetTop - 20, behavior: 'smooth' });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const theme = input.value.trim(); if (!theme) return;
    const id = findCachedId(normalize(theme));
    if (id) loadSearch(id); else generateFresh(theme);
  });

  document.getElementById('surprise').addEventListener('click', () => { input.value = SURPRISES[Math.floor(Math.random() * SURPRISES.length)]; form.requestSubmit(); });
  const chipsEl = document.getElementById('chips');
  function renderChips() {
    const pool = [...SURPRISES]; const pick = [];
    for (let i = 0; i < 7 && pool.length; i++) pick.push(pool.splice(Math.floor(Math.random() * pool.length), 1)[0]);
    chipsEl.innerHTML = pick.map((t) => `<button type="button" class="chip rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">${t}</button>`).join('');
  }
  chipsEl.addEventListener('click', (e) => { const c = e.target.closest('.chip'); if (c) { input.value = c.textContent; form.requestSubmit(); } });
  document.getElementById('chip-shuffle').addEventListener('click', renderChips);
  renderChips();

  refreshGallery();
</script>
