      setSoundtrackMsg('Composing soundtrack with Suno… ' + Math.floor(waited / 1000) + 's');
      try { const r = await fetch('/api/soundtrack?taskId=' + encodeURIComponent(taskId)); const j = await r.json(); if (j.status === 'done' && j.url) return j.url; if (j.status === 'failed') return null; } catch (e) {}
    }
