---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Concept Forge — slot ideation engine"
  description="Type a vibe, get a complete slot game concept: name, art direction, mechanic, a music brief with a generated soundtrack, and marketing hooks. A demo by Carl Palmquist."
>
  <main class="min-h-screen bg-[#0a0a0f] text-stone-100 font-sans">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:py-12">

      <header class="mb-7">
        <div class="mb-3 flex items-center justify-between gap-3">
          <p class="inline-flex items-center gap-2 rounded-full border border-[#2a2a3a] bg-[#15151f] px-3 py-1 text-xs font-medium tracking-wide text-stone-400">
            <span class="h-1.5 w-1.5 rounded-full bg-[#c6ff00]"></span>
            A Carl Palmquist demo · slot ideation accelerator
          </p>
          <button type="button" id="theme-toggle" class="flex-none rounded-full border border-[#2a2a3a] bg-[#15151f] px-3 py-1 text-xs font-medium text-stone-300 hover:border-[#c6ff00]" title="Växla ljust/mörkt">☀️ Light</button>
        </div>
        <h1 class="text-5xl font-black uppercase leading-[0.95] tracking-tight sm:text-6xl">
          Concept <span class="text-[#c6ff00]">Forge</span>
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-400">
          Throw it a vibe. It hands back a complete game concept — names, art direction, mechanic,
          a <span class="font-semibold text-[#ff2d78]">music brief with a generated soundtrack</span>,
          and launch hooks. Re-roll any piece on its own and flip between versions.
        </p>
      </header>

      <form id="forge-form" class="mb-6">
        <div class="flex flex-col gap-3 sm:flex-row">
          <div class="relative flex-1">
            <input id="theme" type="text" autocomplete="off" placeholder="neon yakuza with a country vibe…"
              class="w-full rounded-xl border border-[#2a2a3a] bg-[#15151f] px-4 py-3.5 text-lg text-stone-100 placeholder-stone-500 outline-none focus:border-[#c6ff00]" />
            <!-- Google-style autocomplete: visas bara när fältet fokuseras och är tomt (recent forges promotar redan spenderade credits) -->
            <div id="ac-panel" class="hidden absolute left-0 right-0 top-full z-30 mt-2 max-h-[60vh] overflow-auto rounded-xl border border-[#2a2a3a] bg-[#15151f] p-1.5 shadow-2xl"></div>
          </div>
          <button id="generate" type="submit"
            class="rounded-xl bg-[#c6ff00] px-7 py-3.5 text-lg font-black uppercase tracking-tight text-black transition hover:bg-[#d6ff3a] disabled:opacity-50">Forge it</button>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-2 text-sm">
          <button type="button" id="surprise" class="order-1 flex-none text-[#ff2d78] hover:underline">⚡ Surprise me</button>
          <span class="order-1 hidden flex-none text-stone-600 sm:order-2 sm:inline">·</span>
          <div class="relative order-2 ml-auto flex-none sm:order-4 sm:ml-0" id="recent-wrap">
            <button type="button" id="recent-btn" class="rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 hover:border-[#c6ff00]">⟲ Gallery <span id="recent-count" class="text-stone-500"></span> ▾</button>
            <div id="recent-panel" class="hidden absolute right-0 z-20 mt-2 w-80 max-w-[calc(100vw-2rem)] max-h-96 overflow-auto rounded-xl border border-[#2a2a3a] bg-[#15151f] p-2 shadow-2xl"></div>
          </div>
          <div class="order-3 flex w-full min-w-0 items-center gap-2 sm:order-3 sm:w-auto sm:flex-1">
            <span class="flex-none text-stone-500">try:</span>
            <div class="relative min-w-0 flex-1">
              <span id="chips" class="no-scrollbar flex items-center gap-2 overflow-x-auto whitespace-nowrap pr-7"></span>
              <div class="pointer-events-none absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-[#0a0a0f] to-transparent"></div>
              <button type="button" id="chip-more" class="absolute right-0 top-1/2 -translate-y-1/2 px-1 text-sm leading-none text-stone-500 hover:text-[#c6ff00]" title="Nya förslag">↻</button>
            </div>
          </div>
        </div>
      </form>

      <!-- Tunn avdelare: signalerar att ovan är sökfältet, nedan är resultatet (à la Google) -->
      <div class="mt-8 mb-7 border-t border-[#1c1c28]"></div>

      <div id="loading" class="hidden py-10">
        <canvas id="pong" class="mx-auto block w-full max-w-3xl rounded-2xl border border-[#22222e] bg-[#0c0c12]" style="aspect-ratio:2/1"></canvas>
        <p id="loading-msg" class="mt-4 text-center text-stone-400">Sketching characters…</p>
        <p class="mt-1 text-center text-xs text-stone-600">⚡ Beat the house while it forges — move your paddle with the mouse</p>
      </div>

      <div id="result-wrap" class="relative">
        <button type="button" id="nav-prev" class="cf-swipe cf-swipe-l hidden" title="Previous concept (←)" aria-label="Previous">‹</button>
        <section id="result" class="hidden"></section>
        <button type="button" id="nav-next" class="cf-swipe cf-swipe-r hidden" title="Next concept (→)" aria-label="Next">›</button>
        <div id="nav-counter" class="hidden absolute left-1/2 bottom-0 -translate-x-1/2 translate-y-7 rounded-full border border-[#2a2a3a] bg-[#15151f]/80 px-3 py-1 text-xs tabular-nums text-stone-400"></div>
      </div>

      <footer class="mt-14 border-t border-[#1c1c28] pt-6 text-xs leading-relaxed text-stone-500">
        <p><span class="font-semibold text-stone-400">Ideation accelerator, not an art generator.</span>
        It produces direction and briefs for humans to refine — the model never ships the final asset.
        That keeps it on the right side of regulatory art audits.</p>
        <p class="mt-2">Built with Claude Code in an evening and deployed on this site. — Carl Palmquist</p>
      </footer>
    </div>
  </main>
</Layout>

<style is:global>
  .no-scrollbar { -ms-overflow-style:none; scrollbar-width:none; }
  .no-scrollbar::-webkit-scrollbar { display:none; }
  /* Subtil bottenfade på textrutan → signalerar att det finns mer att scrolla */
  .cf-scrollfade { -webkit-mask-image:linear-gradient(to bottom, #000 calc(100% - 20px), transparent); mask-image:linear-gradient(to bottom, #000 calc(100% - 20px), transparent); }

  /* ---- Light mode: remappar varje färg-token (Game-vyn lämnas mörk medvetet) ---- */
  /* Bakgrunder */
  .cf-light .bg-\[\#0a0a0f\] { background-color:#f3f4f7 !important; }
  .cf-light .bg-\[\#13131c\] { background-color:#ffffff !important; }
  .cf-light .bg-\[\#15151f\] { background-color:#eceef2 !important; }
  .cf-light .bg-\[\#1d212c\] { background-color:#e3e8f0 !important; }
  /* Kanter */
  .cf-light .border-\[\#2a2a3a\] { border-color:#d7d9e1 !important; }
  .cf-light .border-\[\#22222e\] { border-color:#e1e3e9 !important; }
  .cf-light .border-\[\#1c1c28\] { border-color:#e7e9ef !important; }
  /* Text (stone-skala) */
  .cf-light .text-stone-100 { color:#15161a !important; }
  .cf-light .text-stone-200 { color:#202128 !important; }
  .cf-light .text-stone-300 { color:#33353d !important; }
  .cf-light .text-stone-400 { color:#4b4d57 !important; }
  .cf-light .text-stone-500 { color:#6a6d78 !important; }
  .cf-light .text-stone-600 { color:#9499a4 !important; }
  .cf-light .placeholder-stone-500::placeholder { color:#9aa0ac !important; }
  /* Accenter i light mode: lime-grönt blir för svagt mot ljust → byt ALLT lime mot mörkare grön (rosa behålls). */
  .cf-light .text-\[\#c6ff00\] { color:#0a8f54 !important; }
  .cf-light .text-\[\#ff2d78\] { color:#d81b60 !important; }
  .cf-light .bg-\[\#c6ff00\] { background-color:#0a8f54 !important; color:#fff !important; }
  .cf-light .bg-\[\#d6ff3a\] { background-color:#0fa863 !important; }   /* FORGE IT hover: ljusare emerald */
  .cf-light .bg-\[\#c6ff00\]\/15 { background-color:rgba(10,143,84,.15) !important; }
  .cf-light .hover\:bg-\[\#1d212c\]:hover { background-color:#e7eaf0 !important; }   /* gallery/autocomplete-rad vid hover i light mode (annars blir raden svart) */
  .cf-light .border-\[\#c6ff00\] { border-color:#0a8f54 !important; }
  .cf-light .focus\:border-\[\#c6ff00\]:focus { border-color:#0a8f54 !important; }
  .cf-light .ring-\[\#c6ff00\]\/40 { --tw-ring-color:rgba(10,143,84,.4) !important; }
  .cf-light .cf-tab.active { background:#0a8f54; color:#fff; border-color:#0a8f54; }
  .cf-light .cf-refresh { color:#0a8f54; }
  /* Chips-fade tonar mot ljus bakgrund i light mode */
  .cf-light .from-\[\#0a0a0f\] { --tw-gradient-from:#f3f4f7 var(--tw-gradient-from-position) !important; --tw-gradient-to:rgb(243 244 247 / 0) var(--tw-gradient-to-position) !important; }
  /* Komponent-CSS (cf-tab / cf-mini) i light */
  .cf-light .cf-tab { border-color:#d7d9e1; color:#33353d; }
  .cf-light .cf-tab:hover { border-color:#0a8f54; }
  .cf-light .cf-mini { border-color:#d7d9e1; background:#eceef2; color:#5b6675; }
  .cf-light .cf-mini:hover:not(:disabled) { border-color:#0a8f54; color:#1a1a1f; }
  /* Pong-arenan förblir mörk (egen kanvas), men dess ram följer light */
  .cf-tab { display:inline-block; padding:7px 13px; border-radius:9px; font-size:12px; font-weight:800; letter-spacing:-0.01em; text-transform:uppercase; border:1px solid #2a2a3a; color:#d6d3d1; background:transparent; cursor:pointer; }
  .cf-tab:hover { border-color:#c6ff00; }
  .cf-tab.active { background:#c6ff00; color:#000; border-color:#c6ff00; }
  .cf-ctrl { display:inline-flex; align-items:center; gap:4px; vertical-align:middle; }
  .cf-mini { display:inline-flex; align-items:center; justify-content:center; height:22px; min-width:22px; padding:0 5px; border:1px solid #2a2a3a; border-radius:6px; background:#15151f; color:#9aa3b2; font-size:12px; line-height:1; cursor:pointer; font-family:inherit; }
  .cf-mini:hover:not(:disabled) { border-color:#c6ff00; color:#e6e8ee; }
  .cf-mini:disabled { opacity:.35; cursor:default; }
  .cf-refresh { color:#c6ff00; }
  .cf-ver { font-size:10px; color:#5b6675; min-width:26px; text-align:center; }
  .cf-spin { display:inline-block; width:11px; height:11px; border:2px solid #2a2a3a; border-top-color:#c6ff00; border-radius:50%; animation:cfspin .7s linear infinite; }
  @keyframes cfspin { to { transform:rotate(360deg); } }

  /* ---- Nivå 2: komposit game-vy (key art mood-bg + kodad reel-ram/HUD + AI-symboler) ---- */
  .cf-slot { position:relative; width:100%; aspect-ratio:1/1; overflow:hidden; border-radius:16px; border:1px solid hsl(var(--hue,80) 45% 22%); background:#08080d; }
  .cf-slot-bg { position:absolute; inset:0; background-size:cover; background-position:center; transform:scale(1.05); }
  .cf-slot-scrim { position:absolute; inset:0; background:radial-gradient(125% 95% at 50% 42%, transparent 28%, rgba(5,5,9,.5) 80%), linear-gradient(180deg, rgba(5,5,9,.5) 0%, transparent 20%, transparent 64%, rgba(5,5,9,.82) 100%); }
  .cf-slot-fallbg { position:absolute; inset:0; background:radial-gradient(120% 75% at 50% 0%, hsl(var(--hue,80) 55% 13%) 0%, #0b0b11 72%); }
  .cf-slot-inner { position:absolute; inset:0; display:flex; flex-direction:column; gap:6px; padding:11px; }
  .cf-slot-top { display:flex; align-items:center; gap:7px; flex-wrap:wrap; padding-right:120px; min-height:22px; }
  .cf-slot-title { font-weight:900; text-transform:uppercase; letter-spacing:-.02em; font-size:clamp(13px,3vw,20px); line-height:1; color:#fff; text-shadow:0 2px 6px rgba(0,0,0,.9), 0 1px 0 #000; }
  .cf-slot-feat { font-size:9px; font-weight:800; text-transform:uppercase; letter-spacing:.02em; color:#0a0a0f; background:hsl(var(--hue,80) 90% 62%); border-radius:999px; padding:3px 8px; white-space:nowrap; box-shadow:0 1px 4px rgba(0,0,0,.5); }
  .cf-reels { flex:1; min-height:0; display:flex; align-items:center; justify-content:center; }
  .cf-frame { position:relative; width:76%; height:100%; padding:7px; border-radius:13px; border:2px solid hsl(var(--hue,80) 62% 48%); background:linear-gradient(180deg, hsl(var(--hue,80) 40% 12% / .8), hsl(var(--hue,80) 35% 6% / .88)); box-shadow:0 0 0 3px rgba(0,0,0,.45), 0 0 26px hsl(var(--hue,80) 70% 42% / .4), inset 0 0 34px rgba(0,0,0,.55); }
  .cf-grid { width:100%; height:100%; display:grid; gap:4px; }
  .cf-cell { position:relative; display:flex; align-items:center; justify-content:center; overflow:hidden; border-radius:8px; border:1px solid hsl(var(--hue,80) 50% 32% / .55); background:linear-gradient(160deg, hsl(var(--hue,80) 30% 15% / .82), hsl(var(--hue,80) 28% 7% / .9)); box-shadow:inset 0 1px 0 hsl(var(--hue,80) 55% 34% / .4); }
  .cf-cell img { width:88%; height:88%; object-fit:contain; filter:drop-shadow(0 2px 5px rgba(0,0,0,.6)); }
  .cf-cell.cf-letter { font-weight:900; font-style:italic; font-size:clamp(12px,3.1vw,24px); letter-spacing:-.03em; color:hsl(var(--hue,80) 82% 66%); text-shadow:0 0 7px hsl(var(--hue,80) 85% 48% / .6), 0 2px 3px rgba(0,0,0,.8); }
  .cf-grid.cf-spinning .cf-cell { animation:cfreel .42s ease; }
  @keyframes cfreel { 0% { transform:translateY(-9%); filter:blur(3px); opacity:.45; } 100% { transform:none; filter:blur(0); opacity:1; } }
  .cf-hud { display:flex; align-items:center; gap:6px; }
  .cf-hud .cf-ic { width:28px; height:28px; flex:none; border-radius:8px; background:rgba(21,21,31,.85); border:1px solid #2a2a3a; color:#cbd2dd; font-size:13px; display:flex; align-items:center; justify-content:center; }
  .cf-buy { flex:none; display:flex; flex-direction:column; align-items:center; justify-content:center; line-height:1.05; padding:4px 9px; border-radius:9px; background:linear-gradient(#ffd23f,#f3a51c); color:#3a2700; font-weight:900; font-size:8px; text-transform:uppercase; letter-spacing:.02em; box-shadow:0 2px 6px rgba(0,0,0,.5); }
  .cf-buy b { font-size:10px; }
  .cf-meter { display:flex; flex-direction:column; line-height:1.15; text-shadow:0 1px 3px rgba(0,0,0,.9); }
  .cf-meter span { font-size:7px; color:#aeb6c4; text-transform:uppercase; letter-spacing:.05em; }
  .cf-meter b { font-size:12px; color:#fff; font-weight:800; }
  .cf-vol { display:flex; align-items:center; gap:2px; }
  .cf-vol i { width:4px; height:10px; border-radius:1px; background:#3a3a4a; }
  .cf-vol i.on { background:#ff2d78; }
  .cf-bet { display:flex; align-items:center; gap:5px; }
  .cf-step { width:23px; height:23px; flex:none; border-radius:50%; background:rgba(21,21,31,.85); border:1px solid #2a2a3a; color:#cbd2dd; font-size:14px; font-weight:800; display:flex; align-items:center; justify-content:center; cursor:pointer; }
  .cf-spinbtn { margin-left:auto; flex:none; width:50px; height:50px; border:none; border-radius:50%; background:radial-gradient(circle at 50% 32%, #d9ff5a, #9ed400); color:#0a0a0f; font-size:22px; font-weight:900; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 0 0 4px rgba(198,255,0,.16), 0 4px 12px rgba(0,0,0,.5); transition:transform .1s; }
  .cf-spinbtn:active { transform:scale(.9); }
  .cf-spinbtn.cf-spinning { animation:cfspinbtn .42s linear; }
  @keyframes cfspinbtn { to { transform:rotate(360deg); } }
  /* Onboarding: pulsande ring runt Recent tills man hittat dit (slutar vid klick) */
  @keyframes cfpulse { 0%{box-shadow:0 0 0 0 rgba(198,255,0,.5)} 70%{box-shadow:0 0 0 9px rgba(198,255,0,0)} 100%{box-shadow:0 0 0 0 rgba(198,255,0,0)} }
  .cf-pulse { animation:cfpulse 1.9s ease-out infinite; border-color:#c6ff00 !important; }
  /* Invite: SPIN-knappen andas tills första snurr → bjuder in att trycka */
  @keyframes cfinvite { 0%,100%{box-shadow:0 0 0 4px rgba(198,255,0,.16),0 4px 12px rgba(0,0,0,.5)} 50%{box-shadow:0 0 0 9px rgba(198,255,0,.38),0 0 24px rgba(198,255,0,.55)} }
  .cf-spinbtn.cf-invite { animation:cfinvite 1.55s ease-in-out infinite; }
  /* Mjuk crossfade när bild-vyn växlar (auto-rotation Mood↔Game) */
  #cf-image img, #cf-image .cf-slot { animation:cffade .5s ease; }
  @keyframes cffade { from{opacity:.2} to{opacity:1} }
  /* Prev/Next-karusell: diskreta chevroner i marginalen (bläddra galleriet utan Recent) */
  .cf-swipe { position:absolute; top:46%; transform:translateY(-50%); z-index:20; width:46px; height:74px; display:flex; align-items:center; justify-content:center; border:none; background:transparent; color:#ff2d78; font-size:34px; font-weight:600; line-height:1; cursor:pointer; opacity:.4; transition:transform .15s, opacity .15s; }
  .cf-swipe.hidden { display:none; }  /* JS-toggeln måste vinna över .cf-swipe display:flex (annars syns pilarna alltid, även med tomt galleri) */
  .cf-swipe:hover { transform:translateY(-50%) scale(1.18); opacity:1; }   /* diskret i vila, lyser upp vid hover */
  .cf-light .cf-swipe { color:#e0005f; opacity:.55; }   /* light mode: djupare rosa + lite mer synlig mot ljus bakgrund */
  .cf-swipe-l { left:-3.25rem; } .cf-swipe-r { right:-3.25rem; }
  /* Landningsläge: inget resultat än, men galleriet finns → ge pilarna höjd så de syns och går att klicka */
  #result-wrap.landing { min-height:200px; }
  @media (max-width:1180px) { .cf-swipe { background:rgba(12,12,18,.55); border-radius:12px; } .cf-light .cf-swipe { background:rgba(255,255,255,.6); } .cf-swipe-l { left:4px; } .cf-swipe-r { right:4px; } }
  /* Mobil: göm karusell-chevronerna helt (touch-swipe på resultatet + Gallery-dropdownen sköter navigeringen) och ta bort den tomma landningsytan */
  @media (max-width:640px) { .cf-swipe { display:none; } #result-wrap.landing { min-height:0; } }
  /* Tap-again-bekräftelse på ↻ (förhindrar dyra mistryck under demo) */
  .cf-confirm { border-color:#ffb020 !important; color:#ffb020 !important; box-shadow:0 0 0 2px rgba(255,176,32,.28); }
</style>

<script is:inline>
  const form = document.getElementById('forge-form');
  const input = document.getElementById('theme');
  const btn = document.getElementById('generate');
  const loading = document.getElementById('loading');
  const loadingMsg = document.getElementById('loading-msg');
  const result = document.getElementById('result');
  const recentBtn = document.getElementById('recent-btn');
  const recentPanel = document.getElementById('recent-panel');
  // Onboarding: pulsa Recent tills användaren hittat dit (klick), eller automatiskt efter 16 s.
  let recentTouched = false;
  const stopRecentPulse = () => { recentTouched = true; recentBtn.classList.remove('cf-pulse'); };
  setTimeout(stopRecentPulse, 16000);
  const recentCount = document.getElementById('recent-count');

  // ---------- Ljust/mörkt tema ----------
  function applyTheme(light) {
    document.documentElement.classList.toggle('cf-light', light);
    const tb = document.getElementById('theme-toggle');
    if (tb) tb.textContent = light ? '🌙 Dark' : '☀️ Light';
  }
  (function initTheme() {
    let light = false;
    try { light = localStorage.getItem('forge-theme') === 'light'; } catch (e) {}
    applyTheme(light);
    const tb = document.getElementById('theme-toggle');
    if (tb) tb.addEventListener('click', () => {
      const next = !document.documentElement.classList.contains('cf-light');
      applyTheme(next);
      try { localStorage.setItem('forge-theme', next ? 'light' : 'dark'); } catch (e) {}
    });
  })();

  const SURPRISES = ['neon yakuza synthwave heist','haunted disco inferno','viking metal feast','deep sea treasure cult','cyberpunk samurai noodle bar','wild west bank robbery at dawn','baroque vampire opera','arctic monster hunt','lucha libre luchador showdown','egyptian afterlife game show','jurassic jungle bounty','voodoo new orleans jazz funeral','haunted carnival freakshow','retro arcade hacker den','greek underworld boxing','candy factory sugar rush','pirate ghost ship raid','dumpling dojo kung fu','space western bounty hunter','gothic cathedral exorcism','tropical tiki volcano party','steampunk airship robbery','zombie football hooligans','samurai cyber dragon','wild safari jackpot stampede','noir detective speakeasy','frost giant ragnarok','day of the dead mariachi fiesta','toxic sewer mutant rave','medieval dragon siege','street graffiti monster crew','sushi conveyor chaos'];
  const LOADING_MSGS = ['Sketching characters…','Inking the key art…','Designing the bonus round…','Stress-testing the max win…','Writing the launch hooks…'];

  const esc = (s) => String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  const normalize = (s) => String(s || '').trim().toLowerCase().replace(/\s+/g,' ');

  let lastTheme = '';
  let state = null;
  const VCAP = 6;

  // ---------- Delat gallery (server, Cloudflare KV) ----------
  let galleryList = [];
  async function refreshGallery() {
    try { const r = await fetch('/api/gallery'); const j = await r.json(); galleryList = Array.isArray(j.list) ? j.list : []; }
    catch (e) { galleryList = []; }
    renderRecent();
    if (typeof updateSwipeVis === 'function') updateSwipeVis();
  }
  const findCachedId = (key) => { const m = galleryList.find((x) => x.key === key); return m ? m.id : null; };
  async function delEntry(id) { try { await fetch('/api/gallery?id=' + encodeURIComponent(id), { method: 'DELETE' }); } catch (e) {} refreshGallery(); }
  async function clearHist() { try { await fetch('/api/gallery?all=1', { method: 'DELETE' }); } catch (e) {} refreshGallery(); }

  function timeAgo(ts) {
    const s = Math.floor((Date.now() - ts) / 1000);
    if (s < 60) return 'just now';
    if (s < 3600) return Math.floor(s / 60) + 'm ago';
    if (s < 86400) return Math.floor(s / 3600) + 'h ago';
    return Math.floor(s / 86400) + 'd ago';
  }
  function renderRecent() {
    const hist = galleryList;
    recentCount.textContent = hist.length ? '(' + hist.length + ')' : '';
    if (hist.length && !recentTouched) recentBtn.classList.add('cf-pulse'); else recentBtn.classList.remove('cf-pulse');
    if (!hist.length) { recentPanel.innerHTML = '<p class="px-2 py-3 text-xs text-stone-500">No saved concepts yet.</p>'; return; }
    // Tumnagel-cell: temats initial på gradient som ligger BAKOM bilden; om bilden faller bort tas den bara bort.
    const cell = (m) => `<div class="relative h-9 w-9 flex-shrink-0 overflow-hidden rounded">
        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-[#2a2a3a] to-[#15151f] text-xs font-black text-stone-500">${esc(String(m.theme || '?').trim().charAt(0).toUpperCase())}</div>
        ${m.thumb ? `<img src="${esc(m.thumb)}" onerror="this.remove()" class="absolute inset-0 h-9 w-9 object-cover" />` : ''}
