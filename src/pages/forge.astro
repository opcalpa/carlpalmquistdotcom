  }
  const closeRecent = () => recentPanel.classList.add('hidden');
  recentBtn.addEventListener('click', (e) => { e.stopPropagation(); stopRecentPulse(); recentPanel.classList.toggle('hidden'); });
  document.addEventListener('click', (e) => { if (!e.target.closest('#recent-wrap')) closeRecent(); });

  // ---------- Prev/Next-karusell: bläddra galleriet direkt på resultatet (utan Recent) ----------
  const navPrev = document.getElementById('nav-prev'), navNext = document.getElementById('nav-next'), navCounter = document.getElementById('nav-counter');
  // Visa pilarna när det finns något att plocka fram — även på landningssidan (inget resultat än),
  // så man kan börja bläddra i galleriet direkt. Räknaren visas bara när ett resultat faktiskt är laddat.
  const resultWrap = document.getElementById('result-wrap');
  function updateSwipeVis() {
    const resultShown = !result.classList.contains('hidden');
    const show = resultShown ? galleryList.length > 1 : galleryList.length >= 1;
    navPrev.classList.toggle('hidden', !show); navNext.classList.toggle('hidden', !show);
    if (resultWrap) resultWrap.classList.toggle('landing', show && !resultShown);  // ger pilarna höjd i tom yta
    const showCounter = resultShown && galleryList.length > 1;
    navCounter.classList.toggle('hidden', !showCounter);
    if (showCounter) { let idx = galleryList.findIndex((m) => m.id === (state && state.id)); if (idx === -1) idx = 0; navCounter.textContent = (idx + 1) + ' / ' + galleryList.length; }
  }
  // Vänster = nyare granne (idx-1), höger = äldre (idx+1), wrappar runt. Vid sidstart (inget koncept
  // laddat) plockar första klicket fram det senaste konceptet ur galleriet.
  function navConcept(dir) {
    if (!galleryList.length) return;
    stopRecentPulse();
    const curId = state && state.id;
    const idx = galleryList.findIndex((m) => m.id === curId);
    const t = idx === -1 ? 0 : (idx + dir + galleryList.length) % galleryList.length;
    const target = galleryList[t]; if (target && target.id !== curId) loadSearch(target.id);
  }
  navPrev.addEventListener('click', () => navConcept(-1));
  navNext.addEventListener('click', () => navConcept(1));
  // Piltangenter (när man inte skriver i ett fält)
  document.addEventListener('keydown', (e) => {
    if (!galleryList.length) return;
    const tag = (e.target.tagName || '').toLowerCase();
    if (tag === 'input' || tag === 'textarea') return;
    if (e.key === 'ArrowLeft') { e.preventDefault(); navConcept(-1); }
    else if (e.key === 'ArrowRight') { e.preventDefault(); navConcept(1); }
  });
  // Touch-swipe på resultatet (horisontell drag > 60 px)
  let touchX = null, touchY = null;
  result.addEventListener('touchstart', (e) => { const t = e.changedTouches[0]; touchX = t.clientX; touchY = t.clientY; }, { passive: true });
  result.addEventListener('touchend', (e) => {
    if (touchX == null) return; const t = e.changedTouches[0];
    const dx = t.clientX - touchX, dy = t.clientY - touchY; touchX = null;
    if (Math.abs(dx) > 60 && Math.abs(dx) > Math.abs(dy) * 1.5) navConcept(dx < 0 ? 1 : -1);
  }, { passive: true });

  // Vänlig gräns-popup när IP:n gjort sina 3 forges → styr mot Recent.
  function showLimitPopup() {
    if (document.getElementById('cf-limit')) return;
    const el = document.createElement('div');
    el.id = 'cf-limit';
    el.className = 'fixed inset-0 z-50 flex items-center justify-center bg-black/70 p-4';
    el.innerHTML = `<div class="relative w-full max-w-md rounded-2xl border border-[#2a2a3a] bg-[#15151f] p-6 text-center shadow-2xl">
      <div class="mb-3 text-4xl">🎰</div>
      <h3 class="mb-2 text-xl font-black uppercase tracking-tight text-[#c6ff00]">Easy there, high roller</h3>
      <p class="mb-5 text-sm leading-relaxed text-stone-300">You've spent your <strong>10 free forges</strong> — the house needs a breather. 😅 But the vault's wide open: every concept already forged is yours to play with. Hit <strong class="text-[#c6ff00]">⟲ Gallery</strong> up top and dig in. Come back tomorrow for more.</p>
      <div class="flex flex-col gap-2">
        <button id="cf-limit-recent" type="button" class="rounded-xl bg-[#c6ff00] px-5 py-2.5 font-black uppercase tracking-tight text-black transition hover:bg-[#d6ff3a]">⟲ Browse the gallery</button>
        <button id="cf-limit-close" type="button" class="text-xs text-stone-500 hover:text-stone-300">Maybe later</button>
      </div>
    </div>`;
    document.body.appendChild(el);
    const close = () => { el.remove(); document.removeEventListener('keydown', onKey); };
    const onKey = (e) => { if (e.key === 'Escape') close(); };
    document.addEventListener('keydown', onKey);
    el.addEventListener('click', (e) => { if (e.target === el) close(); });
    el.querySelector('#cf-limit-close').addEventListener('click', close);
    el.querySelector('#cf-limit-recent').addEventListener('click', (ev) => { ev.stopPropagation(); close(); recentPanel.classList.remove('hidden'); renderRecent(); try { recentBtn.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) {} });
  }

  // ---------- Loading ----------
  let msgTimer;
  const holdAudio = new Audio('/hold-music.mp3'); holdAudio.loop = true; holdAudio.volume = 0.45;
  function startLoading() { result.classList.add('hidden'); loading.classList.remove('hidden'); btn.disabled = true; try { holdAudio.currentTime = 0; holdAudio.play().catch(() => {}); } catch (e) {} let i = 0; loadingMsg.textContent = LOADING_MSGS[0]; msgTimer = setInterval(() => { i = (i + 1) % LOADING_MSGS.length; loadingMsg.textContent = LOADING_MSGS[i]; }, 1500); startPong(); updateSwipeVis(); }
  function stopLoading() { clearInterval(msgTimer); loading.classList.add('hidden'); btn.disabled = false; try { holdAudio.pause(); } catch (e) {} stopPong(); }

  // ---------- Pong-loader: du mot datorn medan konceptet genereras ----------
  const pong = { raf: 0, running: false, cleanup: null };
  function startPong() {
    const c = document.getElementById('pong'); if (!c) return;
    const ctx = c.getContext('2d'); if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;
    const rect = c.getBoundingClientRect();
    const w = Math.max(320, Math.round(rect.width)), h = Math.round(rect.height) || Math.round(w / 2);
    c.width = w * dpr; c.height = h * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    const PADH = h * 0.2, PADW = 8, R = Math.max(5, h * 0.02), SPD = w * 0.0065;
    const st = { py: h / 2 - PADH / 2, cy: h / 2 - PADH / 2, bx: w / 2, by: h / 2, bvx: -SPD, bvy: SPD * 0.5, ps: 0, cs: 0, mouse: null };
    const onMove = (e) => { const r = c.getBoundingClientRect(); st.mouse = ((e.touches ? e.touches[0].clientY : e.clientY) - r.top); };
    c.addEventListener('mousemove', onMove); c.addEventListener('touchmove', onMove, { passive: true });
    pong.cleanup = () => { c.removeEventListener('mousemove', onMove); c.removeEventListener('touchmove', onMove); };
    const reset = (dir) => { st.bx = w / 2; st.by = h / 2; st.bvx = dir * SPD; st.bvy = (Math.random() * 2 - 1) * SPD * 0.8; };
    pong.running = true;
    const frame = () => {
      if (!pong.running) return;
      if (st.mouse != null) st.py += ((st.mouse - PADH / 2) - st.py) * 0.28;
      st.py = Math.max(0, Math.min(h - PADH, st.py));
      const cpuStep = h * 0.014;   // släpning → slagbar
      st.cy += Math.max(-cpuStep, Math.min(cpuStep, (st.by - PADH / 2 - st.cy) * 0.11));
      st.cy = Math.max(0, Math.min(h - PADH, st.cy));
      st.bx += st.bvx; st.by += st.bvy;
      if (st.by < R) { st.by = R; st.bvy = Math.abs(st.bvy); }
      if (st.by > h - R) { st.by = h - R; st.bvy = -Math.abs(st.bvy); }
      if (st.bx - R < PADW + 4 && st.by > st.py && st.by < st.py + PADH && st.bvx < 0) { st.bvx = Math.abs(st.bvx) * 1.05; st.bvy = ((st.by - (st.py + PADH / 2)) / (PADH / 2)) * SPD; }
      if (st.bx + R > w - PADW - 4 && st.by > st.cy && st.by < st.cy + PADH && st.bvx > 0) { st.bvx = -Math.abs(st.bvx) * 1.05; st.bvy = ((st.by - (st.cy + PADH / 2)) / (PADH / 2)) * SPD; }
      if (st.bx < -R) { st.cs++; reset(-1); }
      if (st.bx > w + R) { st.ps++; reset(1); }
      ctx.clearRect(0, 0, w, h);
      ctx.strokeStyle = '#22222e'; ctx.lineWidth = 2; ctx.setLineDash([6, 10]); ctx.beginPath(); ctx.moveTo(w / 2, 0); ctx.lineTo(w / 2, h); ctx.stroke(); ctx.setLineDash([]);
      ctx.fillStyle = '#5b6675'; ctx.font = `800 ${Math.round(h * 0.07)}px ui-sans-serif,system-ui,sans-serif`; ctx.textAlign = 'center';
      ctx.fillText('YOU', w * 0.32, h * 0.12); ctx.fillText('HOUSE', w * 0.68, h * 0.12);
      ctx.fillStyle = '#9aa3b2'; ctx.font = `800 ${Math.round(h * 0.16)}px ui-sans-serif,system-ui,sans-serif`;
      ctx.fillText(st.ps, w * 0.32, h * 0.3); ctx.fillText(st.cs, w * 0.68, h * 0.3);
      ctx.fillStyle = '#c6ff00'; ctx.fillRect(4, st.py, PADW, PADH);
      ctx.fillStyle = '#ff2d78'; ctx.fillRect(w - PADW - 4, st.cy, PADW, PADH);
      ctx.fillStyle = '#e7eaf0'; ctx.beginPath(); ctx.arc(st.bx, st.by, R, 0, Math.PI * 2); ctx.fill();
      pong.raf = requestAnimationFrame(frame);
    };
    pong.raf = requestAnimationFrame(frame);
  }
  function stopPong() { pong.running = false; cancelAnimationFrame(pong.raf); if (pong.cleanup) { pong.cleanup(); pong.cleanup = null; } }

  // ---------- Version state ----------
  // Fallback-TL;DR om konceptet saknar feature_intro (Claude utelämnar det ibland) → bygg 3 kort
  // ur mekaniken så fliken aldrig visar "No summary yet." (mekanik / bonus / max win, samma ordning som korten).
  function tldrFromConcept(c) {
    const m = (c && c.mechanic) || {}, ma = (c && c.math) || {}, out = [];
    if (m.signature_feature || m.base_game) out.push(m.signature_feature || m.base_game);
    if (m.bonus_round) out.push(m.bonus_round);
    if (ma.suggested_max_win) { const w = String(ma.suggested_max_win); out.push('MAX WIN ' + w + (/x/i.test(w) ? '' : 'x')); }
    return out;
  }
  function initState(c) {
    state = {
      id: null, theme: c.theme || lastTheme || '', imagePrompt: c.image_prompt || c.theme || lastTheme || '', conceptEngine: c.engine || '',
      featureName: c.feature_name || '', featureIntro: (Array.isArray(c.feature_intro) && c.feature_intro.length) ? c.feature_intro : tldrFromConcept(c),
      symbolPrompts: Array.isArray(c.symbols) ? c.symbols : [],
      versions: {
        title: [{ names: c.names || [], logline: c.logline || '' }],
        art: [c.art || {}],
        mechanic: [{ mechanic: c.mechanic || {}, math: c.math || {} }],
        music: [{ music: c.music || {}, soundtrack_prompt: c.soundtrack_prompt || '', sfxPrompts: c.sfx || [] }],
        hooks: [c.hooks || []],
        image: c.image_url ? [{ url: c.image_url, engine: c.engine_image || null }] : [],
        soundtrack: [], sfx: [], animation: [], gameview: [], symbols: [],
      },
      idx: { title: 0, art: 0, mechanic: 0, music: 0, hooks: 0, image: 0, soundtrack: 0, sfx: 0, animation: 0, gameview: 0, symbols: 0 },
      visualMode: 'mood', animBusy: false, gameBusy: false, symbolsBusy: false, grid: null, spinning: false,
    };
  }
  // Bakåtkompat: äldre sparade states saknar symbols/grid-fält → fyll i så de inte kraschar.
  function hydrate(s) {
    s.versions = s.versions || {};
    if (!Array.isArray(s.versions.symbols)) s.versions.symbols = [];
    s.idx = s.idx || {};
    if (s.idx.symbols == null) s.idx.symbols = 0;
    if (!Array.isArray(s.symbolPrompts)) s.symbolPrompts = [];
    if (s.visualMode == null) s.visualMode = 'mood';
    s.symbolsBusy = false; s.grid = null; s.spinning = false;
    return s;
  }
  const cur = (comp) => (state.versions[comp] || [])[state.idx[comp]];
  function pushVersion(comp, value) { const a = state.versions[comp] || (state.versions[comp] = []); a.push(value); while (a.length > VCAP) a.shift(); state.idx[comp] = a.length - 1; }
  function flatConcept() {
    const t = cur('title') || {}, m = cur('mechanic') || { mechanic: {}, math: {} }, mu = cur('music') || { music: {} };
    return { names: t.names, logline: t.logline, art: cur('art') || {}, mechanic: m.mechanic, math: m.math, music: mu.music, hooks: cur('hooks') || [] };
  }

  // ---------- Controls ----------
  function ctrl(comp, busy) {
    const n = state.versions[comp].length, i = state.idx[comp];
    const nav = n > 1 ? `<button class="cf-mini" data-nav="${comp}" data-d="-1" ${i <= 0 ? 'disabled' : ''}>‹</button><span class="cf-ver">${i + 1}/${n}</span><button class="cf-mini" data-nav="${comp}" data-d="1" ${i >= n - 1 ? 'disabled' : ''}>›</button>` : '';
    return `<span class="cf-ctrl">${nav}<button class="cf-mini cf-refresh" data-refresh="${comp}" title="Regenerate this">${busy ? '<span class="cf-spin"></span>' : '↻'}</button></span>`;
  }

  // ---------- Per-component render ----------
  function rows(pairs) { return pairs.filter((r) => r[1]).map((r) => `<div class="mb-3 last:mb-0"><dt class="text-[11px] uppercase tracking-wide text-stone-500">${esc(r[0])}</dt><dd class="mt-0.5 text-sm leading-relaxed text-stone-200">${esc(r[1])}</dd></div>`).join(''); }

  function renderTitle(busy) {
    const el = document.getElementById('cf-title'); if (!el) return;
    const v = cur('title') || { names: [], logline: '' }; const names = v.names || []; const primary = names[0] || 'Untitled'; const alts = names.slice(1);
    el.innerHTML = `<div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <h2 class="text-4xl font-black uppercase tracking-tight text-[#c6ff00] sm:text-5xl">${esc(primary)}</h2>
        ${alts.map((n) => `<span class="rounded-full border border-[#2a2a3a] px-3 py-1 text-sm text-stone-400">${esc(n)}</span>`).join('')}
        ${ctrl('title', busy)}
      </div>
      <p class="mt-2 max-w-3xl text-lg italic text-stone-300">“${esc(v.logline || '')}”</p>
      ${state.featureName ? `<p class="mt-2 text-xs font-semibold uppercase tracking-wide text-[#ff2d78]">⚡ ${esc(state.featureName)}</p>` : ''}`;
  }
  function renderFeatureIntro() {
    const el = document.getElementById('cf-intro'); if (!el) return;
    const cards = (state.featureIntro || []).slice(0, 3);
    if (!cards.length) { el.innerHTML = ''; return; }
    const labels = ['Mechanic', 'Bonus', 'Max win'], accent = ['#c6ff00', '#ff2d78', '#c6ff00'];
    el.innerHTML = `<div class="grid gap-2 sm:grid-cols-3">${cards.map((c, i) => `
      <div class="rounded-xl border border-[#22222e] bg-[#13131c] p-3 ${i === 2 ? 'ring-1 ring-[#c6ff00]/40' : ''}">
        <div class="mb-1 text-[10px] font-black uppercase tracking-wide" style="color:${accent[i] || '#c6ff00'}">${labels[i] || ''}</div>
        <div class="text-xs leading-relaxed text-stone-200">${esc(c)}</div>
      </div>`).join('')}</div>`;
  }
  function renderImage(busy) {
    const el = document.getElementById('cf-image'); if (!el) return;
    const mood = cur('image') || { url: null };
    const an = cur('animation');
    const hasLoop = !!(an && an.url);
    const animBusy = state.animBusy, symBusy = state.symbolsBusy;
    const on = 'style="color:#c6ff00"';
    let mode = state.visualMode || 'mood';
    if (mode === 'loop' && !hasLoop) mode = 'mood';   // 'game' är alltid tillgängligt (gridet ritas i kod)
    let media;
    if (mode === 'loop') media = `<video src="${esc(an.url)}" autoplay muted loop playsinline class="aspect-square w-full rounded-2xl border border-[#22222e] object-cover"></video>`;
    else if (mode === 'game') media = buildMockupHTML();   // kodat reel-grid + AI-symboler
    else media = mood.url ? `<img src="${esc(mood.url)}" alt="Key art" class="aspect-square w-full rounded-2xl border border-[#22222e] object-cover" />` : `<div class="flex aspect-square w-full items-center justify-center rounded-2xl border border-dashed border-[#2a2a3a] bg-[#13131c] p-6 text-center text-xs text-stone-500">${busy ? '🎨 Painting key art…' : 'No image yet.'}</div>`;
    const pill = (m, label) => `<button class="cf-mini" data-vis="${m}" ${mode === m ? on : ''}>${label}</button>`;
    // Loop nedtonad till sekundär (dimmad, mindre) — Mood/Game är huvudtoggeln.
    const loopStyle = mode === 'loop' ? 'style="color:#c6ff00;font-size:10px"' : 'style="opacity:.5;font-size:10px"';
    const loopBtn = hasLoop ? `<button class="cf-mini" data-vis="loop" ${loopStyle}>Loop</button>`
      : (animBusy ? `<span class="cf-mini" style="opacity:.45;font-size:10px">Loop…</span>` : `<button class="cf-mini" data-refresh="animation" ${mood.url ? '' : 'disabled'} ${loopStyle}>▶ Loop</button>`);
    let pills = pill('mood', 'Mood') + pill('game', 'Game') + loopBtn;
    let reroll = '';
    if (mode === 'mood') reroll = ctrl('image', busy && !animBusy && !symBusy);
    else if (mode === 'game') reroll = `<button class="cf-mini cf-refresh" data-refresh="symbols" title="Re-skin the symbols">${symBusy ? '<span class="cf-spin"></span>' : '↻'}</button>`;
    else reroll = `<button class="cf-mini cf-refresh" data-refresh="animation" title="Re-roll loop">${animBusy ? '<span class="cf-spin"></span>' : '↻'}</button>`;
    const note = animBusy ? `<div class="absolute inset-x-2 bottom-2 rounded bg-black/70 px-2 py-1 text-center text-[11px] text-[#c6ff00]">Animating with Luma Ray 2… ~1-2 min</div>`
      : (symBusy && mode === 'game' ? `<div class="absolute inset-x-2 bottom-2 rounded bg-black/70 px-2 py-1 text-center text-[11px] text-[#c6ff00]">Generating themed symbols with Flux…</div>` : '');
    el.innerHTML = `<div class="relative">${media}<div class="absolute right-2 top-2 flex flex-wrap items-center justify-end gap-1">${reroll}<span class="cf-ctrl">${pills}</span></div>${note}</div>`;
  }
  function renderTab(comp, busy) {
    const el = document.getElementById('cf-panel-' + comp); if (!el) return;
    if (comp === 'tldr') {   // pitch-först-sammanfattning (ersätter de tre lösa boxarna) — emoji per sektion
      const cards = (state.featureIntro || []).slice(0, 3);
      const meta = [['🎰', 'Mechanic', 'text-[#c6ff00]'], ['🎁', 'Bonus', 'text-[#ff2d78]'], ['🏆', 'Max win', 'text-[#c6ff00]']];
      el.innerHTML = cards.length
        ? `<div class="grid gap-3">${cards.map((c, i) => `
            <div class="rounded-xl border border-[#22222e] bg-[#15151f] p-3.5 ${i === 2 ? 'ring-1 ring-[#c6ff00]/40' : ''}">
              <div class="mb-1 flex items-center gap-2 text-[10px] font-black uppercase tracking-wide ${(meta[i] || [])[2] || 'text-[#c6ff00]'}"><span class="text-base leading-none">${(meta[i] || [])[0] || '•'}</span>${(meta[i] || [])[1] || ''}</div>
              <div class="text-sm leading-relaxed text-stone-200">${esc(c)}</div>
            </div>`).join('')}</div>`
        : `<p class="text-sm text-stone-500">No summary yet.</p>`;
      return;
    }
    let inner = '';
    if (comp === 'art') { const v = cur('art') || {}; inner = rows([['Style', v.style], ['Palette', v.palette], ['Hero characters', v.hero_characters], ['Mood', v.mood]]); }
    else if (comp === 'mechanic') { const v = cur('mechanic') || { mechanic: {}, math: {} }; const m = v.mechanic || {}, ma = v.math || {}; inner = rows([['Grid', m.grid], ['Type', m.type], ['Base game', m.base_game], ['Signature feature', m.signature_feature], ['Bonus round', m.bonus_round], ['Bonus buy', m.bonus_buy], ['Volatility', ma.volatility], ['RTP', ma.rtp], ['Max win', ma.suggested_max_win]]); }
    else if (comp === 'music') { const v = (cur('music') || {}).music || {}; inner = rows([['Genre', v.genre], ['Instrumentation', v.instrumentation], ['Base vs bonus', v.base_vs_bonus], ['Tempo', v.bpm], ['Reference vibe', v.reference_vibe]]); }
    else if (comp === 'hooks') { const v = cur('hooks') || []; inner = `<ul class="space-y-2.5">${v.map((h) => `<li class="flex gap-2 text-sm leading-relaxed text-stone-200"><span class="text-[#c6ff00]">▸</span><span>${esc(h)}</span></li>`).join('')}</ul>`; }
    el.innerHTML = `<div class="relative"><div class="absolute right-0 top-0 z-10">${ctrl(comp, busy)}</div><div class="pr-9">${inner}</div></div>`;
  }
  function setSoundtrackMsg(t) { const st = document.getElementById('soundtrack-slot'); if (st) st.innerHTML = `<div class="flex items-center gap-2 py-2 text-xs text-stone-500"><span class="h-3 w-3 animate-spin rounded-full border-2 border-[#2a2a3a] border-t-[#ff2d78]"></span> ${esc(t)}</div>`; }
  function renderSoundtrack(busy) {
    const st = document.getElementById('soundtrack-slot'), eng = document.getElementById('st-engine'), c = document.getElementById('cf-st-ctrl');
    const v = cur('soundtrack');
    if (eng) eng.textContent = (v && v.engine) || '';
    if (c) c.innerHTML = ctrl('soundtrack', busy);   // ↻ alltid synlig, även när tomt → kan (om)generera
    if (!st) return;
    if (v && v.url) { st.innerHTML = `<audio data-st loop src="${esc(v.url)}"></audio>
      <div class="flex items-center gap-3 rounded-xl border border-[#22222e] bg-[#15151f] px-3 py-2">
        <button type="button" data-st-toggle class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-[#ff2d78] text-sm text-white transition hover:brightness-110">▶</button>
        <div class="min-w-0 flex-1">
          <div data-st-bar class="group relative h-1.5 cursor-pointer rounded-full bg-[#2a2a3a]"><div data-st-fill class="absolute inset-y-0 left-0 rounded-full bg-[#ff2d78]" style="width:0%"></div></div>
          <div class="mt-1.5 flex justify-between text-[10px] tabular-nums text-stone-500"><span data-st-cur>0:00</span><span data-st-dur>0:00</span></div>
        </div>
      </div>
      <div class="mt-2 flex flex-wrap items-center gap-1.5">
        <input id="st-more" type="text" placeholder="more: …" class="min-w-0 flex-1 rounded border border-[#2a2a3a] bg-[#15151f] px-2 py-1 text-xs text-stone-200 placeholder:text-stone-600" />
        <input id="st-less" type="text" placeholder="less: …" class="min-w-0 flex-1 rounded border border-[#2a2a3a] bg-[#15151f] px-2 py-1 text-xs text-stone-200 placeholder:text-stone-600" />
        <button type="button" data-reshape class="cf-mini cf-refresh" ${busy ? 'disabled' : ''}>${busy ? '<span class="cf-spin"></span>' : '↻ Reshape'}</button>
      </div>
      ${(() => { const sp = ((cur('music') || {}).soundtrack_prompt || '').trim(); return sp ? `<p class="mt-2 text-[10px] italic leading-snug text-stone-500">🎚 ${esc(sp.length > 120 ? sp.slice(0, 119) + '…' : sp)}</p>` : ''; })()}`; bindSoundtrackPlayer(); }
    else if (!busy) st.innerHTML = `<p class="text-xs text-stone-600">Soundtrack unavailable.</p>`;
  }
  // Egen kompakt spelare (rosa accent) som ersätter den vita system-kontrollen; anpassar sig till tema via tokens.
  function bindSoundtrackPlayer() {
    const st = document.getElementById('soundtrack-slot'); if (!st) return;
    const a = st.querySelector('audio[data-st]'); if (!a) return;
    const toggle = st.querySelector('[data-st-toggle]'), bar = st.querySelector('[data-st-bar]'), fill = st.querySelector('[data-st-fill]'), curEl = st.querySelector('[data-st-cur]'), durEl = st.querySelector('[data-st-dur]');
    const fmt = (s) => { if (!isFinite(s) || s < 0) return '0:00'; s = Math.floor(s); return Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0'); };
    const setIcon = () => { if (toggle) toggle.textContent = a.paused ? '▶' : '⏸'; };
    if (toggle) toggle.addEventListener('click', () => { if (a.paused) { a.volume = 0.5; a.play().catch(() => {}); } else a.pause(); });
    a.addEventListener('play', setIcon); a.addEventListener('pause', setIcon);
    a.addEventListener('loadedmetadata', () => { if (durEl) durEl.textContent = fmt(a.duration); });
    a.addEventListener('timeupdate', () => { if (fill) fill.style.width = (a.duration ? (a.currentTime / a.duration * 100) : 0) + '%'; if (curEl) curEl.textContent = fmt(a.currentTime); });
    if (bar) bar.addEventListener('click', (e) => { const r = bar.getBoundingClientRect(); const f = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width)); if (a.duration) a.currentTime = f * a.duration; });
    if (durEl && a.duration) durEl.textContent = fmt(a.duration);
    setIcon();
  }
  function renderSfx(busy) {
    const fx = document.getElementById('sfx-slot'), c = document.getElementById('cf-sfx-ctrl');
    const list = cur('sfx') || [];
    if (c) c.innerHTML = ctrl('sfx', busy);   // ↻ alltid synlig, även vid "No SFX." → kan (om)generera
    if (!fx) return;
