    el.innerHTML = [`Concept by ${esc(state.conceptEngine || 'Claude')}`, im.engine ? 'art by ' + esc(im.engine) : '', an.engine ? 'motion by ' + esc(an.engine) : '', so.engine ? 'soundtrack by ' + esc(so.engine) : '', 'SFX by ElevenLabs'].filter(Boolean).join(' &nbsp;·&nbsp; ') + ' &nbsp;—&nbsp; right model for each step.';
  }
  function render(comp, busy) {
