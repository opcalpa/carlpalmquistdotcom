  // ---------- Audio fetchers ----------
  async function pollSuno(taskId) {
    let waited = 0; const interval = 4000, maxMs = 120000;
    while (waited < maxMs) {
      await new Promise((r) => setTimeout(r, interval)); waited += interval;
      setSoundtrackMsg('Composing soundtrack with Suno… ' + Math.floor(waited / 1000) + 's');
      try { const r = await fetch('/api/soundtrack?taskId=' + encodeURIComponent(taskId)); const j = await r.json(); if (j.status === 'done' && j.url) return j.url; if (j.status === 'failed') return null; } catch (e) {}
    }
    return null;
  }
  // Ren, Lyria-säker musikprompt ur briefen (genre/instrumentering/BPM). Lyria 422:ar prompts som
  // namnger riktiga artister/IP (de sitter i soundtrack_prompt/reference_vibe) → används för fal-fallbacken.
  function cleanMusicPrompt() {
    const mus = (cur('music') || {}).music || {};
    const bpm = (String(mus.bpm || '').match(/\d+/) || [])[0];
    let p = [mus.genre, (typeof mus.instrumentation === 'string' ? mus.instrumentation : ''), bpm ? bpm + ' BPM' : ''].filter(Boolean).join(', ').trim();
    if (!p) p = state.theme || '';
    return (p + ', instrumental, no vocals, high quality, seamless loop').slice(0, 800);
  }
  async function fetchSoundtrack(steer) {
    let prompt = (cur('music') || {}).soundtrack_prompt || state.theme || '';
    if (steer) prompt = prompt + ', ' + steer;
    if (!prompt) return null;
    try { const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt }) }); const j = await r.json(); if (j.taskId) { const url = await pollSuno(j.taskId); if (url) return { url, engine: 'Suno V5' }; } } catch (e) {}
    // Fallback: fal Lyria med REN prompt (Suno tål artistnamn, Lyria gör inte).
    let falPrompt = cleanMusicPrompt(); if (steer) falPrompt = (falPrompt + ', ' + steer).slice(0, 800);
    try { const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: falPrompt, engine: 'fal' }) }); const j = await r.json(); if (j.url) return { url: j.url, engine: j.engine || 'Lyria 2 (fal.ai)' }; } catch (e) {}
    return null;
  }
  async function fetchSfx() {
    try { const r = await fetch('/api/audio', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sfx: (cur('music') || {}).sfxPrompts || [] }) }); const j = await r.json(); return j.sfx || []; } catch (e) { return []; }
  }

  // ---------- Animation (key art -> attract-loop via Luma Ray 2) ----------
  function motionPrompt() {
    const base = (state.imagePrompt || state.theme || '').slice(0, 400);
    return `Subtle cinematic attract-mode loop of this slot key art. Ambient motion only: slowly drifting particles, soft neon and light shimmer, faint haze, the main character breathes and shifts almost imperceptibly with occasional small idle movement. Keep the composition identical, no camera cut, seamless loop. Scene: ${base}`;
  }
  async function pollAnimate(id) {
    let waited = 0; const interval = 5000, maxMs = 200000;
    while (waited < maxMs) {
      await new Promise((r) => setTimeout(r, interval)); waited += interval;
      try { const r = await fetch('/api/animate?id=' + encodeURIComponent(id)); const j = await r.json(); if (j.status === 'done' && j.url) return j.url; if (j.status === 'failed') return null; } catch (e) {}
    }
    return null;
  }
  function gameMotionPrompt() {
    return `Subtle live-gameplay loop of this slot game screen. Ambient motion only: reel symbols shimmer and gently pulse with soft glow, the character mascot makes small idle movements, neon UI elements flicker softly. No spinning reels, no camera cut, keep the layout identical, seamless loop.`;
  }
  async function fetchAnimation() {
    const src = cur('image');   // animera alltid key art (Game-läget är kodat, ingen bild att animera)
    if (!src || !src.url) return null;
    const prompt = motionPrompt();
    try {
      const r = await fetch('/api/animate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ imageUrl: src.url, prompt }) });
      const j = await r.json(); if (!j.requestId) return null;
      const url = await pollAnimate(j.requestId); if (url) return { url, engine: j.engine || 'Luma Ray 2' };
    } catch (e) {}
    return null;
  }

  // ---------- Game-view (hur sökningen ser ut i spelläge, Hacksaw-stil) ----------
  function gamePrompt() {
    const a = cur('art') || {};
    const base = (state.imagePrompt || state.theme || '').slice(0, 340);
    // Scen-baserad: ber om "reel grid" men inramat som art (inte explicit gambling-UI), annars safety-blockar Flux.
    return `In-game art for a mobile slot game showing a grid of glowing themed symbols and stylised A K Q J letter tiles, a character beside the grid, a small control bar at the bottom, bold comic graphic-novel style with thick ink linework and halftone shading, ${a.palette || ''}, bright high-contrast colourful glowing. No real brands, no copyrighted characters, no real text. Scene: ${base}`.slice(0, 720);
  }
  async function fetchGameview() {
