    if (steer) prompt = prompt + ', ' + steer;
    if (!prompt) return null;
    try { const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt }) }); const j = await r.json(); if (j.taskId) { const url = await pollSuno(j.taskId); if (url) return { url, engine: 'Suno V5' }; } else if (j.creditsOut) notifyCreditsOut('soundtrack'); } catch (e) {}
    // Fallback: fal Lyria med REN prompt (Suno tål artistnamn, Lyria gör inte).
    let falPrompt = cleanMusicPrompt(); if (steer) falPrompt = (falPrompt + ', ' + steer).slice(0, 800);
    try { const r = await fetch('/api/soundtrack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: falPrompt, engine: 'fal' }) }); const j = await r.json(); if (j.url) return { url: j.url, engine: j.engine || 'Lyria 2 (fal.ai)' }; else if (j.creditsOut) notifyCreditsOut('soundtrack'); } catch (e) {}
    return null;
  }
  async function fetchSfx() {
    try { const r = await fetch('/api/audio', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sfx: (cur('music') || {}).sfxPrompts || [] }) }); const j = await r.json(); if (j.creditsOut) notifyCreditsOut('sfx'); return j.sfx || []; } catch (e) { return []; }
  }

  // ---------- Animation (key art -> attract-loop via Luma Ray 2) ----------
  function motionPrompt() {
    const scene = (state.imagePrompt || state.theme || '').slice(0, 260);
    const tailored = (state.motionPrompt || '').trim();
    // Kamera-låset måste vara HÅRT (annars push-in:ar Luma), men karaktären ska leva via INTERNA mikrorörelser.
    const rules = 'Animate this slot key art into a seamless looping attract-mode video. LOCKED STATIC CAMERA: the camera is fixed on a tripod and never moves — no zoom, no push-in, no pull-out, no pan, no rotation, no parallax. The framing, crop and the scale of everything stay EXACTLY as the source image for the entire loop. No cuts. The character keeps its identity (no morphing, no warping, no extra limbs).';
    // Karaktär-liv är OBLIGATORISKT (annars fryser Luma figuren), men som interna mikrorörelser — inte förflyttning/skalning.
    const alive = 'The main character stays in the exact same position and scale (it never steps toward or away from camera and never changes size) but must be CLEARLY ALIVE, not a frozen statue: clearly visible slow breathing with the chest and shoulders rising and falling, a faint weight-shift, an occasional blink, a small head tilt and a tiny hand or prop gesture, with clothing, hair, fur or capes swaying softly. Small and tasteful, but perceptible.';
    // Perifera detaljer (det Carl uttryckligen vill ha rörligt): luftpartiklar, fjärilar, fåglar, smådjur + väder.
    const ambient = 'The only freely-moving things are small PERIPHERAL details: drifting air particles and dust, an occasional butterfly, birds and small animals crossing through, soft rain, embers, leaves or snow as fits the scene, slow neon and light shimmer, a faint distant crowd. All gentle and subtle.';
    const extra = tailored ? ` Art-directed motion for this image: ${tailored}` : '';
    return `${rules} ${alive} ${ambient}${extra} Scene: ${scene}`;
  }
  async function pollAnimate(id) {
    let waited = 0; const interval = 5000, maxMs = 200000;
    while (waited < maxMs) {
      await new Promise((r) => setTimeout(r, interval)); waited += interval;
      try { const r = await fetch('/api/animate?id=' + encodeURIComponent(id)); const j = await r.json(); if (j.status === 'done' && j.url) return j.url; if (j.status === 'failed') return null; } catch (e) {}
    }
    return null;
  }
  function gameMotionPrompt() {
    return `Subtle live-gameplay loop of this slot game screen. Ambient motion only: reel symbols shimmer and gently pulse with soft glow, the character mascot makes small idle movements, neon UI elements flicker softly. No spinning reels, no camera cut, keep the layout identical, seamless loop.`;
  }
  async function fetchAnimation() {
    const src = cur('image');   // animera alltid key art (Game-läget är kodat, ingen bild att animera)
    if (!src || !src.url) return null;
    const prompt = motionPrompt();
    try {
      const r = await fetch('/api/animate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ imageUrl: src.url, prompt }) });
      const j = await r.json(); if (!j.requestId) { if (j.creditsOut) notifyCreditsOut('animation'); return null; }
      const url = await pollAnimate(j.requestId); if (url) return { url, engine: j.engine || 'Luma Ray 2' };
    } catch (e) {}
    return null;
  }

  // ---------- Game-view (hur sökningen ser ut i spelläge, Hacksaw-stil) ----------
  function gamePrompt() {
    const a = cur('art') || {};
    const base = (state.imagePrompt || state.theme || '').slice(0, 340);
    // Scen-baserad: ber om "reel grid" men inramat som art (inte explicit gambling-UI), annars safety-blockar Flux.
    return `In-game art for a mobile slot game showing a grid of glowing themed symbols and stylised A K Q J letter tiles, a character beside the grid, a small control bar at the bottom, bold comic graphic-novel style with thick ink linework and halftone shading, ${a.palette || ''}, bright high-contrast colourful glowing. No real brands, no copyrighted characters, no real text. Scene: ${base}`.slice(0, 720);
  }
  async function fetchGameview() {
    try { const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: gamePrompt() }) }); const j = await r.json(); if (j.url) return { url: j.url, engine: j.engine }; } catch (e) {}
    return null;
  }

  // ---------- Game-mockup: kodat reel-grid (struktur i HTML/CSS, AI-symboler droppas in) ----------
  const LETTERS = ['A', 'K', 'Q', 'J', '10'];
  function hashHue(s) { let h = 0; s = String(s || ''); for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0; return h % 360; }
  function gridDims() {
    const m = (cur('mechanic') || {}).mechanic || {};
    const g = String(m.grid || '').match(/(\d+)\s*[x×]\s*(\d+)/i);
    let cols = 5, rows = 4;
    if (g) { cols = Math.min(7, Math.max(3, +g[1])); rows = Math.min(6, Math.max(3, +g[2])); }
    return { cols, rows };
  }
  // Bygg cell-arrangemanget en gång (stabilt mellan renders) — SPIN reshufflar.
  // ~45 % av cellerna blir temade symboler (jämnt fördelat), resten stiliserade bokstavsbrickor.
  function computeGrid() {
    const { cols, rows } = gridDims();
    const total = cols * rows;
    const syms = (cur('symbols') || []).filter((s) => s && s.url);
    const pool = [];
    if (syms.length) {
      const per = Math.max(2, Math.round((total * 0.45) / syms.length));
      syms.forEach((s) => { for (let k = 0; k < per; k++) pool.push({ t: 's', url: s.url, label: s.label }); });
    }
    let li = 0;
    while (pool.length < total) pool.push({ t: 'l', ch: LETTERS[li++ % LETTERS.length] });
    for (let i = pool.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); const tmp = pool[i]; pool[i] = pool[j]; pool[j] = tmp; }
    state.grid = { cols, rows, cells: pool.slice(0, total) };
  }
  // Tema-medveten partikeltyp (för Game-vyn när ingen Luma-loop finns ännu)
  function particleKind(t) {
    t = (t || '').toLowerCase();
    if (/fire|flame|lava|inferno|ember|volcano|hell|dragon|demon|forge|magma|phoenix|blaze|ash|gore|metal/.test(t)) return 'ember';
    if (/ice|frost|snow|arctic|winter|crystal|glacier|polar|blizzard|frozen/.test(t)) return 'snow';
    if (/forest|jungle|leaf|leaves|autumn|garden|nature|wood|safari|tropical|fae|elf|druid/.test(t)) return 'leaf';
    if (/party|disco|circus|candy|carnival|festival|fiesta|rave|birthday|club|pop|gymnastics/.test(t)) return 'confetti';
    return 'spark';
  }
  function volBars(v) {
    const map = { 'low': 2, 'medium': 3, 'med': 3, 'high': 4, 'very high': 5, 'extreme': 5 };
    const n = map[String(v || '').trim().toLowerCase()] || 4;
    let s = ''; for (let i = 0; i < 5; i++) s += `<i class="${i < n ? 'on' : ''}"></i>`; return s;
  }
  function buildMockupHTML() {
    if (!state.grid) computeGrid();
    const g = state.grid; if (!g) return '';
    const name = (cur('title') || {}).names && (cur('title').names[0]) || state.theme || 'Untitled';
    const m = cur('mechanic') || { mechanic: {}, math: {} };
    const buy = (m.mechanic || {}).bonus_buy || '', vol = (m.math || {}).volatility;
    const hue = hashHue(state.theme);
    const anim = (cur('animation') || {}).url;   // genererad Luma-loop → används som animerad Game-bakgrund
    const bg = (cur('image') || {}).url;   // statisk key art = mood-miljö + karaktär till höger om rutnätet
    // Ambient-partiklar (bara när ingen Luma-loop finns): tema-medveten typ + varierad rörelse
    const pkind = particleKind(state.theme);
    const CONFETTI = ['#ff2d78', '#c6ff00', '#3da5ff', '#ffd23f', '#a85cff'];
    const particles = Array.from({ length: 14 }, (_, i) => {
      const left = Math.round(Math.random() * 100), size = (3 + Math.random() * 4).toFixed(1);
      const dur = (6 + Math.random() * 7).toFixed(1), delay = (Math.random() * 9).toFixed(1), dx = Math.round(Math.random() * 26 - 13);
      const col = pkind === 'confetti' ? `;background:${CONFETTI[i % CONFETTI.length]}` : '';
      return `<i style="left:${left}%;width:${size}px;height:${size}px;animation-duration:${dur}s;animation-delay:-${delay}s;--dx:${dx}px${col}"></i>`;
    }).join('');
    const cells = g.cells.map((c) => c.t === 's'
      ? `<div class="cf-cell"><img src="${esc(c.url)}" alt="${esc(c.label)}" loading="lazy" onerror="this.parentNode.classList.add('cf-letter');this.parentNode.textContent='★'" /></div>`
      : `<div class="cf-cell cf-letter">${esc(c.ch)}</div>`).join('');
    const wide = state.aspect === '16:9';
    return `<div class="cf-slot${wide ? ' cf-wide' : ''}" style="--hue:${hue}">
      ${anim
        ? `<video class="cf-slot-bg cf-slot-vid" src="${esc(anim)}" autoplay muted loop playsinline></video><div class="cf-slot-scrim"></div>`
        : (bg ? `<div class="cf-slot-bg" style="background-image:url('${esc(bg)}')"></div><div class="cf-slot-scrim"></div>` : `<div class="cf-slot-fallbg"></div>`)}
      ${anim ? '' : `<div class="cf-particles cf-particles-${pkind}" aria-hidden="true">${particles}</div>`}
      <div class="cf-slot-inner">
        <div class="cf-slot-top">
          <span class="cf-slot-title">${esc(name)}</span>
          ${state.featureName ? `<span class="cf-slot-feat">⚡ ${esc(state.featureName)}</span>` : ''}
        </div>
        <div class="cf-reels">
          <div class="cf-frame"${wide ? ` style="--reel-ar:${g.cols} / ${g.rows}"` : ''}><div class="cf-grid${state.spinning ? ' cf-spinning' : ''}" style="grid-template-columns:repeat(${g.cols},1fr);grid-template-rows:repeat(${g.rows},1fr)">${cells}</div></div>
        </div>
        <div class="cf-hud">
          <span class="cf-ic">☰</span>
          ${buy ? `<div class="cf-buy">Buy<b>Bonus</b><span style="font-size:8px">${esc(buy)}</span></div>` : ''}
          <div class="cf-meter"><span>Balance</span><b>10,000</b></div>
          <div class="cf-meter"><span>Volatility</span><span class="cf-vol">${volBars(vol)}</span></div>
          <div class="cf-bet"><span class="cf-step">−</span><div class="cf-meter" style="align-items:center"><span>Bet</span><b>2.00</b></div><span class="cf-step">+</span></div>
          <button class="cf-spinbtn${state.spinning ? ' cf-spinning' : (state.spun ? '' : ' cf-invite')}" data-spin title="Spin">⟳</button>
          <span class="cf-ic">A</span>
        </div>
      </div>
    </div>`;
  }
  let spinTimer, spinCount = 0;
  // Hitta ett SFX på etikett-nyckelord (Reel spin / Bonus trigger / Big win), med index-reserv.
  function sfxByHint(hint, fallbackIdx) {
    const list = cur('sfx') || [];
    return list.find((s) => s && (s.label || '').toLowerCase().includes(hint)) || list[fallbackIdx] || null;
  }
  function playSfxObj(s, delay) {
    if (!s || !s.url) return;
    const fire = () => { try { const a = new Audio(s.url); a.volume = 0.6; a.play().catch(() => {}); } catch (e) {} };
    delay ? setTimeout(fire, delay) : fire();
  }
  function spinMockup() {
    if (state.spinning) return;
    state.spun = true; stopViewAuto();   // Play/SPIN = aktivt val av Game → lås vyn (slutar auto-rotera, precis som Game-knappen)
    state.spinning = true; spinCount++; computeGrid(); renderImage(false);
    // Eskalerande utfall: reel varje snurr, bonus varannan, big win vart fjärde — lätt staggrat.
    playSfxObj(sfxByHint('spin', 0));
    if (spinCount % 2 === 0) playSfxObj(sfxByHint('bonus', 1), 180);
    if (spinCount % 4 === 0) playSfxObj(sfxByHint('big', 2), 360);
    clearTimeout(spinTimer);
    spinTimer = setTimeout(() => { state.spinning = false; renderImage(false); }, 440);
  }
  async function fetchSymbols() {
    const prompts = state.symbolPrompts || [];
    if (!prompts.length) return [];
    try { const r = await fetch('/api/symbols', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ symbols: prompts }) }); const j = await r.json(); if (j.creditsOut) notifyCreditsOut('symbols'); return Array.isArray(j.symbols) ? j.symbols : []; } catch (e) { return []; }
  }
  // Lazy: symbolerna genereras först när man öppnar Game-vyn (spar credits vid vanlig forge).
  async function ensureSymbols() {
    if (state.symbolsBusy) return;
    if ((cur('symbols') || []).length) return;          // redan genererade
    if (!(state.symbolPrompts || []).length) return;    // inget att generera
    state.symbolsBusy = true; renderImage(false);
    const syms = await fetchSymbols();
    if (syms.length) { state.versions.symbols = [syms]; state.idx.symbols = 0; }
    state.symbolsBusy = false; computeGrid();
    if (state.visualMode === 'game') renderImage(false);
    persist();
  }
  async function reshapeSoundtrack() {
    const more = (document.getElementById('st-more') || {}).value || '';
    const less = (document.getElementById('st-less') || {}).value || '';
    const steer = [more.trim() ? 'more: ' + more.trim() : '', less.trim() ? 'less: ' + less.trim() : ''].filter(Boolean).join('; ');
    if (!steer) return;
    render('soundtrack', true); setSoundtrackMsg('Reshaping soundtrack…');
    const st = await fetchSoundtrack(steer); if (st) pushVersion('soundtrack', st);
    render('soundtrack', false); persist();
  }

  // ---------- Refresh / nav ----------
  async function refresh(comp) {
    if (comp === 'animation') state.animBusy = true;
    if (comp === 'gameview') state.gameBusy = true;
    if (comp === 'symbols') { state.symbolsBusy = true; state.visualMode = 'game'; }
    render(comp, true);
    try {
      if (['title', 'art', 'mechanic', 'music', 'hooks'].includes(comp)) {
        const r = await fetch('/api/section', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ theme: state.theme, section: comp, concept: flatConcept() }) });
        const j = await r.json();
        if (!j.error) {
          if (comp === 'title') pushVersion('title', { names: j.names || [], logline: j.logline || '' });
          else if (comp === 'art') pushVersion('art', j.art || {});
          else if (comp === 'mechanic') pushVersion('mechanic', { mechanic: j.mechanic || {}, math: j.math || {} });
          else if (comp === 'music') pushVersion('music', { music: j.music || {}, soundtrack_prompt: j.soundtrack_prompt || '', sfxPrompts: j.sfx || [] });
          else if (comp === 'hooks') pushVersion('hooks', j.hooks || []);
        }
      } else if (comp === 'image') {
        const imageSize = state.aspect === '16:9' ? 'landscape_16_9' : 'square_hd';
        const r = await fetch('/api/image', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ prompt: state.imagePrompt, imageSize }) });
        const j = await r.json(); if (j.url) pushVersion('image', { url: j.url, engine: j.engine });
      } else if (comp === 'soundtrack') {
        const st = await fetchSoundtrack(); if (st) pushVersion('soundtrack', st);
      } else if (comp === 'sfx') {
        const sfx = await fetchSfx(); if (sfx.length) pushVersion('sfx', sfx);
      } else if (comp === 'animation') {
        const an = await fetchAnimation(); if (an) { pushVersion('animation', an); state.visualMode = 'mood'; }   // visa nya loopen på Mood (Loop-vyn finns inte längre)
      } else if (comp === 'gameview') {
        const g = await fetchGameview();
        if (g) { pushVersion('gameview', g); state.visualMode = 'game'; }
        else { pushVersion('gameview', { url: null }); state.visualMode = 'mood'; }   // blockerad → rensa ev. svart, flippa till Mood
      } else if (comp === 'symbols') {
        const syms = await fetchSymbols();
        if (syms.length) { pushVersion('symbols', syms); computeGrid(); }
        state.visualMode = 'game';
      }
    } catch (e) {}
    state.animBusy = false; state.gameBusy = false; state.symbolsBusy = false;
    render(comp, false);
    persist();
  }
  function nav(comp, d) {
    const n = state.versions[comp].length; let i = state.idx[comp] + d;
    i = Math.max(0, Math.min(n - 1, i)); state.idx[comp] = i; render(comp, false);
  }

  // ---------- Persist ----------
  // Liten, varaktig tumnagel (64px JPEG data-URI) från nuvarande key art → galleri-indexet.
  // Funkar på data:-bilder (inlinade, same-origin) och CORS-vänliga URL:er; faller mjukt till null.
  async function makeThumb() {
    const im = cur('image'); if (!im || !im.url) return null;
    try {
      const img = new Image(); img.crossOrigin = 'anonymous';
      await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = im.url; });
      const cv = document.createElement('canvas'); cv.width = 64; cv.height = 64;
      cv.getContext('2d').drawImage(img, 0, 0, 64, 64);
      return cv.toDataURL('image/jpeg', 0.7);
    } catch (e) { return null; }
  }
  async function persist() {
    let thumb = null; try { thumb = await makeThumb(); } catch (e) {}
    try {
      const r = await fetch('/api/gallery', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: state.id, theme: state.theme, thumb, state: { theme: state.theme, imagePrompt: state.imagePrompt, conceptEngine: state.conceptEngine, featureName: state.featureName, featureIntro: state.featureIntro, motionPrompt: state.motionPrompt, symbolPrompts: state.symbolPrompts, aspect: state.aspect, versions: state.versions, idx: state.idx } }) });
      const j = await r.json();
      if (j.id) {
        const wasNull = !state.id;
        state.id = j.id;
        if (wasNull && cmtScope === 'theme' && document.getElementById('cf-cmt-list')) loadComments();   // färsk forge fick just sitt id → ladda per-koncept-kommentarer
      }
    } catch (e) {}
    refreshGallery();
  }

  // ---------- Build skeleton ----------
  function buildResult(fromCache) {
    // Samma rad oavsett om resultatet är nytt eller hämtat ur galleriet — användaren ska aldrig
    // behöva tänka på cache-state. En tydlig re-roll (samma tema, ny tolkning) finns alltid.
    const strip = `<div class="mb-3 flex items-center justify-between gap-3 text-xs">
      <div class="flex min-w-0 items-center gap-3"><button id="regen-btn" type="button" class="flex-none inline-flex items-center gap-1.5 rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 transition hover:border-[#ff2d78] hover:text-[#ff2d78]">↻ Re-roll this theme</button></div>
      <div class="flex flex-none items-center gap-2">
        <button id="cf-upvote" type="button" title="Upvote this concept" class="inline-flex items-center gap-1.5 rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 transition hover:border-[#c6ff00] hover:text-[#c6ff00]"><span class="cf-up-ico">▲</span><span id="cf-votecount">0</span></button>
        <button id="cf-share" type="button" title="Copy a shareable link" class="inline-flex items-center gap-1.5 rounded-full border border-[#2a2a3a] px-3 py-1 text-stone-300 transition hover:border-[#ff2d78] hover:text-[#ff2d78]">↗ Share</button>
