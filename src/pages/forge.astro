    recentPanel.innerHTML = hist.map((m) => `
      <div class="recent-item flex items-center gap-2 rounded-lg px-2 py-1.5 hover:bg-[#1d212c] cursor-pointer" data-id="${esc(m.id)}">
        ${cell(m)}
        <div class="min-w-0 flex-1"><div class="truncate text-sm text-stone-200">${esc(m.theme)}</div><div class="text-[10px] text-stone-500">${timeAgo(m.ts)}</div></div>
        <button class="flex-shrink-0 px-1 text-stone-600 hover:text-[#ff2d78]" data-del="${esc(m.id)}" title="Remove">✕</button>
      </div>`).join('') +
      `<div class="mt-1 border-t border-[#2a2a3a] pt-1"><button id="recent-clear" class="w-full rounded-lg px-2 py-1.5 text-left text-xs text-stone-500 hover:text-[#ff2d78]">Clear all</button></div>`;
    recentPanel.querySelectorAll('.recent-item').forEach((el) => el.addEventListener('click', (ev) => { if (ev.target.closest('[data-del]')) return; loadSearch(el.dataset.id); }));
    recentPanel.querySelectorAll('[data-del]').forEach((b) => b.addEventListener('click', (ev) => { ev.stopPropagation(); delEntry(b.dataset.del); }));
    const clr = document.getElementById('recent-clear');
