---
import Layout from '../layouts/Layout.astro';
import NodeGraph from '../components/NodeGraph.astro';

const services = [
  {
    title: 'Ship working products',
    description:
      'From idea to deployed app in weeks, not quarters. Web apps, internal tools, AI-powered features. I write the code, you get the product.',
  },
  {
    title: 'Plug AI into what you have',
    description:
      'Drop AI into your existing stack without a six-month migration. Document automation, search, agents, copilots. I work inside your repos and respect your conventions.',
  },
  {
    title: 'Design that ships with it',
    description:
      'Interfaces, flows, and visual identity baked into the product, not stuck in Figma. Available as a standalone engagement or as part of a build.',
  },
  {
    title: 'Senior judgement, solo speed',
    description:
      'Eight years in product. I decide what to cut, what to ship, what to skip. You pay for outcomes, not hours.',
  },
];

const projects = [
  {
    name: 'Renofine',
    metric: '2026',
    role: 'Founder · Product · Engineering',
    description:
      'SaaS for renovation projects, built solo. Live at renofine.com, in beta with homeowners and contractors. Multi-language, AI-translated material specs, project portfolio with structured cost tracking.',
    image: '/images/renofine.png',
    imageAlt: 'Renofine app',
    href: 'https://renofine.com',
    cta: 'renofine.com',
  },
  {
    name: 'Produlog',
    metric: '2026',
    role: 'Founder · Product · Engineering',
    description:
      'Catalog automation for beauty, fashion, and FMCG. Turns supplier data into structured product catalogs without manual cleanup. Early prototype.',
    image: '/images/produlog.png',
    imageAlt: 'Produlog dashboard',
    href: 'https://getprodulog.com',
    cta: 'getprodulog.com',
  },
  {
    name: 'Epidemic Sound — Partner API',
    metric: '0 → 10M MAU',
    role: 'Product Manager · 2018 — 2025',
    description:
      'Built and scaled the Partner API platform powering integrations across creator tools and editing software. Product, partnerships, and engineering coordination in one role.',
    image: '/images/api.avif',
    imageAlt: 'API integration illustration',
    href: null,
    cta: 'Case study',
  },
];

const stack = [
  'TypeScript',
  'Next.js',
  'Astro',
  'React',
  'Postgres',
  'Supabase',
  'Cloudflare',
  'Claude Code',
  'OpenAI',
  'Anthropic API',
];

const links = [
  { label: 'Email', href: 'mailto:carl.palmquist@gmail.com' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/carlpalmquist/' },
  { label: 'GitHub', href: 'https://github.com/opcalpa' },
];
---

<Layout>
  <main class="overflow-hidden">
    <!-- HERO -->
    <section class="relative px-6 pt-20 pb-24 md:pt-32 md:pb-32">
      <div class="mx-auto max-w-6xl">
        <p
          class="mb-6 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
        >
          Carl Palmquist · Stockholm · Booking projects
        </p>
        <h1
          class="max-w-4xl text-5xl leading-[0.95] font-medium tracking-tight text-stone-900 md:text-7xl lg:text-8xl"
        >
          AI-native shipping for teams that need to move.
        </h1>
        <p
          class="mt-8 max-w-2xl text-xl leading-relaxed text-stone-600 md:text-2xl"
        >
          Independent product engineer. I design, build, and ship working
          software, solo. Available for short engagements with companies that
          want to test, prototype, or launch with AI without waiting six months
          for a roadmap slot.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href="mailto:carl.palmquist@gmail.com?subject=Project%20inquiry"
            class="inline-flex items-center gap-2 rounded-full bg-stone-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-stone-700"
          >
            Book an intro call
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="#work"
            class="inline-flex items-center gap-2 rounded-full border border-stone-300 px-6 py-3 text-sm font-medium text-stone-900 transition hover:border-stone-900"
          >
            See work
          </a>
        </div>
      </div>

      <!-- HERO VISUAL -->
      <div class="mx-auto mt-20 max-w-6xl md:mt-28">
        <NodeGraph />
      </div>
    </section>

    <!-- SERVICES -->
    <section class="border-t border-stone-200 bg-stone-50 px-6 py-24 md:py-32">
      <div class="mx-auto max-w-6xl">
        <p
          class="mb-12 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
        >
          What I do
        </p>
        <div class="grid gap-8 md:grid-cols-2 md:gap-10 lg:grid-cols-4">
          {
            services.map((service, i) => (
              <div class="flex flex-col">
                <span class="mb-6 text-sm tracking-tight text-stone-400">
                  0{i + 1}
                </span>
                <h3 class="mb-4 text-2xl font-medium tracking-tight text-stone-900 md:text-3xl">
                  {service.title}
                </h3>
                <p class="leading-relaxed text-stone-600">
                  {service.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="border-t border-stone-200 px-6 py-24 md:py-32">
      <div class="mx-auto max-w-6xl">
        <p
          class="mb-12 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
        >
          About
        </p>
        <div class="grid gap-12 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-5">
            <div
              class="relative aspect-[4/5] w-full overflow-hidden rounded-2xl bg-stone-100 ring-1 ring-stone-200"
            >
              <img
                src="/images/carl.jpg"
                alt="Carl Palmquist"
                class="absolute inset-0 h-full w-full object-cover"
              />
            </div>
          </div>
          <div class="md:col-span-7">
            <h2
              class="text-3xl leading-tight font-medium tracking-tight text-stone-900 md:text-4xl lg:text-5xl"
            >
              Hi, I'm Carl.
            </h2>
            <div
              class="mt-8 space-y-5 text-lg leading-relaxed text-stone-700 md:text-xl"
            >
              <p>
                Eight years in product. Most recently at Epidemic Sound, where I
                built and scaled the Partner API from <span
                  class="text-stone-900">zero to ten million</span
                > monthly users.
              </p>
              <p>
                Now I split my time between my own products (<a
                  href="https://renofine.com"
                  class="text-stone-900 underline decoration-stone-300 underline-offset-[4px] transition hover:decoration-stone-900"
                  >Renofine</a
                >, <a
                  href="https://getprodulog.com"
                  class="text-stone-900 underline decoration-stone-300 underline-offset-[4px] transition hover:decoration-stone-900"
                  >Produlog</a
                >) and consulting engagements with teams that want to ship
                faster than their roadmap allows. AI-native, solo, opinionated.
              </p>
            </div>
            <ul
              class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm text-stone-500"
            >
              <li>Based in Stockholm</li>
              <li>Available remote</li>
              <li>Booking new projects</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="px-6 py-24 md:py-32">
      <div class="mx-auto max-w-6xl">
        <p
          class="mb-12 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
        >
          Selected work
        </p>
        <div class="space-y-24 md:space-y-32">
          {
            projects.map((project) => (
              <article>
                <div class="relative mb-8 aspect-[16/10] w-full overflow-hidden rounded-2xl bg-gradient-to-br from-stone-100 to-stone-200 ring-1 ring-stone-200">
                  <img
                    src={project.image}
                    alt={project.imageAlt}
                    class="absolute inset-0 h-full w-full object-cover"
                    onerror="this.style.display='none'"
                  />
                  <div class="absolute inset-0 flex items-center justify-center text-sm tracking-widest text-stone-400 uppercase">
                    {project.image}
                  </div>
                </div>

                <div class="grid grid-cols-12 gap-4 md:gap-8">
                  <div class="col-span-12 md:col-span-3">
                    <p class="text-sm tracking-tight text-stone-500">
                      {project.metric}
                    </p>
                    <p class="mt-1 text-sm text-stone-500">{project.role}</p>
                  </div>
                  <div class="col-span-12 md:col-span-9">
                    <div class="flex items-baseline justify-between gap-4">
                      <h3 class="text-3xl font-medium tracking-tight md:text-4xl">
                        {project.name}
                      </h3>
                      {project.href ? (
                        <a
                          href={project.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="shrink-0 text-sm whitespace-nowrap text-stone-500 underline decoration-stone-300 underline-offset-4 transition hover:text-stone-900 hover:decoration-stone-900"
                        >
                          {project.cta} ↗
                        </a>
                      ) : (
                        <span class="shrink-0 text-sm whitespace-nowrap text-stone-400">
                          {project.cta}
                        </span>
                      )}
                    </div>
                    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-stone-700">
                      {project.description}
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- HOW I WORK -->
    <section class="border-t border-stone-200 bg-stone-50 px-6 py-24 md:py-32">
      <div class="mx-auto max-w-6xl">
        <p
          class="mb-12 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
        >
          How I work
        </p>
        <div class="grid gap-12 md:grid-cols-2 md:gap-16">
          <div>
            <h2
              class="text-3xl font-medium tracking-tight text-stone-900 md:text-4xl"
            >
              One person. Working software. Every week.
            </h2>
            <p
              class="mt-8 text-lg leading-relaxed text-stone-600 md:text-xl"
            >
              I work directly with founders and product leads. No agency layers,
              no junior overhead, no week-long discovery phases. We agree on a
              clear outcome, I ship in iterations, you see real software in
              days.
            </p>
          </div>
          <div class="space-y-8">
            <div>
              <h4 class="text-sm font-medium tracking-tight text-stone-900">
                Fixed-scope sprints
              </h4>
              <p class="mt-2 leading-relaxed text-stone-600">
                Two to six weeks. Clear deliverable, fixed price, no scope
                creep.
              </p>
            </div>
            <div>
              <h4 class="text-sm font-medium tracking-tight text-stone-900">
                Embedded engagements
              </h4>
              <p class="mt-2 leading-relaxed text-stone-600">
                Drop into your repo and ship features alongside your team. Best
                for prototypes, AI integrations, and unblocking specific
                problems.
              </p>
            </div>
            <div>
              <h4 class="text-sm font-medium tracking-tight text-stone-900">
                Product advisory
              </h4>
              <p class="mt-2 leading-relaxed text-stone-600">
                Senior product judgement on what to build, what to cut, and how
                to position. Hourly or retainer.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-20 border-t border-stone-200 pt-12">
          <p
            class="mb-6 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
          >
            Stack
          </p>
          <ul class="flex flex-wrap gap-2">
            {
              stack.map((item) => (
                <li class="rounded-full border border-stone-300 px-4 py-1.5 text-sm text-stone-700">
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-32 md:py-40">
      <div class="mx-auto max-w-4xl text-center">
        <p
          class="mb-8 text-xs font-medium tracking-[0.2em] text-stone-500 uppercase"
        >
          Get in touch
        </p>
        <h2
          class="text-4xl leading-tight font-medium tracking-tight text-stone-900 md:text-6xl"
        >
          Got a product to ship?<br />
          <span class="text-stone-500">Let's talk.</span>
        </h2>
        <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
          <a
            href="mailto:carl.palmquist@gmail.com?subject=Project%20inquiry"
            class="inline-flex items-center gap-2 rounded-full bg-stone-900 px-8 py-4 text-base font-medium text-white transition hover:bg-stone-700"
          >
            carl.palmquist@gmail.com
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <ul
          class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm"
        >
          {
            links
              .filter((l) => l.label !== 'Email')
              .map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-stone-600 underline decoration-stone-300 underline-offset-4 transition hover:text-stone-900 hover:decoration-stone-900"
                  >
                    {link.label}
                  </a>
                </li>
              ))
          }
        </ul>
      </div>
    </section>

    <footer class="border-t border-stone-200 px-6 py-8">
      <div
        class="mx-auto flex max-w-6xl items-center justify-between text-sm text-stone-400"
      >
        <p>© {new Date().getFullYear()} Carl Palmquist</p>
        <p>Stockholm</p>
      </div>
    </footer>
  </main>
</Layout>
