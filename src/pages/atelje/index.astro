---
// Modeateljén — mobilt påklädningsspel (carlpalmquist.com/atelje).
// Lager-baserat: Flux-dockor (neutral pose) + worn PNG-plagg per slot, färglagda live (canvas multiply).
// Plaggen genereras "burna på osynlig mannekäng" i samma 9:16-pose → läggs 1:1 ovanpå dockan.
---
<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
<meta name="theme-color" content="#fbeef3" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<title>Modeateljén</title>
<style is:global>
  :root{
    --bg:#fbeef3; --panel:#fff; --ink:#3b2c3a; --muted:#9a7f92;
    --accent:#e86fa6; --accent2:#7cc7c0; --line:#f0d9e4;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0; height:100%;}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg); color:var(--ink); display:flex; flex-direction:column; align-items:center;
    min-height:100dvh; overflow-x:hidden;}
  header{width:100%; max-width:520px; padding:10px 16px 2px; text-align:center;}
  header h1{margin:0; font-size:19px;} header h1 .doll{color:var(--accent);}
  header .sub{margin:2px 0 0; font-size:12px; color:var(--muted);}

  .stage{position:relative; height:min(54vh,500px); aspect-ratio:9/16; max-width:96vw; flex:0 0 auto;
    border-radius:22px; overflow:hidden; margin:8px 0; box-shadow:0 10px 30px rgba(120,60,90,.18); touch-action:none;
    background:linear-gradient(160deg,#ffd9e6,#ffeef4 55%,#e9f7f4); transition:background .4s ease;}
  .layer{position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center; pointer-events:none; user-select:none;}
  .acc{position:absolute; transform:translate(-50%,-50%); font-size:40px; cursor:grab; touch-action:none;
    user-select:none; filter:drop-shadow(0 2px 3px rgba(0,0,0,.25)); transition:filter .1s;}
  .acc.drag{cursor:grabbing;}
  .acc.sel{outline:2px dashed rgba(232,111,166,.9); outline-offset:3px; border-radius:6px;}
  .achandle{position:absolute; width:24px; height:24px; border-radius:50%; background:var(--accent); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:13px; cursor:nwse-resize; touch-action:none;
    box-shadow:0 1px 4px rgba(0,0,0,.3); z-index:6; transform:translate(-50%,-50%); user-select:none;}
  /* passforms-kontroll för plagg */
  .fitbar{display:flex; align-items:center; gap:6px; flex-wrap:wrap; background:rgba(232,111,166,.08);
    border:1px solid var(--line); border-radius:12px; padding:7px 9px; margin:2px 0 4px;}
  .fitbar b{font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.3px; margin-right:2px;}
  .fitbtn{border:1px solid var(--line); background:#fff; border-radius:9px; width:34px; height:30px; font-size:15px; cursor:pointer; display:flex; align-items:center; justify-content:center;}
  .fitbtn:active{background:var(--line);}
  .fitbar .fitreset{margin-left:auto; font-size:12px; width:auto; padding:0 10px;}
  .acc.pop{animation:accpop .35s cubic-bezier(.2,1.4,.4,1);}
  @keyframes accpop{0%{transform:translate(-50%,-50%) scale(0) rotate(-25deg);}100%{transform:translate(-50%,-50%) scale(1);}}
  .acc.poof{animation:poof .22s ease forwards; pointer-events:none;}
  @keyframes poof{to{opacity:0; transform:translate(-50%,-160%) scale(.2) rotate(20deg);}}
  .stage.trashglow{box-shadow:0 10px 30px rgba(120,60,90,.18), inset 0 0 0 3px #ff6b8b;}
  /* plagg glider in underifrån + studs */
  .layer.slidein{animation:slidein .4s ease;}
  @keyframes slidein{0%{opacity:0;}100%{opacity:1;}}
  .stage.curtsy{animation:curtsy 1s ease;} @keyframes curtsy{30%{transform:translateY(6px) scale(.99,.98);}60%{transform:translateY(-4px);}}
  .spark{position:absolute; font-size:18px; pointer-events:none; animation:spark .7s ease forwards; z-index:5;}
  @keyframes spark{0%{opacity:0; transform:translate(-50%,-50%) scale(.3);}30%{opacity:1;}100%{opacity:0; transform:translate(-50%,-150%) scale(1.1);}}

  .actions{display:flex; gap:8px; width:100%; max-width:430px; padding:2px 12px 0;}
  .actions button{flex:1; border:0; border-radius:14px; padding:11px; font-size:15px; font-weight:700; cursor:pointer;}
  .btn-done{background:var(--accent); color:#fff;} .btn-reset{background:var(--line); color:var(--ink); flex:0 0 auto; padding:11px 15px;}
  .hint{font-size:11px; color:var(--muted); text-align:center; margin:5px 0 0;}

  .drawer{width:100%; max-width:520px; background:var(--panel); border-radius:20px 20px 0 0;
    box-shadow:0 -6px 20px rgba(120,60,90,.12); padding:8px 12px 14px;}
  .tabs{display:flex; gap:6px; overflow-x:auto; padding-bottom:8px;}
  .tabs button{flex:0 0 auto; border:0; background:var(--line); color:var(--ink); padding:8px 11px;
    border-radius:999px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap;}
  .tabs button.on{background:var(--accent); color:#fff;}
  .panelbody{min-height:120px;}
  .sect{margin:8px 0;} .sect .lbl{font-size:11px; color:var(--muted); font-weight:700; text-transform:uppercase; letter-spacing:.4px; margin:0 0 5px 2px;}
  .row{display:flex; gap:7px; flex-wrap:wrap;}
  .rowsc{display:flex; gap:8px; overflow-x:auto; padding-bottom:4px;}
  /* plagg-brickor */
  .gitem{flex:0 0 auto; width:66px; height:92px; border-radius:12px; border:2px solid var(--line); background:#fff url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg"/>') center/contain no-repeat;
    cursor:pointer; position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center;}
  .gitem img{width:100%; height:100%; object-fit:contain;}
  .gitem.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .gitem .x{font-size:22px; color:var(--muted);}
  .swatch{width:42px; height:42px; border-radius:11px; border:2px solid var(--line); cursor:pointer; overflow:hidden; position:relative; flex:0 0 auto;}
  .swatch canvas{position:absolute; inset:0; width:100%; height:100%;}
  .swatch.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .chip{width:36px; height:36px; border-radius:50%; border:2px solid #fff; cursor:pointer; box-shadow:0 1px 4px rgba(0,0,0,.15); flex:0 0 auto;}
  .chip.sel{outline:3px solid var(--accent); outline-offset:2px;}
  .charcard{border:2px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; background:#fff; text-align:center;}
  .charcard.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .charcard img{width:100%; aspect-ratio:.66; object-fit:contain; object-position:center bottom; display:block; background:linear-gradient(160deg,#ffe1ec,#eafaf6);}
  .charcard span{display:block; font-size:11px; padding:3px 2px; color:#6a5560;}
  .bgcard{border:2px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; background:#fff; text-align:center;}
  .bgcard.sel{border-color:var(--accent2); box-shadow:0 0 0 3px rgba(124,199,192,.3);}
  .bgcard img{width:100%; aspect-ratio:3/4; object-fit:cover; display:block;}
  .bgcard span{display:block; font-size:10.5px; padding:2px; color:#6a5560;}
  .accbtn{font-size:24px; background:var(--line); border:0; border-radius:12px; padding:6px 8px; cursor:pointer;}
  .cards{display:flex; gap:10px; overflow-x:auto; padding-bottom:4px;}
  .card{flex:0 0 132px; border-radius:14px; overflow:hidden; cursor:pointer; border:2px solid var(--line); background:#fff; text-align:left;}
  .card .prev{height:54px; display:flex;} .card .prev i{flex:1;}
  .card .cap{padding:6px 9px;} .card .cap b{display:block; font-size:12.5px;} .card .cap small{color:var(--muted); font-size:10px; line-height:1.25; display:block;}

  .wardrobe{width:100%; max-width:520px; padding:8px 12px 26px;}
  .wardrobe h3{font-size:12px; color:var(--muted); margin:6px 4px; font-weight:700; text-transform:uppercase; letter-spacing:.5px;}
  .wrow{display:flex; gap:8px; overflow-x:auto; padding-bottom:6px; min-height:8px;}
  .wthumb{flex:0 0 66px; height:100px; border-radius:12px; overflow:hidden; border:2px solid var(--line); position:relative; cursor:pointer; background:linear-gradient(160deg,#ffe1ec,#eafaf6);}
  .wthumb img{position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center bottom;}
  .wthumb .wname{position:absolute; bottom:0; left:0; right:0; font-size:9px; text-align:center; background:rgba(255,255,255,.85); padding:1px;}

  .confetti{position:fixed; inset:0; pointer-events:none; overflow:hidden; z-index:50;}
  .conf{position:absolute; top:-20px; animation:fall linear forwards;} @keyframes fall{to{transform:translateY(105vh) rotate(540deg);}}
  .toast{position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:var(--ink); color:#fff;
    padding:10px 16px; border-radius:999px; font-size:13px; z-index:60; opacity:0; transition:opacity .3s;}
  .toast.show{opacity:1;}
</style>
</head>
<body>
<header>
  <h1>👗 Modeateljén <span class="doll" id="dollname">Nadia</span></h1>
  <p class="sub">Välj docka, klä på henne — färg &amp; mönster på varje plagg. Mixa fritt.</p>
</header>

<div class="stage" id="stage">
  <img class="layer" id="L-doll" alt="docka" />
  <img class="layer" id="L-bottom" style="display:none" />
  <img class="layer" id="L-dress" style="display:none" />
  <img class="layer" id="L-top" style="display:none" />
  <img class="layer" id="L-outer" style="display:none" />
</div>

<div class="drawer">
  <div class="tabs" id="tabs">
    <button data-tab="docka" class="on">💃 Docka</button>
    <button data-tab="dress">👗 Klänning</button>
    <button data-tab="top">👚 Topp</button>
    <button data-tab="bottom">👖 Underdel</button>
    <button data-tab="outer">🧥 Ytterplagg</button>
    <button data-tab="stil">✨ Stil</button>
    <button data-tab="pynt">🎀 Pynt</button>
    <button data-tab="bak">🏞️ Bakgrund</button>
  </div>
  <div class="panelbody" id="panelbody"></div>
</div>

<div class="actions">
  <button class="btn-reset" id="reset" title="Klä av">↺</button>
  <button class="btn-done" id="done">📸 Klar!</button>
</div>
<p class="hint" id="hint">Tappa ett plagg så glider det på henne. Markera plagg/pynt för att flytta &amp; ändra storlek. 🗑️</p>

<div class="wardrobe"><h3>👚 Din garderob</h3><div class="wrow" id="wrow"></div></div>
<div class="confetti" id="confetti" hidden></div>
<div class="toast" id="toast"></div>

<script is:inline>
(function(){
  var $=function(id){return document.getElementById(id);};

  // ===== Roster (Flux-dockor, neutral pose, transparent) =====
  var CHARS=[
    {id:"01-nadia",name:"Nadia",bg:"tradgard"},{id:"02-elsa",name:"Elsa",bg:"bal"},{id:"03-mira",name:"Mira",bg:"stad"},
    {id:"04-zoe",name:"Zoe",bg:"strand"},{id:"05-vera",name:"Vera",bg:"skog"},{id:"06-lin",name:"Lin",bg:"slott"},
    {id:"07-ada",name:"Ada",bg:"rum"},{id:"08-noor",name:"Noor",bg:"ang"},{id:"09-stella",name:"Stella",bg:"catwalk"},{id:"10-amara",name:"Amara",bg:"vinter"}
  ];

  // ===== Garderob: worn PNG per slot (/garderob/<slot>/<id>.png), färglagd live =====
  var WARDROBE={
    dress:[["aline","A-linje"],["sundress","Solklänning"],["maxi","Maxi"],["ballgown","Balklänning"],["skater","Skater"],["puff","Puffärm"],["wrap","Omlott"],["shift","Rak"]],
    top:[["tee","T-shirt"],["tank","Linne"],["blouse","Blus"],["sweater","Tröja"],["crop","Kort"],["hoodie","Hoodie"],["offshoulder","Off-shoulder"]],
    bottom:[["flareskirt","Kjol"],["pleatedskirt","Veckad kjol"],["jeans","Jeans"],["leggings","Leggings"],["shorts","Shorts"],["widepants","Vida byxor"],["tutu","Tyllkjol"]],
    outer:[["denimjacket","Jeansjacka"],["blazer","Kavaj"],["trench","Trenchcoat"],["cardigan","Kofta"],["puffer","Pufferjacka"]]
  };
  var SLOT_LABEL={dress:"Klänning",top:"Topp",bottom:"Underdel",outer:"Ytterplagg"};

  // ===== Mönster (canvas-tiles, används både för recolor och swatch-preview) =====
  var PATTERNS={
    slat:"Slätt", prickar:"Prickar", rander:"Ränder", tweed:"Tweed", rutor:"Rutor",
    hjartan:"Hjärtan", blommor:"Blommor", stjarnor:"Stjärnor", leopard:"Leopard"
  };
  function patCanvas(pat,color,fg){
    var s=document.createElement("canvas"); s.width=34; s.height=34; var c=s.getContext("2d");
    c.fillStyle=color; c.fillRect(0,0,34,34); c.fillStyle=fg;
    function dot(x,y,r){c.beginPath();c.arc(x,y,r,0,7);c.fill();}
    function star(x,y,sc){c.save();c.translate(x,y);c.scale(sc,sc);c.beginPath();for(var i=0;i<10;i++){var a=Math.PI/5*i-Math.PI/2;var r=i%2?3:8;c.lineTo(Math.cos(a)*r,Math.sin(a)*r);}c.closePath();c.fill();c.restore();}
    function heart(x,y,sc){c.save();c.translate(x,y);c.scale(sc,sc);c.beginPath();c.moveTo(0,3);c.bezierCurveTo(-6,-4,-11,3,0,10);c.bezierCurveTo(11,3,6,-4,0,3);c.fill();c.restore();}
    function flower(x,y){for(var i=0;i<5;i++){var a=i*72*Math.PI/180;dot(x+Math.cos(a)*4,y+Math.sin(a)*4,2.4);}var o=c.fillStyle;c.fillStyle="#ffe08a";dot(x,y,2);c.fillStyle=o;}
    if(pat==="prickar"){dot(9,9,4);dot(26,26,4);dot(26,9,2.5);dot(9,26,2.5);}
    else if(pat==="rander"){c.fillRect(0,0,34,9);c.globalAlpha=.6;c.fillRect(0,18,34,6);c.globalAlpha=1;}
    else if(pat==="tweed"){c.strokeStyle=fg;c.globalAlpha=.8;c.lineWidth=2;c.beginPath();[8,26].forEach(function(y){c.moveTo(0,y);c.lineTo(34,y);});[8,26].forEach(function(x){c.moveTo(x,0);c.lineTo(x,34);});c.stroke();c.globalAlpha=1;}
    else if(pat==="rutor"){c.globalAlpha=.85;c.fillRect(0,0,17,17);c.fillRect(17,17,17,17);c.globalAlpha=1;}
    else if(pat==="hjartan"){heart(9,9,.9);heart(26,26,.9);}
    else if(pat==="blommor"){flower(11,11);flower(26,26);}
    else if(pat==="stjarnor"){star(10,11,.6);star(25,25,.6);}
    else if(pat==="leopard"){c.save();[[9,10],[25,22],[15,28],[28,8]].forEach(function(p){c.beginPath();c.ellipse(p[0],p[1],4.5,3.2,.4,0,7);c.fill();});c.restore();}
    return s;
  }

  var COLORS=["#ffffff","#111318","#e2506e","#c1122b","#e7b6cf","#d9a441","#8ec5e8","#3a6ea5","#8fd6c4","#9bb58a","#c7b3e6","#f7a072","#6d4423","#e8b0c4"];
  var ACCESSORIES=["🎀","💎","👜","👑","🌸","🕶️","👒","🌹","🧣","⭐","🌿","💐","👠","🥿","🧢","❄️"];

  var BACKDROPS={
    catwalk:{name:"Catwalk",img:"/bg/01-catwalk.jpg"},tradgard:{name:"Trädgård",img:"/bg/02-tradgard.jpg"},
    strand:{name:"Strand",img:"/bg/03-strand.jpg"},bal:{name:"Bal",img:"/bg/04-bal.jpg"},rum:{name:"Rum",img:"/bg/05-rum.jpg"},
    skog:{name:"Skog",img:"/bg/06-skog.jpg"},vinter:{name:"Vinter",img:"/bg/07-vinter.jpg"},ang:{name:"Äng",img:"/bg/08-ang.jpg"},
    stad:{name:"Stad",img:"/bg/09-stad.jpg"},slott:{name:"Slott",img:"/bg/10-slott.jpg"}
  };

  // ===== Designer-recept: sätter riktiga plagg + palett + mönster + pynt =====
  var STYLES=[
    {name:"Chanel",vibe:"Tweed, creme & svart, pärlor",set:{top:{id:"blouse",color:"#f2efe9",pat:"slat",fg:"#111"},bottom:{id:"pleatedskirt",color:"#111318",pat:"slat",fg:"#fff"},outer:{id:"blazer",color:"#f2efe9",pat:"tweed",fg:"#111318"}},clear:["dress"],acc:["💎","👜"],sw:["#f2efe9","#111318","#d9a441"]},
    {name:"Valentino",vibe:"Romantisk röd, volang",set:{dress:{id:"ballgown",color:"#c1122b",pat:"slat",fg:"#fff"}},clear:["top","bottom","outer"],acc:["🌹"],sw:["#c1122b","#8a0d20","#ffd1d9"]},
    {name:"Versace",vibe:"Guld & barock glamour",set:{dress:{id:"maxi",color:"#111318",pat:"blommor",fg:"#d9a441"}},clear:["top","bottom","outer"],acc:["👑","🕶️"],sw:["#111318","#d9a441","#e2c266"]},
    {name:"Dior",vibe:"Elegant marin, ren linje",set:{dress:{id:"skater",color:"#26314f",pat:"slat",fg:"#fff"}},clear:["top","bottom","outer"],acc:["👜","🕶️"],sw:["#26314f","#c9d3e6","#fff"]},
    {name:"Stella M.",vibe:"Ren, salvia, avskalad",set:{top:{id:"sweater",color:"#9bb58a",pat:"slat",fg:"#fff"},bottom:{id:"widepants",color:"#8a9e7a",pat:"slat",fg:"#fff"}},clear:["dress","outer"],acc:["🌿"],sw:["#9bb58a","#8a9e7a","#e7ead9"]},
    {name:"Louisa",vibe:"Din egna stjärn-look!",set:{dress:{id:"puff",color:"#e7b6cf",pat:"stjarnor",fg:"#fff3a0"}},clear:["top","bottom","outer"],acc:["⭐","🎀"],sw:["#e7b6cf","#fff3a0","#e86fa6"]},
    {name:"Frost",vibe:"Isblå prinsessa",set:{dress:{id:"maxi",color:"#bfe3f0",pat:"stjarnor",fg:"#fff"}},clear:["top","bottom","outer"],acc:["❄️","👑"],sw:["#bfe3f0","#7cc7c0","#fff"]}
  ];

  // ===== State =====
  function slot0(){return {id:"",color:"#ffffff",pat:"slat",fg:"#ffffff",adj:{s:1,dx:0,dy:0}};}
  function adj0(){return {s:1,dx:0,dy:0};}
  var state={ char:"01-nadia", dress:slot0(), top:{id:"tee",color:"#e7b6cf",pat:"prickar",fg:"#fff",adj:adj0()}, bottom:{id:"flareskirt",color:"#8ec5e8",pat:"slat",fg:"#fff",adj:adj0()}, outer:slot0(), bd:"tradgard", acc:[] };

  // ===== Recolor: vit worn-PNG → färg/mönster via canvas multiply (destination-in bevarar formen) =====
  var _imgCache={}, _paintCache={};
  function loadImg(src,cb){ if(_imgCache[src]){ var im=_imgCache[src]; if(im.complete&&im.naturalWidth)cb(im); else im.addEventListener("load",function(){cb(im);}); return; } var im=new Image(); im.crossOrigin="anonymous"; _imgCache[src]=im; im.addEventListener("load",function(){cb(im);}); im.addEventListener("error",function(){cb(null);}); im.src=src; }
  function paintGarment(slot,cb){
    var s=state[slot]; if(!s.id){cb(null);return;}
    var src="/garderob/"+slot+"/"+s.id+".png";
    var key=src+"|"+s.color+"|"+s.pat+"|"+s.fg;
    if(_paintCache[key]){cb(_paintCache[key]);return;}
    loadImg(src,function(im){
      if(!im){cb(null);return;}
      var W=im.naturalWidth,H=im.naturalHeight,cv=document.createElement("canvas");cv.width=W;cv.height=H;var x=cv.getContext("2d");
      x.drawImage(im,0,0);
      x.globalCompositeOperation="multiply";
      if(s.pat&&s.pat!=="slat"){ var t=patCanvas(s.pat,s.color,s.fg); var p=x.createPattern(t,"repeat"); var sc=W/430; x.save(); x.scale(sc,sc); x.fillStyle=p; x.fillRect(0,0,W/sc,H/sc); x.restore(); }
      else { x.fillStyle=s.color; x.fillRect(0,0,W,H); }
      x.globalCompositeOperation="destination-in"; x.drawImage(im,0,0);
      x.globalCompositeOperation="source-over";
      var url=cv.toDataURL("image/png"); _paintCache[key]=url; cb(url);
    });
  }

  // ===== Per-docka axel-landmärke (andel av ramen), PIL-mätt via centralt band + klampat [0.25,0.33] =====
  // Varje docka har olika huvud/hår → axeln sitter olika. Plaggen ankras till DENNA dockas axel/midja.
  var DOLL_SH={"01-nadia":0.30,"02-elsa":0.26,"03-mira":0.30,"04-zoe":0.31,"05-vera":0.31,"06-lin":0.26,"07-ada":0.30,"08-noor":0.32,"09-stella":0.26,"10-amara":0.29};
  var SLOT_DY={dress:0.0,top:0.012,bottom:0.20,outer:-0.008};     // förskjutning från axel-linjen per slot (midja = +0.20)
  var SLOT_SCALE={dress:0.92,top:0.84,bottom:0.90,outer:0.90};    // krymp plagg till kroppsbredd
  function slotAnchor(slot){ return (DOLL_SH[state.char]||0.29) + (SLOT_DY[slot]||0); }
  var _bbox={};
  function bboxOf(src,cb){
    if(_bbox[src]){cb(_bbox[src]);return;}
    loadImg(src,function(im){
      if(!im){cb(null);return;}
      var w=120,h=213,cv=document.createElement("canvas");cv.width=w;cv.height=h;var x=cv.getContext("2d");
      x.drawImage(im,0,0,w,h);var d;try{d=x.getImageData(0,0,w,h).data;}catch(e){cb(null);return;}
      var x0=w,y0=h,x1=0,y1=0,f=false;
      for(var yy=0;yy<h;yy++){for(var xx=0;xx<w;xx++){if(d[(yy*w+xx)*4+3]>28){f=true;if(xx<x0)x0=xx;if(xx>x1)x1=xx;if(yy<y0)y0=yy;if(yy>y1)y1=yy;}}}
      var b=f?{y0:y0/h,cx:((x0+x1)/2)/w}:{y0:0,cx:.5};_bbox[src]=b;cb(b);
    });
  }
  function anchorLayer(el,slot,s){
    var src="/garderob/"+slot+"/"+s.id+".png";
    bboxOf(src,function(b){ if(!b){el.style.transform="";return;}
      var a=s.adj||adj0();
      var sc=(SLOT_SCALE[slot]||1)*a.s;
      var ty=(slotAnchor(slot)-b.y0*sc)*100 + a.dy;
      var tx=(0.5-b.cx)*sc*100 + a.dx;
      el.style.transformOrigin="50% 0";
      el.style.transform="translate("+tx.toFixed(1)+"%,"+ty.toFixed(1)+"%) scale("+sc.toFixed(3)+")";
    });
  }

  // ===== Render =====
  function paintLayer(slot,animate){
    var el=$("L-"+slot), s=state[slot];
    var hide=!s.id || ((slot==="top"||slot==="bottom") && state.dress.id);
    if(hide){ el.style.display="none"; el.removeAttribute("src"); el.style.transform=""; return; }
    anchorLayer(el,slot,s);
    paintGarment(slot,function(url){
      if(!url){ el.style.display="none"; return; }
      el.src=url; el.style.display="";
      if(animate){ el.classList.remove("slidein"); void el.offsetWidth; el.classList.add("slidein"); }
    });
  }
  function renderDoll(){
    var c=CHARS.filter(function(x){return x.id===state.char;})[0]||CHARS[0];
    var dl=$("L-doll"); dl.src="/dolls/"+state.char+".png"; $("dollname").textContent=c.name;
    ["bottom","dress","top","outer"].forEach(function(sl){paintLayer(sl,false);});
    saveCurrent();
  }
  function refreshSlot(slot,animate){ paintLayer(slot,animate); if(state.dress.id){ paintLayer("top",false); paintLayer("bottom",false);} saveCurrent(); }

  function setBackdrop(){ var bd=BACKDROPS[state.bd]||BACKDROPS.catwalk,st=$("stage"); st.style.backgroundImage="url('"+bd.img+"')"; st.style.backgroundSize="cover"; st.style.backgroundPosition="center"; }
  function sparkleAt(px,py){var s=document.createElement("div");s.className="spark";s.textContent="✨";s.style.left=px+"px";s.style.top=py+"px";$("stage").appendChild(s);setTimeout(function(){s.remove();},700);}
  function flashStage(){var r=$("stage").getBoundingClientRect();sparkleAt(r.width*.5,r.height*.4);}

  // ===== Paneler =====
  function garmentPanel(slot){
    var s=state[slot], list=WARDROBE[slot];
    var h='<div class="sect"><div class="lbl">'+SLOT_LABEL[slot]+'</div><div class="rowsc">';
    h+='<div class="gitem'+(s.id===""?" sel":"")+'" data-id=""><span class="x">✕</span></div>';
    list.forEach(function(g){h+='<div class="gitem'+(s.id===g[0]?" sel":"")+'" data-id="'+g[0]+'"><img src="/garderob/'+slot+'/'+g[0]+'.png" alt="'+g[1]+'" onerror="this.parentElement.style.opacity=.3;this.remove()"></div>';});
    h+='</div></div>';
    if(s.id){
      h+='<div class="sect"><div class="lbl">Färg</div><div class="rowsc">';
      COLORS.forEach(function(c){h+='<div class="chip'+(s.color===c?" sel":"")+'" style="background:'+c+'" data-c="'+c+'"></div>';});
      h+='</div></div><div class="sect"><div class="lbl">Mönster</div><div class="rowsc" id="patrow"></div></div>';
      h+='<div class="sect"><div class="lbl">Passform — flytta &amp; storlek</div><div class="fitbar">'
        +'<button class="fitbtn" data-fit="left" title="Vänster">◀</button><button class="fitbtn" data-fit="right" title="Höger">▶</button>'
        +'<button class="fitbtn" data-fit="up" title="Upp">▲</button><button class="fitbtn" data-fit="down" title="Ner">▼</button>'
        +'<button class="fitbtn" data-fit="smaller" title="Mindre">－</button><button class="fitbtn" data-fit="bigger" title="Större">＋</button>'
        +'<button class="fitbtn fitreset" data-fit="reset">↺ passform</button></div></div>';
    }
    $("panelbody").innerHTML=h;
    // mönster-swatchar (canvas)
    if(s.id){ var pr=$("patrow"); Object.keys(PATTERNS).forEach(function(k){ var d=document.createElement("div"); d.className="swatch"+(s.pat===k?" sel":""); d.dataset.pat=k; d.title=PATTERNS[k]; d.appendChild(patCanvas(k,s.color,s.fg)); pr.appendChild(d);}); }
    bindAll(".gitem","click",function(el){ var changed=s.id!==el.dataset.id; s.id=el.dataset.id; if(changed)s.adj=adj0(); refreshSlot(slot,true); garmentPanel(slot); if(s.id)flashStage(); });
    bindAll(".fitbtn","click",function(el){ var a=s.adj||(s.adj=adj0()); var k=el.dataset.fit;
      if(k==="left")a.dx-=2.2; else if(k==="right")a.dx+=2.2; else if(k==="up")a.dy-=2.2; else if(k==="down")a.dy+=2.2;
      else if(k==="smaller")a.s=Math.max(.5,+(a.s-0.06).toFixed(2)); else if(k==="bigger")a.s=Math.min(1.8,+(a.s+0.06).toFixed(2));
      else if(k==="reset")s.adj=adj0();
      anchorLayer($("L-"+slot),slot,s); saveCurrent(); });
    bindAll(".chip","click",function(el){ s.color=el.dataset.c; if(s.pat==="slat"){s.fg=el.dataset.c;} refreshSlot(slot,false); garmentPanel(slot); });
    bindAll(".swatch","click",function(el){ s.pat=el.dataset.pat; refreshSlot(slot,false); garmentPanel(slot); flashStage(); });
  }
  var TAB={
    docka:function(){
      var h='<div class="sect"><div class="lbl">Välj docka</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(66px,1fr));gap:8px">';
      CHARS.forEach(function(c){h+='<div class="charcard'+(state.char===c.id?" sel":"")+'" data-char="'+c.id+'"><img src="/dolls/'+c.id+'.png" alt="'+c.name+'"><span>'+c.name+'</span></div>';});
      $("panelbody").innerHTML=h+'</div><p class="hint">Byt docka när du vill — plaggen följer med.</p>';
      bindAll(".charcard","click",function(el){ state.char=el.dataset.char; var c=CHARS.filter(function(x){return x.id===el.dataset.char;})[0]; if(c&&c.bg)state.bd=c.bg; renderDoll(); setBackdrop(); TAB.docka(); flashStage(); });
    },
    dress:function(){garmentPanel("dress");},
    top:function(){garmentPanel("top");},
    bottom:function(){garmentPanel("bottom");},
    outer:function(){garmentPanel("outer");},
    stil:function(){
      var h='<div class="cards">';
      STYLES.forEach(function(st,i){ var sw=(st.sw||["#eee","#ddd","#ccc"]).map(function(c){return '<i style="background:'+c+'"></i>';}).join(""); h+='<div class="card" data-i="'+i+'"><div class="prev">'+sw+'</div><div class="cap"><b>'+st.name+'</b><small>'+st.vibe+'</small></div></div>';});
      $("panelbody").innerHTML=h+'</div><p class="hint">Ett tryck klär henne i en hel designer-look — plagg, färg, mönster &amp; pynt.</p>';
      bindAll(".card","click",function(el){applyStyle(STYLES[+el.dataset.i]);});
    },
    pynt:function(){
      var h='<div class="row">';
      ACCESSORIES.forEach(function(e){h+='<button class="accbtn" data-e="'+e+'">'+e+'</button>';});
      $("panelbody").innerHTML=h+'</div><p class="hint">Tappa för att lägga till, dra sen dit du vill. Dra utanför rutan = ta bort.</p>';
      bindAll(".accbtn","click",function(el){addAccessory(el.dataset.e);});
    },
    bak:function(){
      var h='<div class="sect"><div class="lbl">Bakgrund</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(76px,1fr));gap:8px">';
      Object.keys(BACKDROPS).forEach(function(k){h+='<div class="bgcard'+(state.bd===k?" sel":"")+'" data-bd="'+k+'"><img src="'+BACKDROPS[k].img+'" alt="'+BACKDROPS[k].name+'"><span>'+BACKDROPS[k].name+'</span></div>';});
      $("panelbody").innerHTML=h+'</div></div>';
      bindAll(".bgcard","click",function(el){state.bd=el.dataset.bd;setBackdrop();saveCurrent();TAB.bak();});
    }
  };
  function applyStyle(st){
    Object.keys(st.set||{}).forEach(function(sl){ var d=st.set[sl]; state[sl]={id:d.id,color:d.color,pat:d.pat||"slat",fg:d.fg||d.color}; });
    (st.clear||[]).forEach(function(sl){ state[sl]=slot0(); });
    document.querySelectorAll(".acc").forEach(function(e){e.remove();}); state.acc=[];
    (st.acc||[]).forEach(function(e){addAccessory(e);});
    ["bottom","dress","top","outer"].forEach(function(sl){paintLayer(sl,true);});
    saveCurrent(); toast("💃 "+st.name+"-look!"); flashStage();
  }

  // ===== Pynt: placera, flytta, markera → ändra storlek (handtag + nyp) =====
  var ANCHORS=[{x:50,y:11},{x:50,y:30},{x:50,y:46},{x:30,y:58},{x:70,y:58},{x:50,y:20}];
  var selAcc=null;
  function setPos(el,xp,yp){el.style.left=xp+"%";el.style.top=yp+"%";el._x=xp;el._y=yp;}
  function setSize(el,px){el._size=px;el.style.fontSize=px+"px";}
  function spawnAcc(a){
    var el=document.createElement("div"); el.className="acc"; el.dataset.e=a.e; el.textContent=a.e;
    setSize(el,a.size||44); setPos(el,a.x,a.y); $("stage").appendChild(el); makeDraggable(el); return el;
  }
  function addAccessory(emoji){
    var a=/👑|👒|🎀|🕶️|⭐|🧢|❄️/.test(emoji)?ANCHORS[0]:(/💎|🧣|🌹|🌸/.test(emoji)?ANCHORS[1]:(/👠|🥿/.test(emoji)?{x:50,y:92}:ANCHORS[2]));
    var el=spawnAcc({e:emoji,x:a.x,y:a.y,size:44}); el.classList.add("pop");
    var r=$("stage").getBoundingClientRect(); sparkleAt(a.x/100*r.width,a.y/100*r.height); selectAcc(el); saveCurrent();
  }
  function removeHandle(el){var h=el.querySelector(".achandle");if(h)h.remove();}
  function addHandle(el){
    if(el.querySelector(".achandle"))return;
    var hd=document.createElement("div"); hd.className="achandle"; hd.textContent="⤢"; hd.style.left="100%"; hd.style.top="100%"; el.appendChild(hd);
    hd.addEventListener("pointerdown",function(ev){ ev.preventDefault(); ev.stopPropagation(); hd.setPointerCapture(ev.pointerId);
      var rc=el.getBoundingClientRect(), cx=rc.left+rc.width/2, cy=rc.top+rc.height/2;
      function mv(e){ setSize(el,Math.max(20,Math.min(140,Math.hypot(e.clientX-cx,e.clientY-cy)*1.4))); }
      function up(){ try{hd.releasePointerCapture(ev.pointerId);}catch(_){} hd.removeEventListener("pointermove",mv); hd.removeEventListener("pointerup",up); saveCurrent(); }
      hd.addEventListener("pointermove",mv); hd.addEventListener("pointerup",up);
    });
  }
  function selectAcc(el){ if(selAcc&&selAcc!==el){selAcc.classList.remove("sel");removeHandle(selAcc);} selAcc=el; el.classList.add("sel"); addHandle(el); }
  function deselectAcc(){ if(selAcc){selAcc.classList.remove("sel");removeHandle(selAcc);selAcc=null;} }
  function makeDraggable(el){
    var pts={}, startDist=0, startSize=0, moved=false, downPt=null;
    function dst(a,b){return Math.hypot(a.x-b.x,a.y-b.y);}
    el.addEventListener("pointerdown",function(ev){
      if(ev.target.classList.contains("achandle"))return;
      ev.preventDefault(); el.setPointerCapture(ev.pointerId); pts[ev.pointerId]={x:ev.clientX,y:ev.clientY};
      var ids=Object.keys(pts);
      if(ids.length===1){ moved=false; downPt={x:ev.clientX,y:ev.clientY}; el.classList.add("drag"); }
      else if(ids.length===2){ startDist=dst(pts[ids[0]],pts[ids[1]]); startSize=el._size||44; }
    });
    el.addEventListener("pointermove",function(ev){
      if(!pts[ev.pointerId])return; pts[ev.pointerId]={x:ev.clientX,y:ev.clientY};
      var ids=Object.keys(pts);
      if(ids.length>=2){ if(startDist){ setSize(el,Math.max(20,Math.min(140,startSize*dst(pts[ids[0]],pts[ids[1]])/startDist))); } return; }
      var r=$("stage").getBoundingClientRect(), M=6;
      if(downPt&&Math.hypot(ev.clientX-downPt.x,ev.clientY-downPt.y)>4)moved=true;
      var out=ev.clientX<r.left-M||ev.clientX>r.right+M||ev.clientY<r.top-M||ev.clientY>r.bottom+M; el._out=out; $("stage").classList.toggle("trashglow",out);
      setPos(el,Math.max(2,Math.min(98,(ev.clientX-r.left)/r.width*100)),Math.max(2,Math.min(98,(ev.clientY-r.top)/r.height*100)));
    });
    function endPtr(ev){
      if(!pts[ev.pointerId])return; delete pts[ev.pointerId]; try{el.releasePointerCapture(ev.pointerId);}catch(e){}
      if(Object.keys(pts).length>0)return;
      el.classList.remove("drag"); $("stage").classList.remove("trashglow");
      if(el._out){ if(selAcc===el)deselectAcc(); el.classList.add("poof"); toast("🗑️ Borttaget"); setTimeout(function(){el.remove();saveCurrent();},220); return; }
      if(!moved){ if(selAcc===el)deselectAcc(); else selectAcc(el); }
      saveCurrent();
    }
    el.addEventListener("pointerup",endPtr); el.addEventListener("pointercancel",endPtr);
    el.addEventListener("dblclick",function(){ if(selAcc===el)deselectAcc(); el.remove(); saveCurrent(); });
  }

  // ===== Persistens (överlever skärmlås / omladdning) =====
  var CKEY="atelje_current_v3";
  function snapAcc(){return Array.prototype.slice.call(document.querySelectorAll(".acc")).map(function(el){return {e:el.dataset.e||el.textContent,x:el._x,y:el._y,size:el._size||44};});}
  function saveCurrent(){ try{localStorage.setItem(CKEY,JSON.stringify({char:state.char,dress:state.dress,top:state.top,bottom:state.bottom,outer:state.outer,bd:state.bd,acc:snapAcc()}));}catch(e){} }
  function restoreCurrent(){ try{ var c=JSON.parse(localStorage.getItem(CKEY)||"null"); if(!c)return; ["char","dress","top","bottom","outer","bd"].forEach(function(k){if(c[k]!==undefined)state[k]=c[k];}); ["dress","top","bottom","outer"].forEach(function(sl){if(state[sl]&&!state[sl].adj)state[sl].adj=adj0();}); (c.acc||[]).forEach(function(a){spawnAcc(a);}); }catch(e){} }

  // ===== Garderob (sparade looks) =====
  var WKEY="atelje_wardrobe_v2";
  function loadW(){try{return JSON.parse(localStorage.getItem(WKEY)||"[]");}catch(e){return [];}}
  function saveLook(){ var w=loadW(); w.push({char:state.char,dress:state.dress,top:state.top,bottom:state.bottom,outer:state.outer,bd:state.bd,acc:snapAcc(),name:"Look "+(w.length+1)}); try{localStorage.setItem(WKEY,JSON.stringify(w));}catch(e){} renderWardrobe(); }
  function renderWardrobe(){
    var w=$("wrow"), list=loadW(); w.innerHTML="";
    list.forEach(function(s){ var t=document.createElement("div"); t.className="wthumb"; var im=document.createElement("img"); im.src="/dolls/"+s.char+".png"; t.appendChild(im);
      (s.acc||[]).forEach(function(a){var sp=document.createElement("span");sp.style.cssText="position:absolute;left:"+a.x+"%;top:"+a.y+"%;transform:translate(-50%,-50%);font-size:12px";sp.textContent=a.e;t.appendChild(sp);});
      var nm=document.createElement("div"); nm.className="wname"; nm.textContent=s.name; t.appendChild(nm);
      t.addEventListener("click",function(){loadLook(s);}); w.appendChild(t); });
  }
  function loadLook(s){ ["char","dress","top","bottom","outer","bd"].forEach(function(k){if(s[k]!==undefined)state[k]=s[k];}); ["dress","top","bottom","outer"].forEach(function(sl){if(state[sl]&&!state[sl].adj)state[sl].adj=adj0();}); deselectAcc(); document.querySelectorAll(".acc").forEach(function(e){e.remove();}); (s.acc||[]).forEach(function(a){spawnAcc(a);}); renderDoll(); setBackdrop(); toast("👗 "+s.name+" laddad"); }

  // ===== Firande =====
  function done(){
    deselectAcc();
    var c=$("confetti"); c.hidden=false; c.innerHTML=""; var em=["🎉","✨","💖","⭐","🌸","💫"];
    for(var i=0;i<44;i++){var s=document.createElement("div");s.className="conf";s.textContent=em[i%6];s.style.left=((i*97+13)%100)+"%";s.style.animationDuration=(1.6+((i%5)*.3))+"s";s.style.fontSize=(14+(i%4)*6)+"px";c.appendChild(s);}
    setTimeout(function(){c.hidden=true;},2600);
    var st=$("stage"); st.classList.remove("curtsy"); void st.offsetWidth; st.classList.add("curtsy");
    saveLook(); toast("✨ Sparad i garderoben!");
  }

  // ===== Hjälp =====
  function bindAll(sel,ev,fn){Array.prototype.slice.call(document.querySelectorAll("#panelbody "+sel)).forEach(function(el){el.addEventListener(ev,function(){fn(el);});});}
  var toEl=$("toast"),toT=null;
  function toast(m){toEl.textContent=m;toEl.classList.add("show");clearTimeout(toT);toT=setTimeout(function(){toEl.classList.remove("show");},1500);}

  Array.prototype.slice.call(document.querySelectorAll("#tabs button")).forEach(function(b){b.addEventListener("click",function(){document.querySelectorAll("#tabs button").forEach(function(x){x.classList.remove("on");});b.classList.add("on");TAB[b.dataset.tab]();});});
  $("done").addEventListener("click",done);
  $("reset").addEventListener("click",function(){deselectAcc();document.querySelectorAll(".acc").forEach(function(e){e.remove();});state.acc=[];state.dress=slot0();state.top=slot0();state.bottom=slot0();state.outer=slot0();renderDoll();toast("↺ Avklädd — börja om!");});
  // klick på tom scen (eller dockan) avmarkerar pynt
  $("stage").addEventListener("pointerdown",function(e){ if(e.target===$("stage")) deselectAcc(); });

  // init
  restoreCurrent(); renderDoll(); setBackdrop(); renderWardrobe(); TAB.docka();
})();
</script>
</body>
</html>
