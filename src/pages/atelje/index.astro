  var _gownImgCache={};                       // id → laddad vit PNG (Image)
  function loadGownImg(id,cb){
    if(_gownImgCache[id]){ if(_gownImgCache[id].complete) cb(_gownImgCache[id]); else _gownImgCache[id].addEventListener("load",function(){cb(_gownImgCache[id]);}); return; }
    var im=new Image(); im.crossOrigin="anonymous"; _gownImgCache[id]=im;
    im.addEventListener("load",function(){cb(im);}); im.src="/garderob/"+id+".png";
  }
  // Rasterisera ett PATTERN-tile (samma bibliotek som vektorplaggen) till en canvas för createPattern.
  function gownPatternTile(pat,color,fg,cb){
    var svg='<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34">'+PATTERNS[pat].tile(color,fg)+'</svg>';
    var im=new Image(); im.addEventListener("load",function(){cb(im);}); im.src="data:image/svg+xml;utf8,"+encodeURIComponent(svg);
  }
  function paintGown(im,tileImg){
    var W=im.width,H=im.height,cv=document.createElement("canvas");cv.width=W;cv.height=H;var ctx=cv.getContext("2d");
    ctx.drawImage(im,0,0);
    ctx.globalCompositeOperation="multiply";
    ctx.fillStyle=tileImg?ctx.createPattern(tileImg,"repeat"):state.gown.color;
    ctx.fillRect(0,0,W,H);
    if(MATERIALS[state.gown.mat] && MATERIALS[state.gown.mat].fill!=="none"){ ctx.globalCompositeOperation="overlay"; ctx.fillStyle="rgba(255,255,255,.10)"; ctx.fillRect(0,0,W,H); }
    ctx.globalCompositeOperation="destination-in"; ctx.drawImage(im,0,0);
    ctx.globalCompositeOperation="source-over";
    $("gownImg").setAttribute("href",cv.toDataURL("image/png"));
  }
  function renderGown(){
    var el=$("gownImg"); if(!el) return;
    if(!state.gown.id){ el.style.display="none"; el.removeAttribute("href"); return; }
    el.style.display="";
    loadGownImg(state.gown.id,function(im){
      if(state.gown.pat && state.gown.pat!=="slat"){ gownPatternTile(state.gown.pat,state.gown.color,state.gown.fg,function(t){ paintGown(im,t); }); }
      else { paintGown(im,null); }
    });
  }
