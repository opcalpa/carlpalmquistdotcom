---
// Modeateljén — mobilt påklädningsspel (carlpalmquist.com/atelje).
// Lager-baserat: Flux-dockor (neutral pose) + worn PNG-plagg per slot, färglagda live (canvas multiply).
// Plaggen genereras "burna på osynlig mannekäng" i samma 9:16-pose → läggs 1:1 ovanpå dockan.
---
<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
<meta name="theme-color" content="#fbeef3" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<title>Modeateljén</title>
<style is:global>
  :root{
    --bg:#fbeef3; --panel:#fff; --ink:#3b2c3a; --muted:#9a7f92;
    --accent:#e86fa6; --accent2:#7cc7c0; --line:#f0d9e4;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0; height:100%;}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg); color:var(--ink); display:flex; flex-direction:column; align-items:center;
    min-height:100dvh; overflow-x:hidden;}
  header{width:100%; max-width:520px; padding:10px 16px 2px; text-align:center;}
  header h1{margin:0; font-size:19px;} header h1 .doll{color:var(--accent);}
  header .sub{margin:2px 0 0; font-size:12px; color:var(--muted);}

  .stage{position:relative; height:min(54vh,500px); aspect-ratio:9/16; max-width:96vw; flex:0 0 auto;
    border-radius:22px; overflow:hidden; margin:8px 0; box-shadow:0 10px 30px rgba(120,60,90,.18); touch-action:none;
    background:linear-gradient(160deg,#ffd9e6,#ffeef4 55%,#e9f7f4); transition:background .4s ease;}
  .layer{position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center; pointer-events:none; user-select:none;}
  .acc{position:absolute; transform:translate(-50%,-50%); font-size:40px; cursor:grab; touch-action:none; z-index:20;
    user-select:none; filter:drop-shadow(0 2px 3px rgba(0,0,0,.25)); transition:filter .1s;}
  .acc.drag{cursor:grabbing;}
  .acc.sel{outline:2px dashed rgba(232,111,166,.9); outline-offset:3px; border-radius:6px;}
  .achandle{position:absolute; width:24px; height:24px; border-radius:50%; background:var(--accent); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:13px; cursor:nwse-resize; touch-action:none;
    box-shadow:0 1px 4px rgba(0,0,0,.3); z-index:6; transform:translate(-50%,-50%); user-select:none;}
  /* på-canvas plagg-editor */
  .garbox{position:absolute; border:2px dashed var(--accent); border-radius:6px; box-sizing:border-box; z-index:30; cursor:move; touch-action:none;}
  .garbox .gh{position:absolute; width:30px; height:30px; border-radius:50%; background:var(--accent); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; transform:translate(-50%,-50%);
    touch-action:none; box-shadow:0 1px 5px rgba(0,0,0,.35); user-select:none;}
  .garbox .gh.w{cursor:ew-resize;} .garbox .gh.h{cursor:ns-resize;}
  .garbox .ghint{position:absolute; top:-24px; left:50%; transform:translateX(-50%); background:var(--ink); color:#fff;
    font-size:10px; padding:3px 8px; border-radius:8px; white-space:nowrap; pointer-events:none;}
  /* passforms-kontroll för plagg */
  .fitbar{display:flex; align-items:center; gap:6px; flex-wrap:wrap; background:rgba(232,111,166,.08);
    border:1px solid var(--line); border-radius:12px; padding:7px 9px; margin:2px 0 4px;}
  .fitbar b{font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.3px; margin-right:2px;}
  .fitbtn{border:1px solid var(--line); background:#fff; border-radius:9px; width:34px; height:30px; font-size:15px; cursor:pointer; display:flex; align-items:center; justify-content:center;}
  .fitbtn:active{background:var(--line);}
  .fitbar .fitreset{margin-left:auto; font-size:12px; width:auto; padding:0 10px;}
  .acc.pop{animation:accpop .35s cubic-bezier(.2,1.4,.4,1);}
  @keyframes accpop{0%{transform:translate(-50%,-50%) scale(0) rotate(-25deg);}100%{transform:translate(-50%,-50%) scale(1);}}
  .acc.poof{animation:poof .22s ease forwards; pointer-events:none;}
  @keyframes poof{to{opacity:0; transform:translate(-50%,-160%) scale(.2) rotate(20deg);}}
  .stage.trashglow{box-shadow:0 10px 30px rgba(120,60,90,.18), inset 0 0 0 3px #ff6b8b;}
  /* plagg glider in underifrån + studs */
  .layer.slidein{animation:slidein .4s ease;}
  @keyframes slidein{0%{opacity:0;}100%{opacity:1;}}
  .stage.curtsy{animation:curtsy 1s ease;} @keyframes curtsy{30%{transform:translateY(6px) scale(.99,.98);}60%{transform:translateY(-4px);}}
  .spark{position:absolute; font-size:18px; pointer-events:none; animation:spark .7s ease forwards; z-index:5;}
  @keyframes spark{0%{opacity:0; transform:translate(-50%,-50%) scale(.3);}30%{opacity:1;}100%{opacity:0; transform:translate(-50%,-150%) scale(1.1);}}

  .actions{display:flex; gap:8px; width:100%; max-width:430px; padding:2px 12px 0;}
  .actions button{flex:1; border:0; border-radius:14px; padding:11px; font-size:15px; font-weight:700; cursor:pointer;}
  .btn-done{background:var(--accent); color:#fff;} .btn-reset{background:var(--line); color:var(--ink); flex:0 0 auto; padding:11px 15px;}
  .hint{font-size:11px; color:var(--muted); text-align:center; margin:5px 0 0;}

  /* --- Layout-wrapper: mobil = stack (docka överst, meny under); desktop = docka HÖGER, meny VÄNSTER --- */
  .workspace{width:100%; display:flex; flex-direction:column; align-items:center;}
  .menu-col{width:100%; max-width:520px; display:flex; flex-direction:column; align-items:stretch;}
  @media (min-width:900px){
    body{justify-content:flex-start;}
    .workspace{flex-direction:row-reverse; align-items:flex-start; justify-content:center; gap:26px; max-width:1120px; margin-top:8px;}
    .workspace > .stage{height:min(84vh,780px); max-width:none; margin:0; flex:0 0 auto;} /* större canvas */
    .menu-col{flex:0 0 500px; max-width:500px; position:sticky; top:10px;}
    .menu-col .drawer{border-radius:20px; box-shadow:0 10px 30px rgba(120,60,90,.14); max-width:none;}
    .menu-col .actions{max-width:none; margin-top:8px;}
    .menu-col .hint{margin-top:8px;}
  }

  .drawer{width:100%; max-width:520px; background:var(--panel); border-radius:20px 20px 0 0;
    box-shadow:0 -6px 20px rgba(120,60,90,.12); padding:8px 12px 14px;}
  .tabs{display:flex; gap:6px; overflow-x:auto; padding-bottom:8px;}
  .tabs button{flex:0 0 auto; border:0; background:var(--line); color:var(--ink); padding:8px 11px;
    border-radius:999px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap;}
  .tabs button.on{background:var(--accent); color:#fff;}
  .panelbody{min-height:120px;}
  .sect{margin:8px 0;} .sect .lbl{font-size:11px; color:var(--muted); font-weight:700; text-transform:uppercase; letter-spacing:.4px; margin:0 0 5px 2px;}
  .row{display:flex; gap:7px; flex-wrap:wrap;}
  .rowsc{display:flex; gap:8px; overflow-x:auto; padding-bottom:4px;}
  /* plagg-brickor */
  .gitem{flex:0 0 auto; width:66px; height:92px; border-radius:12px; border:2px solid var(--line); background:#fff url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg"/>') center/contain no-repeat;
    cursor:pointer; position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center;}
  .gitem img{width:100%; height:100%; object-fit:contain;}
  .gitem.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .gitem .x{font-size:22px; color:var(--muted);}
  .swatch{width:42px; height:42px; border-radius:11px; border:2px solid var(--line); cursor:pointer; overflow:hidden; position:relative; flex:0 0 auto;}
  .swatch canvas{position:absolute; inset:0; width:100%; height:100%;}
  .swatch.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .chip{width:36px; height:36px; border-radius:50%; border:2px solid #fff; cursor:pointer; box-shadow:0 1px 4px rgba(0,0,0,.15); flex:0 0 auto;}
  .chip.sel{outline:3px solid var(--accent); outline-offset:2px;}
  .charcard{border:2px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; background:#fff; text-align:center;}
  .charcard.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .charcard img{width:100%; aspect-ratio:.66; object-fit:contain; object-position:center bottom; display:block; background:linear-gradient(160deg,#ffe1ec,#eafaf6);}
  .charcard span{display:block; font-size:11px; padding:3px 2px; color:#6a5560;}
  .bgcard{border:2px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; background:#fff; text-align:center;}
  .bgcard.sel{border-color:var(--accent2); box-shadow:0 0 0 3px rgba(124,199,192,.3);}
  .bgcard img{width:100%; aspect-ratio:3/4; object-fit:cover; display:block;}
  .bgcard span{display:block; font-size:10.5px; padding:2px; color:#6a5560;}
  .accbtn{font-size:24px; background:var(--line); border:0; border-radius:12px; padding:6px 8px; cursor:pointer;}
  .cards{display:flex; gap:10px; overflow-x:auto; padding-bottom:4px;}
  .card{flex:0 0 132px; border-radius:14px; overflow:hidden; cursor:pointer; border:2px solid var(--line); background:#fff; text-align:left;}
  .card .prev{height:54px; display:flex;} .card .prev i{flex:1;}
  .card .cap{padding:6px 9px;} .card .cap b{display:block; font-size:12.5px;} .card .cap small{color:var(--muted); font-size:10px; line-height:1.25; display:block;}

  .wardrobe{width:100%; max-width:520px; padding:8px 12px 26px;}
  .wardrobe h3{font-size:12px; color:var(--muted); margin:6px 4px; font-weight:700; text-transform:uppercase; letter-spacing:.5px;}
  .wrow{display:flex; gap:8px; overflow-x:auto; padding-bottom:6px; min-height:8px;}
  .wthumb{flex:0 0 66px; height:100px; border-radius:12px; overflow:hidden; border:2px solid var(--line); position:relative; cursor:pointer; background:linear-gradient(160deg,#ffe1ec,#eafaf6);}
  .wthumb img{position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center bottom;}
  .wthumb .wname{position:absolute; bottom:0; left:0; right:0; font-size:9px; text-align:center; background:rgba(255,255,255,.85); padding:1px;}

  .confetti{position:fixed; inset:0; pointer-events:none; overflow:hidden; z-index:50;}
  .conf{position:absolute; top:-20px; animation:fall linear forwards;} @keyframes fall{to{transform:translateY(105vh) rotate(540deg);}}
  .toast{position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:var(--ink); color:#fff;
    padding:10px 16px; border-radius:999px; font-size:13px; z-index:60; opacity:0; transition:opacity .3s;}
  .toast.show{opacity:1;}
  /* Suddgummi: in-canvas verktygsrad + pensel-markör */
  .erasebtn{width:100%; padding:11px; border:0; border-radius:12px; background:var(--ink); color:#fff; font-size:14px; font-weight:700; cursor:pointer;}
  .edcursor{position:absolute; border:2px solid #e2506e; border-radius:999px; pointer-events:none; transform:translate(-50%,-50%); display:none; z-index:40; box-shadow:0 0 0 1px rgba(255,255,255,.85);}
  body.editing #stage{cursor:none;}
  body.editing .garbox,body.editing .acc{display:none !important;}
  .edbar{position:fixed; left:50%; bottom:14px; transform:translateX(-50%); z-index:70; background:#fff; border-radius:16px; box-shadow:0 12px 40px rgba(0,0,0,.28); padding:10px 12px; display:flex; flex-direction:column; gap:8px; width:min(94vw,420px);}
  .edbar[hidden]{display:none;}
  .edrow{display:flex; gap:8px;}
  .edtool{flex:1; padding:10px; border:2px solid #f0e6ec; border-radius:12px; background:#faf5f8; color:var(--ink); font-size:13px; font-weight:700; cursor:pointer;}
  .edtool.on{border-color:var(--pink,#e2506e); background:#fdeef3;}
  .edsize{display:flex; align-items:center; gap:8px; font-size:13px; color:var(--ink); font-weight:700;}
  .edsize input{flex:1;}
  .edbtn{flex:1; padding:10px; border:0; border-radius:12px; background:#f2e7ee; color:var(--ink); font-size:13px; font-weight:700; cursor:pointer;}
  .edbtn.edsave{background:var(--pink,#e2506e); color:#fff;}
  .edbtn.eddone{background:var(--ink); color:#fff;}
</style>
</head>
<body>
<header>
  <h1>👗 Modeateljén <span class="doll" id="dollname">Nadia</span></h1>
  <p class="sub">Välj docka, klä på henne — färg &amp; mönster på varje plagg. Mixa fritt.</p>
</header>

<div class="workspace">
<div class="stage" id="stage">
  <img class="layer" id="L-outer-b" style="display:none;z-index:-4" />
  <img class="layer" id="L-top-b" style="display:none;z-index:-3" />
  <img class="layer" id="L-dress-b" style="display:none;z-index:-2" />
  <img class="layer" id="L-bottom-b" style="display:none;z-index:-1" />
  <img class="layer" id="L-doll" alt="docka" style="z-index:0" />
  <img class="layer" id="L-bottom" style="display:none;z-index:2" />
  <img class="layer" id="L-dress" style="display:none;z-index:3" />
  <img class="layer" id="L-top" style="display:none;z-index:4" />
  <img class="layer" id="L-outer" style="display:none;z-index:5" />
  <div class="edcursor" id="edCursor"></div>
</div>
<div class="menu-col">
<div class="drawer">
  <div class="tabs" id="tabs">
    <button data-tab="docka" class="on">💃 Docka</button>
    <button data-tab="dress">👗 Klänning</button>
    <button data-tab="top">👚 Topp</button>
    <button data-tab="bottom">👖 Underdel</button>
    <button data-tab="outer">🧥 Ytterplagg</button>
    <button data-tab="stil">✨ Stil</button>
    <button data-tab="pynt">🎀 Pynt</button>
    <button data-tab="bak">🏞️ Bakgrund</button>
  </div>
  <div class="panelbody" id="panelbody"></div>
</div>

<div class="actions">
  <button class="btn-reset" id="reset" title="Klä av">↺</button>
  <button class="btn-done" id="done">📸 Klar!</button>
</div>
<p class="hint" id="hint">Tappa ett plagg så glider det på henne. Markera plagg/pynt för att flytta &amp; ändra storlek. 🗑️</p>
</div><!-- /menu-col -->
</div><!-- /workspace -->

<div class="wardrobe"><h3>👚 Din garderob</h3><div class="wrow" id="wrow"></div></div>
<div class="confetti" id="confetti" hidden></div>
<div class="toast" id="toast"></div>

<!-- Suddgummi: verktygsrad för att sudda plagg DIREKT på dockan (in-canvas) -->
<div class="edbar" id="edbar" hidden>
  <div class="edrow">
    <button class="edtool on" id="edErase">🧽 Sudda</button>
    <button class="edtool" id="edPaint">🖌 Måla tillbaka</button>
  </div>
  <label class="edsize">Storlek <input type="range" id="edSize" min="4" max="120" value="34"><span id="edSizeVal">34</span></label>
  <div class="edrow">
    <button class="edbtn" id="edUndo">↺ Ångra</button>
    <button class="edbtn" id="edReset">⟲ Original</button>
    <button class="edbtn edsave" id="edSave">💾 Spara</button>
    <button class="edbtn eddone" id="edDone">✓ Klar</button>
  </div>
</div>

<script is:inline>
(function(){
  var $=function(id){return document.getElementById(id);};

  // ===== Roster (Flux-dockor, neutral pose, transparent) =====
  var CHARS=[
    {id:"01-nadia",name:"Nadia",bg:"tradgard"},{id:"02-elsa",name:"Elsa",bg:"bal"},{id:"03-mira",name:"Mira",bg:"stad"},
    {id:"04-zoe",name:"Zoe",bg:"strand"},{id:"05-vera",name:"Vera",bg:"skog"},{id:"06-lin",name:"Lin",bg:"slott"},
    {id:"07-ada",name:"Ada",bg:"rum"},{id:"08-noor",name:"Noor",bg:"ang"},{id:"09-stella",name:"Stella",bg:"catwalk"},{id:"10-amara",name:"Amara",bg:"vinter"}
  ];

  // ===== Garderob: worn PNG per slot (/garderob/<slot>/<id>.png), färglagd live =====
  var WARDROBE={
    dress:[["aline","A-linje"],["sundress","Solklänning"],["maxi","Maxi"],["ballgown","Balklänning"],["skater","Skater"],["puff","Puffärm"],["wrap","Omlott"],["shift","Rak"]],
    top:[["tee","T-shirt"],["tank","Linne"],["blouse","Blus"],["sweater","Tröja"],["crop","Kort"],["hoodie","Hoodie"],["offshoulder","Off-shoulder"]],
    bottom:[["flareskirt","Kjol"],["pleatedskirt","Veckad kjol"],["jeans","Jeans"],["leggings","Leggings"],["shorts","Shorts"],["widepants","Vida byxor"],["tutu","Tyllkjol"]],
    outer:[["denimjacket","Jeansjacka"],["blazer","Kavaj"],["trench","Trenchcoat"],["cardigan","Kofta"],["puffer","Pufferjacka"]]
  };
  var SLOT_LABEL={dress:"Klänning",top:"Topp",bottom:"Underdel",outer:"Ytterplagg"};

  // ===== Textilmönster (canvas-tiles, klassiska/tidstypiska; used för recolor + swatch-preview) =====
  var PAT={
    slat:{name:"Slätt",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);}},
    prickar:{name:"Prickar",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;var r=T*0.12;[[.25,.25],[.75,.75]].forEach(function(p){c.beginPath();c.arc(p[0]*T,p[1]*T,r,0,7);c.fill();});}},
    pindots:{name:"Småprickar",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;var r=T*0.045;for(var i=0;i<3;i++)for(var j=0;j<3;j++){c.beginPath();c.arc((i+.5)/3*T,(j+.5)/3*T,r,0,7);c.fill();}}},
    breton:{name:"Ränder",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;c.fillRect(0,0,T,T*0.42);}},
    pinstripe:{name:"Kritstreck",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;c.globalAlpha=.85;c.fillRect(T*0.5-1,0,2,T);c.globalAlpha=1;}},
    gingham:{name:"Gingham",f:function(c,T,b,f){c.fillStyle="#ffffff";c.fillRect(0,0,T,T);c.fillStyle=b;c.globalAlpha=.5;c.fillRect(0,0,T*0.5,T);c.fillRect(0,0,T,T*0.5);c.globalAlpha=1;}},
    rutor:{name:"Rutor",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.strokeStyle=f;c.globalAlpha=.55;c.lineWidth=T*0.06;c.beginPath();c.moveTo(T*0.3,0);c.lineTo(T*0.3,T);c.moveTo(0,T*0.3);c.lineTo(T,T*0.3);c.stroke();c.globalAlpha=.9;c.lineWidth=T*0.03;c.beginPath();c.moveTo(T*0.72,0);c.lineTo(T*0.72,T);c.moveTo(0,T*0.72);c.lineTo(T,T*0.72);c.stroke();c.globalAlpha=1;}},
    houndstooth:{name:"Hundtand",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;var u=T/4;c.fillRect(0,0,2*u,2*u);c.fillRect(2*u,2*u,2*u,2*u);function tri(a,d,e,g,h,i){c.beginPath();c.moveTo(a,d);c.lineTo(e,g);c.lineTo(h,i);c.closePath();c.fill();}tri(2*u,0,3*u,0,2*u,u);tri(0,2*u,0,3*u,u,2*u);tri(2*u,4*u,u,4*u,2*u,3*u);tri(4*u,2*u,4*u,u,3*u,2*u);}},
    chevron:{name:"Sicksack",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.strokeStyle=f;c.lineWidth=T*0.14;c.lineJoin="round";[-0.15,0.3,0.75].forEach(function(y){c.beginPath();c.moveTo(0,(y+0.35)*T);c.lineTo(T*0.5,y*T);c.lineTo(T,(y+0.35)*T);c.stroke();});}},
    argyle:{name:"Argyle",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;c.globalAlpha=.85;c.beginPath();c.moveTo(T*0.5,T*0.1);c.lineTo(T*0.9,T*0.5);c.lineTo(T*0.5,T*0.9);c.lineTo(T*0.1,T*0.5);c.closePath();c.fill();c.globalAlpha=.7;c.strokeStyle="#ffffff";c.lineWidth=T*0.02;c.beginPath();c.moveTo(0,0);c.lineTo(T,T);c.moveTo(T,0);c.lineTo(0,T);c.stroke();c.globalAlpha=1;}},
    stjarnor:{name:"Stjärnor",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;function star(cx,cy,R){c.save();c.translate(cx,cy);c.beginPath();for(var i=0;i<10;i++){var a=Math.PI/5*i-Math.PI/2;var r=i%2?R*0.42:R;c.lineTo(Math.cos(a)*r,Math.sin(a)*r);}c.closePath();c.fill();c.restore();}star(T*0.28,T*0.3,T*0.16);star(T*0.72,T*0.72,T*0.16);}},
