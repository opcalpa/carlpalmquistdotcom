  function toast(m){toEl.textContent=m;toEl.classList.add("show");clearTimeout(toT);toT=setTimeout(function(){toEl.classList.remove("show");},1500);}

  Array.prototype.slice.call(document.querySelectorAll("#tabs button")).forEach(function(b){b.addEventListener("click",function(){document.querySelectorAll("#tabs button").forEach(function(x){x.classList.remove("on");});b.classList.add("on"); if(["dress","top","bottom","outer"].indexOf(b.dataset.tab)<0)deselectGarment(); TAB[b.dataset.tab]();});});
  $("done").addEventListener("click",done);
  $("reset").addEventListener("click",function(){deselectAll();document.querySelectorAll(".acc").forEach(function(e){e.remove();});state.acc=[];state.dress=slot0();state.top=slot0();state.bottom=slot0();state.outer=slot0();renderDoll();toast("↺ Avklädd — börja om!");});
  // klick på plagget → markera det för justering; klick på tom scen/docka → avmarkera
  $("stage").addEventListener("pointerdown",function(e){ if(edSlot)return; if(e.target!==$("stage"))return;
    var r=$("stage").getBoundingClientRect(), nx=(e.clientX-r.left)/r.width, ny=(e.clientY-r.top)/r.height;
    var slot=garmentAt(nx,ny); if(slot)gotoGarmentTab(slot); else deselectAll(); });
  // avmarkera även vid klick UTANFÖR canvas (var som helst i fönstret), utom i justerings-panelen
  document.addEventListener("pointerdown",function(e){ if(edSlot)return; if(!selGar&&!selAcc)return;
    if($("stage").contains(e.target))return;                        // canvas hanteras av handlern ovan
    if(e.target.closest&&e.target.closest(".drawer"))return;         // panel/justeringskontroller ska ej avmarkera
    deselectAll(); });

  // init
  restoreCurrent(); renderDoll(); setBackdrop(); renderWardrobe(); TAB.docka();
})();
</script>
</body>
</html>
