  function removeHandle(el){var h=el.querySelector(".achandle");if(h)h.remove();}
  function addHandle(el){
    if(el.querySelector(".achandle"))return;
    var hd=document.createElement("div"); hd.className="achandle"; hd.textContent="⤢"; hd.style.left="100%"; hd.style.top="100%"; el.appendChild(hd);
    hd.addEventListener("pointerdown",function(ev){ ev.preventDefault(); ev.stopPropagation(); hd.setPointerCapture(ev.pointerId);
      var rc=el.getBoundingClientRect(), cx=rc.left+rc.width/2, cy=rc.top+rc.height/2;
      function mv(e){ setSize(el,Math.max(20,Math.min(140,Math.hypot(e.clientX-cx,e.clientY-cy)*1.4))); }
      function up(){ try{hd.releasePointerCapture(ev.pointerId);}catch(_){} hd.removeEventListener("pointermove",mv); hd.removeEventListener("pointerup",up); saveCurrent(); }
      hd.addEventListener("pointermove",mv); hd.addEventListener("pointerup",up);
    });
  }
  function selectAcc(el){ deselectGarment(); if(selAcc&&selAcc!==el){selAcc.classList.remove("sel");removeHandle(selAcc);} selAcc=el; el.classList.add("sel"); addHandle(el); }
  function deselectAcc(){ if(selAcc){selAcc.classList.remove("sel");removeHandle(selAcc);selAcc=null;} }

  // ===== På-canvas plagg-editor: klicka plagget → ram med handtag (↔ bredd · ↕ längd · dra = flytta) =====
  var selGar=null, garbox=null;
  function ensureGarbox(){
    if(garbox)return garbox;
    garbox=document.createElement("div"); garbox.className="garbox"; garbox.style.display="none";
    garbox.innerHTML='<div class="ghint">↔ bredd · ↕ längd · dra = flytta</div>'
      +'<div class="gh w" data-h="wl" style="left:0;top:50%">↔</div>'
      +'<div class="gh w" data-h="wr" style="left:100%;top:50%">↔</div>'
      +'<div class="gh h" data-h="hb" style="left:50%;top:100%">↕</div>';
    $("stage").appendChild(garbox);
    dragGar(garbox,"move");
    Array.prototype.slice.call(garbox.querySelectorAll(".gh")).forEach(function(h){ dragGar(h,h.dataset.h); });
    return garbox;
  }
  function selectGarment(slot){ if(!state[slot]||!state[slot].id)return; deselectAcc(); selGar=slot; ensureGarbox(); positionGarbox(); }
  // klick på plagg på canvas → byt även FLIK/panel till det plagget (annars styr färg/mönster fel slot)
  function gotoGarmentTab(slot){
    var btn=document.querySelector('#tabs button[data-tab="'+slot+'"]');
    if(btn){ document.querySelectorAll("#tabs button").forEach(function(x){x.classList.remove("on");}); btn.classList.add("on"); try{btn.scrollIntoView({inline:"center",block:"nearest"});}catch(_){} }
    if(TAB[slot])TAB[slot](); // renderar panelen för slot; garmentPanel markerar plagget (garbox) på slutet
  }
  function deselectGarment(){ selGar=null; if(garbox)garbox.style.display="none"; }
  function deselectAll(){ deselectAcc(); deselectGarment(); }
  function positionGarbox(){
    if(!selGar||!garbox)return; var el=$("L-"+selGar), tf=el._tf;
    if(!tf||el.style.display==="none"){ garbox.style.display="none"; return; }
    var b=tf.b;
    function X(px){return 0.5+(px-0.5)*tf.scX+tf.tx/100;}
    function Y(py){return py*tf.scY+tf.ty/100;}
    var L=X(b.x0),R=X(b.x1),T=Y(b.y0),B=Y(b.y1);
    garbox.style.display=""; garbox.style.left=(L*100)+"%"; garbox.style.top=(T*100)+"%";
    garbox.style.width=((R-L)*100)+"%"; garbox.style.height=((B-T)*100)+"%";
  }
  function dragGar(elm,kind){
    elm.addEventListener("pointerdown",function(ev){ if(!selGar)return; ev.preventDefault(); ev.stopPropagation(); try{elm.setPointerCapture(ev.pointerId);}catch(_){}
      var s=state[selGar]; fixAdj(s); var a=s.adj, el=$("L-"+selGar), b=el._tf.b, base=SLOT_SCALE[selGar]||1, r=$("stage").getBoundingClientRect();
      var start={x:ev.clientX,y:ev.clientY,sx:a.sx,sy:a.sy,dx:a.dx,dy:a.dy};
      var halfW=(b.x1-b.cx)*base*start.sx||0.001, fullH=(b.y1-b.y0)*base*start.sy||0.001;
      function mv(e){ var ddx=(e.clientX-start.x)/r.width, ddy=(e.clientY-start.y)/r.height;
        if(kind==="move"){ a.dx=start.dx+ddx*100; a.dy=start.dy+ddy*100; }
        else if(kind==="wr"||kind==="wl"){ var sgn=kind==="wr"?1:-1; a.sx=Math.max(.3,Math.min(2.4, start.sx*Math.max(0.03,halfW+sgn*ddx)/halfW)); }
        else if(kind==="hb"){ a.sy=Math.max(.3,Math.min(2.6, start.sy*Math.max(0.03,fullH+ddy)/fullH)); }
        anchorLayer(el,selGar,s); positionGarbox();
      }
      function up(){ try{elm.releasePointerCapture(ev.pointerId);}catch(_){}; elm.removeEventListener("pointermove",mv); elm.removeEventListener("pointerup",up); saveCurrent(); }
      elm.addEventListener("pointermove",mv); elm.addEventListener("pointerup",up);
    });
  }
  // vilket synligt plagg ligger under (nx,ny) i [0,1]? topp→botten-ordning
  function garmentAt(nx,ny){
    var order=["outer","top","dress","bottom"];
    for(var i=0;i<order.length;i++){ var slot=order[i], el=$("L-"+slot); if(!el||el.style.display==="none"||!el._tf)continue;
      var s=state[slot]; if(!s.id)continue; var b=_bbox["/garderob/"+slot+"/"+s.id+".png"]; if(!b||!b.grid)continue;
      var tf=el._tf, px=(nx-0.5-tf.tx/100)/tf.scX+0.5, py=(ny-tf.ty/100)/tf.scY;
      if(px<0||px>1||py<0||py>1)continue; var gx=Math.floor(px*b.gw), gy=Math.floor(py*b.gh);
      if(b.grid[gy*b.gw+gx])return slot;
    }
    return null;
  }
  function makeDraggable(el){
    var pts={}, startDist=0, startSize=0, moved=false, downPt=null;
    function dst(a,b){return Math.hypot(a.x-b.x,a.y-b.y);}
    el.addEventListener("pointerdown",function(ev){
      if(ev.target.classList.contains("achandle"))return;
      ev.preventDefault(); el.setPointerCapture(ev.pointerId); pts[ev.pointerId]={x:ev.clientX,y:ev.clientY};
      var ids=Object.keys(pts);
      if(ids.length===1){ moved=false; downPt={x:ev.clientX,y:ev.clientY}; el.classList.add("drag"); }
      else if(ids.length===2){ startDist=dst(pts[ids[0]],pts[ids[1]]); startSize=el._size||44; }
    });
    el.addEventListener("pointermove",function(ev){
      if(!pts[ev.pointerId])return; pts[ev.pointerId]={x:ev.clientX,y:ev.clientY};
      var ids=Object.keys(pts);
      if(ids.length>=2){ if(startDist){ setSize(el,Math.max(20,Math.min(140,startSize*dst(pts[ids[0]],pts[ids[1]])/startDist))); } return; }
      var r=$("stage").getBoundingClientRect(), M=6;
      if(downPt&&Math.hypot(ev.clientX-downPt.x,ev.clientY-downPt.y)>4)moved=true;
      var out=ev.clientX<r.left-M||ev.clientX>r.right+M||ev.clientY<r.top-M||ev.clientY>r.bottom+M; el._out=out; $("stage").classList.toggle("trashglow",out);
      setPos(el,Math.max(2,Math.min(98,(ev.clientX-r.left)/r.width*100)),Math.max(2,Math.min(98,(ev.clientY-r.top)/r.height*100)));
    });
    function endPtr(ev){
      if(!pts[ev.pointerId])return; delete pts[ev.pointerId]; try{el.releasePointerCapture(ev.pointerId);}catch(e){}
      if(Object.keys(pts).length>0)return;
      el.classList.remove("drag"); $("stage").classList.remove("trashglow");
      if(el._out){ if(selAcc===el)deselectAcc(); el.classList.add("poof"); toast("🗑️ Borttaget"); setTimeout(function(){el.remove();saveCurrent();},220); return; }
      if(!moved){ if(selAcc===el)deselectAcc(); else selectAcc(el); }
      saveCurrent();
    }
    el.addEventListener("pointerup",endPtr); el.addEventListener("pointercancel",endPtr);
    el.addEventListener("dblclick",function(){ if(selAcc===el)deselectAcc(); el.remove(); saveCurrent(); });
  }

