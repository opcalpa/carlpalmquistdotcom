---
// Modeateljén — fristående mobil klädspel-sida (carlpalmquist.com/atelje).
// Karaktärsväljare (transparenta Flux-dockor via birefnet) + vektor-rita-själv + 10 Flux-bakgrunder.
---
<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
  <meta name="theme-color" content="#fbeef3" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
<title>Modeateljén — slot-prototyp</title>
<style is:global>
  :root{
    --bg:#fbeef3; --panel:#fff; --ink:#3b2c3a; --muted:#9a7f92;
    --accent:#e86fa6; --accent2:#7cc7c0; --line:#f0d9e4;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0; height:100%;}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg); color:var(--ink); display:flex; flex-direction:column; align-items:center;
    min-height:100dvh; overflow-x:hidden;}
  header{width:100%; max-width:520px; padding:12px 16px 4px; text-align:center;}
  header h1{margin:0; font-size:19px;} header h1 .doll{color:var(--accent);}
  header .sub{margin:2px 0 0; font-size:12px; color:var(--muted);}

  .stage{position:relative; width:100%; max-width:520px; aspect-ratio:3/4; min-height:64vh; flex:0 0 auto; border-radius:22px;
    overflow:hidden; margin:8px 0; box-shadow:0 10px 30px rgba(120,60,90,.18); touch-action:none;
    background:linear-gradient(160deg,#ffd9e6,#ffeef4 55%,#e9f7f4); transition:background .5s ease;}
  .stage .bd-emoji{position:absolute; font-size:28px; opacity:.7; pointer-events:none; user-select:none;}
  #charimg{position:absolute; inset:0; width:100%; height:100%; object-fit:contain; object-position:center bottom; pointer-events:none;}
  #doll{position:absolute; inset:0; width:100%; height:100%; display:block;}
  /* Karaktärsläge: göm vektor-hud/hår/ansikte, behåll kläd-lagret ovanpå Flux-dockan. */
  #doll.charmode .vskin{display:none;}
  .charcard{border:2px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; background:#fff; text-align:center;}
  .charcard.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .charcard img{width:100%; aspect-ratio:1; object-fit:cover; object-position:center top; display:block;}
  .charcard .drawher{aspect-ratio:1; display:flex; align-items:center; justify-content:center; font-size:28px; background:#faf1f6;}
  .charcard span{display:block; font-size:11px; padding:3px 2px; color:#6a5560;}
  .bgcard{border:2px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; background:#fff; text-align:center;}
  .bgcard.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .bgcard img{width:100%; aspect-ratio:3/4; object-fit:cover; display:block;}
  .bgcard span{display:block; font-size:10.5px; padding:2px; color:#6a5560;}
  .acc{position:absolute; transform:translate(-50%,-50%); font-size:32px; cursor:grab; touch-action:none;
    user-select:none; filter:drop-shadow(0 2px 3px rgba(0,0,0,.25)); transition:transform .08s;}
  .acc.drag{cursor:grabbing; transform:translate(-50%,-50%) scale(1.18);}
  .acc.pop{animation:accpop .35s cubic-bezier(.2,1.4,.4,1);}
  @keyframes accpop{0%{transform:translate(-50%,-50%) scale(0) rotate(-25deg);}100%{transform:translate(-50%,-50%) scale(1);}}
  .acc.trashing{opacity:.35; transform:translate(-50%,-50%) scale(.7) rotate(-12deg);}
  .acc.poof{animation:poof .22s ease forwards; pointer-events:none;}
  @keyframes poof{to{opacity:0; transform:translate(-50%,-160%) scale(.2) rotate(20deg);}}
  .stage.trashglow{box-shadow:0 10px 30px rgba(120,60,90,.18), inset 0 0 0 3px #ff6b8b;}
  .flash{animation:flash .4s ease;} @keyframes flash{40%{filter:brightness(1.45) saturate(1.25);}}
  .spark{position:absolute; font-size:18px; pointer-events:none; animation:spark .7s ease forwards;}
  @keyframes spark{0%{opacity:0; transform:translate(-50%,-50%) scale(.3);}30%{opacity:1;}100%{opacity:0; transform:translate(-50%,-150%) scale(1.1);}}

  .drawer{width:100%; max-width:520px; background:var(--panel); border-radius:20px 20px 0 0;
    box-shadow:0 -6px 20px rgba(120,60,90,.12); padding:8px 12px 18px; margin-top:auto;}
  .tabs{display:flex; gap:6px; overflow-x:auto; padding-bottom:8px;}
  .tabs button{flex:0 0 auto; border:0; background:var(--line); color:var(--ink); padding:8px 11px;
    border-radius:999px; font-size:13px; font-weight:600; cursor:pointer;}
  .tabs button.on{background:var(--accent); color:#fff;}
  .panelbody{min-height:120px;}
  .sect{margin:6px 0;} .sect .lbl{font-size:11px; color:var(--muted); font-weight:700; text-transform:uppercase; letter-spacing:.4px; margin:0 0 4px 2px;}
  .row{display:flex; gap:7px; flex-wrap:wrap;}
  .rowsc{display:flex; gap:7px; overflow-x:auto; padding-bottom:2px;}
  .shape{flex:0 0 auto; min-width:58px; height:44px; border-radius:12px; border:2px solid var(--line); background:#fff;
    cursor:pointer; font-size:12px; display:flex; align-items:center; justify-content:center; padding:0 8px; gap:4px;}
  .shape.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .swatch{width:44px; height:44px; border-radius:11px; border:2px solid var(--line); cursor:pointer; overflow:hidden; position:relative;}
  .swatch svg{position:absolute; inset:0; width:100%; height:100%;}
  .swatch.sel{border-color:var(--accent); box-shadow:0 0 0 3px rgba(232,111,166,.22);}
  .chip{width:38px; height:38px; border-radius:50%; border:2px solid #fff; cursor:pointer; box-shadow:0 1px 4px rgba(0,0,0,.15);}
  .chip.sel{outline:3px solid var(--accent); outline-offset:2px;}
  .mat{flex:0 0 auto; border:2px solid var(--line); background:#fff; border-radius:11px; padding:7px 10px; font-size:12px; cursor:pointer;}
  .mat.sel{border-color:var(--accent2); background:#effaf8;}
  .cards{display:flex; gap:10px; overflow-x:auto;}
  .card{flex:0 0 128px; border-radius:14px; overflow:hidden; cursor:pointer; border:2px solid var(--line); background:#fff;}
  .card .prev{height:50px;} .card .cap{padding:5px 8px;}
  .card .cap b{display:block; font-size:12.5px;} .card .cap small{color:var(--muted); font-size:10px; line-height:1.2; display:block;}
  .accbtn{font-size:24px; background:var(--line); border:0; border-radius:12px; padding:6px 8px; cursor:pointer;}
  .bdbtn{border:2px solid var(--line); background:#fff; border-radius:12px; padding:8px 10px; cursor:pointer; font-size:13px;}
  .bdbtn.sel{border-color:var(--accent2);}

  .actions{display:flex; gap:8px; width:100%; max-width:520px; padding:8px 12px 0;}
  .actions button{flex:1; border:0; border-radius:14px; padding:12px; font-size:15px; font-weight:700; cursor:pointer;}
  .btn-done{background:var(--accent); color:#fff;} .btn-reset{background:var(--line); color:var(--ink); flex:0 0 auto; padding:12px 15px;}
  .hint{font-size:11px; color:var(--muted); text-align:center; margin:6px 0 0;}

  .wardrobe{width:100%; max-width:520px; padding:8px 12px 24px;}
  .wardrobe h3{font-size:12px; color:var(--muted); margin:6px 4px; font-weight:700; text-transform:uppercase; letter-spacing:.5px;}
  .wrow{display:flex; gap:8px; overflow-x:auto; padding-bottom:6px; min-height:8px;}
  .wthumb{flex:0 0 72px; height:96px; border-radius:12px; overflow:hidden; border:2px solid var(--line); position:relative; cursor:pointer;}
  .wthumb svg{position:absolute; inset:0; width:100%; height:100%;}
  .wthumb .wname{position:absolute; bottom:0; left:0; right:0; font-size:9px; text-align:center; background:rgba(255,255,255,.85); padding:1px;}

  .confetti{position:fixed; inset:0; pointer-events:none; overflow:hidden; z-index:50;}
  .conf{position:absolute; top:-20px; animation:fall linear forwards;} @keyframes fall{to{transform:translateY(105vh) rotate(540deg);}}
  .curtsy{animation:curtsy 1s ease;} @keyframes curtsy{30%{transform:translateY(6px) scale(.98,.97);}60%{transform:translateY(-4px);}}
  .toast{position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:var(--ink); color:#fff;
    padding:10px 16px; border-radius:999px; font-size:13px; z-index:60; opacity:0; transition:opacity .3s;}
  .toast.show{opacity:1;}
</style>
</head>
<body>
<header>
  <h1>👗 Modeateljén <span class="doll" id="dollname">Louna</span></h1>
  <p class="sub">Välj slot, byt plagg, styr mönster · material · färg. Mixa fritt.</p>
</header>

<div class="stage" id="stage">
  <img id="charimg" alt="" hidden />
  <svg id="doll" viewBox="0 0 240 420" aria-label="docka">
    <defs>
      <pattern id="fabTop" patternUnits="userSpaceOnUse" width="34" height="34"><g id="tileTop"></g></pattern>
      <pattern id="fabBot" patternUnits="userSpaceOnUse" width="34" height="34"><g id="tileBot"></g></pattern>
      <pattern id="fabFeet" patternUnits="userSpaceOnUse" width="34" height="34"><g id="tileFeet"></g></pattern>
      <clipPath id="clipTop"><path id="shapeTop" d=""/></clipPath>
      <clipPath id="clipBot"><path id="shapeBot" d=""/></clipPath>
      <linearGradient id="gForm" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#000" stop-opacity=".30"/><stop offset=".2" stop-color="#000" stop-opacity="0"/>
        <stop offset=".5" stop-color="#fff" stop-opacity=".14"/><stop offset=".8" stop-color="#000" stop-opacity="0"/>
        <stop offset="1" stop-color="#000" stop-opacity=".30"/></linearGradient>
      <linearGradient id="gDrop" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#fff" stop-opacity=".10"/><stop offset=".7" stop-color="#000" stop-opacity="0"/>
        <stop offset="1" stop-color="#000" stop-opacity=".18"/></linearGradient>
      <linearGradient id="gSatin" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#fff" stop-opacity="0"/><stop offset=".45" stop-color="#fff" stop-opacity=".55"/>
        <stop offset=".6" stop-color="#fff" stop-opacity="0"/></linearGradient>
      <radialGradient id="gLeather" cx=".4" cy=".3" r=".8">
        <stop offset="0" stop-color="#fff" stop-opacity=".5"/><stop offset=".5" stop-color="#fff" stop-opacity="0"/>
        <stop offset="1" stop-color="#000" stop-opacity=".18"/></radialGradient>
      <pattern id="mDenim" patternUnits="userSpaceOnUse" width="6" height="6"><path d="M0 6L6 0" stroke="#00000022" stroke-width="1.4"/></pattern>
      <pattern id="mKnit" patternUnits="userSpaceOnUse" width="8" height="5"><path d="M0 2.5H8" stroke="#00000018" stroke-width="1.6"/></pattern>
      <pattern id="mSeq" patternUnits="userSpaceOnUse" width="9" height="9"><circle cx="4.5" cy="4.5" r="2.6" fill="#ffffff55"/><circle cx="3.5" cy="3.5" r="1" fill="#fff"/></pattern>
    </defs>

    <!-- ben (vskin: göms i karaktärsläge, då Flux-dockans egen kropp syns) -->
    <path class="vskin" d="M108 294 C104 335 101 374 105 401 C105 408 114 408 115 401 C118 374 118 335 118 296 C114 298 111 298 108 294 Z" fill="#f4d3bd"/>
    <path class="vskin" d="M132 294 C136 335 139 374 135 401 C135 408 126 408 125 401 C122 374 122 335 122 296 C126 298 129 298 132 294 Z" fill="#f4d3bd"/>
    <!-- armar + händer (hänger nära kroppen) -->
    <path class="vskin" d="M94 150 C88 178 84 210 84 245 C84 253 87 259 91 259 C95 259 96 251 96 244 C97 213 99 184 102 158 Z" fill="#f4d3bd"/>
    <ellipse class="vskin" cx="87" cy="260" rx="6" ry="7.5" fill="#f4d3bd"/>
    <path class="vskin" d="M146 150 C152 178 156 210 156 245 C156 253 153 259 149 259 C145 259 144 251 144 244 C143 213 141 184 138 158 Z" fill="#f4d3bd"/>
    <ellipse class="vskin" cx="153" cy="260" rx="6" ry="7.5" fill="#f4d3bd"/>
    <!-- hals + torso -->
    <rect class="vskin" x="110" y="104" width="20" height="26" rx="8" fill="#f4d3bd"/>
    <path class="vskin" d="M92 150 q28 -20 56 0 l-4 150 q-24 12 -48 0z" fill="#f4d3bd"/>

    <!-- KLÄDER: eget lager. transform sätts per Flux-docka så plaggen landar på hennes kropp. -->
    <g id="vclothes">
      <!-- FÖTTER (skor, bytbara) -->
      <g id="feetG"><path id="shoeL" d="" fill="url(#fabFeet)"/><path id="shoeR" d="" fill="url(#fabFeet)"/></g>
      <!-- UNDERKROPP -->
      <g clip-path="url(#clipBot)"><rect x="50" y="180" width="140" height="230" fill="url(#fabBot)"/><rect x="50" y="180" width="140" height="230" fill="url(#gForm)"/><rect x="50" y="180" width="140" height="230" fill="url(#gDrop)"/><rect id="matBot" x="50" y="180" width="140" height="230" fill="none"/></g>
      <!-- ÖVERKROPP -->
      <g clip-path="url(#clipTop)"><rect x="50" y="110" width="140" height="230" fill="url(#fabTop)"/><rect x="50" y="110" width="140" height="230" fill="url(#gForm)"/><rect x="50" y="110" width="140" height="230" fill="url(#gDrop)"/><rect id="matTop" x="50" y="110" width="140" height="230" fill="none"/></g>
      <!-- FLUX-GARDEROB: färglagd gråskale-klänning (canvas→dataURL). Ärver #vclothes-transformen. -->
      <image id="gownImg" href="" x="34" y="92" width="172" height="316" preserveAspectRatio="xMidYMid meet" style="display:none"/>
    </g>

    <!-- HÅR bakom huvud -->
    <path class="vskin" id="hairBack" d="" fill="#6d4423"/>
    <!-- huvud -->
    <circle class="vskin" cx="120" cy="80" r="34" fill="#f4d3bd"/>
    <!-- HÅR fram -->
    <path class="vskin" id="hairFront" d="" fill="#6d4423"/>
    <!-- ansikte -->
    <g class="vskin" id="eyes"><ellipse class="eye" cx="108" cy="82" rx="4.2" ry="5.4" fill="#3b2c3a"/><ellipse class="eye" cx="132" cy="82" rx="4.2" ry="5.4" fill="#3b2c3a"/></g>
    <circle class="vskin" cx="100" cy="94" r="5" fill="#ffb3c6" opacity=".7"/><circle class="vskin" cx="140" cy="94" r="5" fill="#ffb3c6" opacity=".7"/>
    <path class="vskin" d="M112 96 q8 7 16 0" fill="none" stroke="#b5647f" stroke-width="2.4" stroke-linecap="round"/>
  </svg>
</div>

<div class="actions">
  <button class="btn-reset" id="reset">↺</button>
  <button class="btn-done" id="done">📸 Klar!</button>
</div>
<p class="hint" id="hint">Dra pynt dit du vill. Dra det utanför rutan för att ta bort. 🗑️</p>

<div class="drawer">
  <div class="tabs" id="tabs">
    <button data-tab="docka" class="on">💃 Docka</button>
    <button data-tab="huvud">💇 Huvud</button>
    <button data-tab="garderob">👗 Garderob</button>
    <button data-tab="top">👚 Överkropp</button>
    <button data-tab="bottom">👖 Underkropp</button>
    <button data-tab="feet">👠 Fötter</button>
    <button data-tab="stil">✨ Stil-kort</button>
    <button data-tab="pynt">🎀 Pynt</button>
    <button data-tab="bak">🏞️ Bakgrund</button>
  </div>
  <div class="panelbody" id="panelbody"></div>
</div>

<div class="wardrobe"><h3>👚 Din garderob</h3><div class="wrow" id="wrow"></div></div>
<div class="confetti" id="confetti" hidden></div>
<div class="toast" id="toast"></div>

<script is:inline>
(function(){
  var $=function(id){return document.getElementById(id);};

  // ===== Bibliotek =====
  var TOP_SHAPES={
    tshirt:{name:"T-shirt", d:"M97 130 C106 124 134 124 143 130 L160 148 Q156 156 149 152 L140 141 C139 165 138 186 138 200 Q120 208 102 200 C102 186 101 165 100 141 L91 152 Q84 156 80 148 Z", dress:false},
    linne:{name:"Linne", d:"M101 126 q19 -8 38 0 l3 10 -7 6 -2 74 q-15 8 -30 0 l-2 -74 -7 -6z", dress:false},
    troja:{name:"Tröja", d:"M90 128 C104 121 136 121 150 128 L158 210 Q151 216 143 210 L140 150 C139 178 138 198 138 206 Q120 214 102 206 C102 198 101 178 100 150 L97 210 Q89 216 82 210 Z", dress:false},
    klanning:{name:"Klänning", d:"M96 130 q24 -14 48 0 l7 22 -9 6 -5 42 l20 118 q-33 16 -64 0 l20 -118 -5 -42 -9 -6z", dress:true}
  };
  var BOT_SHAPES={
    ingen:{name:"Ingen", d:""},
    kjol:{name:"Kjol", d:"M96 198 Q120 208 144 198 L166 288 Q120 306 74 288 Z"},
    langkjol:{name:"Lång kjol", d:"M88 200 q32 12 64 0 l14 182 q-47 16 -92 0z"},
    byxor:{name:"Byxor", d:"M88 200 q32 12 64 0 l3 22 -11 176 -21 0 -6 -150 -6 150 -21 0 -11 -176z"},
    shorts:{name:"Shorts", d:"M89 200 q31 11 62 0 l3 46 -27 4 -6 -30 -6 30 -27 -4z"}
  };
  var FEET={
    ingen:{name:"Barfota", l:"", r:""},
    ballerina:{name:"Ballerina", l:"M99 402 q-3 11 12 11 q10 0 12 -6 l0 -6 q-12 3 -24 1z", r:"M141 402 q3 11 -12 11 q-10 0 -12 -6 l0 -6 q12 3 24 1z"},
    stovlar:{name:"Stövlar", l:"M100 384 q-4 24 10 30 q12 4 14 -3 l0 -30 q-12 4 -24 3z", r:"M140 384 q4 24 -10 30 q-12 4 -14 -3 l0 -30 q12 4 24 3z"},
    sneakers:{name:"Sneakers", l:"M96 400 q-3 13 14 13 q12 0 13 -7 l-1 -8 q-14 4 -26 2z", r:"M144 400 q3 13 -14 13 q-12 0 -13 -7 l1 -8 q14 4 26 2z"}
  };
  var HAIR={
    kort:{name:"Kort", back:"M80 78 q0 -48 40 -48 q40 0 40 48 q0 22 -9 36 l-62 0 q-9 -14 -9 -36z", front:"M84 70 q-4 -42 36 -44 q40 2 36 44 q-13 -15 -36 -15 q-23 0 -36 15z"},
    langt:{name:"Långt", back:"M78 78 q0 -50 42 -50 q42 0 42 50 q0 60 -8 120 l-16 4 q6 -70 4 -110 q-22 -16 -44 0 q2 40 8 110 l-16 -4 q-8 -60 -8 -120z", front:"M84 70 q-4 -42 36 -44 q40 2 36 44 q-13 -15 -36 -15 q-23 0 -36 15z"},
    tofsar:{name:"Tofsar", back:"M80 78 q0 -48 40 -48 q40 0 40 48 q0 20 -8 34 l-64 0 q-8 -14 -8 -34z", front:"M84 70 q-4 -42 36 -44 q40 2 36 44 q-13 -15 -36 -15 q-23 0 -36 15z M74 66 a12 12 0 1 0 .1 0z M166 66 a12 12 0 1 0 .1 0z"}
  };

  var PATTERNS={
    slat:{name:"Slätt",tile:function(b,f){return rect(b);}},
    prickar:{name:"Prickar",tile:function(b,f){return rect(b)+dot(9,9,4,f)+dot(26,26,4,f)+dot(26,9,2.5,f)+dot(9,26,2.5,f);}},
    rander:{name:"Ränder",tile:function(b,f){return rect(b)+'<rect y="0" width="34" height="9" fill="'+f+'"/><rect y="18" width="34" height="6" fill="'+f+'" opacity=".6"/>';}},
    tweed:{name:"Tweed",tile:function(b,f){return rect(b)+grid(f);}},
    hjartan:{name:"Hjärtan",tile:function(b,f){return rect(b)+heart(9,9,f)+heart(26,26,f);}},
    blommor:{name:"Blommor",tile:function(b,f){return rect(b)+flower(11,11,f)+flower(26,26,f);}},
    leopard:{name:"Leopard",tile:function(b,f){return rect(b)+blob(9,10,f)+blob(25,22,f)+blob(14,27,f);}},
    stjarnor:{name:"Stjärnor",tile:function(b,f){return rect(b)+star(10,11,f)+star(25,25,f);}},
    rutor:{name:"Rutor",tile:function(b,f){return rect(b)+'<rect width="17" height="17" fill="'+f+'" opacity=".85"/><rect x="17" y="17" width="17" height="17" fill="'+f+'" opacity=".85"/>';}}
  };
  function rect(c){return '<rect width="34" height="34" fill="'+c+'"/>';}
  function dot(x,y,r,c){return '<circle cx="'+x+'" cy="'+y+'" r="'+r+'" fill="'+c+'"/>';}
  function grid(c){return '<g stroke="'+c+'" stroke-width="2" opacity=".8"><path d="M0 8H34M0 26H34M8 0V34M26 0V34"/></g>';}
  function heart(x,y,c){return '<path transform="translate('+(x-6)+','+(y-5)+') scale(.5)" d="M12 21 C2 13 2 5 8 4 q4 0 4 4 q0 -4 4 -4 c6 1 6 9 -4 17z" fill="'+c+'"/>';}
  function flower(x,y,c){var p='';for(var i=0;i<5;i++){var a=i*72*Math.PI/180;p+=dot(x+Math.cos(a)*4,y+Math.sin(a)*4,2.4,c);}return p+dot(x,y,2,"#ffe08a");}
  function blob(x,y,c){return '<ellipse cx="'+x+'" cy="'+y+'" rx="4.5" ry="3.2" fill="'+c+'" transform="rotate(20 '+x+' '+y+')"/>';}
  function star(x,y,c){return '<path transform="translate('+x+','+y+') scale(.5)" d="M0 -8 2 -2 8 -2 3 2 5 8 0 4 -5 8 -3 2 -8 -2 -2 -2z" fill="'+c+'"/>';}

  var MATERIALS={matt:{name:"Matt",fill:"none"},satin:{name:"Satin",fill:"url(#gSatin)"},lader:{name:"Läder",fill:"url(#gLeather)"},denim:{name:"Denim",fill:"url(#mDenim)"},stickat:{name:"Stickat",fill:"url(#mKnit)"},paljett:{name:"Paljett",fill:"url(#mSeq)"}};
  var COLORS=["#e7b6cf","#e2506e","#111318","#f2efe9","#d9a441","#8fd6c4","#c7b3e6","#8ec5e8","#f7a072","#9bb58a"];
  var HAIRCOLORS=["#6d4423","#2b1d16","#c98a3a","#e6b34d","#b5546b","#8a8f98"];
  var ACCESSORIES=["🎀","💎","👜","👑","🌸","🕶️","👒","🌹","🧣","⭐","🌿","💐"];

  var STYLES=[
    {name:"Chanel",vibe:"Tweed, svart & vitt, pärlor",top:{shape:"troja",pat:"tweed",color:"#f2efe9",fg:"#111318",mat:"matt"},bot:{shape:"kjol",pat:"tweed",color:"#f2efe9",fg:"#111318",mat:"matt"},acc:["💎"]},
