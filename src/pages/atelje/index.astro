  function saveLook(){
    var wardrobe=load();
    wardrobe.push({top:Object.assign({},state.top),bot:Object.assign({},state.bot),feet:Object.assign({},state.feet),hair:Object.assign({},state.hair),gown:Object.assign({},state.gown),bd:state.bd,acc:snapAcc(),char:state.char,name:"Look "+(wardrobe.length+1)});
    try{localStorage.setItem(WKEY,JSON.stringify(wardrobe));}catch(e){}
    renderWardrobe();
  }
  function load(){try{return JSON.parse(localStorage.getItem(WKEY)||"[]");}catch(e){return [];}}
  function renderWardrobe(){
    var w=$("wrow"); var list=load(); w.innerHTML="";
    list.forEach(function(s,i){
      var t=document.createElement("div"); t.className="wthumb"; var wbd=BACKDROPS[s.bd]||BACKDROPS.catwalk; t.style.backgroundImage="url('"+wbd.img+"')"; t.style.backgroundSize="cover"; t.style.backgroundPosition="center";
      var pid="tp"+i;
      var base=s.char ? '<img src="/dolls/'+s.char+'.png" style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;object-position:center bottom">'
        : '<svg viewBox="0 0 34 44" preserveAspectRatio="xMidYMid slice"><defs><pattern id="'+pid+'" patternUnits="userSpaceOnUse" width="34" height="34">'+PATTERNS[s.top.pat].tile(s.top.color,s.top.fg)+'</pattern></defs><rect width="34" height="44" fill="url(#'+pid+')"/></svg>';
      t.innerHTML=base+
        s.acc.map(function(a){return '<span style="position:absolute;left:'+a.x+'%;top:'+a.y+'%;transform:translate(-50%,-50%);font-size:12px">'+a.e+'</span>';}).join("")+
        '<div class="wname">'+s.name+'</div>';
      t.addEventListener("click",function(){loadLook(s);});
      w.appendChild(t);
    });
  }
  function loadLook(s){
    state.top=Object.assign({},s.top); state.bot=Object.assign({},s.bot); state.feet=Object.assign({},s.feet); state.hair=Object.assign({},s.hair); state.gown=Object.assign({id:"",color:"#e2506e",pat:"slat",fg:"#fff",mat:"matt"},s.gown||{}); state.bd=s.bd; state.char=s.char||"";
    document.querySelectorAll(".acc").forEach(function(e){e.remove();});
    (s.acc||[]).forEach(function(a){var el=document.createElement("div");el.className="acc";el.textContent=a.e;setPos(el,a.x,a.y);$("stage").appendChild(el);makeDraggable(el);});
    applyChar(); draw(); setBackdrop(); toast("👗 "+s.name+" laddad");
  }

  // ===== Firande =====
  function done(){
    var c=$("confetti"); c.hidden=false; c.innerHTML=""; var em=["🎉","✨","💖","⭐","🌸","💫"];
    for(var i=0;i<40;i++){var s=document.createElement("div");s.className="conf";s.textContent=em[i%6];s.style.left=((i*97+13)%100)+"%";s.style.animationDuration=(1.6+((i%5)*.3))+"s";s.style.fontSize=(14+(i%4)*6)+"px";c.appendChild(s);}
    setTimeout(function(){c.hidden=true;},2600);
    var d=$("doll"); d.classList.remove("curtsy"); void d.offsetWidth; d.classList.add("curtsy");
    saveLook(); toast("✨ Sparad i garderoben!");
  }

  // ===== Hjälp =====
  function bind(sel,ev,fn){Array.prototype.slice.call(document.querySelectorAll("#panelbody "+sel)).forEach(function(el){el.addEventListener(ev,function(){fn(el);});});}
  var toEl=$("toast"),toT=null;
  function toast(m){toEl.textContent=m;toEl.classList.add("show");clearTimeout(toT);toT=setTimeout(function(){toEl.classList.remove("show");},1500);}
  setInterval(function(){var eyes=document.querySelectorAll(".eye");eyes.forEach(function(e){e.setAttribute("ry","0.6");});setTimeout(function(){eyes.forEach(function(e){e.setAttribute("ry","5.4");});},130);},3800);

  Array.prototype.slice.call(document.querySelectorAll("#tabs button")).forEach(function(b){b.addEventListener("click",function(){document.querySelectorAll("#tabs button").forEach(function(x){x.classList.remove("on");});b.classList.add("on");TAB[b.dataset.tab]();});});
  $("done").addEventListener("click",done);
  $("reset").addEventListener("click",function(){document.querySelectorAll(".acc").forEach(function(e){e.remove();});state.acc=[];state.gown.id="";state.top={shape:"tshirt",pat:"prickar",color:"#e7b6cf",fg:"#fff",mat:"matt"};state.bot={shape:"kjol",pat:"slat",color:"#8ec5e8",fg:"#fff",mat:"denim"};draw();toast("↺ Ren docka!");});

  // init — återställ pågående docka (överlever stängd webbläsare), sen rita
  restoreCurrent(); applyChar(); draw(); setBackdrop(); renderWardrobe(); TAB.docka();
})();
</script>
</body>
</html>
