  }
  function burst(){var c=$("confetti");c.hidden=false;c.innerHTML="";var em=["🎉","✨","🧠","⭐","💫","🏆"];for(var i=0;i<38;i++){var s=document.createElement("div");s.className="conf";s.textContent=em[i%6];s.style.left=((i*97+11)%100)+"%";s.style.animationDuration=(1.7+((i%5)*.3))+"s";s.style.fontSize=(14+(i%4)*7)+"px";c.appendChild(s);}setTimeout(function(){c.hidden=true;},2800);}

  // ===== Start =====
  function gbtn(g){return '<button class="mode" data-game="'+g+'"><span class="em">'+GAMES[g].icon+'</span><span><span class="t">'+GAMES[g].name+'</span><span class="d">'+GAMES[g].d+'</span></span></button>';}
  GAMES.logik.d="Mönster & matriser — kluriga hjärngåtor."; GAMES.matte.d="Räkna ut svaret och välj rätt."; GAMES.bokstaver.d="Lär dig bokstäver och börja läsa.";
  function home(){
    var best=hi();
    app.innerHTML='<div class="card"><div class="modes">'+gbtn("logik")+gbtn("matte")+gbtn("bokstaver")+'</div>'+
      (best?'<p class="ask" style="margin-top:14px">🏆 Rekord: '+best.score+' p ('+best.rank+')</p>':'')+'</div>';
    app.querySelectorAll("[data-game]").forEach(function(b){b.onclick=function(){pickLevel(b.dataset.game);};});
  }
  function pickLevel(game){
    var rows='';
    if(game==="logik") rows+='<button class="mode" data-mode="adapt"><span class="em">🧗</span><span><span class="t">Äventyret</span><span class="d">Rätt svar → svårare. Klättra så högt du kan!</span></span></button>';
    [[1,"🐣","Lätt","För de yngsta (Mathilde)"],[2,"🐥","Mellan","Lite klurigare"],[3,"🦉","Klurig","Tänk till (Louisa)"],[4,"🧠","Svår","För proffs"]].forEach(function(L){
      rows+='<button class="mode" data-lev="'+L[0]+'"><span class="em">'+L[1]+'</span><span><span class="t">'+L[2]+'</span><span class="d">'+L[3]+'</span></span></button>';
    });
    app.innerHTML='<div class="card"><button class="btn ghost" id="back" style="margin-bottom:12px">← Välj spel</button><div class="ask" style="text-align:left;margin:0 2px 8px">'+GAMES[game].icon+' '+GAMES[game].name+' — välj svårighet</div><div class="modes">'+rows+'</div></div>';
    $("back").onclick=home;
    app.querySelectorAll("[data-mode]").forEach(function(b){b.onclick=function(){start(game,b.dataset.mode,QCOUNT);};});
    app.querySelectorAll("[data-lev]").forEach(function(b){b.onclick=function(){start(game,+b.dataset.lev,QCOUNT);};});
  }
  function resumeOrHome(){
    var s=loadSession();
    if(!s){home();return;}
    app.innerHTML='<div class="card final"><div class="rankbig">↩︎</div><div class="rankname">Fortsätt där du var?</div>'+
      '<p class="ask" style="margin-top:8px">'+(GAMES[s.game]?GAMES[s.game].icon+" "+GAMES[s.game].name+" · ":"")+'Fråga '+(s.qi+1)+'/'+s.total+' · '+s.score+' poäng</p>'+
      '<button class="btn" id="res">▶︎ Fortsätt</button><button class="btn ghost" id="new" style="margin-top:10px">Nej, börja om</button></div>';
    $("res").onclick=function(){st=s;render();};
    $("new").onclick=function(){clearSession();home();};
  }
  resumeOrHome();
})();
</script>
</body>
</html>
