---
// Modeateljén v2 — mobil-först dress-up: docka + chroma-plagg + z-lager + recolor/mönster.
// Flöde: kategori-flik → plagg-roller → färg/mönster. iPhone-app-känsla.
---
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1" />
<title>Modeateljén</title>
<link rel="stylesheet" href="/atelje2.css" />
</head>
<body>
  <div id="picker">
    <h2>Vem spelar? 👗</h2>
    <p>Välj spelare — dina looks sparas för dig.</p>
    <div class="who">
      <button class="whobtn" data-p="Louisa"><span class="big">🌸</span><span class="nm">Louisa</span></button>
      <button class="whobtn" data-p="Mathilde"><span class="big">🦋</span><span class="nm">Mathilde</span></button>
    </div>
  </div>

  <div class="stage" id="stage">
    <div class="brand">👗 Modeateljén <span>v2</span></div>
    <button class="pbadge" id="pbadge">👤 —</button>
    <button class="clear" id="reset">Klä av</button>
    <img id="doll" alt="docka" />
    <div class="ehint">✥ Dra plagget · handtagen ändrar storlek</div>
    <div class="ghandle hw" id="hW">↔</div>
    <div class="ghandle hh" id="hH">↕</div>
    <button class="ghandle hx" id="hX">✕</button>
  </div>

  <div class="sheet">
    <div class="grip"></div>
    <div class="looks" id="looks">
      <div class="lookhd">
        <span class="t" id="lookstitle">Mina looks</span>
        <div class="lookbtns">
          <button class="lookbtn" id="btnUpdate" style="display:none">💾 Uppdatera</button>
          <button class="lookbtn solid" id="btnSaveNew">＋ Spara ny</button>
        </div>
      </div>
      <div class="lookroll scroll" id="lookroll"></div>
    </div>
    <div class="tabs scroll" id="tabs"></div>
    <div class="roller scroll" id="roller"></div>
    <div class="style hidden" id="style">
      <p class="cap" id="stylecap">Färg</p>
      <div class="swrow scroll" id="colrow"></div>
      <p class="cap">Mönster</p>
      <div class="swrow scroll" id="patrow"></div>
      <div class="fitwrap" id="fitwrap"></div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

<script is:inline>
(async function(){
  var man = await fetch('/garderob-v2/manifest.json').then(function(r){return r.json();});
  document.getElementById('doll').src = man.doll;

  var PAT={
    slat:{n:"Slätt",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);}},
    prickar:{n:"Prickar",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;var r=T*0.12;[[.25,.25],[.75,.75]].forEach(function(p){c.beginPath();c.arc(p[0]*T,p[1]*T,r,0,7);c.fill();});}},
    breton:{n:"Ränder",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;c.fillRect(0,0,T,T*0.42);}},
    gingham:{n:"Gingham",f:function(c,T,b,f){c.fillStyle="#fff";c.fillRect(0,0,T,T);c.fillStyle=b;c.globalAlpha=.5;c.fillRect(0,0,T*0.5,T);c.fillRect(0,0,T,T*0.5);c.globalAlpha=1;}},
    rutor:{n:"Rutor",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.strokeStyle=f;c.globalAlpha=.55;c.lineWidth=T*0.06;c.beginPath();c.moveTo(T*0.3,0);c.lineTo(T*0.3,T);c.moveTo(0,T*0.3);c.lineTo(T,T*0.3);c.stroke();c.globalAlpha=1;}},
    stjarnor:{n:"Stjärnor",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;function s(cx,cy,R){c.save();c.translate(cx,cy);c.beginPath();for(var i=0;i<10;i++){var a=Math.PI/5*i-Math.PI/2;var r=i%2?R*0.42:R;c.lineTo(Math.cos(a)*r,Math.sin(a)*r);}c.closePath();c.fill();c.restore();}s(T*0.28,T*0.3,T*0.16);s(T*0.72,T*0.72,T*0.16);}},
    hjartan:{n:"Hjärtan",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);c.fillStyle=f;function h(cx,cy,s){c.save();c.translate(cx,cy);c.scale(s,s);c.beginPath();c.moveTo(0,3);c.bezierCurveTo(-6,-4,-12,4,0,11);c.bezierCurveTo(12,4,6,-4,0,3);c.fill();c.restore();}h(T*0.28,T*0.3,T*0.018);h(T*0.72,T*0.72,T*0.018);}},
    blommor:{n:"Blommor",f:function(c,T,b,f){c.fillStyle=b;c.fillRect(0,0,T,T);function fl(cx,cy,R){c.fillStyle=f;for(var i=0;i<5;i++){var a=i*72*Math.PI/180;c.beginPath();c.arc(cx+Math.cos(a)*R,cy+Math.sin(a)*R,R*0.62,0,7);c.fill();}c.fillStyle="#ffd24a";c.beginPath();c.arc(cx,cy,R*0.5,0,7);c.fill();}fl(T*0.28,T*0.3,T*0.1);fl(T*0.72,T*0.72,T*0.1);}}
  };
  var COLORS=["#ffffff","#111318","#e2506e","#c1122b","#e7b6cf","#d9a441","#8ec5e8","#3a6ea5","#7cc7c0","#9bb58a","#c7b3e6","#f7a072","#6d4423"];
  function patCanvas(p,c,f){var s=document.createElement("canvas");s.width=48;s.height=48;(PAT[p]||PAT.slat).f(s.getContext("2d"),48,c,f);return s;}
  function ink(hex){var c=(hex||"#fff").replace("#","");if(c.length===3)c=c[0]+c[0]+c[1]+c[1]+c[2]+c[2];var r=parseInt(c.slice(0,2),16),g=parseInt(c.slice(2,4),16),b=parseInt(c.slice(4,6),16);return (0.299*r+0.587*g+0.114*b)>150?"#1c1c22":"#ffffff";}
  function recolor(im,color,pat,fg){
    var W=im.naturalWidth,H=im.naturalHeight,cv=document.createElement("canvas");cv.width=W;cv.height=H;var x=cv.getContext("2d");
    x.drawImage(im,0,0);x.globalCompositeOperation="multiply";
    if(pat&&pat!=="slat"){var t=patCanvas(pat,color,fg),p=x.createPattern(t,"repeat"),sc=W/430;x.save();x.scale(sc,sc);x.fillStyle=p;x.fillRect(0,0,W/sc,H/sc);x.restore();}
    else{x.fillStyle=color;x.fillRect(0,0,W,H);}
    x.globalCompositeOperation="destination-in";x.drawImage(im,0,0);x.globalCompositeOperation="source-over";return cv.toDataURL("image/png");
  }

  var CATS=[['bottom','👖','Underdel'],['dress','👗','Klänning'],['tank','🎽','Linne'],['tshirt','👕','T-shirt'],['shirt','👔','Skjorta'],['sweatshirt','🧶','Tröja'],['outer','🧥','Ytterplagg'],['shoes','👟','Skor']];
  var byCat={},gById={};
  man.garments.forEach(function(g){(byCat[g.category]=byCat[g.category]||[]).push(g);gById[g.id]=g;});
  CATS=CATS.filter(function(c){return byCat[c[0]];});
  var activeCat=CATS[0][0];
  var worn={};                          // category -> {id,color,pat,fg}
  var stage=document.getElementById('stage'),layers={},_src={};

  function loadImg(g,cb){if(_src[g.id]){cb(_src[g.id]);return;}var im=new Image();im.onload=function(){_src[g.id]=im;cb(im);};im.onerror=function(){cb(null);};im.src=g.file;}
  function applyOne(g,st){var im=layers[g.id];if(!im){im=new Image();im.style.zIndex=g.z;layers[g.id]=im;stage.appendChild(im);}im.style.zIndex=g.z;applyAdj(im,st);loadImg(g,function(s){if(s)im.src=recolor(s,st.color,st.pat,st.fg);});}
  function applyAdj(im,st){var a=st.adj||(st.adj={dx:0,dy:0,sx:1,sy:1});im.style.transformOrigin='center';im.style.transform='translate('+a.dx+'%,'+a.dy+'%) scale('+a.sx+','+a.sy+')';}
  function renderDoll(){
    Object.keys(layers).forEach(function(id){var g=gById[id];if(!worn[g.category]||worn[g.category].id!==id){layers[id].remove();delete layers[id];}});
    man.garments.forEach(function(g){var st=worn[g.category];if(st&&st.id===g.id)applyOne(g,st);});
    updateHighlight();
  }
  function updateHighlight(){Object.keys(layers).forEach(function(id){var g=gById[id];layers[id].classList.toggle('sel',!!(worn[g.category]&&worn[g.category].id===id&&activeCat===g.category));});positionHandles();}

  // ---- pixel-precis hit-test: vilket buret plagg ligger överst vid (cx,cy) ----
  var _alpha={};
  function alphaMap(g){var im=_src[g.id];if(!im||!im.naturalWidth)return null;if(_alpha[g.id])return _alpha[g.id];
    var sc=200/im.naturalWidth,w=Math.max(1,Math.round(im.naturalWidth*sc)),h=Math.max(1,Math.round(im.naturalHeight*sc));
    var c=document.createElement('canvas');c.width=w;c.height=h;var x=c.getContext('2d');x.drawImage(im,0,0,w,h);
    var d=x.getImageData(0,0,w,h).data,x0=w,y0=h,x1=0,y1=0;
    for(var yy=0;yy<h;yy++)for(var xx=0;xx<w;xx++){if(d[(yy*w+xx)*4+3]>40){if(xx<x0)x0=xx;if(xx>x1)x1=xx;if(yy<y0)y0=yy;if(yy>y1)y1=yy;}}
    // bbox i bild-native px
    var bbox=x1>=x0?{x0:x0/sc,y0:y0/sc,x1:(x1+1)/sc,y1:(y1+1)/sc}:{x0:0,y0:0,x1:im.naturalWidth,y1:im.naturalHeight};
    var m={w:w,h:h,sc:sc,d:d,bbox:bbox,iw:im.naturalWidth,ih:im.naturalHeight};_alpha[g.id]=m;return m;}
  function garmentAt(cx,cy,SW,SH){
    var ord=man.garments.filter(function(g){return worn[g.category]&&worn[g.category].id===g.id;}).sort(function(a,b){return b.z-a.z;});
    for(var i=0;i<ord.length;i++){var g=ord[i],im=_src[g.id];if(!im||!im.naturalWidth)continue;
      var st=worn[g.category],a=st.adj||{dx:0,dy:0,sx:1,sy:1};
      var sc=Math.min(SW/im.naturalWidth,SH/im.naturalHeight),dw=im.naturalWidth*sc,dh=im.naturalHeight*sc,ox=(SW-dw)/2,oy=(SH-dh)/2;
      var tx=a.dx/100*SW,ty=a.dy/100*SH;
      var ex=(cx-SW/2-tx)/a.sx+SW/2, ey=(cy-SH/2-ty)/a.sy+SH/2;   // invers element-transform
      var px=(ex-ox)/sc, py=(ey-oy)/sc;                            // element → bild-pixel
      var mp=alphaMap(g);if(!mp)continue;var mx=Math.round(px*mp.sc),my=Math.round(py*mp.sc);
      if(mx<0||my<0||mx>=mp.w||my>=mp.h)continue;
      if(mp.d[(my*mp.w+mx)*4+3]>40)return g;
    }
    return null;
  }
  function selectGarment(g){
    activeCat=g.category;renderTabs();renderRoller();renderStyle();updateHighlight();
    var t=[].slice.call(document.querySelectorAll('.tab')).find(function(x){return x.classList.contains('on');});
    if(t)t.scrollIntoView({inline:'center',block:'nearest',behavior:'smooth'});
    var c=document.querySelector('.card.on');if(c)c.scrollIntoView({inline:'center',block:'nearest',behavior:'smooth'});
  }

  var tabsEl=document.getElementById('tabs');
  function renderTabs(){
    tabsEl.innerHTML='';
    CATS.forEach(function(c){
      var b=document.createElement('button');b.className='tab'+(activeCat===c[0]?' on':'');
      b.innerHTML='<span class="em">'+c[1]+'</span>'+c[2]+(worn[c[0]]?'<span class="dot"></span>':'');
      b.onclick=function(){activeCat=c[0];renderTabs();renderRoller();renderStyle();
        b.scrollIntoView({inline:'center',block:'nearest',behavior:'smooth'});};
      tabsEl.appendChild(b);
    });
  }
  var rollEl=document.getElementById('roller');
  function renderRoller(){
    rollEl.innerHTML='';var list=byCat[activeCat]||[];
    if(!list.length){rollEl.innerHTML='<div class="empty">Inga plagg här än</div>';return;}
    list.forEach(function(g){
      var d=document.createElement('div');d.className='card'+(worn[activeCat]&&worn[activeCat].id===g.id?' on':'');
      d.innerHTML='<img src="'+g.file+'" alt="'+g.label+'"><div class="tick">✓</div>';
      d.onclick=function(){
        if(worn[activeCat]&&worn[activeCat].id===g.id) delete worn[activeCat];
        else {var dc=g.defaultColor||'#ffffff';worn[activeCat]={id:g.id,color:dc,pat:'slat',fg:ink(dc),adj:{dx:0,dy:0,sx:1,sy:1}};}
        renderDoll();renderRoller();renderTabs();renderStyle();
      };
      rollEl.appendChild(d);
    });
  }
  var styleEl=document.getElementById('style');
  function renderStyle(){
    var st=worn[activeCat];
    if(!st){styleEl.classList.add('hidden');return;}
    styleEl.classList.remove('hidden');
    document.getElementById('stylecap').textContent='Färg — '+gById[st.id].label;
    var cr=document.getElementById('colrow');cr.innerHTML='';
    COLORS.forEach(function(hex){var d=document.createElement('div');d.className='col'+(st.color===hex?' on':'');d.style.background=hex;
      d.onclick=function(){st.color=hex;st.fg=ink(hex);renderDoll();renderStyle();};cr.appendChild(d);});
    var pr=document.getElementById('patrow');pr.innerHTML='';
    Object.keys(PAT).forEach(function(k){var d=document.createElement('div');d.className='pat'+(st.pat===k?' on':'');
      d.style.backgroundImage='url('+patCanvas(k,st.color,st.fg).toDataURL()+')';
      d.onclick=function(){st.pat=k;renderDoll();renderStyle();};pr.appendChild(d);});
    renderFit(st);
  }
  function renderFit(st){
    var fw=document.getElementById('fitwrap');fw.innerHTML='';
    if(!st.adj)st.adj={dx:0,dy:0,sx:1,sy:1};
    var rs=document.createElement('button');rs.className='fitbtn';rs.textContent='↺ Återställ storlek & position';
    rs.onclick=function(){st.adj={dx:0,dy:0,sx:1,sy:1};var im=layers[st.id];if(im)applyAdj(im,st);positionHandles();};
    fw.appendChild(rs);
  }
  // ---- on-canvas-handtag: bredd (höger), höjd (under), ✕ (ta bort) ----
  function positionHandles(){
    var hW=document.getElementById('hW'),hH=document.getElementById('hH'),hX=document.getElementById('hX');
    var st=worn[activeCat],mp=st?alphaMap(gById[st.id]):null;
    if(!st||!mp){[hW,hH,hX].forEach(function(h){h.classList.remove('show');});stage.classList.remove('hassel');return;}
    stage.classList.add('hassel');
    var SW=stage.clientWidth,SH=stage.clientHeight,a=st.adj||{dx:0,dy:0,sx:1,sy:1};
    var sc=Math.min(SW/mp.iw,SH/mp.ih),ox=(SW-mp.iw*sc)/2,oy=(SH-mp.ih*sc)/2;
    var ex0=ox+mp.bbox.x0*sc,ey0=oy+mp.bbox.y0*sc,ex1=ox+mp.bbox.x1*sc,ey1=oy+mp.bbox.y1*sc;
    function TX(e){return a.sx*(e-SW/2)+SW/2+a.dx/100*SW;}
    function TY(e){return a.sy*(e-SH/2)+SH/2+a.dy/100*SH;}
    var X0=TX(ex0),X1=TX(ex1),Y0=TY(ey0),Y1=TY(ey1);
    function cl(v,m){return Math.max(6,Math.min(m-6,v));}
    hW.style.left=cl(X1,SW)+'px';hW.style.top=cl((Y0+Y1)/2,SH)+'px';hW.classList.add('show');
    hH.style.left=cl((X0+X1)/2,SW)+'px';hH.style.top=cl(Y1,SH)+'px';hH.classList.add('show');
    hX.style.left=cl(X1,SW)+'px';hX.style.top=cl(Y0,SH)+'px';hX.classList.add('show');
    hW._k=Math.max(24,ex1-SW/2);hH._k=Math.max(24,ey1-SH/2);
  }
  (function(){
    function bindResize(el,axis){
      el.addEventListener('pointerdown',function(e){e.stopPropagation();var st=worn[activeCat];if(!st)return;
        var s={x:e.clientX,y:e.clientY,sx:st.adj.sx,sy:st.adj.sy,k:el._k};el.setPointerCapture(e.pointerId);
        function mv(ev){var st2=worn[activeCat];if(!st2)return;
          if(axis==='w')st2.adj.sx=Math.max(0.5,Math.min(2,s.sx+(ev.clientX-s.x)/s.k));
          else st2.adj.sy=Math.max(0.5,Math.min(2,s.sy+(ev.clientY-s.y)/s.k));
          var im=layers[st2.id];if(im)applyAdj(im,st2);positionHandles();}
        function up(){el.removeEventListener('pointermove',mv);el.removeEventListener('pointerup',up);}
        el.addEventListener('pointermove',mv);el.addEventListener('pointerup',up);});
    }
    bindResize(document.getElementById('hW'),'w');
    bindResize(document.getElementById('hH'),'h');
    document.getElementById('hX').addEventListener('pointerdown',function(e){e.stopPropagation();});
    document.getElementById('hX').addEventListener('click',function(e){e.stopPropagation();
      if(worn[activeCat]){delete worn[activeCat];renderDoll();renderTabs();renderRoller();renderStyle();positionHandles();}});
    window.addEventListener('resize',positionHandles);
  })();
  // ---- klick = markera plagg; drag på markerat plagg = flytta ----
  (function(){
    var stg=document.getElementById('stage'),down=null,moved=false;
    function loc(e){var r=stg.getBoundingClientRect();return {x:e.clientX-r.left,y:e.clientY-r.top,w:r.width,h:r.height};}
    stg.addEventListener('pointerdown',function(e){
      var p=loc(e),hit=garmentAt(p.x,p.y,p.w,p.h);down={x:p.x,y:p.y,w:p.w,h:p.h,hit:hit};moved=false;
      if(hit&&worn[activeCat]&&worn[activeCat].id===hit.id){down.move=true;down.dx=worn[activeCat].adj.dx;down.dy=worn[activeCat].adj.dy;stg.setPointerCapture(e.pointerId);}
    });
    stg.addEventListener('pointermove',function(e){
      if(!down)return;var p=loc(e);if(Math.abs(p.x-down.x)+Math.abs(p.y-down.y)>7)moved=true;
      if(down.move){var st=worn[activeCat];if(!st)return;st.adj.dx=down.dx+(p.x-down.x)/down.w*100;st.adj.dy=down.dy+(p.y-down.y)/down.h*100;var im=layers[st.id];if(im)applyAdj(im,st);positionHandles();}
    });
    function end(){if(down&&!moved&&down.hit)selectGarment(down.hit);down=null;}
    stg.addEventListener('pointerup',end);stg.addEventListener('pointercancel',function(){down=null;});
  })();
  document.getElementById('reset').onclick=function(){worn={};currentN=null;renderDoll();renderTabs();renderRoller();renderStyle();renderLooks();};

  // ===== Spelare + spara/ladda (localStorage) =====
  var PLAYERS={Louisa:'🌸',Mathilde:'🦋'};
  var player=null, currentN=null;
  function getSaves(){try{return JSON.parse(localStorage.getItem('atelje2_saves')||'{}');}catch(e){return {};}}
  function setSaves(s){localStorage.setItem('atelje2_saves',JSON.stringify(s));}
  function mySaves(){var s=getSaves();return (s[player]||[]);}
  function toast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show');},1600);}

  function captureThumb(cb){
    var doll=document.getElementById('doll');
    var W=140,H=Math.round(W*(doll.naturalHeight/doll.naturalWidth||1.85));
    var c=document.createElement('canvas');c.width=W;c.height=H;var x=c.getContext('2d');
    x.fillStyle='#ffe9f1';x.fillRect(0,0,W,H);
    function fit(im){var s=Math.min(W/im.naturalWidth,H/im.naturalHeight);var w=im.naturalWidth*s,h=im.naturalHeight*s;x.drawImage(im,(W-w)/2,(H-h)/2,w,h);}
    if(doll.complete)fit(doll);
    // rita plaggen i z-ordning
    var ordered=man.garments.filter(function(g){return worn[g.category]&&worn[g.category].id===g.id;}).sort(function(a,b){return a.z-b.z;});
    var pend=ordered.length;
    if(!pend){cb(c.toDataURL('image/jpeg',0.72));return;}
    ordered.forEach(function(g){var im=layers[g.id];if(im&&im.complete&&im.naturalWidth){fit(im);if(!--pend)cb(c.toDataURL('image/jpeg',0.72));}
      else{var t=new Image();t.onload=function(){fit(t);if(!--pend)cb(c.toDataURL('image/jpeg',0.72));};t.onerror=function(){if(!--pend)cb(c.toDataURL('image/jpeg',0.72));};t.src=im?im.src:g.file;}});
  }
  function saveLook(overwriteN){
    captureThumb(function(thumb){
      var s=getSaves();var arr=s[player]||(s[player]=[]);
      var wornClone=JSON.parse(JSON.stringify(worn));
      if(overwriteN){var it=arr.find(function(l){return l.n===overwriteN;});if(it){it.worn=wornClone;it.thumb=thumb;toast('Look #'+overwriteN+' uppdaterad');}}
      else{var maxN=arr.reduce(function(m,l){return Math.max(m,l.n);},0);var n=maxN+1;arr.push({n:n,worn:wornClone,thumb:thumb});currentN=n;toast('Sparad som look #'+n);}
      setSaves(s);renderLooks();
    });
  }
  function loadLook(n){var it=mySaves().find(function(l){return l.n===n;});if(!it)return;worn=JSON.parse(JSON.stringify(it.worn));currentN=n;renderDoll();renderTabs();renderRoller();renderStyle();renderLooks();toast('Look #'+n);}
  function delLook(n){var s=getSaves();s[player]=(s[player]||[]).filter(function(l){return l.n!==n;});setSaves(s);if(currentN===n)currentN=null;renderLooks();}

  function renderLooks(){
    document.getElementById('lookstitle').textContent=(player||'')+'s looks';
    document.getElementById('btnUpdate').style.display=currentN?'':'none';
    var roll=document.getElementById('lookroll');roll.innerHTML='';
    var arr=mySaves();
    if(!arr.length){roll.innerHTML='<div class="emptylooks">Inga sparade looks än — klä på och tryck ＋ Spara ny.</div>';return;}
    arr.forEach(function(l){
      var d=document.createElement('div');d.className='lookcard'+(currentN===l.n?' on':'');
      d.innerHTML='<img src="'+l.thumb+'"><div class="n">#'+l.n+'</div><div class="del">×</div>';
      d.querySelector('img').onclick=function(){loadLook(l.n);};
      d.querySelector('.n').onclick=function(){loadLook(l.n);};
      d.querySelector('.del').onclick=function(e){e.stopPropagation();if(confirm('Ta bort look #'+l.n+'?'))delLook(l.n);};
      roll.appendChild(d);
    });
  }
  function pickPlayer(name){player=name;localStorage.setItem('atelje2_player',name);currentN=null;
    document.getElementById('pbadge').textContent=PLAYERS[name]+' '+name;
    document.getElementById('picker').style.display='none';renderLooks();}

  document.getElementById('btnSaveNew').onclick=function(){if(!player)return;saveLook(null);};
  document.getElementById('btnUpdate').onclick=function(){if(currentN)saveLook(currentN);};
  document.getElementById('pbadge').onclick=function(){document.getElementById('picker').style.display='';};
  [].forEach.call(document.querySelectorAll('.whobtn'),function(b){b.onclick=function(){pickPlayer(b.dataset.p);};});

  renderTabs();renderRoller();renderStyle();
  // återuppta senaste spelaren om den finns
  var last=localStorage.getItem('atelje2_player');
  if(last&&PLAYERS[last])pickPlayer(last); else document.getElementById('picker').style.display='';
})();
</script>
</body>
</html>
