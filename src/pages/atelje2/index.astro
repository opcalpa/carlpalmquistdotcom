---
// Modeateljén v2 — prototyp: inbakad-frisyr-docka + chroma-plagg + z-lager (flera samtidigt).
---
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Modeateljén v2</title>
<style is:global>
  *{box-sizing:border-box}
  html,body{margin:0;height:100%}
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:#fbeef3;color:#3b2c3a;min-height:100dvh}
  header{text-align:center;padding:12px 16px 4px}
  header h1{margin:0;font-size:19px}.hint{color:#9a7f92;font-size:12px;margin:2px 0 0}
  .workspace{display:flex;flex-direction:column;align-items:center;gap:14px;padding:12px}
  .stage{position:relative;width:min(92vw,340px);aspect-ratio:9/16;background:linear-gradient(160deg,#ffd9e6,#ffeef4 55%,#e9f7f4);
    border-radius:22px;overflow:hidden;box-shadow:0 10px 30px rgba(120,60,90,.18);flex:0 0 auto}
  .stage img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;pointer-events:none}
  .menu{width:100%;max-width:520px}
  .cat{margin:10px 0}
  .cat h3{margin:0 0 6px;font-size:12px;text-transform:uppercase;letter-spacing:.4px;color:#9a7f92}
  .row{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px}
  .gitem{flex:0 0 auto;width:60px;height:84px;border-radius:12px;border:2px solid #f0d9e4;background:#fff;cursor:pointer;overflow:hidden;position:relative}
  .gitem img{width:100%;height:100%;object-fit:contain}
  .gitem.on{border-color:#e86fa6;box-shadow:0 0 0 3px rgba(232,111,166,.22)}
  .bar{display:flex;gap:8px;width:100%;max-width:520px}
  .bar button{flex:1;border:0;border-radius:14px;padding:11px;font-size:15px;font-weight:700;cursor:pointer;background:#f0d9e4;color:#3b2c3a}
  @media (min-width:900px){
    .workspace{flex-direction:row-reverse;align-items:flex-start;justify-content:center;gap:26px;max-width:1120px;margin:0 auto}
    .stage{width:auto;height:min(84vh,780px)}
    .menu{max-width:520px;position:sticky;top:10px}
  }
</style>
</head>
<body>
<header><h1>👗 Modeateljén <span style="color:#e86fa6">v2</span></h1>
<p class="hint">Klicka plagg för att klä på/av. Flera lager samtidigt — ytterplagg hamnar alltid överst.</p></header>

<div class="workspace">
  <div class="stage" id="stage"><img id="doll" alt="docka" /></div>
  <div class="menu">
    <div id="cats"></div>
    <div class="bar"><button id="reset">↺ Klä av</button></div>
  </div>
</div>

<script is:inline>
(async function(){
  var man = await fetch('/garderob-v2/manifest.json').then(r=>r.json());
  document.getElementById('doll').src = man.doll;
  var CATS = [
    ['bottom','Underdel'],['dress','Klänning'],['shoes','Skor'],
    ['tank','Linne'],['tshirt','T-shirt'],['shirt','Skjorta'],
    ['sweatshirt','Tröja'],['outer','Ytterplagg']
  ];
  var byCat = {}; man.garments.forEach(function(g){ (byCat[g.category]=byCat[g.category]||[]).push(g); });
  var worn = {};              // category -> garment id
  var stage = document.getElementById('stage');
  var layers = {};            // id -> img element

  function render(){
    // ta bort avklädda
    Object.keys(layers).forEach(function(id){
      var stillOn = Object.keys(worn).some(function(c){ return worn[c]===id; });
      if(!stillOn){ layers[id].remove(); delete layers[id]; }
    });
    // lägg på burna, z från manifest
    man.garments.forEach(function(g){
      if(worn[g.category]!==g.id) return;
      var im = layers[g.id];
      if(!im){ im=new Image(); im.src=g.file; im.style.zIndex=g.z; layers[g.id]=im; stage.appendChild(im); }
      im.style.zIndex=g.z;
    });
  }
  function toggle(g){
    if(worn[g.category]===g.id) delete worn[g.category];
    else worn[g.category]=g.id;
    render(); paint();
  }
  function paint(){
    document.querySelectorAll('.gitem').forEach(function(el){
      el.classList.toggle('on', worn[el.dataset.cat]===el.dataset.id);
    });
  }
  var html='';
  CATS.forEach(function(c){
    var list=byCat[c[0]]; if(!list) return;
    html+='<div class="cat"><h3>'+c[1]+'</h3><div class="row">';
    list.forEach(function(g){ html+='<div class="gitem" data-cat="'+g.category+'" data-id="'+g.id+'"><img src="'+g.file+'" alt="'+g.label+'"></div>'; });
    html+='</div></div>';
  });
  document.getElementById('cats').innerHTML=html;
  document.querySelectorAll('.gitem').forEach(function(el){
    var g = byCat[el.dataset.cat].find(function(x){return x.id===el.dataset.id;});
    el.addEventListener('click', function(){ toggle(g); });
  });
  document.getElementById('reset').addEventListener('click', function(){ worn={}; render(); paint(); });
})();
</script>
</body>
</html>
